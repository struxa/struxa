# Git archives / GitHub ZIP: omit local extensions (core repo ships CMS + Struxa Vision theme only)
/plugins/ export-ignore
/themes/* export-ignore
!/themes/struxa-theme/

# Live catalog on StruxaPoint is generated by struxa-admin — do not ship from git archives
/public/struxa-dist/repo.json export-ignore
/public/struxa-dist/repo-summary.json export-ignore
/public/struxa-dist/publish.json export-ignore
/public/struxa-dist/news.json export-ignore
/public/struxa-dist/zips/ export-ignore
/public/struxa-dist/catalog/ export-ignore
/struxa-dist/ export-ignore
