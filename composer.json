{
    "name": "struxa/cms",
    "description": "Struxa — Slim/Twig content CMS",
    "version": "1.0.11",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.8",
        "slim/twig-view": "^3.4",
        "twig/twig": "^3.24",
        "phpauth/phpauth": "^1.6",
        "vlucas/phpdotenv": "^5.6",
        "ezyang/htmlpurifier": "^4.19",
        "robthree/twofactorauth": "^3.0",
        "stripe/stripe-php": "^16.0",
        "webonyx/graphql-php": "^15.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "migrate": "php bin/migrate.php",
        "cms": "php bin/cms.php",
        "test": "php tests/run.php",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "render-marketing-preview": "php bin/render-marketing-static.php",
        "lint:twig-layouts": "php bin/lint-twig-layouts.php",
        "plugin-deps": "php bin/plugin-deps.php",
        "plugin-deps:prod": "php bin/plugin-deps.php --no-dev",
        "check:plugin-deps": "php bin/plugin-dependency-health.php",
        "cache:clear": "php bin/cache-clear.php"
    }
}
