# First-time setup: open /install.php in a browser (empty MySQL DB), or copy this file to .env and run php bin/migrate.php.
# After setup, remove public/install.php in production.
#
# Local PHP: 127.0.0.1. In Docker, docker-compose overrides DB_HOST to the mysql service.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=studio
DB_USER=studio
DB_PASS=studio

# Required in production: long random string (PHPAuth session hashing)
PHPAUTH_SITE_KEY=

# Public URL of the app (no trailing slash); used by PHPAuth for links in emails.
# Match the host port you publish (Docker Compose maps app to localhost:3439).
PHPAUTH_SITE_URL=http://localhost:3439

# Local only: set to 1 or true to show stack traces on 5xx errors and extra 404 hints. Never enable in production.
# APP_DEBUG=1

# Set to 1 behind HTTPS
PHPAUTH_COOKIE_SECURE=0

PHPAUTH_COOKIE_SAMESITE=Lax
PHPAUTH_SITE_EMAIL=no-reply@localhost
SITE_NAME="Your Studio"

# Max upload size for the media library (MB). Also ensure PHP upload_max_filesize / post_max_size allow this.
CMS_UPLOAD_MAX_MB=5

# Theme catalog for Admin → Themes → Browse catalog. If unset, the CMS loads https://struxapoint.com/struxa-dist/repo.json, then falls back to storage/theme-catalog.json.
STRUXA_THEME_CATALOG_URL=https://struxapoint.com/struxa-dist/repo.json
# Extra hostnames allowed for theme ZIP download_url (comma-separated). struxapoint.com is built in.
# STRUXA_THEME_DOWNLOAD_HOSTS=

# CMS version check: JSON feed (default) OR GitHub (when STRUXA_UPDATES_GITHUB_REPO is set — overrides JSON).
# STRUXA_UPDATES_JSON_URL=https://struxapoint.com/dist/struxa-updates-json.php
# (or a static file, e.g. https://struxapoint.com/struxa-dist/updates.json from cron --write)
# If the server cannot HTTP-fetch its own public URL (NAT hairpin), mirror the JSON to disk and set:
# STRUXA_UPDATES_JSON_PATH=/var/www/struxa/storage/struxa-updates.json
# Public repo, e.g. struxa/struxa — reads latest GitHub Release tag; ZIP = release zipball. No Releases? Uses composer.json on branch:
# STRUXA_UPDATES_GITHUB_REPO=struxa/struxa
# STRUXA_UPDATES_GITHUB_REF=main

# Admin → Updates: show “Update automatically” and allow POST /admin/updates/apply (staff). Off by default.
# STRUXA_ALLOW_AUTO_UPDATE=1
# If the button still does not appear: php-fpm/Apache may define this var empty (Dotenv will not override). Remove the empty pool/SetEnv entry; the CMS also reads STRUXA_ALLOW_AUTO_UPDATE from .env when the process env is empty.
# If composer is not in PATH for PHP CLI (self-update / migrations), set full path:
# STRUXA_COMPOSER_PATH=/home/you/bin/composer
# (Auto-update infers HOME from .../bin/composer; optional overrides if needed:)
# STRUXA_WEB_HOME=/home/you
# STRUXA_COMPOSER_HOME=/home/you/.composer
# CLI PHP for bin/migrate.php and bin/plugin-deps.php after self-update. Under php-fpm, PHP_BINARY is often php-fpm — set this to real CLI php:
# STRUXA_PHP_CLI_PATH=/usr/bin/php

# Headless JSON + GraphQL API (/api/v1/*). Optional shared secret: Authorization: Bearer <key> or X-Api-Key.
# If empty, you can still use per-client keys from Admin → Tools → API keys (migration 019). If both are unset, the API returns 503.
CMS_PUBLIC_API_KEY=

# Comma-separated scopes for CMS_PUBLIC_API_KEY only: read, read_drafts, write (default: all three).
# CMS_PUBLIC_API_KEY_SCOPES=read,read_drafts,write

# Optional: allow browser clients (e.g. SPA). Use * or a single origin, e.g. https://app.example.com
# CMS_PUBLIC_API_CORS_ORIGIN=*

# Rate limits (per client IP). Login counts POSTs to /login and /login/two-factor per 15 minutes.
# CMS_LOGIN_MAX_ATTEMPTS_PER_QUARTER_HOUR=40
# CMS_API_RATE_LIMIT_PER_MINUTE=180

# GraphQL: introspection disabled by default. Set to 1 for GraphiQL / schema tools in trusted environments.
# CMS_GRAPHQL_ALLOW_INTROSPECTION=0
# CMS_GRAPHQL_MAX_QUERY_BYTES=24000

# Comma-separated trusted reverse-proxy IPs (or IPv4 CIDR). When REMOTE_ADDR matches, X-Forwarded-For / X-Real-IP is used for API + login rate limits and PHPAuth session IP binding. Example: 127.0.0.1,::1,10.0.0.0/8
# CMS_TRUSTED_PROXY_IPS=
# If admin XHR falsely reports “session expired” behind a proxy, set CMS_TRUSTED_PROXY_IPS to your proxy’s REMOTE_ADDR, then sign out and sign in again. Last resort (less secure): CMS_PHPAUTH_SKIP_SESSION_IP_CHECK=1

# Storefront Content-Security-Policy (set 0 or off to disable if a third-party script is blocked).
# CMS_PUBLIC_CSP=1
# Optional: extra CSP source expressions (comma or space separated) appended to public storefront directives.
# Example embeds: https://www.youtube.com https://www.youtube-nocookie.com (frame-src), https://js.stripe.com (script-src).
# CMS_PUBLIC_CSP_SCRIPT_SRC_EXTRA=
# CMS_PUBLIC_CSP_FRAME_SRC_EXTRA=
# CMS_PUBLIC_CSP_CONNECT_SRC_EXTRA=
