/vendor/
# Plugin deps: run `composer plugin-deps` or `php bin/plugin-deps.php` (do not commit vendor)
plugins/**/vendor/
dist/*.zip

# Secrets & local env (never commit real credentials)
.env
.env.*
!.env.example

# Composer HTTP basic auth (can contain tokens)
/auth.json

# Database dumps / local DB files (schema lives under database/migrations/)
*.sql.gz
dump*.sql
*.sqlite
*.sqlite3
/data/mysql/
/mysql-data/

# Node (Playwright e2e)
node_modules/
playwright-report/
test-results/

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/

storage/installed.lock
storage/composer-home/
storage/cache/*
!storage/cache/.gitkeep
storage/dist-catalog.json
storage/config-sync-inbox/*
!storage/config-sync-inbox/.gitkeep
# Optional: composer render-marketing-preview
public/marketing-preview.html
public/uploads/*
!public/uploads/.gitkeep

# Local cache from scripts/struxa-updates-json.php (vendor site generator)
scripts/.struxa-updates-cache.json

# Extensions and extra themes — not in core git (install via Admin → Browse catalog / struxa-dist)
# Only plugins/.gitkeep (+ README) and themes/struxa-theme/ ship with the CMS repo.
/plugins/*
!/plugins/.gitkeep
!/plugins/README.txt
!/plugins/struxa-admin/
!/plugins/struxa-admin/**

/themes/*
!/themes/.gitkeep
!/themes/struxa-theme/
!/themes/struxa-theme/**

# Build staging (scripts/build-safe-update-zip.sh) — never commit
dist/cms-update/

# Generated catalog (scripts/build-struxa-dist.sh or struxa-admin Regenerate on production)
struxa-dist/repo.json
struxa-dist/repo-summary.json
struxa-dist/zips/
public/struxa-dist/repo.json
public/struxa-dist/repo-summary.json
public/struxa-dist/publish.json
public/struxa-dist/zips/
public/struxa-dist/catalog/

# Runtime plugin boot telemetry (see PluginPerformanceStore)
storage/plugin-performance.json
