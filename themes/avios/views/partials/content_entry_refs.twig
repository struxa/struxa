{# Interlinked entries: add one or more custom fields with type "entry_refs" on the
   content type (Content types → Fields). Store a JSON array of target entry IDs,
   e.g. [12, 34]. The CMS resolves each to a title + public URL (or "not public" /
   "missing" labels). This partial renders every non-empty entry_refs field in field
   order, using each field's admin label as the section heading. #}
{% for row in content_field_rows|default([]) %}
  {% if row.field_type == 'entry_refs' and row.html|trim != '' %}
    <section class="av-related-entries" aria-labelledby="av-related-{{ row.field_key|e('html_attr') }}">
      <h2 class="av-related-entries__title" id="av-related-{{ row.field_key|e('html_attr') }}">{{ row.label|e }}</h2>
      <div class="av-related-entries__body">
        {{ row.html|raw }}
      </div>
    </section>
  {% endif %}
{% endfor %}
