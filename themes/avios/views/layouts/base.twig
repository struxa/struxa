<!DOCTYPE html>
<html lang="{{ settings.site_html_lang|default('en')|e('html_attr') }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {% include 'partials/_deferred_theme_css.twig' with {
      font_url: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap',
      theme_stylesheets: ['css/app.css'],
    } only %}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link
      rel="preload" as="style"
      href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.2/css/all.min.css"
      onload="this.onload=null;this.rel='stylesheet'"
      crossorigin="anonymous"
      referrerpolicy="no-referrer">
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer"></noscript>
    <title>
      {%- if struxa_seo|default(false) -%}
        {{- struxa_html_title|default('')|e -}}
      {%- else -%}
        {%- block title -%}{{ settings.default_meta_title|default(settings.site_name)|e }}{%- endblock -%}
      {%- endif -%}
    </title>
    <meta
      name="description"
      content="{%- if struxa_seo|default(false) -%}{{ struxa_meta_description|default('')|e('html_attr') }}{%- else -%}{%- block meta_description -%}{{ settings.default_meta_description|default('')|e }}{%- endblock -%}{%- endif -%}"
    />
    {% block meta_extra %}
      {% if struxa_seo|default(false) %}
        {% include 'public/_struxa_social_head.twig' %}
      {% endif %}
    {% endblock %}
    <link rel="canonical" href="{% if struxa_seo|default(false) %}{{ struxa_canonical_url|default('')|e('html_attr') }}{% else %}{% block canonical_href %}{{ site_url }}/{% endblock %}{% endif %}" />
    <meta name="theme-color" content="#071d3a" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" href="{{ settings.favicon_href|default('/favicon.svg')|e('html_attr') }}" />
    {# `<style>` is CDATA, so HTML-entity encoding (e.g. `&#x23;` for `#`)
       would be left literal by the browser and invalidate the value. We
       must only inject characters that are safe inside CSS. Whitelist hex
       colours like #abc, #abcd, #aabbcc, #aabbccdd; fall back to the
       brand blue otherwise. This stops a malformed setting from breaking
       `--theme-accent`, which downstream rules (e.g. `.forum-btn--primary`)
       depend on for a visible background. #}
    {% set _accent = theme_settings.accent|default('#1557e8') %}
    {% if _accent matches '/^#[0-9a-fA-F]{3,8}$/' %}
      <style>:root { --theme-accent: {{ _accent }}; }</style>
    {% else %}
      <style>:root { --theme-accent: #1557e8; }</style>
    {% endif %}
    {% if not struxa_seo|default(false) %}
      {# `og_type` and `twitter_card` are blocks so a template that knows
         better (e.g. a forum thread = article, a profile page = profile)
         can override them. Without blocks, child templates would have to
         emit duplicate <meta> tags in meta_extra, which crawlers handle
         unpredictably (some take first, some last). #}
      <meta property="og:type" content="{% block og_type %}website{% endblock %}" />
      <meta property="og:site_name" content="{{ settings.site_name|e }}" />
      <meta property="og:title" content="{% block og_title %}{{ settings.default_meta_title|default(settings.site_name)|e }}{% endblock %}" />
      <meta property="og:description" content="{% block og_description %}{{ settings.default_meta_description|default('')|e }}{% endblock %}" />
      <meta name="twitter:card" content="{% block twitter_card %}summary_large_image{% endblock %}" />
      <meta name="twitter:title" content="{% block twitter_title %}{{ settings.default_meta_title|default(settings.site_name)|e }}{% endblock %}" />
      <meta name="twitter:description" content="{% block twitter_description %}{{ settings.default_meta_description|default('')|e }}{% endblock %}" />
    {% endif %}
    {% block head_extra %}{% endblock %}
  </head>
  <body class="theme-avios">
    <a class="av-skip" href="#main-content">{{ 'Skip to main content'|e }}</a>
    {% include 'partials/header.twig' %}
    <div class="theme-main">
      {% block body %}{% endblock %}
    </div>
    {% include 'partials/footer.twig' %}

    <div
      id="header-search-overlay"
      class="header-search-overlay"
      hidden
      aria-hidden="true"
      data-search-url="{{ url_for('public.search')|e('html_attr') }}"
      data-search-min="2"
    >
      <div class="header-search-backdrop" aria-hidden="true"></div>
      <div
        class="header-search-dialog"
        id="header-search-dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="header-search-title"
      >
        <div class="header-search-dialog__head">
          <h2 id="header-search-title" class="header-search-dialog__title">Search the site</h2>
          <button type="button" class="header-search-dialog__close" id="header-search-close" aria-label="Close search">
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
        </div>
        <form id="header-search-form" class="header-search-form" method="get" action="{{ url_for('public.search')|e('html_attr') }}" role="search" autocomplete="off">
          <label for="header-search-q" class="header-search-form__label">Your search</label>
          <div class="header-search-form__row">
            <span class="header-search-form__icon" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input
              type="search"
              name="q"
              id="header-search-q"
              class="header-search-form__input"
              placeholder="e.g. Avios, destinations, guides…"
              maxlength="80"
              spellcheck="false"
            />
            <button type="submit" class="header-search-form__submit">Search</button>
          </div>
          <p id="header-search-hint" class="header-search-form__hint" hidden></p>
        </form>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous" defer></script>
    <script src="{{ theme_asset('js/header-search.js') }}" defer></script>
    <script src="{{ theme_asset('js/main.js') }}" defer></script>
    {% include 'partials/_struxa_tracking.twig' %}
    {% block scripts_extra %}{% endblock %}
  </body>
</html>
