{# Default theme fallback when Queue sections are used without the Queue skin — strux layout #}
<section class="strux-section strux-bg--{{ options.background|default('default')|e('html_attr') }}" data-section="queue_marketing_hero">
  <div class="strux-section-inner strux-section-inner--{{ options.padding|default('comfortable')|e('html_attr') }}">
    <p class="strux-section-eyebrow">{{ section.kicker|default('')|trim != '' ? section.kicker|e : (settings.site_tagline|default('')|trim != '' ? settings.site_tagline|e : section.kicker_fallback|default('')|e) }}</p>
    <h1 class="strux-hero__title">{{ section.title_line_1|default('')|e }}</h1>
    <p class="strux-hero__sub">
      {{ section.title_line_2_before|default('')|e }}<strong>{{ section.highlight_word|default('')|e }}</strong>{{ section.title_line_2_after|default('')|e }}
    </p>
    {% if section.badges_json|default([]) is not empty %}
      <p class="strux-section-tags">
        {% for b in section.badges_json %}<span class="strux-tag">{{ b|e }}</span>{% endfor %}
      </p>
    {% endif %}
    {% if section.lead_use_branded_opening|default(true) %}
      <p class="strux-hero__sub"><strong>{{ settings.site_name|default('Site')|e }}</strong> {{ section.lead_branded_rest|default('')|e }}</p>
    {% else %}
      <div class="strux-prose">{{ section.lead_html|default('')|raw }}</div>
    {% endif %}
    {% if section.chips_json|default([]) is not empty %}
      <ul class="strux-chip-row">
        {% for chip in section.chips_json %}<li class="strux-chip">{{ chip|e }}</li>{% endfor %}
      </ul>
    {% endif %}
    <div class="strux-hero__actions">
      {% if section.primary_cta_label|default('')|trim != '' and section.primary_cta_url|default('')|trim != '' %}
        <a class="strux-btn strux-btn--primary" href="{{ section.primary_cta_url|e('html_attr') }}">{{ section.primary_cta_label|e }}</a>
      {% endif %}
      {% if section.secondary_cta_label|default('')|trim != '' and section.secondary_cta_url|default('')|trim != '' %}
        <a class="strux-btn strux-btn--ghost" href="{{ section.secondary_cta_url|e('html_attr') }}">{{ section.secondary_cta_label|e }}</a>
      {% endif %}
    </div>
    {% if section.show_cms_mock|default(true) %}
      <p class="strux-section-hint" style="margin-top:1.5rem;opacity:0.75;font-size:0.875rem">Activate the <strong>Builder Queue</strong> theme for the animated CMS illustration on this block.</p>
    {% endif %}
  </div>
</section>
