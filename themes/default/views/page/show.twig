{% extends 'layouts/base.twig' %}

{% block head_extra %}
  {% if cms_page_preview|default(false) %}
    <meta name="referrer" content="no-referrer" />
  {% endif %}
{% endblock %}

{% set _site = settings.site_name|default('Your Studio') %}
{% set _og_title = cms_page.seoTitle|default('')|trim != '' ? cms_page.seoTitle : cms_page.title %}

{% block title %}{{ cms_page.metaTitle(_site)|e }}{% endblock %}

{% block meta_description %}{{ cms_page.metaDescription()|e }}{% endblock %}

{% block meta_extra %}
  {{ parent() }}
  {% if cms_page_preview|default(false) %}
    <meta name="robots" content="noindex, nofollow, noarchive" />
  {% endif %}
  {% if cms_page_featured_url|default('')|trim != '' %}
    <meta property="og:image" content="{{ site_url }}{{ cms_page_featured_url|e('html_attr') }}" />
    <meta name="twitter:image" content="{{ site_url }}{{ cms_page_featured_url|e('html_attr') }}" />
  {% endif %}
  {% if cms_page.tags is not empty %}
    <meta name="keywords" content="{{ cms_page.tags|join(', ')|e('html_attr') }}" />
  {% endif %}
{% endblock %}

{% block canonical_href %}{% if cms_page_public_home|default(false) %}{{ site_url }}/{% else %}{{ site_url }}/p/{{ cms_page.slug }}{% endif %}{% endblock %}

{% block og_title %}{{ _og_title|e }}{% endblock %}
{% block og_description %}{{ cms_page.metaDescription()|e }}{% endblock %}
{% block twitter_title %}{{ _og_title|e }}{% endblock %}
{% block twitter_description %}{{ cms_page.metaDescription()|e }}{% endblock %}

{% block body %}
{% if cms_page_preview|default(false) %}
  <div class="cms-preview-banner" role="status">
    <strong>Private preview</strong> — not saved, not public. Only visible while you are signed in as staff.
  </div>
{% endif %}
<main id="main-content">
  <article class="theme-cms-page{% if cms_page_public_home|default(false) %} theme-cms-page--public-home{% endif %}">
    <header class="theme-cms-page-hero">
      {% if not cms_page_public_home|default(false) %}
      <p class="eyebrow">
        <span class="eyebrow-pulse" aria-hidden="true"></span>
        Page
      </p>
      {% endif %}
      <h1 class="theme-cms-page-title">{{ cms_page.title|e }}</h1>
      {% if cms_page.tags is not empty %}
        <ul class="theme-cms-tags theme-cms-page-tags" aria-label="Tags">
          {% for tag in cms_page.tags %}
            <li><span class="theme-cms-tag">{{ tag|replace({'-': ' '})|title|e }}</span></li>
          {% endfor %}
        </ul>
      {% endif %}
    </header>

    {% if cms_page_featured_url|default('')|trim != '' %}
      <figure class="theme-cms-page-featured theme-cms-page-featured--hero">
        <div class="theme-cms-page-featured-frame">
          <img src="{{ cms_page_featured_url|e('html_attr') }}" alt="" loading="eager" decoding="async" />
        </div>
      </figure>
    {% endif %}

    {% if cms_page_has_sections|default(false) and cms_page_sections_html|default('')|trim != '' %}
      <div class="theme-cms-sections theme-cms-page-sections-block" data-strux-sections>{{ cms_page_sections_html|raw }}</div>
    {% endif %}

    {% if cms_page.content|trim != '' %}
      <div class="theme-cms-page-body theme-cms-body cms-prose">{{ cms_page.content|raw }}</div>
    {% endif %}
    {% include 'partials/comments_widget.twig' %}
  </article>
</main>
{% endblock %}
