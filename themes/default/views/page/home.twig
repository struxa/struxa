{% extends 'layouts/base.twig' %}

{% block body %}
<main id="main-content" class="theme-home-fq">
  <div class="theme-home-fq__glow" aria-hidden="true"></div>
  <div class="theme-home-fq__grid" aria-hidden="true"></div>

  <div class="theme-home-fq__inner">
    <p class="theme-home-fq__kicker">
      {% if settings.site_tagline|default('')|trim != '' %}
        {{ settings.site_tagline|e }}
      {% else %}
        Ship pages and structured content — without the bloat.
      {% endif %}
    </p>

    <h1 class="theme-home-fq__title">
      <span class="theme-home-fq__title-line">Your site.</span>
      <span class="theme-home-fq__title-line theme-home-fq__title-line--emph">
        <span class="theme-home-fq__highlight">Structured</span> content.
      </span>
      <span class="theme-home-fq__title-badges">
        <span class="theme-home-fq__badge">Blocks</span>
        <span class="theme-home-fq__badge">Types</span>
        <span class="theme-home-fq__badge">Themes</span>
      </span>
    </h1>

    <p class="theme-home-fq__lead">
      <strong class="theme-home-fq__brand">{{ settings.site_name|e }}</strong>
      is powered by Struxa — a modular CMS with visual pages, reusable types, and a public site theme you control.
    </p>

    <ul class="theme-home-fq__chips">
      <li>Section builder</li>
      <li>SEO-ready</li>
      <li>Plugin-friendly</li>
    </ul>

    <div class="theme-home-fq__actions">
      <a class="theme-home-fq__btn theme-home-fq__btn--primary" href="{{ url_for('register') }}">Get started free</a>
      <a class="theme-home-fq__btn theme-home-fq__btn--ghost" href="{{ url_for('login') }}">Sign in</a>
    </div>

    <dl class="theme-home-fq__stats">
      <div class="theme-home-fq__stat">
        <dt class="theme-home-fq__stat-k">Model</dt>
        <dd class="theme-home-fq__stat-v">Pages + types</dd>
      </div>
      <div class="theme-home-fq__stat">
        <dt class="theme-home-fq__stat-k">Stack</dt>
        <dd class="theme-home-fq__stat-v">PHP · Twig · MySQL</dd>
      </div>
      <div class="theme-home-fq__stat">
        <dt class="theme-home-fq__stat-k">You own</dt>
        <dd class="theme-home-fq__stat-v">Theme + data</dd>
      </div>
    </dl>

    <p class="theme-home-fq__footnote">
      Edit branding in <strong>Settings</strong>. Layout and styles live in <code>themes/default</code>.
    </p>
  </div>
</main>
{% endblock %}
