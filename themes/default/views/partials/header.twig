{% set _rp = request_path|default('/') %}
<header class="theme-header">
  <div class="theme-header__inner">
    <a class="theme-brand{% if _rp == '/' %} theme-brand--active{% endif %}" href="{{ url_for('home') }}"{% if _rp == '/' %} aria-current="page"{% endif %}>
      {% if settings.logo_href|default('')|trim != '' %}
        <img src="{{ settings.logo_href|e('html_attr') }}" alt="{{ settings.site_name|e('html_attr') }}" width="140" height="36" loading="eager" />
      {% else %}
        {{ settings.site_name|e }}
      {% endif %}
    </a>
    <button type="button" class="theme-nav-toggle" aria-expanded="false" aria-controls="theme-primary-nav" aria-label="Open menu">
      <span></span>
      <span></span>
    </button>
    <nav id="theme-primary-nav" class="theme-nav" aria-label="Primary">
      {% for item in header_menu %}
        <a href="{{ item.href|e('html_attr') }}" class="{% if item.is_active|default(false) %}is-nav-active{% endif %}" {% if item.target == '_blank' %}target="_blank"{% endif %}{% if item.anchor_rel|default('')|trim != '' %} rel="{{ item.anchor_rel|e('html_attr') }}"{% endif %}{% if item.is_active|default(false) %} aria-current="page"{% endif %}>{{ item.label|e }}</a>
      {% endfor %}
      {% if commerce_enabled|default(false) %}
        <a href="{{ url_for('public.commerce.shop') }}" class="theme-nav-commerce-shop{% if _rp == '/shop' %} is-nav-active{% endif %}"{% if _rp == '/shop' %} aria-current="page"{% endif %}>Shop</a>
        <a href="{{ url_for('public.commerce.cart') }}" class="theme-nav-commerce-cart{% if _rp == '/commerce/cart' %} is-nav-active{% endif %}">Cart{% if commerce_cart_count|default(0) > 0 %} ({{ commerce_cart_count }}){% endif %}</a>
      {% endif %}
      {% if logged_in %}
        {% set _uname = user_username|default('')|trim %}
        {% set _nav_label = _uname != '' ? _uname : (user_email|default('Account')|split('@')|first) %}
        <span class="theme-nav-user" title="{{ user_email|default('')|e('html_attr') }}">{{ _nav_label|e }}</span>
        <form method="post" action="{{ url_for('logout') }}" class="theme-nav-logout-form">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <button type="submit" class="theme-nav-logout">Log out</button>
        </form>
      {% else %}
        {% set _auth_login_active = _rp == '/login' or _rp starts with '/login/' %}
        {% set _auth_register_active = _rp == '/register' or _rp starts with '/register/' %}
        <a href="{{ url_for('login') }}" class="theme-nav-link theme-nav-signin{% if _auth_login_active %} is-nav-active{% endif %}"{% if _auth_login_active %} aria-current="page"{% endif %}>Sign in</a>
        <a href="{{ url_for('register') }}" class="theme-nav-cta{% if _auth_register_active %} is-nav-active{% endif %}"{% if _auth_register_active %} aria-current="page"{% endif %}>Register</a>
      {% endif %}
    </nav>
  </div>
</header>
