{% extends 'layouts/base.twig' %}

{% set score_row = content_field_rows|filter(r => r.field_key == 'score')|first %}
{% set score_val = score_row ? score_row.value_raw|trim : '' %}

{% set _desc = content_meta_description|default('') %}
{% if _desc == '' and settings.default_meta_description|default('') %}
  {% set _desc = settings.default_meta_description %}
{% endif %}

{% block title %}{{ content_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ _desc|e }}{% endblock %}

{% block head_extra %}
  {% if content_featured_url %}
    <meta property="og:image" content="{{ site_url }}{{ content_featured_url|e('html_attr') }}" />
  {% endif %}
  <link rel="canonical" href="{{ site_url }}/{{ content_type.slug }}/{{ content_entry.slug }}" />
  {% if score_val != '' %}
    {% set review_ld = {
      '@context': 'https://schema.org',
      '@type': 'Review',
      'name': content_entry.title,
      'reviewBody': _desc,
      'reviewRating': {'@type': 'Rating', 'ratingValue': score_val + 0, 'bestRating': 5},
      'itemReviewed': {'@type': 'Thing', 'name': content_entry.title}
    } %}
    <script type="application/ld+json">{{ review_ld|json_encode|raw }}</script>
  {% endif %}
{% endblock %}

{% block body %}
<main class="theme-review-single">
  <article>
    <p class="eyebrow"><a href="{{ url_for('public.content_type_index', { typeSlug: content_type.slug }) }}">{{ content_type.name|e }}</a></p>
    <header class="theme-review-single-header">
      <h1>{{ content_entry.title|e }}</h1>
      {% if score_val != '' %}
        <p class="theme-review-single-score" aria-label="Score {{ score_val }} of 5"><strong>{{ score_val|e }}</strong> / 5</p>
      {% endif %}
      {% if content_entry.publishedAt %}
        <p class="theme-content-meta"><time datetime="{{ content_entry.publishedAt|e('html_attr') }}">{{ content_entry.publishedAt|e }}</time></p>
      {% endif %}
    </header>

    {% if entry_taxonomy_groups is defined and entry_taxonomy_groups is not empty %}
      <div class="theme-entry-taxonomies">
        {% for g in entry_taxonomy_groups %}
          <p class="theme-entry-taxonomy-row">
            <span class="theme-entry-taxonomy-name">{{ g.taxonomy.name|e }}</span>
            {% for t in g.terms %}
              <a class="theme-entry-taxonomy-link" href="{{ taxonomy_archive_url(content_type.slug, g.taxonomy.slug, t.slug) }}">{{ t.name|e }}</a>{% if not loop.last %}<span class="theme-entry-taxonomy-sep"> · </span>{% endif %}
            {% endfor %}
          </p>
        {% endfor %}
      </div>
    {% endif %}

    {% if content_featured_url %}
      <figure class="theme-content-featured">
        <img src="{{ content_featured_url|e('html_attr') }}" alt="" loading="eager" decoding="async" />
      </figure>
    {% endif %}

    {% set summary_row = content_field_rows|filter(r => r.field_key == 'summary')|first %}
    {% if summary_row and summary_row.value_raw|trim != '' %}
      <p class="theme-review-summary">{{ summary_row.value_raw|e|nl2br }}</p>
    {% endif %}

    <div class="theme-review-pc-grid">
      {% for row in content_field_rows %}
        {% if row.field_key == 'pros' %}
          <section class="theme-review-pc theme-review-pc--pros">
            <h2 class="theme-field-label">{{ row.label|e }}</h2>
            <div class="theme-field-value theme-field-value--richtext">{{ row.html|raw }}</div>
          </section>
        {% endif %}
        {% if row.field_key == 'cons' %}
          <section class="theme-review-pc theme-review-pc--cons">
            <h2 class="theme-field-label">{{ row.label|e }}</h2>
            <div class="theme-field-value theme-field-value--richtext">{{ row.html|raw }}</div>
          </section>
        {% endif %}
      {% endfor %}
    </div>

    {% for row in content_field_rows %}
      {% if row.field_key == 'verdict' %}
        <section class="theme-review-verdict">
          <div class="theme-field-value theme-field-value--richtext">{{ row.html|raw }}</div>
        </section>
      {% endif %}
    {% endfor %}

    {% for row in content_field_rows %}
      {% if row.field_key == 'affiliate_link' and row.value_raw|trim != '' %}
        <p class="theme-review-affiliate"><a href="{{ row.value_raw|e('html_attr') }}" rel="nofollow sponsored noopener noreferrer">View official site →</a></p>
      {% endif %}
    {% endfor %}
  </article>
</main>
{% endblock %}
