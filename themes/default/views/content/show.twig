{% extends 'layouts/base.twig' %}

{% set _desc = content_meta_description|default('') %}
{% if _desc == '' and settings.default_meta_description|default('') %}
  {% set _desc = settings.default_meta_description %}
{% endif %}

{% block title %}{{ content_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ _desc|e }}{% endblock %}
{% block og_title %}{{ content_page_title|e }}{% endblock %}
{% block og_description %}{{ _desc|e }}{% endblock %}
{% block twitter_title %}{{ content_page_title|e }}{% endblock %}
{% block twitter_description %}{{ _desc|e }}{% endblock %}

{% block head_extra %}
  {% if content_featured_url %}
    {% set _fu = content_featured_url|trim %}
    {% set _og_img = (_fu|slice(0, 7) == 'http://' or _fu|slice(0, 8) == 'https://') ? _fu : site_url ~ _fu %}
    <meta property="og:image" content="{{ _og_img|e('html_attr') }}" />
    <meta name="twitter:image" content="{{ _og_img|e('html_attr') }}" />
  {% endif %}
  <link rel="canonical" href="{{ site_url }}/{{ content_type.slug }}/{{ content_entry.slug }}" />
{% endblock %}

{% block body %}
<main class="theme-content-entry">
  <article>
    <p class="eyebrow">{{ content_type.name|e }}</p>
    <h1>{{ content_entry.title|e }}</h1>
    {% if content_entry.publishedAt %}
      <p class="theme-content-meta">
        <time datetime="{{ content_entry.publishedAt|e('html_attr') }}">{{ content_entry.publishedAt|e }}</time>
      </p>
    {% endif %}

    {% if entry_taxonomy_groups is defined and entry_taxonomy_groups is not empty %}
      <div class="theme-entry-taxonomies">
        {% for g in entry_taxonomy_groups %}
          <p class="theme-entry-taxonomy-row">
            <span class="theme-entry-taxonomy-name">{{ g.taxonomy.name|e }}</span>
            {% for t in g.terms %}
              <a class="theme-entry-taxonomy-link" href="{{ taxonomy_archive_url(content_type.slug, g.taxonomy.slug, t.slug) }}">{{ t.name|e }}</a>{% if not loop.last %}<span class="theme-entry-taxonomy-sep"> · </span>{% endif %}
            {% endfor %}
          </p>
        {% endfor %}
      </div>
    {% endif %}

    {% if content_featured_url %}
      <figure class="theme-content-featured">
        <img src="{{ content_featured_url|e('html_attr') }}" alt="" loading="eager" decoding="async" />
      </figure>
    {% endif %}

    {% if commerce_product is defined and commerce_product %}
      <div class="theme-commerce-buy-wrap">
        {% include 'commerce/_buy_form.twig' %}
      </div>
    {% endif %}

    {% if content_entry_has_sections|default(false) and content_entry_sections_html|default('')|trim != '' %}
      <div class="theme-cms-sections theme-content-entry-sections" data-strux-sections>{{ content_entry_sections_html|raw }}</div>
    {% endif %}

    <div class="theme-cms-body">
      {% for row in content_field_rows %}
        {% if commerce_product is defined and commerce_product and row.field_key in ['price_cents', 'purchasable', 'stripe_price_id', 'sku', 'stock_qty', 'digital_file', 'digital_url', 'digital_entry_slug', 'digital_label'] %}
          {# Shown via commerce buy form #}
        {% else %}
        <section class="theme-field-block" data-field-key="{{ row.field_key|e('html_attr') }}">
          <h2 class="theme-field-label">{{ row.label|e }}</h2>
          <div class="theme-field-value theme-field-value--{{ row.field_type|e('html_attr') }}">
            {{ row.html|raw }}
          </div>
        </section>
        {% endif %}
      {% endfor %}
    </div>
    {% if comments_enabled_for_view|default(false) %}
      {% include 'partials/comments_widget.twig' %}
    {% endif %}
  </article>
</main>
{% endblock %}
