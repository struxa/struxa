{% extends 'layouts/base.twig' %}

{% block title %}{{ taxonomy_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ taxonomy_meta_description|default('')|e }}{% endblock %}

{% block body %}
<main class="theme-taxonomy-archive">
  <article>
    <p class="eyebrow">{{ taxonomy.name|e }} · {{ content_type.name|e }}</p>
    <h1>{{ taxonomy_term.name|e }}</h1>
    {% if taxonomy_term.description %}
      <p class="theme-taxonomy-archive-lead">{{ taxonomy_term.description|e }}</p>
    {% endif %}

    {% if archive_entries is empty %}
      <p class="theme-muted">No published entries in this archive yet.</p>
    {% else %}
      <ul class="theme-taxonomy-archive-list">
        {% for row in archive_entries %}
          <li>
            <a href="{{ site_url }}/{{ content_type.slug|e }}/{{ row.slug|e }}">{{ row.title|e }}</a>
            {% if row.published_at %}
              <span class="theme-muted theme-taxonomy-archive-date">{{ row.published_at|e }}</span>
            {% endif %}
          </li>
        {% endfor %}
      </ul>

      {% if archive_total_pages > 1 %}
        <nav class="theme-pager" aria-label="Pagination">
          {% if archive_page > 1 %}
            <a href="{{ url_for('public.taxonomy_archive', { typeSlug: content_type.slug, taxonomySlug: taxonomy.slug, termSlug: taxonomy_term.slug }) }}?page={{ archive_page - 1 }}">Newer</a>
          {% endif %}
          <span class="theme-muted">Page {{ archive_page }} of {{ archive_total_pages }}</span>
          {% if archive_page < archive_total_pages %}
            <a href="{{ url_for('public.taxonomy_archive', { typeSlug: content_type.slug, taxonomySlug: taxonomy.slug, termSlug: taxonomy_term.slug }) }}?page={{ archive_page + 1 }}">Older</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endif %}
  </article>
</main>
{% endblock %}
