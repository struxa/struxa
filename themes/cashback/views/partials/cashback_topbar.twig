{% set _rp = request_path|default('/') %}
{% set _top = header_menu|slice(0, 4) %}
<header class="cb-topbar">
  <nav class="cb-topnav" aria-label="Section">
    {% if _top is not empty %}
      {% for item in _top %}
        <a
          href="{{ item.href|e('html_attr') }}"
          class="{{ item.is_active|default(false) ? 'cb-active' : '' }}"
          {% if item.is_active|default(false) %}aria-current="page"{% endif %}
          {% if item.target == '_blank' %}target="_blank"{% endif %}
          {% if item.anchor_rel|default('')|trim != '' %}rel="{{ item.anchor_rel|e('html_attr') }}"{% endif %}
        >{{ item.label|e }}</a>
      {% endfor %}
    {% else %}
      <a class="cb-active" href="{{ url_for('home') }}"{% if _rp == '/' %} aria-current="page"{% endif %}>🟢 Earn</a>
      <a href="#">📄 My Offers</a>
      <a href="#">💰 Cashout</a>
      <a href="#">🏅 Rewards</a>
    {% endif %}
  </nav>

  <div class="cb-top-actions">
    <div class="cb-badge-box" aria-label="Balance demo">£7.07</div>
    <button type="button" class="cb-icon-btn" aria-label="Hot">🔥</button>
    <button type="button" class="cb-icon-btn" aria-label="Shield">🛡️</button>
    {% if logged_in|default(false) %}
      {% set _cb_display = user_username|default('')|trim != '' ? user_username : (user_email|default('')|trim != '' ? user_email : 'Account') %}
      <a class="cb-user-box" href="#" title="{{ user_email|default('')|e('html_attr') }}"><span class="cb-avatar" aria-hidden="true"></span> {{ _cb_display|e }}</a>
    {% else %}
      <a class="cb-user-box" href="{{ url_for('login') }}"><span class="cb-avatar" aria-hidden="true"></span> {{ 'Sign in'|e }}</a>
    {% endif %}
    <button type="button" class="cb-icon-btn" aria-label="Notifications">🔔</button>
    <button type="button" class="cb-icon-btn" aria-label="Messages">💬</button>
  </div>
</header>
