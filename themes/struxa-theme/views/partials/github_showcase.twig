{# Open-source spotlight — defaults to struxa/struxa on GitHub. #}
{% set _repo_url = theme_settings.github_repo_url|default('https://github.com/struxa/struxa')|trim %}
{% if _repo_url != '' %}
  {% set _repo_path = _repo_url|replace({'https://github.com/': '', 'http://github.com/': '', '.git': ''})|trim('/') %}
  {% set _repo_parts = _repo_path|split('/') %}
  {% set _org = _repo_parts[0]|default('struxa') %}
  {% set _repo = _repo_parts[1]|default('struxa') %}
  {% set _title = theme_settings.github_showcase_title|default('Fork the core on GitHub')|trim %}
  {% set _lead = theme_settings.github_showcase_lead|default('Struxa CMS is open source — Slim 4, Twig, plugins, and themes you can clone, extend, and deploy.')|trim %}
  {% set _clone = 'git clone ' ~ _repo_url ~ '.git' %}
  {% set _stats = github_showcase_stats(_repo_url) %}

  <div class="st-github-showcase" data-section="github_showcase">
    <div class="st-github-showcase__glow" aria-hidden="true"></div>
    <div class="st-github-showcase__grid">
      <div class="st-github-showcase__copy">
        <p class="st-github-showcase__eyebrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Open source
        </p>
        {% if _title != '' %}
          <h3 class="st-github-showcase__title">{{ _title|e }}</h3>
        {% endif %}
        {% if _lead != '' %}
          <p class="st-github-showcase__lead">{{ _lead|e }}</p>
        {% endif %}
        {% if _stats.latest_version|default('')|trim != '' or _stats.themes_count|default(0) > 0 or _stats.plugins_count|default(0) > 0 or _stats.lines_of_code_label|default('')|trim != '' %}
          <dl class="st-github-showcase__metrics" aria-label="Project stats">
            {% if _stats.latest_version|default('')|trim != '' %}
              <div class="st-github-showcase__metric">
                <dt>Latest release</dt>
                <dd>
                  {% if _stats.release_url|default('')|trim != '' %}
                    <a href="{{ _stats.release_url|e('html_attr') }}" target="_blank" rel="noopener noreferrer">v{{ _stats.latest_version|e }}</a>
                  {% else %}
                    v{{ _stats.latest_version|e }}
                  {% endif %}
                </dd>
              </div>
            {% endif %}
            {% if _stats.themes_count|default(0) > 0 %}
              <div class="st-github-showcase__metric">
                <dt>Themes</dt>
                <dd>{{ _stats.themes_count|e }}</dd>
              </div>
            {% endif %}
            {% if _stats.plugins_count|default(0) > 0 %}
              <div class="st-github-showcase__metric">
                <dt>Plugins</dt>
                <dd>{{ _stats.plugins_count|e }}</dd>
              </div>
            {% endif %}
            {% if _stats.lines_of_code_label|default('')|trim != '' %}
              <div class="st-github-showcase__metric">
                <dt>Lines of code</dt>
                <dd title="Estimated from GitHub language stats">{{ _stats.lines_of_code_label|e }}</dd>
              </div>
            {% endif %}
            {% if _stats.stars|default(null) is not null and _stats.stars > 0 %}
              <div class="st-github-showcase__metric">
                <dt>Stars</dt>
                <dd>{{ _stats.stars|number_format(0, '.', ',') }}</dd>
              </div>
            {% endif %}
          </dl>
        {% endif %}
        <div class="st-github-showcase__actions">
          <a class="st-btn st-btn--primary" href="{{ _repo_url|e('html_attr') }}" target="_blank" rel="noopener noreferrer">
            View {{ _org|e }}/{{ _repo|e }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17 17 7M17 7H9M17 7v8"/></svg>
          </a>
        </div>
      </div>

      <div class="st-github-repo">
        <a class="st-github-repo__link" href="{{ _repo_url|e('html_attr') }}" target="_blank" rel="noopener noreferrer">
          <div class="st-github-repo__top">
            <span class="st-github-repo__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            </span>
            <span class="st-github-repo__name"><span class="st-github-repo__org">{{ _org|e }}</span> / <strong>{{ _repo|e }}</strong></span>
            {% if _stats.latest_version|default('')|trim != '' %}
              <span class="st-github-repo__version">v{{ _stats.latest_version|e }}</span>
            {% endif %}
            <span class="st-github-repo__pill">Public</span>
          </div>
          <p class="st-github-repo__desc">Struxa CMS · Slim/Twig content management with plugins, themes, and a full admin.</p>
          <ul class="st-github-repo__tags" aria-label="Tech stack">
            <li><span class="st-github-repo__dot st-github-repo__dot--php"></span> PHP</li>
            <li><span class="st-github-repo__dot st-github-repo__dot--twig"></span> Twig</li>
            <li><span class="st-github-repo__dot st-github-repo__dot--slim"></span> Slim 4</li>
            {% if _stats.themes_count|default(0) > 0 %}
              <li>{{ _stats.themes_count|e }} themes</li>
            {% endif %}
            {% if _stats.plugins_count|default(0) > 0 %}
              <li>{{ _stats.plugins_count|e }} plugins</li>
            {% endif %}
            {% if _stats.lines_of_code_label|default('')|trim != '' %}
              <li>{{ _stats.lines_of_code_label|e }} lines</li>
            {% endif %}
          </ul>
        </a>
        <div class="st-github-repo__clone">
          <code class="st-github-repo__cmd" id="st-github-clone-cmd">{{ _clone|e }}</code>
          <button type="button" class="st-github-repo__copy" data-copy-target="st-github-clone-cmd" aria-label="Copy git clone command">
            <span class="st-github-repo__copy-label">Copy</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
{% endif %}
