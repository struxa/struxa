<!DOCTYPE html>
<html lang="{{ settings.site_html_lang|default('en')|e('html_attr') }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {% set _accent = theme_settings.accent|default('')|trim %}
    {% if _accent == '' %}{% set _accent = '#ff6b2b' %}{% endif %}
    <style>
      :root{--st-bg:#f9f5f2;--st-surface:#fff;--st-text:#111827;--st-topbar:#632a13;--st-accent:#ff6b2b}
      *,*::before,*::after{box-sizing:border-box}
      body.theme-struxa{margin:0;background:var(--st-bg);color:var(--st-text);font-family:ui-sans-serif,system-ui,sans-serif;line-height:1.6}
      img{max-width:100%;height:auto;display:block}
      .st-shell{min-height:100vh;display:flex;flex-direction:column}
      .st-main{flex:1}
      .st-skip-link{position:absolute;left:-9999px}
    </style>
    {% include 'partials/_deferred_theme_css.twig' with {
      theme_stylesheets_async: ['css/app.css'],
    } only %}
    <title>
      {%- if struxa_seo|default(false) -%}
        {{- struxa_html_title|default('')|e -}}
      {%- else -%}
        {%- block title -%}{{ settings.default_meta_title|default(settings.site_name)|e }}{%- endblock -%}
      {%- endif -%}
    </title>
    <meta
      name="description"
      content="{%- if struxa_seo|default(false) -%}{{ struxa_meta_description|default('')|e('html_attr') }}{%- else -%}{%- block meta_description -%}{{ settings.default_meta_description|default('')|e }}{%- endblock -%}{%- endif -%}"
    />
    {% block meta_extra %}
      {% if struxa_seo|default(false) %}
        {% include 'public/_struxa_social_head.twig' %}
      {% endif %}
    {% endblock %}
    <link rel="canonical" href="{% if struxa_seo|default(false) %}{{ struxa_canonical_url|default('')|e('html_attr') }}{% else %}{% block canonical_href %}{{ site_url }}/{% endblock %}{% endif %}" />
    <meta name="theme-color" content="#632a13" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" href="{{ settings.favicon_href|default('/favicon.svg')|e('html_attr') }}" />
    {% if not struxa_seo|default(false) %}
      <meta property="og:type" content="website" />
      <meta property="og:site_name" content="{{ settings.site_name|e }}" />
      <meta property="og:title" content="{% block og_title %}{{ settings.default_meta_title|default(settings.site_name)|e }}{% endblock %}" />
      <meta property="og:description" content="{% block og_description %}{{ settings.default_meta_description|default('')|e }}{% endblock %}" />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content="{% block twitter_title %}{{ settings.default_meta_title|default(settings.site_name)|e }}{% endblock %}" />
      <meta name="twitter:description" content="{% block twitter_description %}{{ settings.default_meta_description|default('')|e }}{% endblock %}" />
    {% endif %}
    {% block head_extra %}{% endblock %}
    {% if request_path|default('') starts with '/forum' %}
      {% include 'partials/_nonblocking_stylesheet.twig' with { href: theme_asset('css/forum-overrides.css') } only %}
    {% endif %}
  </head>
  <body class="theme-struxa" style="--st-accent: {{ _accent|e('html_attr') }}">
    <div class="st-shell">
      <a class="st-skip-link" href="#main-content">Skip to main content</a>
      {% set _search_on = storefront_search_on() %}
      {% if _search_on %}
        {% include 'partials/site_search_modal.twig' %}
      {% endif %}
      {% include 'partials/header.twig' %}
      <div class="st-main">
        {% block body %}{% endblock %}
      </div>
      {% include 'partials/footer.twig' %}
    </div>
    <script src="{{ theme_asset('js/main.js') }}" defer></script>
    {% include 'partials/_struxa_tracking.twig' %}
    {% block scripts_extra %}{% endblock %}
  </body>
</html>
