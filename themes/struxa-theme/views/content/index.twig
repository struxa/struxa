{% extends 'layouts/base.twig' %}

{% block title %}{{ content_type.name|e }} — {{ settings.site_name|e }}{% endblock %}
{% block canonical_href %}{{ site_url }}/{{ content_type.slug }}{% endblock %}

{% block body %}
<main id="main-content" class="st-page{% if content_type.slug == 'kb' %} st-page--kb{% endif %}">
  <div class="st-page__inner{% if content_type.slug == 'kb' %} st-page__inner--wide{% endif %}">
    {% if content_type.slug == 'kb' %}
      {% include 'content/kb/_index_main.twig' %}
    {% else %}
    {% include 'content/_index_grid.twig' with {
      eyebrow_label: content_type.name,
      blog_archive_title: content_type.name,
      content_index_description: content_type.description|default(''),
      empty_message: 'No entries published yet.',
      read_more_label: 'Read more',
      newer_label: 'Newer',
      older_label: 'Older',
      card_tag_fallback: 'Article',
    } %}
    {% endif %}
  </div>
</main>
{% endblock %}
