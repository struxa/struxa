{% extends 'layouts/base.twig' %}

{% set _desc = content_meta_description|default('') %}
{% if _desc == '' and settings.default_meta_description|default('') %}
  {% set _desc = settings.default_meta_description %}
{% endif %}

{% block title %}{{ content_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ _desc|e }}{% endblock %}
{% block og_title %}{{ content_page_title|e }}{% endblock %}
{% block og_description %}{{ _desc|e }}{% endblock %}
{% block twitter_title %}{{ content_page_title|e }}{% endblock %}
{% block twitter_description %}{{ _desc|e }}{% endblock %}

{% block head_extra %}
  {% if content_featured_url %}
    {% set _fu = content_featured_url|trim %}
    {% set _og_img = (_fu|slice(0, 7) == 'http://' or _fu|slice(0, 8) == 'https://') ? _fu : site_url ~ _fu %}
    <meta property="og:image" content="{{ _og_img|e('html_attr') }}" />
    <meta name="twitter:image" content="{{ _og_img|e('html_attr') }}" />
  {% endif %}
  <link rel="canonical" href="{{ site_url }}/{{ content_type.slug }}/{{ content_entry.slug }}" />
{% endblock %}

{% block body %}
<main id="main-content" class="st-page st-page--kb">
  <div class="st-page__inner st-page__inner--wide">
    {% if kb_public_enabled() %}
      <div class="st-kb-layout">
        {% include 'partials/kb_sidebar.twig' with { kb_current_slug: content_entry.slug } %}
        <div class="st-kb-layout__main">
          <article class="st-kb-article">
            <nav class="st-kb-article__crumb" aria-label="Breadcrumb">
              <a href="{{ url_for('public.content_type_index', { typeSlug: content_type.slug }) }}">{{ content_type.name|e }}</a>
              <span aria-hidden="true">/</span>
              <span>{{ content_entry.title|e }}</span>
            </nav>
            <header class="st-kb-article__head">
              <h1>{{ content_entry.title|e }}</h1>
              {% if content_entry.publishedAt %}
                <p class="st-meta">
                  <time datetime="{{ content_entry.publishedAt|e('html_attr') }}">{{ content_entry.publishedAt|e }}</time>
                </p>
              {% endif %}
            </header>

            {% if content_featured_url %}
              <figure class="st-content-featured">
                <img src="{{ content_featured_url|e('html_attr') }}" alt="" loading="eager" decoding="async" />
              </figure>
            {% endif %}

            {% if content_entry_has_sections|default(false) and content_entry_sections_html|default('')|trim != '' %}
              <div class="cms-prose st-cms-sections" data-strux-sections>{{ content_entry_sections_html|raw }}</div>
            {% endif %}

            <div class="cms-prose st-cms-body st-kb-article__body">
              {% for row in content_field_rows %}
                {% if row.field_key == 'summary' and row.html|striptags|trim != '' %}
                  <p class="st-kb-article__lead">{{ row.html|raw }}</p>
                {% elseif row.field_key == 'body' %}
                  <div class="st-kb-article__prose">{{ row.html|raw }}</div>
                {% elseif row.field_key not in ['summary', 'body'] %}
                  <section class="st-field-block" data-field-key="{{ row.field_key|e('html_attr') }}">
                    {% if row.label|default('')|trim != '' %}
                      <h2 class="st-field-label">{{ row.label|e }}</h2>
                    {% endif %}
                    <div class="st-field-value st-field-value--{{ row.field_type|e('html_attr') }}">
                      {{ row.html|raw }}
                    </div>
                  </section>
                {% endif %}
              {% endfor %}
            </div>
          </article>
        </div>
      </div>
    {% else %}
      <article class="st-article">
        <p class="st-eyebrow">{{ content_type.name|e }}</p>
        <h1>{{ content_entry.title|e }}</h1>
        <div class="cms-prose st-cms-body">
          {% for row in content_field_rows %}
            <div class="st-field-value">{{ row.html|raw }}</div>
          {% endfor %}
        </div>
      </article>
    {% endif %}
  </div>
</main>
{% endblock %}
