{% set _rp = request_path|default('/') %}
{% set _subtitle = theme_settings.brand_subtitle|default('TIPSTER') %}
<header class="site-header">
  <div class="container nav">
    <a class="brand" href="{{ url_for('home') }}"{% if _rp == '/' %} aria-current="page"{% endif %}>
      <div class="logo-mark" aria-hidden="true">♞</div>
      <div>
        <div class="brand-title">{{ settings.site_name|upper|e }}</div>
        <div class="brand-subtitle">{{ _subtitle|upper|e }}</div>
      </div>
    </a>

    <nav class="nav-links" id="hrNavLinks" aria-label="Primary">
      {% if header_menu is empty %}
        {# Demo rail when no Header menu is configured (matches bundled HTML mockup). #}
        <a href="{{ url_for('home') }}" class="{% if _rp == '/' %}active{% endif %}" {% if _rp == '/' %}aria-current="page"{% endif %}>HOME</a>
        <a href="{{ url_for('home') }}#tips">TODAY'S TIPS</a>
        <a href="{{ url_for('home') }}#results">RESULTS</a>
        <a href="{{ url_for('home') }}#record">TIPPING RECORD</a>
        <a href="{{ url_for('home') }}#membership">MEMBERSHIP</a>
        <a href="/blog">BLOG</a>
        <a href="{{ url_for('home') }}#about">ABOUT</a>
      {% else %}
        {% for item in header_menu %}
          <a
            href="{{ item.href|e('html_attr') }}"
            class="{% if item.is_active|default(false) %}active{% endif %}"
            {% if item.target == '_blank' %}target="_blank"{% endif %}
            {% if item.anchor_rel|default('')|trim != '' %}rel="{{ item.anchor_rel|e('html_attr') }}"{% endif %}
            {% if item.is_active|default(false) %}aria-current="page"{% endif %}
          >{{ item.label|upper|e }}</a>
        {% endfor %}
      {% endif %}
      {% if logged_in %}
        {% set _uname = user_username|default('')|trim %}
        {% set _nav_label = _uname != '' ? _uname : (user_email|default('Account')|split('@')|first) %}
        <span style="color:rgba(255,255,255,.75);font-size:12px;font-weight:800">{{ _nav_label|e }}</span>
        <form method="post" action="{{ url_for('logout') }}" style="display:inline;margin:0">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <button type="submit" class="btn btn-outline btn-header" style="cursor:pointer;height:auto">LOG OUT</button>
        </form>
      {% endif %}
    </nav>

    <div class="nav-actions">
      {% if not logged_in %}
        {% set _login_active = _rp == '/login' or _rp starts with '/login/' %}
        {% set _reg_active = _rp == '/register' or _rp starts with '/register/' %}
        <a href="{{ url_for('login') }}" class="btn btn-outline btn-header{% if _login_active %} active{% endif %}"{% if _login_active %} aria-current="page"{% endif %}>♙ LOGIN</a>
        <a href="{{ url_for('register') }}" class="btn btn-gold btn-header{% if _reg_active %} active{% endif %}"{% if _reg_active %} aria-current="page"{% endif %}>♛ JOIN NOW</a>
      {% endif %}
      <button type="button" class="mobile-toggle" id="hrMobileToggle" aria-expanded="false" aria-controls="hrNavLinks">☰</button>
    </div>
  </div>
</header>
