{% extends 'layouts/base.twig' %}

{% block title %}{{ settings.default_meta_title|default(settings.site_name)|e }}{% endblock %}
{% block meta_description %}{{ settings.default_meta_description|default(settings.site_tagline|default(''))|e }}{% endblock %}

{% block body %}
{% set eb = theme_settings.hero_eyebrow|default('Data-led racing selections') %}
{% set h1 = theme_settings.hero_heading_line1|default('Expert Tips.') %}
{% set h2 = theme_settings.hero_heading_line2|default('Stronger Results.') %}
{% set lead = theme_settings.hero_lead|default('Daily horse racing tips built from form, market movement, trainer data and in-depth race analysis.') %}

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="eyebrow">{{ eb|e }}</div>
      <h1 class="hr-hero-title">{{ h1|e }}<br />{{ h2|e }}</h1>
      <p>{{ lead|e }}</p>
      <div class="hero-buttons">
        <a class="btn btn-gold btn-hero" href="{{ url_for('register') }}">♛ <span>JOIN NOW<small>Start winning today</small></span></a>
        <a class="btn btn-outline btn-hero" href="#tips">▤ <span>TODAY'S TIPS<small>See our top selections</small></span></a>
      </div>
    </div>
  </div>
</section>

<section class="stats-strip">
  <div class="container">
    <div class="stats-card">
      <div class="stat">
        <div class="stat-icon">🏆</div>
        <div><div class="stat-label">Win Strike Rate</div><div class="stat-value" data-count="24">0%</div><div class="stat-note">Last 12 months</div></div>
      </div>
      <div class="stat">
        <div class="stat-icon">🎯</div>
        <div><div class="stat-label">Place Strike Rate</div><div class="stat-value" data-count="53">0%</div><div class="stat-note">Last 12 months</div></div>
      </div>
      <div class="stat">
        <div class="stat-icon">📈</div>
        <div><div class="stat-label">Profit ROI</div><div class="stat-value" data-count="28.7">0%</div><div class="stat-note">Last 12 months</div></div>
      </div>
      <div class="stat">
        <div class="stat-icon">📅</div>
        <div><div class="stat-label">Tips This Month</div><div class="stat-value" data-count="78">0</div><div class="stat-note">Across all meetings</div></div>
      </div>
      <div class="stat">
        <div>
          <div class="stat-label">Trusted by 1,000+</div>
          <div class="stars">★★★★★</div>
          <div class="stat-note">4.9/5 from 230+ reviews</div>
        </div>
      </div>
    </div>
  </div>
</section>

<main id="main-content" class="hr-main">
  <div class="container">
    <div class="grid">
      <section class="panel" id="tips">
        <div class="panel-header">
          <div class="panel-title">♞ TODAY'S TOP TIPS</div>
          <button type="button" class="mini-btn">VIEW ALL TIPS</button>
        </div>
        <div class="tips-table-wrap">
          <table class="hr-panel-table">
            <thead>
              <tr>
                <th>Time</th>
                <th>Meeting</th>
                <th>Horse</th>
                <th>Tip</th>
                <th>Price</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="hrTipsBody"></tbody>
          </table>
        </div>
        <div class="view-all"><a href="#tips">VIEW ALL TODAY'S TIPS →</a></div>
      </section>

      <aside>
        <section class="panel" id="record">
          <div class="panel-header">
            <div class="panel-title">↗ TIPPING RECORD</div>
            <label class="sr-only" for="hrRangeSelect">Date range</label>
            <select id="hrRangeSelect" class="hr-select" aria-label="Tipping record range">
              <option value="12">Last 12 Months</option>
              <option value="6">Last 6 Months</option>
              <option value="3">Last 3 Months</option>
            </select>
          </div>
          <div class="record-body">
            <div class="record-top">
              <div>
                <div class="stat-label" style="color:#192420">Profit ROI</div>
                <div class="record-value" id="hrRoiValue">+28.7%</div>
              </div>
            </div>
            <svg class="chart" viewBox="0 0 520 160" preserveAspectRatio="none" aria-label="ROI chart">
              <defs>
                <linearGradient id="hrAreaGradient" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0" stop-color="#1e8e4d" stop-opacity=".28" />
                  <stop offset="1" stop-color="#1e8e4d" stop-opacity="0" />
                </linearGradient>
              </defs>
              <path id="hrAreaPath" d="" fill="url(#hrAreaGradient)"></path>
              <path id="hrLinePath" d="" fill="none" stroke="#1e8e4d" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
        </section>

        <section class="panel features" id="about">
          <div class="panel-header">
            <div class="panel-title">WHY CHOOSE {{ settings.site_name|upper|e }}?</div>
          </div>
          <div class="feature-grid">
            <div class="feature"><div class="feature-icon">📋</div><strong>Proven Tips</strong><p>Researched and form-backed selections.</p></div>
            <div class="feature"><div class="feature-icon">📊</div><strong>Strong Results</strong><p>Clear performance and ROI tracking.</p></div>
            <div class="feature"><div class="feature-icon">🔍</div><strong>Deep Analysis</strong><p>Trainer, jockey, pace and going data.</p></div>
            <div class="feature"><div class="feature-icon">🛡️</div><strong>Trusted</strong><p>Simple pricing with no hidden catches.</p></div>
          </div>
        </section>
      </aside>
    </div>

    <section class="cta" id="membership">
      <div class="cta-left">
        <div class="crown">♛</div>
        <div><strong>READY TO IMPROVE YOUR RESULTS?</strong><span>Join today and get access to all tips, stats and member benefits.</span></div>
      </div>
      <a class="btn btn-gold btn-header" href="{{ url_for('register') }}">♛ JOIN NOW</a>
    </section>
  </div>
</main>

<style>
  .sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0; }
</style>
{% endblock %}
