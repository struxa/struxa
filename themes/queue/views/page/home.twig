{% extends 'layouts/base.twig' %}
{% set strux_queue_static_home = true %}

{% block body %}
<main id="main-content" class="theme-home-fq">
  <div class="theme-home-fq__glow" aria-hidden="true"></div>
  <div class="theme-home-fq__grid" aria-hidden="true"></div>

  <div class="theme-home-fq__inner">
    <div class="theme-home-fq__layout">
      <div class="theme-home-fq__copy">
        <p class="theme-home-fq__kicker">
          {% if settings.site_tagline|default('')|trim != '' %}
            {{ settings.site_tagline|e }}
          {% else %}
            Honest structure beats vague “looks fine” — for your site and your editors.
          {% endif %}
        </p>

        <h1 class="theme-home-fq__title">
          <span class="theme-home-fq__title-line">You ship the product.</span>
          <span class="theme-home-fq__title-line theme-home-fq__title-line--emph">
            Now ship the <span class="theme-home-fq__highlight">experience</span>.
          </span>
          <span class="theme-home-fq__title-badges">
            <span class="theme-home-fq__badge">Pages</span>
            <span class="theme-home-fq__badge">Types</span>
            <span class="theme-home-fq__badge">Themes</span>
          </span>
        </h1>

        <p class="theme-home-fq__lead">
          <strong class="theme-home-fq__brand">{{ settings.site_name|e }}</strong>
          runs on Struxa — structured content, real Twig templates, and a public theme you can swap without migrating data.
        </p>

        <ul class="theme-home-fq__chips">
          <li>Visual page builder</li>
          <li>First-class types &amp; taxonomies</li>
          <li>Theme inheritance</li>
        </ul>

        <div class="theme-home-fq__actions">
          <a class="theme-home-fq__btn theme-home-fq__btn--primary" href="{{ url_for('register') }}">Get started free</a>
          <a class="theme-home-fq__btn theme-home-fq__btn--ghost" href="{{ url_for('login') }}">Sign in</a>
        </div>
      </div>

      <aside class="theme-home-fq__visual" aria-hidden="true">
        <div class="theme-cms-mock">
          <div class="theme-cms-mock__chrome">
            <span class="theme-cms-mock__dot"></span>
            <span class="theme-cms-mock__dot theme-cms-mock__dot--amber"></span>
            <span class="theme-cms-mock__dot theme-cms-mock__dot--green"></span>
            <div class="theme-cms-mock__url"><span class="theme-cms-mock__url-lock"></span> {{ settings.site_name|default('Site')|e }} · Visual editor</div>
          </div>
          <div class="theme-cms-mock__body">
            <div class="theme-cms-mock__sidebar">
              <div class="theme-cms-mock__tool theme-cms-mock__tool--active"></div>
              <div class="theme-cms-mock__tool"></div>
              <div class="theme-cms-mock__tool"></div>
              <div class="theme-cms-mock__sidebar-gap"></div>
              <div class="theme-cms-mock__add">+</div>
            </div>
            <div class="theme-cms-mock__canvas">
              <div class="theme-cms-mock__block theme-cms-mock__block--hero">
                <div class="theme-cms-mock__hero-bar"></div>
                <div class="theme-cms-mock__hero-glow"></div>
              </div>
              <div class="theme-cms-mock__block theme-cms-mock__block--rich">
                <div class="theme-cms-mock__line"></div>
                <div class="theme-cms-mock__line theme-cms-mock__line--mid"></div>
                <div class="theme-cms-mock__line theme-cms-mock__line--short"></div>
              </div>
              <div class="theme-cms-mock__block theme-cms-mock__block--cards">
                <span class="theme-cms-mock__card"></span>
                <span class="theme-cms-mock__card"></span>
                <span class="theme-cms-mock__card theme-cms-mock__card--accent"></span>
              </div>
            </div>
          </div>
          <div class="theme-cms-mock__toast">
            <span class="theme-cms-mock__toast-dot"></span>
            Live preview synced
          </div>
        </div>
      </aside>
    </div>

    <dl class="theme-home-fq__stats">
      <div class="theme-home-fq__stat">
        <dt class="theme-home-fq__stat-k">Model</dt>
        <dd class="theme-home-fq__stat-v">Entries + routes</dd>
      </div>
      <div class="theme-home-fq__stat">
        <dt class="theme-home-fq__stat-k">Surface</dt>
        <dd class="theme-home-fq__stat-v">Blog · catalog · CMS pages</dd>
      </div>
      <div class="theme-home-fq__stat">
        <dt class="theme-home-fq__stat-k">You keep</dt>
        <dd class="theme-home-fq__stat-v">Code + database</dd>
      </div>
    </dl>

    <p class="theme-home-fq__footnote">
      Branding lives in <strong>Settings</strong>. For an editable homepage, use <strong>Pages</strong> with sections <em>Queue: Marketing hero</em>, <em>Queue: Stat bar</em>, and <em>Queue: Footnote</em> (see blueprint <code>queue-marketing-home.json</code>) or set <strong>Public site homepage</strong> in Site settings.
    </p>
  </div>
</main>
{% endblock %}
