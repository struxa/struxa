<div class="theme-home-fq theme-home-fq--section theme-home-fq--section-tail strux-section" data-section="queue_marketing_stats">
  <div class="theme-home-fq__inner">
    <dl class="theme-home-fq__stats">
      {% for row in section.queue_stats_json|default([]) %}
        <div class="theme-home-fq__stat">
          <dt class="theme-home-fq__stat-k">{{ row.heading|default('')|e }}</dt>
          <dd class="theme-home-fq__stat-v">{{ row.text|default('')|e }}</dd>
        </div>
      {% endfor %}
    </dl>
  </div>
</div>
