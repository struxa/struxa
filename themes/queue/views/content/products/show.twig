{% extends 'layouts/subpage_main.twig' %}

{% set _desc = content_meta_description|default('') %}
{% if _desc == '' and settings.default_meta_description|default('') %}
  {% set _desc = settings.default_meta_description %}
{% endif %}

{% block title %}{{ content_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ _desc|e }}{% endblock %}
{% block og_title %}{{ content_page_title|e }}{% endblock %}
{% block og_description %}{{ _desc|e }}{% endblock %}
{% block twitter_title %}{{ content_page_title|e }}{% endblock %}
{% block twitter_description %}{{ _desc|e }}{% endblock %}

{% block canonical_href %}{{ site_url }}/{{ content_type.slug }}/{{ content_entry.slug }}{% endblock %}

{% block head_extra %}
  {% if content_featured_url %}
    {% set _fu = content_featured_url|trim %}
    {% set _og_img = (_fu|slice(0, 7) == 'http://' or _fu|slice(0, 8) == 'https://') ? _fu : site_url ~ _fu %}
    <meta property="og:image" content="{{ _og_img|e('html_attr') }}" />
    <meta name="twitter:image" content="{{ _og_img|e('html_attr') }}" />
  {% endif %}
{% endblock %}

{% set excerpt_row = content_field_rows|filter(r => r.field_key == 'excerpt')|first %}
{% set body_row = content_field_rows|filter(r => r.field_key == 'body')|first %}
{% set price_row = content_field_rows|filter(r => r.field_key == 'price_display')|first %}
{% if not price_row or price_row.value_raw|default('')|trim == '' %}
  {% set price_row = content_field_rows|filter(r => r.field_key == 'price')|first %}
{% endif %}
{% set buy_row = content_field_rows|filter(r => r.field_key in ['buy_url', 'checkout_url', 'cta_url', 'purchase_url'] and r.value_raw|default('')|trim != '')|first %}
{% set demo_row = content_field_rows|filter(r => r.field_key in ['demo_url', 'trial_url'] and r.value_raw|default('')|trim != '')|first %}
{% set _hero_raw = content_featured_url|default('')|trim %}
{% set _has_hero = _hero_raw != '' %}
{% set _hero_src = (_hero_raw|slice(0, 7) == 'http://' or _hero_raw|slice(0, 8) == 'https://')
  ? _hero_raw
  : (_hero_raw|slice(0, 1) == '/' ? _hero_raw : site_url ~ '/' ~ _hero_raw|trim('/')) %}
{% set _index_url = url_for('public.content_type_index', { typeSlug: content_type.slug }) %}

{% block subpage_main %}
  <article class="blog-post product-detail">
    <section class="section product-detail-hero">
      <div class="product-detail-hero-shell" data-reveal>
      <div class="product-detail-stage">
        <div class="product-detail-intro">
          <div class="section-head blog-archive-head product-detail-intro__head">
            <p class="eyebrow reveal">
              <span class="eyebrow-pulse"></span>
              <a href="{{ _index_url }}">{{ content_type.name|e }}</a>
            </p>
            <h1 class="blog-archive-title">{{ content_entry.title|e }}</h1>

            <div class="product-detail-commerce" data-product-commerce>
              {% if price_row and price_row.value_raw|trim != '' %}
                <div class="product-detail-price-wrap">
                  <span class="product-detail-price-label">Pricing</span>
                  <p class="product-price product-price--hero">{{ price_row.value_raw|e }}</p>
                </div>
              {% endif %}
              <div class="product-detail-actions">
                {% if buy_row %}
                  <a class="btn btn-primary product-detail-btn-buy" href="{{ buy_row.value_raw|trim|e('html_attr') }}" rel="noopener noreferrer">{{ buy_row.label|default('Buy now')|e }}</a>
                {% endif %}
                {% if demo_row %}
                  <a class="btn btn-ghost product-detail-btn-demo" href="{{ demo_row.value_raw|trim|e('html_attr') }}" rel="noopener noreferrer">{{ demo_row.label|default('Book a demo')|e }}</a>
                {% endif %}
                {% if settings.contact_email|default('')|trim != '' %}
                  <a class="btn btn-ghost product-detail-btn-contact" href="mailto:{{ settings.contact_email|trim|e('html_attr') }}?subject={{ ('Question about ' ~ content_entry.title)|url_encode }}">{{ 'Contact sales'|e }}</a>
                {% endif %}
                <a class="btn {% if buy_row %}btn-ghost product-detail-btn-back--quiet{% else %}btn-primary{% endif %} product-detail-btn-back" href="{{ _index_url }}">All {{ content_type.name|e }}</a>
                {% if entry_taxonomy_groups is defined and entry_taxonomy_groups is not empty %}
                  {% set _first = entry_taxonomy_groups|first %}
                  {% set _term = _first.terms|first %}
                  {% if _term %}
                    <a class="btn btn-ghost product-detail-btn-tax" href="{{ taxonomy_archive_url(content_type.slug, _first.taxonomy.slug, _term.slug) }}">{{ _term.name|e }}</a>
                  {% endif %}
                {% endif %}
              </div>
            </div>
          </div>

          {% if entry_taxonomy_groups is defined and entry_taxonomy_groups is not empty %}
            <div class="blog-taxonomies product-taxonomies pill-row product-detail-intro__tax" aria-label="Categories">
              {% for g in entry_taxonomy_groups %}
                {% for t in g.terms %}
                  <a class="pill pill--cyan" href="{{ taxonomy_archive_url(content_type.slug, g.taxonomy.slug, t.slug) }}">{{ t.name|e }}</a>
                {% endfor %}
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <div class="product-detail-visual{% if not _has_hero %} product-detail-visual--empty{% endif %}">
          <div class="product-detail-visual__aurora" aria-hidden="true"></div>
          <div class="product-detail-visual__grid" aria-hidden="true"></div>
          {% if _has_hero %}
            <figure class="product-detail-visual__frame">
              <img
                class="product-detail-visual__img"
                src="{{ _hero_src|e('html_attr') }}"
                alt="{{ content_entry.title|e('html_attr') }}"
                loading="eager"
                decoding="async"
                width="1200"
                height="750"
              />
            </figure>
          {% else %}
            <div class="product-detail-visual__placeholder">
              <svg class="product-detail-visual__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="8" y="12" width="48" height="40" rx="8" stroke="currentColor" stroke-width="2" opacity="0.35" />
                <circle cx="24" cy="28" r="6" stroke="currentColor" stroke-width="2" opacity="0.5" />
                <path d="M38 36 L52 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.45" />
                <path d="M14 48 L28 34 L36 42 L46 32" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.4" />
              </svg>
              <span class="product-detail-visual__ph-label">Add a featured image</span>
              <span class="visually-hidden">No product image provided</span>
            </div>
          {% endif %}
        </div>
      </div>

      {% if excerpt_row and excerpt_row.value_raw|trim != '' %}
        <p class="blog-dek product-detail-dek">{{ excerpt_row.value_raw|e|nl2br }}</p>
      {% endif %}

      </div>

      {% if body_row and body_row.html|trim != '' %}
        <div class="product-detail-body-tabs" data-product-body-tabs data-reveal data-reveal-delay="160">
          <div class="blog-post-body cms-prose product-detail-prose theme-cms-body product-detail-body-tabs__source">{{ body_row.html|raw }}</div>
        </div>
      {% endif %}

      {% for row in content_field_rows %}
        {% if row.field_key not in ['excerpt', 'body', 'thumbnail_url', 'price_display', 'price', 'buy_url', 'checkout_url', 'cta_url', 'purchase_url', 'demo_url', 'trial_url'] and row.value_raw|trim != '' %}
          <div class="product-extra-field" data-reveal data-reveal-delay="{{ 200 + loop.index0 * 70 }}">
            <h2 class="theme-field-label">{{ row.label|e }}</h2>
            <div class="theme-field-value theme-field-value--{{ row.field_type|e('html_attr') }} cms-prose">{{ row.html|raw }}</div>
          </div>
        {% endif %}
      {% endfor %}

      <p class="product-detail-back" data-reveal data-reveal-delay="320">
        <a class="btn btn-ghost" href="{{ _index_url }}">← {{ content_type.name|e }}</a>
      </p>
    </section>
  </article>
{% endblock %}
