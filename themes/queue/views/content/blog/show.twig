{% extends 'layouts/subpage_main.twig' %}

{% set _desc = content_meta_description|default('') %}
{% if _desc == '' and settings.default_meta_description|default('') %}
  {% set _desc = settings.default_meta_description %}
{% endif %}

{% block title %}{{ content_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ _desc|e }}{% endblock %}
{% block og_title %}{{ content_page_title|e }}{% endblock %}
{% block og_description %}{{ _desc|e }}{% endblock %}
{% block twitter_title %}{{ content_page_title|e }}{% endblock %}
{% block twitter_description %}{{ _desc|e }}{% endblock %}

{% block canonical_href %}{{ site_url }}/{{ content_type.slug }}/{{ content_entry.slug }}{% endblock %}

{% block head_extra %}
  {% if not struxa_seo|default(false) and content_featured_url %}
    <meta property="og:image" content="{{ site_url }}{{ content_featured_url|e('html_attr') }}" />
    <meta name="twitter:image" content="{{ site_url }}{{ content_featured_url|e('html_attr') }}" />
  {% endif %}
{% endblock %}

{% set author_row = content_field_rows|filter(r => r.field_key == 'author_name')|first %}
{% set read_row = content_field_rows|filter(r => r.field_key == 'read_time')|first %}

{% block subpage_main %}
  <article class="blog-post">
    <section class="section blog-post-hero">
      <div class="blog-post-hero-shell" data-reveal>
        <div class="section-head blog-archive-head">
          <p class="eyebrow reveal">
            <span class="eyebrow-pulse"></span>
            <a href="{{ url_for('public.content_type_index', { typeSlug: content_type.slug }) }}">{{ content_type.name|e }}</a>
          </p>
          <h1 class="blog-archive-title">{{ content_entry.title|e }}</h1>
          <p class="blog-byline">
            {% if author_row and author_row.value_raw|trim != '' %}
              <span class="blog-byline-author">{{ author_row.html|raw }}</span>
            {% endif %}
            {% if content_entry.publishedAt %}
              <time datetime="{{ content_entry.publishedAt|e('html_attr') }}">{{ content_entry.publishedAt|e }}</time>
            {% endif %}
            {% if read_row and read_row.value_raw|trim != '' %}
              <span class="blog-byline-read">{{ read_row.html|raw }}</span>
            {% endif %}
          </p>
        </div>

        {% if entry_taxonomy_groups is defined and entry_taxonomy_groups is not empty %}
          <div class="blog-taxonomies pill-row" aria-label="Topics">
            {% for g in entry_taxonomy_groups %}
              {% for t in g.terms %}
                <a class="pill pill--violet" href="{{ taxonomy_archive_url(content_type.slug, g.taxonomy.slug, t.slug) }}">{{ t.name|e }}</a>
              {% endfor %}
            {% endfor %}
          </div>
        {% endif %}

        {% if content_featured_url %}
          <figure class="blog-featured content-entry-featured theme-content-featured">
            <img src="{{ content_featured_url|e('html_attr') }}" alt="" loading="eager" decoding="async" />
          </figure>
        {% else %}
          <figure class="blog-featured blog-featured--placeholder content-entry-featured theme-content-featured" aria-label="{{ 'This post has no featured image.'|e }}">
            <div class="blog-featured-placeholder">
              <svg class="blog-featured-placeholder__icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="8" y="12" width="48" height="40" rx="8" stroke="currentColor" stroke-width="2" opacity="0.35" />
                <circle cx="24" cy="28" r="6" stroke="currentColor" stroke-width="2" opacity="0.5" />
                <path d="M38 36 L52 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.45" />
                <path d="M14 48 L28 34 L36 42 L46 32" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.4" />
              </svg>
              <span class="blog-featured-placeholder__label" aria-hidden="true">{{ 'No cover image'|e }}</span>
            </div>
          </figure>
        {% endif %}

        {% set excerpt_row = content_field_rows|filter(r => r.field_key == 'excerpt')|first %}
        {% if excerpt_row and excerpt_row.value_raw|trim != '' %}
          <p class="blog-dek">{{ excerpt_row.value_raw|e|nl2br }}</p>
        {% endif %}

        {% set _blog_index = url_for('public.content_type_index', { typeSlug: content_type.slug }) %}
        <nav class="blog-post-actions" aria-label="{{ 'Post actions'|e }}">
          <a class="btn btn-primary blog-post-btn-index" href="{{ _blog_index }}">{{ 'All'|e }} {{ content_type.name|e }}</a>
          {% if settings.contact_email|default('')|trim != '' %}
            <a class="btn btn-ghost blog-post-btn-contact" href="mailto:{{ settings.contact_email|trim|e('html_attr') }}?subject={{ ('Question about ' ~ content_entry.title)|url_encode }}">{{ 'Contact'|e }}</a>
          {% endif %}
        </nav>
      </div>

      {% set body_row = content_field_rows|filter(r => r.field_key == 'body')|first %}
      {% if body_row %}
        <div class="blog-post-body cms-prose theme-cms-body" data-reveal data-reveal-delay="100">{{ body_row.html|raw }}</div>
      {% endif %}
    </section>
  </article>
{% endblock %}
