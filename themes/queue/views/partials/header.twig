{% set _rp = request_path|default('/') %}
<header class="theme-header">
  <div class="theme-header__inner">
    <a class="theme-brand{% if _rp == '/' %} theme-brand--active{% endif %}" href="{{ url_for('home') }}"{% if _rp == '/' %} aria-current="page"{% endif %}>
      {% if settings.logo_href|default('')|trim != '' %}
        <img src="{{ settings.logo_href|e('html_attr') }}" alt="{{ settings.site_name|e('html_attr') }}" width="140" height="36" loading="eager" />
      {% else %}
        {{ settings.site_name|e }}
      {% endif %}
    </a>
    <button type="button" class="theme-nav-toggle" aria-expanded="false" aria-controls="theme-primary-nav" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav id="theme-primary-nav" class="theme-nav" aria-label="Primary">
      <div class="theme-nav__primary">
        {% for item in header_menu %}
          <a class="theme-nav__link{% if item.is_active|default(false) %} theme-nav__link--active{% endif %}" href="{{ item.href|e('html_attr') }}" {% if item.target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}{% if item.is_active|default(false) %} aria-current="page"{% endif %}>{{ item.label|e }}</a>
        {% endfor %}
      </div>
      <div class="theme-nav__actions">
        {% if logged_in %}
          {% set _uname = user_username|default('')|trim %}
          {% set _nav_label = _uname != '' ? _uname : (user_email|default('Account')|split('@')|first) %}
          <span class="theme-nav__user" title="{{ user_email|default('')|e('html_attr') }}">{{ _nav_label|e }}</span>
          <form method="post" action="{{ url_for('logout') }}" class="theme-nav__logout-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
            <button type="submit" class="theme-nav__btn-logout">Log out</button>
          </form>
        {% else %}
          {% set _auth_login_active = _rp == '/login' or _rp starts with '/login/' %}
          {% set _auth_register_active = _rp == '/register' or _rp starts with '/register/' %}
          <a class="theme-nav__link theme-nav__link--ghost theme-nav__btn-signin{% if _auth_login_active %} theme-nav__link--active{% endif %}" href="{{ url_for('login') }}"{% if _auth_login_active %} aria-current="page"{% endif %}>Sign in</a>
          <a class="theme-nav-cta{% if _auth_register_active %} theme-nav__link--active{% endif %}" href="{{ url_for('register') }}"{% if _auth_register_active %} aria-current="page"{% endif %}>Register</a>
        {% endif %}
      </div>
    </nav>
  </div>
</header>
