{% extends 'layouts/subpage_main.twig' %}

{% block title %}{{ content_index_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ content_index_description|default(settings.default_meta_description|default(''))|e }}{% endblock %}
{% block og_title %}{{ content_index_title|e }}{% endblock %}
{% block og_description %}{{ content_index_description|default(settings.default_meta_description|default(''))|e }}{% endblock %}
{% block twitter_title %}{{ content_index_title|e }}{% endblock %}
{% block twitter_description %}{{ content_index_description|default(settings.default_meta_description|default(''))|e }}{% endblock %}

{% block canonical_href %}{{ site_url }}/{{ content_type.slug }}{% if index_page > 1 %}?page={{ index_page }}{% endif %}{% endblock %}

{% set _catalog_slugs = ['products', 'store', 'catalog', 'shop'] %}
{% set _use_catalog = content_type.slug in _catalog_slugs %}

{% block subpage_main %}
  {% include 'content/_index_grid.twig' with {
    section_modifier: _use_catalog ? 'product-catalog' : 'blog-archive',
    eyebrow_label: _use_catalog ? 'Apps & platforms' : 'Archive',
    empty_message: _use_catalog ? 'No products yet. Import a products blueprint or publish your first entry.' : 'No published entries yet.',
    read_more_label: _use_catalog ? 'View product →' : 'Read more →',
    newer_label: 'Newer',
    older_label: 'Older',
    card_tag_fallback: _use_catalog ? 'Product' : 'Article',
  } %}
{% endblock %}
