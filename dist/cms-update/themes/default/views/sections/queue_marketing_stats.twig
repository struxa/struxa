<section class="strux-section strux-stats strux-bg--{{ options.background|default('default')|e('html_attr') }}" data-section="queue_marketing_stats">
  <div class="strux-section-inner strux-section-inner--{{ options.padding|default('comfortable')|e('html_attr') }}">
    <ul class="strux-stats__grid">
      {% for row in section.queue_stats_json|default([]) %}
        <li class="strux-stats__item">
          <span class="strux-stats__label">{{ row.heading|default('')|e }}</span>
          <span class="strux-stats__value">{{ row.text|default('')|e }}</span>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>
