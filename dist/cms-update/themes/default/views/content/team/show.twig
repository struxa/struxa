{% extends 'layouts/base.twig' %}

{% set role_row = content_field_rows|filter(r => r.field_key == 'role')|first %}
{% set role_val = role_row ? role_row.value_raw|trim : '' %}
{% set linkedin_row = content_field_rows|filter(r => r.field_key == 'linkedin')|first %}
{% set linkedin_val = linkedin_row ? linkedin_row.value_raw|trim : '' %}

{% block title %}{{ content_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ content_meta_description|default('')|e }}{% endblock %}

{% block head_extra %}
  {% if content_featured_url %}
    <meta property="og:image" content="{{ site_url }}{{ content_featured_url|e('html_attr') }}" />
  {% endif %}
  <link rel="canonical" href="{{ site_url }}/{{ content_type.slug }}/{{ content_entry.slug }}" />
{% endblock %}

{% block body %}
<main class="theme-team-single">
  <article>
    <p class="eyebrow"><a href="{{ url_for('public.content_type_index', { typeSlug: content_type.slug }) }}">Team</a></p>
    <header class="theme-team-single-header">
      {% if content_featured_url %}
        <img class="theme-team-single-photo" src="{{ content_featured_url|e('html_attr') }}" alt="" loading="eager" decoding="async" />
      {% endif %}
      <div>
        <h1>{{ content_entry.title|e }}</h1>
        {% if role_val != '' %}
          <p class="theme-team-single-role">{{ role_val|e }}</p>
        {% endif %}
        {% if linkedin_val != '' %}
          <p><a href="{{ linkedin_val|e('html_attr') }}" rel="noopener noreferrer">LinkedIn profile →</a></p>
        {% endif %}
      </div>
    </header>

    {% if entry_taxonomy_groups is defined and entry_taxonomy_groups is not empty %}
      <div class="theme-entry-taxonomies">
        {% for g in entry_taxonomy_groups %}
          <p class="theme-entry-taxonomy-row">
            <span class="theme-entry-taxonomy-name">{{ g.taxonomy.name|e }}</span>
            {% for t in g.terms %}
              <a class="theme-entry-taxonomy-link" href="{{ taxonomy_archive_url(content_type.slug, g.taxonomy.slug, t.slug) }}">{{ t.name|e }}</a>{% if not loop.last %}<span class="theme-entry-taxonomy-sep"> · </span>{% endif %}
            {% endfor %}
          </p>
        {% endfor %}
      </div>
    {% endif %}

    {% for row in content_field_rows %}
      {% if row.field_key == 'bio' %}
        <div class="theme-cms-body theme-team-bio">{{ row.html|raw }}</div>
      {% endif %}
    {% endfor %}
  </article>
</main>
{% endblock %}
