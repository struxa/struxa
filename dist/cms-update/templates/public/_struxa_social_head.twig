{% if struxa_robots_noindex|default(false) %}
  <meta name="robots" content="noindex, nofollow" />
{% endif %}
<meta property="og:type" content="website" />
<meta property="og:site_name" content="{{ settings.site_name|e }}" />
<meta property="og:locale" content="{{ settings.site_og_locale|default('en_US')|e('html_attr') }}" />
<meta property="og:title" content="{{ struxa_og_title|default('')|e('html_attr') }}" />
<meta property="og:description" content="{{ struxa_og_description|default('')|e('html_attr') }}" />
{% if struxa_og_image|default('')|trim != '' %}
  <meta property="og:image" content="{{ struxa_og_image|e('html_attr') }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
{% endif %}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ struxa_twitter_title|default('')|e('html_attr') }}" />
<meta name="twitter:description" content="{{ struxa_twitter_description|default('')|e('html_attr') }}" />
{% if struxa_twitter_image|default('')|trim != '' %}
  <meta name="twitter:image" content="{{ struxa_twitter_image|e('html_attr') }}" />
{% endif %}
{% if struxa_schema_json_ld|default('')|trim != '' %}
  <script type="application/ld+json">{{ struxa_schema_json_ld|raw }}</script>
{% endif %}
