<section class="hero" id="top">
  <canvas id="hero-matrix" class="hero-matrix" aria-hidden="true"></canvas>
  <div class="hero-spotlight" id="hero-spotlight" aria-hidden="true"></div>
  <div class="hero-layout">
    <div class="hero-inner">
      <p class="eyebrow reveal" data-reveal>
        <span class="eyebrow-pulse"></span>
        Clarity beats vague handoffs
      </p>
      <h1 class="hero-title hero-title--stack reveal" data-reveal>
        <span class="hero-title-line">You finish the vision.</span>
        <span class="hero-title-line">We ship software that</span>
        <span class="hero-title-line hero-title-line--emphasis">
          feels <span class="gradient-text">alive</span> in production.
        </span>
      </h1>
      <p class="hero-lede reveal" data-reveal>
        Polished web apps, native-feel mobile, and internal tools — documented, transferable, and built so your
        team can own the roadmap without reverse-engineering intent.
      </p>
      <div class="hero-actions reveal" data-reveal>
        <a class="btn btn-primary" href="#work">Explore offerings</a>
        <a class="btn btn-ghost" href="mailto:hello@example.com">Start a conversation</a>
      </div>
      <ul class="hero-trust-strip reveal" data-reveal aria-label="Highlights">
        <li>Ship-ready deliverables</li>
        <li>Source &amp; IP transfer</li>
        <li>Modern, maintainable stack</li>
      </ul>
      <ul class="hero-chips reveal" data-reveal aria-label="Focus areas">
        <li>Licensing</li>
        <li>Custom builds</li>
        <li>Ongoing support</li>
      </ul>
    </div>
    <aside class="hero-visual reveal" data-reveal aria-hidden="true">
      <div class="hero-orbit">
        <div class="hero-card hero-card--web">
          <span class="hero-card-dot"></span>
          <span class="hero-card-title">Web app</span>
          <span class="hero-card-bar hero-card-bar--cyan"></span>
        </div>
        <div class="hero-card hero-card--mobile">
          <span class="hero-card-dot"></span>
          <span class="hero-card-title">Mobile</span>
          <span class="hero-card-bar hero-card-bar--rose"></span>
        </div>
        <div class="hero-card hero-card--desk">
          <span class="hero-card-dot"></span>
          <span class="hero-card-title">Desktop</span>
          <span class="hero-card-bar hero-card-bar--amber"></span>
        </div>
      </div>
      <div class="hero-ring"></div>
    </aside>
  </div>
  <div class="hero-metrics-band reveal" data-reveal>
    <div class="hero-metrics-head">
      <p class="hero-metrics-kicker">At a glance</p>
      <p class="hero-metrics-sub">What you get when we work together — real deliverables, not vanity metrics.</p>
    </div>
    <div class="hero-metrics">
      <article class="metric-card metric-card--violet">
        <div class="metric-card-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            <path d="M3.27 6.96 12 12.01l8.73-5.05M12 22.08V12" />
          </svg>
        </div>
        <div class="metric-card-stat">
          <span class="metric-value" data-count="12">0</span><span class="metric-plus">+</span>
        </div>
        <h3 class="metric-title">Products &amp; builds</h3>
        <p class="metric-blurb">Apps, internal tools, and experiments — documented and ready to hand off or white-label.</p>
      </article>
      <article class="metric-card metric-card--cyan">
        <div class="metric-card-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
          </svg>
        </div>
        <div class="metric-card-stat">
          <span class="metric-value" data-count="8">0</span>
        </div>
        <h3 class="metric-title">Tech verticals</h3>
        <p class="metric-blurb">From ops dashboards to customer-facing apps — depth across stacks, not one-trick demos.</p>
      </article>
      <article class="metric-card metric-card--rose">
        <div class="metric-card-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            <path d="m9 12 2 2 4-4" />
          </svg>
        </div>
        <div class="metric-card-stat">
          <span class="metric-value" data-count="100" data-suffix="%">0</span>
        </div>
        <h3 class="metric-title">Ownership ready</h3>
        <p class="metric-blurb">Repos, IP, envs, and handoff notes packaged so you can onboard engineers without guesswork.</p>
      </article>
    </div>
  </div>
</section>
