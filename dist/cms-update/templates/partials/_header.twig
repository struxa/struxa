<header class="site-header">
  <a class="logo" href="{{ url_for('home') }}">
    {% if settings.logo_href|default('')|trim != '' %}
      <img src="{{ settings.logo_href|e('html_attr') }}" alt="{{ settings.site_name|e('html_attr') }}" class="logo-img" width="140" height="36" loading="eager" />
    {% else %}
      {{ settings.site_name|e }}<span class="logo-dot">.</span>
    {% endif %}
  </a>
  <nav class="nav" aria-label="Primary">
    {% for item in header_menu %}
      <a
        href="{{ item.href|e('html_attr') }}"
        class="{{ (item.css_class|default('nav-link nav-link--violet'))|e('html_attr') }}"
        {% if item.target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}
      >
        <span class="nav-link-label">{{ item.label|e }}</span>
      </a>
    {% endfor %}
    {% if logged_in %}
      <form method="post" action="{{ url_for('logout') }}" style="display:inline;margin:0;padding:0">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <button type="submit" class="nav-link nav-link--violet" style="background:none;border:none;font:inherit;cursor:pointer;color:inherit;padding:0;display:inline-flex;align-items:center;gap:0.35rem">
          <span class="nav-link-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
              <polyline points="16 17 21 12 16 7" />
              <line x1="21" x2="9" y1="12" y2="12" />
            </svg>
          </span>
          <span class="nav-link-label">Log out</span>
        </button>
      </form>
    {% else %}
      <a href="{{ url_for('login') }}" class="nav-link nav-link--cyan">
        <span class="nav-link-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
            <polyline points="10 17 15 12 10 7" />
            <line x1="15" x2="3" y1="12" y2="12" />
          </svg>
        </span>
        <span class="nav-link-label">Log in</span>
      </a>
      <a href="{{ url_for('register') }}" class="nav-link nav-link--amber">
        <span class="nav-link-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <line x1="19" x2="19" y1="8" y2="14" />
            <line x1="22" x2="16" y1="11" y2="11" />
          </svg>
        </span>
        <span class="nav-link-label">Register</span>
      </a>
    {% endif %}
  </nav>
  <button type="button" class="menu-toggle" aria-expanded="false" aria-controls="mobile-nav">
    <span class="menu-toggle-bar"></span>
    <span class="menu-toggle-bar"></span>
  </button>
</header>

<div id="mobile-nav" class="mobile-nav" hidden>
  {% for item in header_menu %}
    <a
      href="{{ item.href|e('html_attr') }}"
      class="{{ (item.css_class|default('nav-link nav-link--violet'))|e('html_attr') }} nav-link--mobile"
      {% if item.target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}
    >
      <span class="nav-link-label">{{ item.label|e }}</span>
    </a>
  {% endfor %}
  {% if logged_in %}
    <form method="post" action="{{ url_for('logout') }}" style="display:block;margin:0;padding:0">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
      <button type="submit" class="nav-link nav-link--violet nav-link--mobile" style="background:none;border:none;font:inherit;cursor:pointer;color:inherit;width:100%;text-align:left;padding:inherit">
        <span class="nav-link-label">Log out</span>
      </button>
    </form>
  {% else %}
    <a href="{{ url_for('login') }}" class="nav-link nav-link--cyan nav-link--mobile">
      <span class="nav-link-label">Log in</span>
    </a>
    <a href="{{ url_for('register') }}" class="nav-link nav-link--amber nav-link--mobile">
      <span class="nav-link-label">Register</span>
    </a>
  {% endif %}
</div>
