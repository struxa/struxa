{# Resolves to active theme layouts/base.twig via theme_layout() — avoids core string-extends linter rule. #}
{% extends theme_layout() %}

{% block title %}Page not found — {{ settings.site_name|default('Site')|e }}{% endblock %}

{% block meta_extra %}
  {{ parent() }}
  <meta name="robots" content="noindex, nofollow" />
{% endblock %}

{% block canonical_href %}{{ site_url }}/{% endblock %}

{% block og_title %}Page not found — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block og_description %}This page does not exist or has moved.{% endblock %}
{% block twitter_title %}Page not found — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block twitter_description %}This page does not exist or has moved.{% endblock %}

{% block body %}
<main id="main-content" class="theme-public-solo{% if active_theme|default('') == 'queue' %} theme-fq-editorial{% endif %}"{% if active_theme|default('') == 'queue' %} data-fq-subpage{% endif %}>
  <article class="theme-cms-page theme-error-404" aria-labelledby="not-found-heading">
    <header class="theme-cms-page-hero">
      <p class="eyebrow">
        <span class="eyebrow-pulse" aria-hidden="true"></span>
        {{ 'Error 404'|e }}
      </p>
      <h1 class="theme-cms-page-title" id="not-found-heading">Page not found</h1>
      <p class="theme-error-404__lede">
        We couldn’t find that page. It may have been removed or the link might be wrong.
      </p>
      <div class="theme-error-404__actions" role="group" aria-label="{{ 'Next steps'|e }}">
        <a class="theme-home-fq__btn theme-home-fq__btn--primary" href="{{ url_for('home') }}">{{ 'Back to home'|e }}</a>
        <a class="theme-home-fq__btn theme-home-fq__btn--ghost" href="{{ url_for('login') }}">{{ 'Sign in'|e }}</a>
      </div>
      {% if not_found_debug and not_found_debug_detail %}
        <details class="theme-error-404__debug">
          <summary>Technical details (APP_DEBUG)</summary>
          <pre>{{ not_found_debug_detail|e }}</pre>
        </details>
      {% endif %}
    </header>
  </article>
</main>
{% endblock %}
