<section class="strux-section strux-split strux-bg--{{ options.background|default('default')|e('html_attr') }}" data-section="image_text">
  <div class="strux-section-inner strux-section-inner--{{ options.padding|default('comfortable')|e('html_attr') }} strux-split__layout strux-split__layout--{{ section.image_position|default('left')|e('html_attr') }}">
    {% if section.image_media_id %}
      <div class="strux-split__media">
        <img src="{{ media_url(section.image_media_id) }}" alt="" class="strux-split__img" loading="lazy" decoding="async" width="900" height="600" />
      </div>
    {% endif %}
    <div class="strux-split__copy cms-prose">
      <h2 class="strux-section-title">{{ section.title|default('')|e }}</h2>
      {{ section.body_html|default('')|raw }}
    </div>
  </div>
</section>
