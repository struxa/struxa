<section class="strux-section strux-quotes strux-bg--{{ options.background|default('default')|e('html_attr') }}" data-section="testimonials">
  <div class="strux-section-inner strux-section-inner--{{ options.padding|default('comfortable')|e('html_attr') }}">
    <h2 class="strux-section-title">{{ section.title|default('')|e }}</h2>
    <div class="strux-quotes__grid">
      {% for q in section.quotes_json|default([]) %}
        <blockquote class="strux-quotes__card">
          <p class="strux-quotes__text">“{{ q.quote|default('')|e }}”</p>
          <footer class="strux-quotes__meta">
            <strong>{{ q.attribution|default('')|e }}</strong>
            {% if q.role|default('')|trim != '' %}<span class="strux-quotes__role">{{ q.role|e }}</span>{% endif %}
          </footer>
        </blockquote>
      {% endfor %}
    </div>
  </div>
</section>
