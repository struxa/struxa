<section class="strux-section strux-stats strux-bg--{{ options.background|default('default')|e('html_attr') }}" data-section="stats_grid">
  <div class="strux-section-inner strux-section-inner--{{ options.padding|default('comfortable')|e('html_attr') }}">
    {% if section.title|default('')|trim != '' %}
      <h2 class="strux-section-title">{{ section.title|e }}</h2>
    {% endif %}
    <ul class="strux-stats__grid">
      {% for s in section.stats_json|default([]) %}
        <li class="strux-stats__item">
          <span class="strux-stats__value">{{ s.value|default('')|e }}</span>
          <span class="strux-stats__label">{{ s.label|default('')|e }}</span>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>
