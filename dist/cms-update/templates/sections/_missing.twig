{# Core fallback when no section template exists anywhere #}
<section class="strux-section strux-section--missing" data-section="{{ section_key|e('html_attr') }}">
  <div class="strux-section-inner">
    <p class="strux-section-missing-note">Section template missing: <code>{{ section_key|e }}</code></p>
  </div>
</section>
