<section class="strux-section strux-section--generic" data-section="{{ section_key|e('html_attr') }}">
  <div class="strux-section-inner strux-section-inner--{{ options.padding|default('comfortable')|e('html_attr') }} strux-bg--{{ options.background|default('default')|e('html_attr') }}">
    <p class="strux-section-eyebrow">{{ section_label|e }}</p>
    <pre class="strux-section-debug">{{ section|json_encode|e }}</pre>
  </div>
</section>
