{% extends 'admin/base.twig' %}

{% block admin_title %}Two-factor authentication{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Two-factor authentication</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Use an authenticator app (Google Authenticator, 1Password, etc.) for an extra step when you sign in.</p>
{% endblock %}

{% block admin_content %}
  {% if flash_error %}
    <p class="admin-flash admin-flash--error" role="alert">{{ flash_error|e }}</p>
  {% endif %}
  {% if flash_success %}
    <p class="admin-flash admin-flash--success" role="status">{{ flash_success|e }}</p>
  {% endif %}

  <section class="admin-card" style="margin-bottom:1.25rem">
    <h2 class="admin-card-title">Status</h2>
    {% if totp_enabled %}
      <p class="admin-hint" style="margin-top:0">Two-factor authentication is <strong>on</strong> for your account.</p>
    {% else %}
      <p class="admin-hint" style="margin-top:0">Two-factor authentication is <strong>off</strong>. We recommend turning it on for admin access.</p>
    {% endif %}
  </section>

  {% if not totp_enabled %}
    {% if enroll_qr_uri %}
      <section class="admin-card" style="margin-bottom:1.25rem">
        <h2 class="admin-card-title">Scan QR code</h2>
        <p class="admin-hint" style="margin-top:0">Add this account to your app, then enter a code to confirm.</p>
        <p style="margin:1rem 0"><img src="{{ enroll_qr_uri|e('html_attr') }}" width="200" height="200" alt="QR code for authenticator setup" /></p>
        <p class="admin-hint">If you cannot scan, enter the secret manually (treat it like a password): <code style="word-break:break-all">{{ enroll_secret|e }}</code></p>
        <form class="admin-form" method="post" action="{{ url_for('admin.account.two_factor.confirm') }}" style="margin-top:1.25rem">
          <div class="admin-field admin-field--full">
            <label class="admin-label" for="confirm_code">6-digit code</label>
            <input class="admin-input" type="text" id="confirm_code" name="code" inputmode="numeric" maxlength="12" required autocomplete="one-time-code" />
          </div>
          <div class="admin-form-actions">
            <button class="admin-btn-primary" type="submit">Confirm and enable</button>
            <a class="admin-btn-ghost" href="{{ url_for('admin.account.two_factor') }}">Cancel</a>
          </div>
        </form>
      </section>
    {% else %}
      <section class="admin-card" style="margin-bottom:1.25rem">
        <h2 class="admin-card-title">Enable</h2>
        <p class="admin-hint" style="margin-top:0">You will see a QR code to scan with your authenticator app.</p>
        <form method="post" action="{{ url_for('admin.account.two_factor.start') }}">
          <button class="admin-btn-primary" type="submit">Start setup</button>
        </form>
      </section>
    {% endif %}
  {% else %}
    <section class="admin-card">
      <h2 class="admin-card-title">Turn off</h2>
      <p class="admin-hint" style="margin-top:0">Enter your account password and a current authenticator code.</p>
      <form class="admin-form" method="post" action="{{ url_for('admin.account.two_factor.disable') }}">
        <div class="admin-field admin-field--full">
          <label class="admin-label" for="disable_password">Password</label>
          <input class="admin-input" type="password" id="disable_password" name="password" autocomplete="current-password" required />
        </div>
        <div class="admin-field admin-field--full">
          <label class="admin-label" for="disable_code">Authenticator code</label>
          <input class="admin-input" type="text" id="disable_code" name="code" inputmode="numeric" maxlength="12" required autocomplete="one-time-code" />
        </div>
        <div class="admin-form-actions">
          <button class="admin-btn-primary" type="submit">Disable two-factor</button>
        </div>
      </form>
    </section>
  {% endif %}
{% endblock %}
