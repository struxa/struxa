{# Expects: breadcrumbs as list of { label: string, url?: string } — last item may omit url for current page #}
{% if breadcrumbs is defined and breadcrumbs is not empty %}
  <nav class="admin-breadcrumbs" aria-label="Breadcrumb">
    <ol class="admin-breadcrumbs-list">
      {% for item in breadcrumbs %}
        <li class="admin-breadcrumbs-item">
          {% if item.url is defined and item.url %}
            <a class="admin-breadcrumbs-link" href="{{ item.url }}">{{ item.label|e }}</a>
          {% else %}
            <span class="admin-breadcrumbs-current" aria-current="page">{{ item.label|e }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
{% endif %}
