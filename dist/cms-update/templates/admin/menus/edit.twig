{% extends 'admin/base.twig' %}

{% block admin_title %}Edit menu{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Edit menu</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">
    <a class="admin-link" href="{{ url_for('admin.menus.index') }}">← Menus</a>
    <span class="admin-hero-sub-dot" aria-hidden="true">·</span>
    <code class="admin-inline-code">{{ menu.location|e }}</code>
    <span class="admin-hero-sub-dot" aria-hidden="true">·</span>
    <span class="admin-table-muted">{{ menu.name|e }}</span>
  </p>
{% endblock %}

{% block admin_content %}
  {% set mn = menu_old|default(null) %}
  {% set me = menu_errors|default({}) %}

  <div class="admin-user-edit-stack admin-menu-edit-stack">
    <section class="admin-card admin-settings-card admin-menu-edit-card">
      <h2 class="admin-settings-card-title">Menu details</h2>
      <p class="admin-settings-card-desc">Name is internal; placement chooses where the theme renders this menu.</p>
      <form class="admin-form" method="post" action="{{ url_for('admin.menus.update', { id: menu.id }) }}">
        <div class="admin-form-grid admin-form-grid--2col-tight">
          <div class="admin-field admin-field--full {{ me.name is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="name">Menu name <span class="admin-req">*</span></label>
            <input class="admin-input" type="text" id="name" name="name" value="{{ mn ? mn.name|e('html_attr') : menu.name|e('html_attr') }}" maxlength="160" required />
            {% if me.name is defined %}<p class="admin-field-error">{{ me.name|e }}</p>{% endif %}
          </div>
          <div class="admin-field admin-field--full {{ me.location is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="location">Placement <span class="admin-req">*</span></label>
            {% set loc = mn ? mn.location : menu.location %}
            <select class="admin-select" id="location" name="location" required>
              <option value="header" {{ loc == 'header' ? 'selected' : '' }}>Header</option>
              <option value="footer" {{ loc == 'footer' ? 'selected' : '' }}>Footer</option>
            </select>
            {% if me.location is defined %}<p class="admin-field-error">{{ me.location|e }}</p>{% endif %}
          </div>
        </div>
        <div class="admin-form-actions" style="margin-top:1rem;padding-top:0;border-top:none">
          <button type="submit" class="admin-btn-primary">Save menu</button>
        </div>
      </form>
    </section>

    <section class="admin-card admin-settings-card admin-menu-edit-card">
      <h2 class="admin-settings-card-title">Links</h2>
      <p class="admin-settings-card-desc">Drag order via sort numbers, then save. Add pages or custom URLs as needed.</p>
      <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:0.75rem">
        <span class="admin-hint" style="margin:0">
          {% if menu_items is empty %}No links yet.{% else %}{{ menu_items|length }} link{% if menu_items|length != 1 %}s{% endif %}{% endif %}
        </span>
        <a class="admin-btn-primary" href="{{ url_for('admin.menus.items.new', { id: menu.id }) }}">Add link</a>
      </div>

      {% if menu_items is empty %}
        <p class="admin-hint" style="margin:0">Use <strong>Add link</strong> to attach a page or external URL.</p>
      {% else %}
        <form id="menu-reorder-form" method="post" action="{{ url_for('admin.menus.items.reorder', { id: menu.id }) }}" hidden aria-hidden="true"></form>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th scope="col">Label</th>
                <th scope="col">Sort</th>
                <th class="admin-table-col-actions" scope="col"><span class="admin-table-muted">Actions</span></th>
              </tr>
            </thead>
            <tbody>
              {% for it in menu_items %}
                <tr>
                  <td>
                    <strong>{{ it.label|e }}</strong>
                    {% if it.pageId %}<span class="admin-table-muted"> · page #{{ it.pageId }}</span>{% elseif it.url %}<span class="admin-table-muted"> · {{ it.url|e }}</span>{% endif %}
                  </td>
                  <td style="max-width:7rem">
                    <input class="admin-input" type="number" form="menu-reorder-form" name="order[{{ it.id }}]" value="{{ it.sortOrder }}" min="0" step="1" aria-label="Sort order for {{ it.label|e('html_attr') }}" />
                  </td>
                  <td class="admin-table-actions">
                    <a class="admin-link" href="{{ url_for('admin.menus.items.edit', { id: menu.id, itemId: it.id }) }}">Edit</a>
                    <form class="admin-inline-form" method="post" action="{{ url_for('admin.menus.items.delete', { id: menu.id, itemId: it.id }) }}" onsubmit="return confirm('Remove this link?');" style="display:inline;margin-left:0.5rem">
                      <button type="submit" class="admin-link admin-link--danger" style="background:none;border:none;padding:0;cursor:pointer;font:inherit">Remove</button>
                    </form>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <div class="admin-form-actions" style="margin-top:0.75rem;padding:0;border:none">
          <button type="submit" class="admin-btn-primary" form="menu-reorder-form">Save order</button>
        </div>
      {% endif %}
    </section>

    <section class="admin-card admin-settings-card admin-menu-edit-card">
      <h2 class="admin-settings-card-title">Danger zone</h2>
      <p class="admin-settings-card-desc">Deleting removes this menu and every link. This cannot be undone.</p>
      <form class="admin-inline-form" method="post" action="{{ url_for('admin.menus.delete', { id: menu.id }) }}" onsubmit="return confirm('Delete this menu and all links?');">
        <button type="submit" class="admin-link admin-link--danger" style="background:none;border:none;padding:0;cursor:pointer;font:inherit">Delete menu</button>
      </form>
    </section>
  </div>
{% endblock %}
