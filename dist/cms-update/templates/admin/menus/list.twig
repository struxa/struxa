{% extends 'admin/base.twig' %}

{% block admin_title %}Menus{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Navigation menus</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Header and footer placements. Each placement can have one menu.</p>
{% endblock %}

{% block admin_content %}
  <div class="admin-toolbar">
    <a class="admin-btn-primary" href="{{ url_for('admin.menus.new') }}">New menu</a>
  </div>

  {% if menus is empty %}
    <p class="admin-empty">No menus yet. Create one for the header or footer.</p>
  {% else %}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Placement</th>
            <th class="admin-table-actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for m in menus %}
            <tr>
              <td><strong>{{ m.name|e }}</strong></td>
              <td><span class="admin-badge admin-badge--muted">{{ m.location|e }}</span></td>
              <td class="admin-table-actions">
                <a class="admin-link" href="{{ url_for('admin.menus.edit', { id: m.id }) }}">Edit</a>
                <form class="admin-inline-form" method="post" action="{{ url_for('admin.menus.delete', { id: m.id }) }}" onsubmit="return confirm('Delete this menu and all its links?');">
                  <button type="submit" class="admin-link admin-link--danger">Delete</button>
                </form>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
{% endblock %}
