{% extends 'admin/base.twig' %}

{% block admin_title %}Sitemap{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Sitemap</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hint" style="margin-top:0">
    <a class="admin-link" href="{{ url_for('admin.seo.redirects') }}">URL redirects</a>
    ·
    <a class="admin-link" href="{{ url_for('admin.seo.not_found') }}">404 monitor</a>
  </p>
{% endblock %}

{% block admin_content %}
  <section class="admin-card" style="margin-bottom:1.25rem">
    <h2 class="admin-card-title">Live sitemap</h2>
    <p class="admin-hint" style="margin-top:0">
      Search engines read <code class="admin-inline-code">/sitemap.xml</code> (standard location). It lists your public site URL, published CMS pages (<code class="admin-inline-code">/p/…</code>), published content entries with a public route, and indexable taxonomy term archives.
    </p>
    <p class="admin-hint" style="margin-top:0.75rem">
      <strong>Public URL:</strong>
      <a class="admin-link" href="{{ url_for('public.sitemap') }}" target="_blank" rel="noopener noreferrer">{{ site_url }}/sitemap.xml</a>
      {% if not sitemap_enabled %}
        <span class="admin-pill" style="margin-left:0.5rem">Disabled</span>
        <span class="admin-hint" style="display:block;margin-top:0.35rem">With the sitemap off, that address returns <strong>404</strong> and <code class="admin-inline-code">robots.txt</code> omits the <code class="admin-inline-code">Sitemap:</code> line (unless you added one in custom robots text under Settings).</span>
      {% endif %}
    </p>
    <p class="admin-hint" style="margin-top:0.75rem">
      <strong>URLs with current options:</strong> {{ sitemap_url_count }} (includes the site homepage once).
    </p>
  </section>

  <form class="admin-form" method="post" action="{{ url_for('admin.seo.sitemap.save') }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
    <section class="admin-card" style="margin-bottom:1.25rem">
      <h2 class="admin-card-title">Options</h2>
      <div class="admin-form-grid">
        <div class="admin-field admin-field--full">
          <label class="admin-label admin-label--checkbox">
            <input type="checkbox" name="sitemap_enabled" value="1" {{ sitemap_enabled ? 'checked' : '' }} />
            Publish <code class="admin-inline-code">/sitemap.xml</code> and advertise it in default <code class="admin-inline-code">robots.txt</code>
          </label>
        </div>
        <div class="admin-field admin-field--full">
          <label class="admin-label admin-label--checkbox">
            <input type="checkbox" name="sitemap_include_pages" value="1" {{ sitemap_include_pages ? 'checked' : '' }} />
            Include published <strong>pages</strong> (<code class="admin-inline-code">/p/{slug}</code>)
          </label>
        </div>
        <div class="admin-field admin-field--full">
          <label class="admin-label admin-label--checkbox">
            <input type="checkbox" name="sitemap_include_entries" value="1" {{ sitemap_include_entries ? 'checked' : '' }} />
            Include published <strong>content entries</strong> for types that have a public route
          </label>
        </div>
        <div class="admin-field admin-field--full">
          <label class="admin-label admin-label--checkbox">
            <input type="checkbox" name="sitemap_include_taxonomy_archives" value="1" {{ sitemap_include_taxonomy_archives ? 'checked' : '' }} />
            Include <strong>taxonomy term</strong> archive URLs (indexable terms only)
          </label>
        </div>
      </div>
      <p class="admin-hint" style="margin-top:1rem;margin-bottom:0">Pages and entries with <code class="admin-inline-code">noindex</code> are omitted automatically. The homepage URL is always listed once when the sitemap is enabled.</p>
    </section>
    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Save sitemap settings</button>
    </div>
  </form>
{% endblock %}
