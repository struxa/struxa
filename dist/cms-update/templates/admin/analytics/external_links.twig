{% extends 'admin/base.twig' %}

{% block admin_title %}External link analytics{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">External link analytics</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hint" style="margin-top:0">
    Click tracking for outbound links across the storefront. Counts, source pages, and recent clicks below.
    <a class="admin-link" href="?range=7{% if not tracking_enabled %}&tracking={{ tracking_enabled ? '1' : '0' }}{% endif %}">7d</a> ·
    <a class="admin-link" href="?range=30">30d</a> ·
    <a class="admin-link" href="?range=90">90d</a> ·
    <a class="admin-link" href="?range=all">All time</a>
    {% if not tracking_enabled %}
      · <strong style="color:#f97316">Tracking disabled</strong>
    {% endif %}
  </p>
{% endblock %}

{% block admin_content %}
  <section class="admin-card admin-settings-card" style="margin-bottom:1.5rem">
    <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:0.75rem;align-items:flex-start;gap:1rem;flex-wrap:wrap">
      <div>
        <h2 class="admin-settings-card-title" style="margin:0">Summary</h2>
        <p class="admin-settings-card-desc" style="margin:0.35rem 0 0">
          {{ total_clicks }} click{{ total_clicks == 1 ? '' : 's' }}{% if range != 'all' %} in the last {{ range }} day{{ range == '1' ? '' : 's' }}{% endif %}.
        </p>
      </div>
    </div>
  </section>

  <section class="admin-card admin-settings-card" style="margin-bottom:1.5rem">
    <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:0.75rem;align-items:flex-start;gap:1rem;flex-wrap:wrap">
      <div>
        <h2 class="admin-settings-card-title" style="margin:0">Top destinations</h2>
        <p class="admin-settings-card-desc" style="margin:0.35rem 0 0">Where users go when they leave your site.</p>
      </div>
    </div>
    {% if top_destinations is empty %}
      <p class="admin-hint" style="margin:0">No clicks recorded yet.</p>
    {% else %}
      <div class="admin-table-wrap" style="overflow-x:auto">
        <table class="admin-table">
          <thead>
            <tr>
              <th scope="col">Destination URL</th>
              <th scope="col">Host</th>
              <th scope="col">Clicks</th>
              <th scope="col">Source pages</th>
              <th scope="col">Last clicked</th>
            </tr>
          </thead>
          <tbody>
            {% for row in top_destinations %}
              <tr>
                <td style="max-width:32rem;overflow:hidden;text-overflow:ellipsis"><a class="admin-link" href="{{ row.destination_url|e('html_attr') }}" rel="noopener noreferrer nofollow" target="_blank">{{ row.destination_url|e }}</a></td>
                <td>{{ row.destination_host|e }}</td>
                <td><strong>{{ row.clicks }}</strong></td>
                <td>{{ row.unique_sources }}</td>
                <td><time datetime="{{ row.last_clicked_at|e('html_attr') }}">{{ row.last_clicked_at|e }}</time></td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </section>

  <section class="admin-card admin-settings-card" style="margin-bottom:1.5rem">
    <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:0.75rem;align-items:flex-start;gap:1rem;flex-wrap:wrap">
      <div>
        <h2 class="admin-settings-card-title" style="margin:0">Top source pages</h2>
        <p class="admin-settings-card-desc" style="margin:0.35rem 0 0">Pages on your site that send the most users away.</p>
      </div>
    </div>
    {% if top_sources is empty %}
      <p class="admin-hint" style="margin:0">No clicks recorded yet.</p>
    {% else %}
      <div class="admin-table-wrap" style="overflow-x:auto">
        <table class="admin-table">
          <thead>
            <tr>
              <th scope="col">Source page</th>
              <th scope="col">Clicks</th>
              <th scope="col">Unique destinations</th>
              <th scope="col">Last clicked</th>
            </tr>
          </thead>
          <tbody>
            {% for row in top_sources %}
              <tr>
                <td><a class="admin-link" href="{{ row.source_path|e('html_attr') }}" target="_blank" rel="noopener">{{ row.source_path|e }}</a></td>
                <td><strong>{{ row.clicks }}</strong></td>
                <td>{{ row.unique_destinations }}</td>
                <td><time datetime="{{ row.last_clicked_at|e('html_attr') }}">{{ row.last_clicked_at|e }}</time></td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </section>

  <section class="admin-card admin-settings-card" style="margin-bottom:1.5rem">
    <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:0.75rem;align-items:flex-start;gap:1rem;flex-wrap:wrap">
      <div>
        <h2 class="admin-settings-card-title" style="margin:0">Recent clicks</h2>
        <p class="admin-settings-card-desc" style="margin:0.35rem 0 0">The 50 most recent outbound clicks (any time range).</p>
      </div>
    </div>
    {% if recent_clicks is empty %}
      <p class="admin-hint" style="margin:0">No clicks recorded yet.</p>
    {% else %}
      <div class="admin-table-wrap" style="overflow-x:auto">
        <table class="admin-table">
          <thead>
            <tr>
              <th scope="col">When</th>
              <th scope="col">Source page</th>
              <th scope="col">Destination</th>
              <th scope="col">Anchor text</th>
              <th scope="col">User</th>
            </tr>
          </thead>
          <tbody>
            {% for row in recent_clicks %}
              <tr>
                <td><time datetime="{{ row.clicked_at|e('html_attr') }}">{{ row.clicked_at|e }}</time></td>
                <td><a class="admin-link" href="{{ row.source_path|e('html_attr') }}" target="_blank" rel="noopener">{{ row.source_path|e }}</a></td>
                <td style="max-width:24rem;overflow:hidden;text-overflow:ellipsis"><a class="admin-link" href="{{ row.destination_url|e('html_attr') }}" rel="noopener noreferrer nofollow" target="_blank">{{ row.destination_url|e }}</a></td>
                <td>{{ row.link_text|default('')|e }}</td>
                <td>{% if row.user_id %}#{{ row.user_id }}{% else %}—{% endif %}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </section>

  <section class="admin-card admin-settings-card" style="margin-bottom:1.5rem">
    <div>
      <h2 class="admin-settings-card-title" style="margin:0 0 0.35rem">Tracker settings</h2>
      <p class="admin-settings-card-desc" style="margin:0 0 1rem">Enable/disable the storefront beacon, exclude noisy hosts, and choose retention.</p>
    </div>
    <form method="post" action="{{ url_for('admin.analytics.external_links.settings') }}" class="admin-form admin-form--stack">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
      <label class="admin-form-row" style="display:flex;align-items:center;gap:0.6rem">
        <input type="checkbox" name="enabled" value="1" {% if tracking_enabled %}checked{% endif %} />
        <span>Track outbound link clicks</span>
      </label>
      <label class="admin-form-row" style="display:block">
        <span class="admin-form-label">Exclude destinations (one host per line; subdomains match)</span>
        <textarea name="exclude_hosts" rows="4" class="admin-input admin-input--code" style="width:100%;max-width:36rem">{{ exclude_hosts|e }}</textarea>
      </label>
      <label class="admin-form-row" style="display:block">
        <span class="admin-form-label">Auto-purge after (days, 0 disables)</span>
        <input type="number" min="0" name="retention_days" value="{{ retention_days }}" class="admin-input" style="max-width:8rem" />
      </label>
      <div class="admin-form-actions" style="margin-top:0.75rem">
        <button type="submit" class="admin-btn-primary">Save settings</button>
      </div>
    </form>
  </section>

  <section class="admin-card admin-settings-card admin-card--danger" style="margin-bottom:1.5rem">
    <div>
      <h2 class="admin-settings-card-title" style="margin:0 0 0.35rem">Maintenance</h2>
      <p class="admin-settings-card-desc" style="margin:0 0 1rem">Delete older click events or wipe the log entirely.</p>
    </div>
    <form method="post" action="{{ url_for('admin.analytics.external_links.purge') }}" class="admin-form admin-form--inline" style="display:flex;gap:0.5rem;align-items:end;flex-wrap:wrap;margin-bottom:0.75rem">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
      <input type="hidden" name="mode" value="older_than" />
      <label style="display:flex;flex-direction:column">
        <span class="admin-form-label">Delete clicks older than (days)</span>
        <input type="number" name="days" min="1" value="90" class="admin-input" style="max-width:7rem" />
      </label>
      <button type="submit" class="admin-btn-secondary">Delete old clicks</button>
    </form>
    <form method="post" action="{{ url_for('admin.analytics.external_links.purge') }}" class="admin-form" onsubmit="return confirm('Delete ALL external-link click events? This cannot be undone.');" style="margin:0">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
      <input type="hidden" name="mode" value="all" />
      <button type="submit" class="admin-btn-danger">Delete all clicks</button>
    </form>
  </section>
{% endblock %}
