{% extends 'admin/base.twig' %}

{% block admin_title %}Compare revision{% endblock %}

{% block admin_hero_title %}<h1 class="admin-hero-title">Compare with revision</h1>{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.pages.revisions', { id: page.id }) }}">← Revisions</a>
    · saved {{ revision.created_at|e }}
  </p>
{% endblock %}

{% block admin_content %}
  <div class="admin-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;align-items:start">
    <div class="admin-card">
      <h2 class="admin-card-title">Current</h2>
      <p class="admin-hint">{{ page.status|e }} · {{ page.slug|e }}</p>
      <p class="admin-hint" style="margin-top:0.5rem"><strong>SEO title:</strong> {{ page.seoTitle|default('—')|e }}</p>
      <p class="admin-hint"><strong>SEO description:</strong> {{ page.seoDescription|default('—')|e }}</p>
      <p class="admin-hint"><strong>Tags:</strong> {{ page.tagsEditString() != '' ? page.tagsEditString()|e : '—' }}</p>
      <h3 style="margin:0.75rem 0 0.35rem">{{ page.title|e }}</h3>
      <pre style="white-space:pre-wrap;font:inherit;font-size:0.9rem;opacity:0.9">{{ page.content|e }}</pre>
    </div>
    <div class="admin-card">
      <h2 class="admin-card-title">Revision #{{ revision.id }}</h2>
      <p class="admin-hint">{{ revision.status|e }} · {{ revision.slug|e }}</p>
      <p class="admin-hint" style="margin-top:0.5rem"><strong>SEO title:</strong> {{ revision.seo_title|default('—')|e }}</p>
      <p class="admin-hint"><strong>SEO description:</strong> {{ revision.seo_description|default('—')|e }}</p>
      <p class="admin-hint"><strong>Tags:</strong> {{ revision_tags_display != '' ? revision_tags_display|e : '—' }}</p>
      <h3 style="margin:0.75rem 0 0.35rem">{{ revision.title|e }}</h3>
      <pre style="white-space:pre-wrap;font:inherit;font-size:0.9rem;opacity:0.9">{{ revision.content|e }}</pre>
    </div>
  </div>
{% endblock %}
