{% extends 'admin/base.twig' %}

{% block admin_title %}Terms — {{ taxonomy.name|e }}{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Terms</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.content_types.taxonomies.index', { id: content_type.id }) }}">← Taxonomies</a>
    · <strong>{{ taxonomy.name|e }}</strong> ({{ taxonomy.slug|e }})
  </p>
{% endblock %}

{% block admin_content %}
  <div class="admin-toolbar" style="margin-bottom:1.25rem;flex-wrap:wrap;gap:0.75rem;align-items:flex-end">
    <a class="admin-btn-primary" href="{{ url_for('admin.content_types.taxonomies.terms.new', { id: content_type.id, taxId: taxonomy.id }) }}">New term</a>
    <form method="post" action="{{ url_for('admin.content_types.taxonomies.terms.quick', { id: content_type.id, taxId: taxonomy.id }) }}" class="admin-inline-form" style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
      <input class="admin-input" type="text" name="name" placeholder="Quick add name…" maxlength="191" style="min-width:12rem" />
      <button class="admin-btn-ghost" type="submit">Quick add</button>
    </form>
  </div>

  {% if term_rows is empty %}
    <div class="admin-empty">
      <p class="admin-empty-title">No terms</p>
      <p class="admin-empty-text">Create terms editors can assign to entries.</p>
      <a class="admin-btn-primary" href="{{ url_for('admin.content_types.taxonomies.terms.new', { id: content_type.id, taxId: taxonomy.id }) }}">Add term</a>
    </div>
  {% else %}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Slug</th>
            <th scope="col">Order</th>
            <th scope="col" class="admin-table-col-actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for row in term_rows %}
            {% set tr = row.term %}
            {% set d = row.depth %}
            <tr>
              <td style="padding-left:{{ d * 1.25 + 0.5 }}rem"><strong>{{ tr.name|e }}</strong></td>
              <td><code class="admin-inline-code">{{ tr.slug|e }}</code></td>
              <td class="admin-hint">{{ tr.sortOrder }}</td>
              <td>
                <a class="admin-link" href="{{ url_for('admin.content_types.taxonomies.terms.edit', { id: content_type.id, taxId: taxonomy.id, termId: tr.id }) }}">Edit</a>
                ·
                <form method="post" action="{{ url_for('admin.content_types.taxonomies.terms.delete', { id: content_type.id, taxId: taxonomy.id, termId: tr.id }) }}" style="display:inline" onsubmit="return confirm('Delete this term?');">
                  <button type="submit" class="admin-link" style="background:none;border:none;padding:0;cursor:pointer;color:var(--accent-rose)">Delete</button>
                </form>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
{% endblock %}
