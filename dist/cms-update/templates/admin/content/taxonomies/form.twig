{% extends 'admin/base.twig' %}

{% set is_edit = taxonomy is not null %}
{% set o = old ?? {} %}
{% set nm = o.name|default(taxonomy ? taxonomy.name : '') %}
{% set sl = o.slug|default(taxonomy ? taxonomy.slug : '') %}
{% set dsc = o.description|default(taxonomy ? (taxonomy.description ?? '') : '') %}
{% set tt = o.taxonomy_type|default(taxonomy ? taxonomy.taxonomyType : 'custom') %}
{% set hier = o.is_hierarchical is defined ? o.is_hierarchical : (taxonomy ? taxonomy.isHierarchical : false) %}

{% block admin_title %}{{ is_edit ? 'Edit taxonomy' : 'New taxonomy' }} — {{ content_type.name|e }}{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ is_edit ? 'Edit taxonomy' : 'New taxonomy' }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.content_types.taxonomies.index', { id: content_type.id }) }}">← Taxonomies</a>
    · {{ content_type.name|e }}
  </p>
{% endblock %}

{% block admin_content %}
  <form class="admin-form" method="post" action="{{ is_edit ? url_for('admin.content_types.taxonomies.update', { id: content_type.id, taxId: taxonomy.id }) : url_for('admin.content_types.taxonomies.store', { id: content_type.id }) }}">
    <div class="admin-form-grid">
      <div class="admin-field {{ errors.name is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="tax-name">Name <span class="admin-req">*</span></label>
        <input class="admin-input" id="tax-name" name="name" type="text" maxlength="160" value="{{ nm|e }}" required />
        {% if errors.name is defined %}<p class="admin-field-error">{{ errors.name|e }}</p>{% endif %}
      </div>
      <div class="admin-field {{ errors.slug is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="tax-slug">Slug <span class="admin-req">*</span></label>
        <input class="admin-input" id="tax-slug" name="slug" type="text" value="{{ sl|e }}" placeholder="auto from name" />
        {% if errors.slug is defined %}<p class="admin-field-error">{{ errors.slug|e }}</p>{% endif %}
        <p class="admin-hint">Used in public URLs: <code class="admin-inline-code">/{{ content_type.slug|e }}/{{ sl|default('slug')|e }}/term</code></p>
      </div>
      <div class="admin-field admin-field--full {{ errors.taxonomy_type is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="tax-type">Taxonomy type</label>
        <select class="admin-select" id="tax-type" name="taxonomy_type">
          <option value="category" {{ tt == 'category' ? 'selected' : '' }}>category</option>
          <option value="tag" {{ tt == 'tag' ? 'selected' : '' }}>tag</option>
          <option value="custom" {{ tt == 'custom' ? 'selected' : '' }}>custom</option>
        </select>
        {% if errors.taxonomy_type is defined %}<p class="admin-field-error">{{ errors.taxonomy_type|e }}</p>{% endif %}
      </div>
      <div class="admin-field admin-field--full">
        <label class="admin-label" for="tax-desc">Description</label>
        <textarea class="admin-textarea" id="tax-desc" name="description" rows="2">{{ dsc|e }}</textarea>
      </div>
      <div class="admin-field admin-field--full">
        <label class="admin-check">
          <input type="checkbox" name="is_hierarchical" value="1" {{ hier ? 'checked' : '' }} />
          <span>Hierarchical (nested terms)</span>
        </label>
      </div>
    </div>
    <div class="admin-form-actions">
      <button class="admin-btn-primary" type="submit">{{ is_edit ? 'Save' : 'Create' }}</button>
      <a class="admin-btn-ghost" href="{{ url_for('admin.content_types.taxonomies.index', { id: content_type.id }) }}">Cancel</a>
    </div>
  </form>
{% endblock %}
