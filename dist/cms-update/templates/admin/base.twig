<!DOCTYPE html>
<html lang="{{ settings.site_html_lang|default('en')|e('html_attr') }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% block admin_title %}{{ settings.cms_panel_title|default('Struxa') }}{% endblock %} — {{ settings.site_name|default('struxapoint.com') }}</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="color-scheme" content="dark" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}" />
    {% block admin_head %}{% endblock %}
  </head>
  <body class="admin-body {% block admin_body_class %}admin-body--dash-ref{% endblock %}">
    <div class="admin-bg-grid" aria-hidden="true"></div>

    <div class="admin-app">
      {% block admin_banner %}
        {% set admin_user_label = cms_user.display_name|default(cms_user.email|split('@')|first|default('Account')) %}
        {% set admin_user_initial = (cms_user.display_name|default(cms_user.email|default('?')))|slice(0, 1)|upper %}
        <div class="admin-top-bar">
          <div class="admin-top-bar-spacer" aria-hidden="true"></div>
          {% set _cms_up = cms_update_status|default({}) %}
          <a
            href="{{ url_for('admin.updates.index') }}"
            class="admin-top-update-bell{% if _cms_up.update_available|default(false) %} admin-top-update-bell--alert{% endif %}"
            title="{% if _cms_up.update_available|default(false) and _cms_up.latest_version|default('') != '' %}Struxa {{ _cms_up.latest_version|e }} available{% elseif _cms_up.update_available|default(false) %}CMS update available{% else %}CMS updates{% endif %}"
            aria-label="{% if _cms_up.update_available|default(false) and _cms_up.latest_version|default('') != '' %}Struxa version {{ _cms_up.latest_version|e }} is available. Open updates.{% elseif _cms_up.update_available|default(false) %}CMS update available. Open updates.{% else %}Open CMS updates.{% endif %}"
          >
            <span class="admin-top-update-bell-inner">
              <svg class="admin-top-update-bell-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
              </svg>
              {% if _cms_up.update_available|default(false) and _cms_up.latest_version|default('') != '' %}
                <span class="admin-top-update-version" aria-hidden="true">v{{ _cms_up.latest_version|e }}</span>
              {% endif %}
            </span>
            {% if _cms_up.update_available|default(false) %}
              <span class="admin-top-update-badge" aria-hidden="true"></span>
            {% endif %}
          </a>
          <details class="admin-user-menu">
            <summary class="admin-user-pill" aria-label="Account menu for {{ admin_user_label|e('html_attr') }}">
              <span class="admin-user-pill-avatar" aria-hidden="true">{{ admin_user_initial|e }}</span>
              <span class="admin-user-pill-label">
                <span class="admin-user-pill-name">{{ admin_user_label|e }}</span>
                <span class="admin-user-pill-email">{{ cms_user.email|default('')|e }}</span>
              </span>
              <svg class="admin-user-pill-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 9l6 6 6-6" />
              </svg>
            </summary>
            <div class="admin-user-menu-panel" role="menu">
              <div class="admin-user-menu-head">
                <span class="admin-user-menu-head-name">{{ admin_user_label|e }}</span>
                <span class="admin-user-menu-head-email">{{ cms_user.email|default('')|e }}</span>
                {% if cms_user.role_labels is defined and cms_user.role_labels is not empty %}
                  <span class="admin-user-menu-head-roles">{{ cms_user.role_labels|join(' · ')|e }}</span>
                {% elseif cms_user.role is defined and cms_user.role %}
                  <span class="admin-user-menu-head-roles">{{ cms_user.role|capitalize|e }}</span>
                {% endif %}
              </div>
              <div class="admin-user-menu-actions">
                <a class="admin-user-menu-link" role="menuitem" href="{{ url_for('admin.account.two_factor') }}">Two-factor authentication</a>
                <form method="post" action="{{ url_for('logout') }}" style="display:inline;margin:0;padding:0">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                  <button type="submit" class="admin-user-menu-signout" role="menuitem" style="background:none;border:none;font:inherit;cursor:pointer;color:inherit;padding:0;display:inline-flex;align-items:center;gap:0.35rem;width:100%;text-align:left">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                      <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" />
                    </svg>
                    Sign out
                  </button>
                </form>
              </div>
            </div>
          </details>
        </div>
        {% if _cms_up.update_available|default(false) and not (_cms_up.skipped|default(false)) %}
          <div
            class="admin-update-banner"
            id="struxa-admin-update-banner"
            role="region"
            aria-label="CMS update available"
            data-latest-version="{{ (_cms_up.latest_version|default(''))|e('html_attr') }}"
          >
            <div class="admin-update-banner-inner">
              <span class="admin-update-banner-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="M12 8v4M12 16h.01" />
                </svg>
              </span>
              <p class="admin-update-banner-text">
                {% if _cms_up.latest_version|default('') != '' %}
                  <strong>Struxa {{ _cms_up.latest_version|e }}</strong> is available.
                {% else %}
                  A <strong>new Struxa version</strong> is available.
                {% endif %}
                Open Updates to review release notes or apply an update.
              </p>
              <a class="admin-btn-primary admin-update-banner-cta" href="{{ url_for('admin.updates.index') }}">Open updates</a>
              <button type="button" class="admin-update-banner-dismiss" id="struxa-admin-update-dismiss" aria-label="Dismiss this notice">×</button>
            </div>
          </div>
          <script>
            (function () {
              var bar = document.getElementById("struxa-admin-update-banner");
              var btn = document.getElementById("struxa-admin-update-dismiss");
              if (!bar) return;
              var v = bar.getAttribute("data-latest-version") || "";
              try {
                if (localStorage.getItem("struxa_dismissed_update") === v) {
                  bar.classList.add("is-hidden");
                }
              } catch (e) {}
              if (btn) {
                btn.addEventListener("click", function () {
                  try {
                    localStorage.setItem("struxa_dismissed_update", v);
                  } catch (e) {}
                  bar.classList.add("is-hidden");
                });
              }
            })();
          </script>
        {% endif %}
      {% endblock %}

      <div class="admin-shell admin-shell--nav-open" id="admin-shell">
        <aside class="admin-sidebar is-open" id="admin-sidebar" aria-label="Sidebar">
          <a class="admin-brand" href="{{ url_for('admin.dashboard') }}">
            <span class="admin-brand-mark" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="8" height="8" x="3" y="3" rx="1.5" />
                <rect width="8" height="8" x="13" y="3" rx="1.5" />
                <rect width="8" height="8" x="3" y="13" rx="1.5" />
                <rect width="8" height="8" x="13" y="13" rx="1.5" />
              </svg>
            </span>
            <span class="admin-brand-text">
              <span class="admin-brand-title">{{ settings.cms_panel_title|default('Struxa') }}</span>
              <span class="admin-brand-sub">{{ settings.site_name|default('struxapoint.com') }}</span>
            </span>
          </a>

          {% include 'admin/partials/sidebar_nav.twig' %}

          <button
            type="button"
            class="admin-sidebar-rail-toggle"
            id="admin-sidebar-rail-toggle"
            aria-label="Hide sidebar"
            title="Hide sidebar"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M15 18l-6-6 6-6" />
            </svg>
          </button>

          <div class="admin-sidebar-foot">
            <a href="{{ url_for('home') }}">
              <svg class="admin-foot-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              View site
            </a>
            <p class="admin-sidebar-version" role="status">{{ settings.cms_panel_title|default('Struxa')|e }} v{{ cms_version|e }}</p>
          </div>
        </aside>
        <script>
          (function () {
            if (!window.matchMedia('(max-width: 960px)').matches) return;
            var s = document.getElementById('admin-sidebar');
            var sh = document.getElementById('admin-shell');
            if (s) s.classList.remove('is-open');
            if (sh) sh.classList.remove('admin-shell--nav-open');
          })();
        </script>

        <div class="admin-main">
          <div class="admin-main-toolbar">
            <button type="button" class="admin-menu-toggle" id="admin-menu-toggle" aria-expanded="true" aria-controls="admin-primary-nav" title="Hide sidebar">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="16" y2="18"/></svg>
            </button>
            <div class="admin-toolbar-spacer"></div>
            {% if cms_can('manage_pages') or cms_can('manage_media') or cms_can('manage_content_types') or cms_can('create_content') or cms_can('manage_portability') %}
              <details class="admin-create-menu">
                <summary class="admin-create-menu-trigger" title="Create">＋ Create</summary>
                <div class="admin-create-menu-panel" role="menu">
                  {% if cms_can('manage_pages') %}
                    <a role="menuitem" href="{{ url_for('admin.pages.new') }}">New page</a>
                  {% endif %}
                  {% if cms_can('manage_media') %}
                    <a role="menuitem" href="{{ url_for('admin.media.index') }}">Media library</a>
                  {% endif %}
                  {% if cms_can('manage_content_types') %}
                    <a role="menuitem" href="{{ url_for('admin.content_types.new') }}">New content type</a>
                  {% endif %}
                  {% if cms_can('create_content') %}
                    <a role="menuitem" href="{{ url_for('admin.content.entries.new_picker') }}">New entry…</a>
                  {% endif %}
                  {% if cms_can('manage_portability') %}
                    <a role="menuitem" href="{{ url_for('admin.tools.blueprints') }}">Blueprints</a>
                  {% endif %}
                  {% if cms_can('manage_themes') %}
                    <a role="menuitem" href="{{ url_for('admin.themes.index') }}">Themes</a>
                  {% endif %}
                </div>
              </details>
            {% endif %}
            {% if cms_can('manage_settings') %}
              <div class="admin-toolbar-cache-actions" role="group" aria-label="Cache">
                {% if cms_public_page_cache_on %}
                  <form class="admin-toolbar-cache-form" method="post" action="{{ url_for('admin.tools.cache.process') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                    <input type="hidden" name="action" value="toolbar_disable" />
                    <button type="submit" class="admin-toolbar-btn">Disable cache</button>
                  </form>
                {% endif %}
                <form class="admin-toolbar-cache-form" method="post" action="{{ url_for('admin.tools.cache.process') }}" onsubmit="return confirm('Clear all storefront file caches?\n\nPublic HTML/XML and internal Twig globals snapshots will be removed.');">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                  <input type="hidden" name="action" value="toolbar_clear" />
                  <button type="submit" class="admin-toolbar-btn admin-toolbar-btn--muted">Clear cache</button>
                </form>
              </div>
            {% endif %}
            <a class="admin-toolbar-link" href="{{ url_for('admin.dashboard') }}">Dashboard</a>
          </div>

          <div class="admin-sidebar-backdrop" id="admin-sidebar-backdrop" hidden aria-hidden="true"></div>

          <div class="admin-main-inner">
            <header class="admin-hero">
              <div class="admin-hero-avatar" aria-hidden="true">{{ (cms_user.display_name|default(cms_user.email|default('?')))|slice(0, 1)|upper }}</div>
              <div class="admin-hero-text">
                {% block admin_hero_title %}
                  <h1 class="admin-hero-title">Welcome back<span class="admin-hero-emoji" aria-hidden="true"> 👋</span></h1>
                {% endblock %}
                {% block admin_hero_sub %}
                  <p class="admin-hero-sub">
                    Signed in as <strong class="admin-hero-strong">{{ cms_user.email|default('') }}</strong>
                    {% if cms_user.role_labels is defined and cms_user.role_labels is not empty %}
                      · {{ cms_user.role_labels|join(', ')|e }}
                    {% elseif cms_user.role is defined and cms_user.role %}
                      · {{ cms_user.role|capitalize }}
                    {% endif %}
                  </p>
                {% endblock %}
              </div>
              <div class="admin-hero-actions">
                {% block admin_hero_actions %}{% endblock %}
              </div>
            </header>

            {% block admin_breadcrumbs %}{% endblock %}

            <div id="admin-unsaved-banner" class="admin-unsaved-banner" role="status" hidden>
              You have unsaved changes. Save before leaving, or your edits may be lost.
            </div>

            {% block admin_content %}{% endblock %}
          </div>
        </div>
      </div>
    </div>

    <div class="admin-toast-stack" aria-live="polite" aria-atomic="true">
      {% if flash_success %}
        <div class="admin-toast admin-toast--success" data-admin-toast data-dismiss-ms="9000" role="status">
          <span class="admin-toast-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
              <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
          </span>
          <span class="admin-toast-body">
            <span class="admin-toast-msg">{{ flash_success|e }}</span>
          </span>
          <button type="button" class="admin-toast-close" aria-label="Dismiss">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" aria-hidden="true">
              <path d="M18 6L6 18M6 6l12 12" />
            </svg>
          </button>
        </div>
      {% endif %}
      {% if flash_error %}
        <div class="admin-toast admin-toast--error" data-admin-toast data-dismiss-ms="14000" role="alert">
          <span class="admin-toast-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <line x1="15" y1="9" x2="9" y2="15" />
              <line x1="9" y1="9" x2="15" y2="15" />
            </svg>
          </span>
          <span class="admin-toast-body">
            <span class="admin-toast-msg">{{ flash_error|e }}</span>
          </span>
          <button type="button" class="admin-toast-close" aria-label="Dismiss">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" aria-hidden="true">
              <path d="M18 6L6 18M6 6l12 12" />
            </svg>
          </button>
        </div>
      {% endif %}
    </div>

    {% if cms_user is defined and (cms_can('create_content') or cms_can('manage_settings')) %}
      {% include 'admin/partials/ai_chat_widget.twig' %}
    {% endif %}

    <details class="admin-fab">
      <summary class="admin-fab-trigger" aria-label="Quick actions">＋</summary>
      <div class="admin-fab-panel">
        {% if cms_can('manage_pages') %}<a href="{{ url_for('admin.pages.new') }}">New page</a>{% endif %}
        {% if cms_can('manage_media') %}<a href="{{ url_for('admin.media.index') }}">Media</a>{% endif %}
        {% if cms_can('create_content') %}
          <a href="{{ url_for('admin.content.entries.new_picker') }}">New entry</a>
        {% elseif cms_can('manage_content_types') %}
          <a href="{{ url_for('admin.content_types.index') }}">Content</a>
        {% endif %}
        {% if cms_can('manage_portability') %}<a href="{{ url_for('admin.tools.blueprints') }}">Blueprint</a>{% endif %}
      </div>
    </details>

    <script src="{{ asset('js/admin-actions-menu.js') }}"></script>
    <script src="{{ asset('js/admin-form-ux.js') }}" defer></script>
    {% if cms_user is defined and (cms_can('create_content') or cms_can('manage_settings')) %}
      <script src="{{ asset('js/admin-ai-chat.js') }}" defer></script>
    {% endif %}
    <script>
      (function () {
        var body = document.body;
        var shell = document.getElementById('admin-shell');
        var sidebar = document.getElementById('admin-sidebar');
        var toggle = document.getElementById('admin-menu-toggle');
        var backdrop = document.getElementById('admin-sidebar-backdrop');
        var lastMobileNav = null;

        function isMobileNav() {
          return window.matchMedia('(max-width: 960px)').matches;
        }

        function syncShellClass() {
          if (shell && sidebar) {
            shell.classList.toggle('admin-shell--nav-open', sidebar.classList.contains('is-open'));
          }
        }

        function setToggleUi(expanded) {
          if (!toggle) return;
          toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
          if (isMobileNav()) {
            toggle.setAttribute('title', expanded ? 'Close menu' : 'Open menu');
            toggle.setAttribute('aria-label', expanded ? 'Close menu' : 'Open menu');
          } else {
            toggle.setAttribute('title', expanded ? 'Hide sidebar' : 'Show sidebar');
            toggle.setAttribute('aria-label', expanded ? 'Hide sidebar' : 'Show sidebar');
          }
        }

        function closeNav() {
          if (!sidebar) return;
          sidebar.classList.remove('is-open');
          if (backdrop) {
            backdrop.hidden = true;
            backdrop.setAttribute('aria-hidden', 'true');
          }
          if (isMobileNav()) {
            body.classList.remove('admin-nav-open');
          }
          setToggleUi(false);
          syncShellClass();
        }

        function openNav() {
          if (!sidebar) return;
          sidebar.classList.add('is-open');
          if (isMobileNav() && backdrop) {
            backdrop.hidden = false;
            backdrop.setAttribute('aria-hidden', 'false');
            body.classList.add('admin-nav-open');
          } else if (backdrop) {
            backdrop.hidden = true;
            backdrop.setAttribute('aria-hidden', 'true');
            body.classList.remove('admin-nav-open');
          }
          setToggleUi(true);
          syncShellClass();
        }

        function applyViewportNav() {
          if (!sidebar) return;
          var mobile = isMobileNav();
          if (mobile) {
            body.classList.remove('admin-nav-open');
            if (backdrop) {
              backdrop.hidden = true;
              backdrop.setAttribute('aria-hidden', 'true');
            }
            sidebar.classList.remove('is-open');
            setToggleUi(false);
          } else {
            body.classList.remove('admin-nav-open');
            if (backdrop) {
              backdrop.hidden = true;
              backdrop.setAttribute('aria-hidden', 'true');
            }
            if (lastMobileNav === true) {
              sidebar.classList.add('is-open');
            } else if (lastMobileNav === null && !sidebar.classList.contains('is-open')) {
              sidebar.classList.add('is-open');
            }
            setToggleUi(sidebar.classList.contains('is-open'));
          }
          lastMobileNav = mobile;
          syncShellClass();
        }

        if (toggle && sidebar) {
          toggle.addEventListener('click', function () {
            if (sidebar.classList.contains('is-open')) closeNav(); else openNav();
          });
        }
        var railToggle = document.getElementById('admin-sidebar-rail-toggle');
        if (railToggle && sidebar) {
          railToggle.addEventListener('click', function () {
            if (sidebar.classList.contains('is-open')) closeNav(); else openNav();
          });
        }
        if (backdrop) backdrop.addEventListener('click', closeNav);

        applyViewportNav();
        var resizeT;
        window.addEventListener('resize', function () {
          clearTimeout(resizeT);
          resizeT = setTimeout(applyViewportNav, 120);
        });

        document.querySelectorAll('[data-admin-toast]').forEach(function (el) {
          var ms = parseInt(el.getAttribute('data-dismiss-ms') || '0', 10);
          var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          var close = function () {
            if (reduceMotion) {
              el.remove();
              return;
            }
            el.classList.add('admin-toast--out');
            setTimeout(function () {
              el.remove();
            }, 320);
          };
          var btn = el.querySelector('.admin-toast-close');
          if (btn) btn.addEventListener('click', close);
          if (ms > 0 && !reduceMotion) {
            setTimeout(close, ms);
          }
          if (ms > 0 && reduceMotion) {
            setTimeout(function () {
              el.remove();
            }, ms);
          }
        });

        document.addEventListener('click', function (e) {
          var t = e.target;
          if (t && t.closest && !t.closest('.admin-actions-menu')) {
            document.querySelectorAll('.admin-actions-menu[open]').forEach(function (d) { d.removeAttribute('open'); });
          }
          if (t && t.closest && !t.closest('.admin-create-menu')) {
            document.querySelectorAll('.admin-create-menu[open]').forEach(function (d) { d.removeAttribute('open'); });
          }
          if (t && t.closest && !t.closest('.admin-user-menu')) {
            document.querySelectorAll('.admin-user-menu[open]').forEach(function (d) { d.removeAttribute('open'); });
          }
          if (t && t.closest && !t.closest('.admin-fab')) {
            document.querySelectorAll('.admin-fab[open]').forEach(function (d) { d.removeAttribute('open'); });
          }
        });
      })();
    </script>
    <script>
      (function () {
        var t = {{ csrf_token()|json_encode|raw }};
        document.querySelectorAll('form').forEach(function (f) {
          var m = (f.getAttribute('method') || 'get').toLowerCase();
          if (m !== 'post') return;
          if (f.querySelector('input[name="_csrf_token"]')) return;
          var i = document.createElement('input');
          i.type = 'hidden';
          i.name = '_csrf_token';
          i.value = t;
          f.appendChild(i);
        });
      })();
    </script>
    {% block admin_scripts %}{% endblock %}
  </body>
</html>
