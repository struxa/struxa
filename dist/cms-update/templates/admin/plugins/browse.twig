{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}Browse plugin catalog{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Browse plugin catalog</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">
    <a class="admin-link" href="{{ url_for('admin.extensions.plugins.index') }}">← Installed plugins</a>
    · Install from the Struxa distribution catalog (same registry as themes).
  </p>
{% endblock %}

{% block admin_content %}
  {% if not catalog_ok %}
    <div class="admin-card admin-settings-card" style="margin-bottom:1.25rem;border-color:rgba(251,191,36,0.35)">
      <h2 class="admin-settings-card-title">Catalog unavailable</h2>
      <p class="admin-settings-card-desc" style="margin-bottom:0">{{ catalog_error|e }}</p>
    </div>
    <p class="admin-hint">Default catalog: <code class="admin-inline-code">https://struxapoint.com/struxa-dist/repo.json</code> (plugin ZIPs under <code class="admin-inline-code">/struxa-dist/zips/</code>). Local fallback: <code class="admin-inline-code">storage/dist-catalog.json</code>.</p>
  {% elseif catalog_plugins is empty %}
    {{ ui.empty_state(
      'No plugins listed',
      'The catalog loaded but the plugins list is empty. If this site hosts the catalog, ensure public/struxa-dist/repo.json includes a plugins array (not only storage/theme-catalog.json). See struxa-dist/ in the CMS repo.',
      url_for('admin.extensions.plugins.index'),
      'Back to installed plugins',
      '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>'
    ) }}
  {% else %}
    <p class="admin-hint" style="margin:0 0 1.25rem">Catalog and plugin ZIPs are served from <strong>struxapoint.com</strong> (<code class="admin-inline-code">/struxa-dist/repo.json</code> and <code class="admin-inline-code">/struxa-dist/zips/*.zip</code>). Same registry as themes.</p>
    <div class="admin-theme-grid admin-theme-grid--browse">
      {% for p in catalog_plugins %}
        <article class="admin-card admin-theme-card admin-theme-card--browse">
          <div class="admin-theme-card-body">
            <h2 class="admin-card-title" style="margin-top:0">{{ p.name|e }}</h2>
            <p class="admin-hint" style="margin:0 0 0.5rem">
              <code class="admin-inline-code">{{ p.slug|e }}</code>
              {% if p.version %}· v{{ p.version|e }}{% endif %}
              {% if p.author %}· {{ p.author|e }}{% endif %}
            </p>
            {% if p.requiresCmsVersion %}
              <p class="admin-hint">Requires CMS {{ p.requiresCmsVersion|e }}+</p>
            {% endif %}
            {% if p.description %}
              <p class="admin-theme-desc">{{ p.description|e }}</p>
            {% endif %}
            <div class="admin-theme-card-actions">
              {% if installed_plugin_slugs[p.slug] is defined %}
                <span class="admin-badge admin-badge--ok">Installed</span>
                <a class="admin-link" href="{{ url_for('admin.extensions.plugins.index') }}">Open plugins list</a>
              {% else %}
                <form method="post" action="{{ url_for('admin.extensions.plugins.install_from_catalog') }}" onsubmit="return confirm('Install plugin {{ p.slug|e('js') }} from the catalog?');">
                  <input type="hidden" name="plugin_slug" value="{{ p.slug|e('html_attr') }}" />
                  <button type="submit" class="admin-btn-primary">Install</button>
                </form>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
