{% extends 'public/root.twig' %}

{% block title %}Checkout cancelled — {{ settings.site_name|default('Site')|e }}{% endblock %}

{% block body %}
<main id="main-content" class="cms-page" style="max-width:40rem;margin:3rem auto;padding:0 1.25rem;">
  <h1 style="font-family:system-ui,sans-serif;">Checkout cancelled</h1>
  <p style="color:#64748b;line-height:1.6;">No charge was made. You can close this tab or continue browsing.</p>
  <p style="margin-top:1.5rem;"><a href="{{ site_url|default('/')|e('html_attr') }}">Home</a></p>
</main>
{% include 'partials/_footer.twig' %}
{% endblock %}
