{% extends 'public/root.twig' %}

{% block title %}Thank you — {{ settings.site_name|default('Site')|e }}{% endblock %}

{% block body %}
<main id="main-content" class="cms-page" style="max-width:40rem;margin:3rem auto;padding:0 1.25rem;">
  <h1 style="font-family:system-ui,sans-serif;">Thank you</h1>
  <p style="color:#64748b;line-height:1.6;">Your payment was submitted. Stripe will send a receipt by email when the payment completes.</p>
  {% if stripe_session_id|default('')|trim != '' %}
    <p style="font-size:0.875rem;color:#94a3b8;">Reference: <code>{{ stripe_session_id|e }}</code></p>
  {% endif %}
  <p style="margin-top:1.5rem;"><a href="{{ site_url|default('/')|e('html_attr') }}">Back to site</a></p>
</main>
{% include 'partials/_footer.twig' %}
{% endblock %}
