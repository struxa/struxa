{% extends 'admin/base.twig' %}

{% block admin_title %}SEO helper{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">SEO helper</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Quick checks against global settings your theme uses for <code>&lt;title&gt;</code> and meta tags.</p>
{% endblock %}

{% block admin_content %}
  <section class="admin-section">
    <div class="admin-cards">
      <article class="admin-card admin-card--featured">
        <div class="admin-card-body">
          <p class="admin-card-kicker">Site name</p>
          <p class="admin-card-stat">{{ settings.site_name|default('')|e }}</p>
          <p class="admin-card-desc">Shown in Open Graph and many layouts. Set under <strong>Settings</strong> if empty.</p>
        </div>
      </article>
      <article class="admin-card">
        <div class="admin-card-body">
          <p class="admin-card-kicker">Default meta title</p>
          <p class="admin-card-stat">{{ settings.default_meta_title|default('—')|e }}</p>
          <p class="admin-card-desc">Fallback when a page or entry has no SEO title. Aim for concise, unique value.</p>
        </div>
      </article>
      <article class="admin-card">
        <div class="admin-card-body">
          <p class="admin-card-kicker">Default meta description</p>
          <p class="admin-card-desc">{{ settings.default_meta_description|default('Not set — add a short summary in Settings for better snippets.')|e }}</p>
        </div>
      </article>
    </div>
  </section>

  <div class="admin-callout">
    <p class="admin-prose">
      Content types with <strong>supports_seo</strong> let editors override per entry. This screen only reflects global defaults.
    </p>
  </div>
{% endblock %}
