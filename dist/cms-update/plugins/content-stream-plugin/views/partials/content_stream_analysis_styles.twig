{# Content Stream admin wizard — matches dark admin shell (admin.css variables) #}
<style>
  .cs-wizard-canvas {
    margin-bottom: 1.75rem;
    padding: 1.35rem 1.35rem 1.5rem;
    border-radius: var(--admin-radius);
    border: 1px solid var(--admin-border);
    background:
      linear-gradient(145deg, rgba(59, 130, 246, 0.06) 0%, transparent 42%),
      linear-gradient(210deg, rgba(168, 85, 247, 0.05) 0%, transparent 38%),
      var(--admin-card);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 18px 48px -20px rgba(0, 0, 0, 0.55);
  }

  @media (min-width: 720px) {
    .cs-wizard-canvas {
      padding: 1.5rem 1.65rem 1.65rem;
    }
  }

  .cs-wizard-shell {
    margin-bottom: 1.35rem;
  }

  .cs-wizard-track {
    display: flex;
    align-items: center;
    gap: 0;
    width: 100%;
    max-width: 28rem;
    margin: 0 0 1.25rem;
  }

  .cs-wizard-track--four {
    max-width: 100%;
  }

  @media (min-width: 900px) {
    .cs-wizard-track--four {
      max-width: 40rem;
    }
  }

  @media (max-width: 640px) {
    .cs-wizard-track--four .cs-wizard-crumb-label {
      font-size: 0.5625rem;
      max-width: 3.75rem;
    }
    .cs-wizard-track--four .cs-wizard-crumb-num {
      width: 1.65rem;
      height: 1.65rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 520px) {
    .cs-wizard-track {
      flex-wrap: wrap;
      justify-content: center;
      row-gap: 0.5rem;
      max-width: none;
    }
    .cs-wizard-track-line {
      display: none;
    }
  }

  .cs-wizard-track-line {
    flex: 1;
    min-width: 0.5rem;
    height: 2px;
    margin: 0 0.35rem;
    border-radius: 1px;
    background: linear-gradient(90deg, var(--admin-border), rgba(59, 130, 246, 0.22));
    align-self: center;
    position: relative;
    top: -0.55rem;
  }

  .cs-wizard-crumb {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    text-align: center;
    flex-shrink: 0;
  }

  .cs-wizard-crumb-num {
    width: 1.85rem;
    height: 1.85rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--admin-muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--admin-border);
    transition:
      color 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .cs-wizard-crumb-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--admin-dim);
    max-width: 5.5rem;
    line-height: 1.25;
    transition: color 0.2s ease;
  }

  .cs-wizard-crumb.is-active .cs-wizard-crumb-num {
    color: #fff;
    background: linear-gradient(135deg, var(--admin-blue), #6366f1);
    border-color: rgba(99, 102, 241, 0.5);
    box-shadow: 0 0 0 3px var(--admin-blue-soft), 0 6px 16px -4px rgba(59, 130, 246, 0.45);
  }

  .cs-wizard-crumb.is-active .cs-wizard-crumb-label {
    color: var(--admin-sidebar-accent-text);
  }

  .cs-wizard-crumb.is-done .cs-wizard-crumb-num {
    color: #a7f3d0;
    background: rgba(45, 212, 191, 0.12);
    border-color: rgba(45, 212, 191, 0.35);
  }

  .cs-wizard-crumb.is-done .cs-wizard-crumb-label {
    color: var(--admin-teal);
  }

  .cs-wizard-step-heading {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: 0 0 0.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--admin-border);
  }

  .cs-wizard-step-kicker {
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--admin-purple);
  }

  .cs-wizard-step-title {
    margin: 0;
    font-size: clamp(1.05rem, 2.5vw, 1.2rem);
    font-weight: 750;
    letter-spacing: -0.03em;
    line-height: 1.35;
    color: var(--admin-text);
  }

  .cs-wizard-panel {
    margin-bottom: 0;
    padding-top: 0.25rem;
  }

  .cs-wizard-panel--domain {
    padding-top: 0.5rem;
  }

  .cs-wizard-panel-head {
    margin-bottom: 1.15rem;
  }

  .cs-wizard-panel-title {
    margin-bottom: 0.5rem !important;
    font-size: 1rem !important;
    font-weight: 800 !important;
    letter-spacing: -0.025em !important;
    color: var(--admin-text) !important;
  }

  .cs-wizard-panel-lead {
    margin: 0;
    max-width: 40rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--admin-muted);
  }

  .cs-wizard-domain-chip {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.65rem;
    margin: 0 0 0.65rem;
    padding: 0.4rem 0.65rem 0.4rem 0.5rem;
    border-radius: var(--admin-radius-sm);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--admin-border);
  }

  .cs-wizard-domain-chip-label {
    font-size: 0.625rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--admin-dim);
  }

  .cs-wizard-domain-chip-value {
    font-size: 0.875rem;
    font-weight: 650;
    color: var(--admin-sidebar-accent-text);
    word-break: break-all;
  }

  .cs-wizard-field-highlight .admin-input {
    font-size: 1rem;
    padding: 0.65rem 0.85rem;
    border-color: rgba(59, 130, 246, 0.22);
    background: rgba(0, 0, 0, 0.2);
  }

  .cs-wizard-field-highlight .admin-input:focus {
    border-color: rgba(99, 102, 241, 0.55);
    box-shadow: 0 0 0 3px var(--admin-purple-soft);
  }

  .cs-wizard-actions {
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cs-wizard-actions--footer {
    padding-top: 0.35rem;
    border-top: 1px solid var(--admin-border);
  }

  .cs-wizard-hint-below {
    margin-top: 1rem !important;
    max-width: 40rem;
    line-height: 1.5;
  }

  .cs-wizard-subpanel {
    margin-top: 1.5rem;
    padding: 1.1rem 1.15rem 1.15rem;
    border-radius: var(--admin-radius-sm);
    border: 1px solid var(--admin-border);
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.03) inset;
  }

  .cs-wizard-subpanel-title {
    margin: 0 0 0.45rem;
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--admin-text);
  }

  .cs-wizard-subpanel-lead {
    margin: 0 0 0.25rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--admin-muted);
    max-width: 42rem;
  }

  .cs-engine-plan-meta {
    margin: 0 0 0.75rem !important;
    padding: 0.5rem 0.65rem;
    border-radius: 8px;
    font-size: 0.8125rem !important;
    color: var(--admin-muted) !important;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--admin-border);
  }

  .cs-wizard-engine-mount {
    margin-top: 1.15rem;
  }

  /* Analysis cards — dark surfaces */
  .cs-analysis-cards { margin-top: 0.35rem; }

  .cs-analysis-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .cs-analysis-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .cs-analysis-card {
    border-radius: var(--admin-radius-sm);
    border: 1px solid var(--admin-border);
    background: rgba(255, 255, 255, 0.02);
    padding: 1rem 1.05rem;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.03) inset;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .cs-analysis-card:hover {
    border-color: rgba(59, 130, 246, 0.2);
    box-shadow: 0 8px 24px -12px rgba(0, 0, 0, 0.4);
  }

  .cs-analysis-card--wide { grid-column: 1 / -1; }

  .cs-analysis-card h3 {
    margin: 0 0 0.45rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--admin-dim);
    font-weight: 800;
  }

  .cs-analysis-card p,
  .cs-analysis-card .cs-analysis-body {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--admin-text);
  }

  .cs-analysis-card a {
    word-break: break-all;
    color: var(--admin-sidebar-accent-text);
    font-weight: 600;
  }

  .cs-analysis-card a:hover {
    color: #fff;
  }

  .cs-analysis-pill {
    display: inline-block;
    margin: 0.2rem 0.35rem 0 0;
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    font-size: 0.75rem;
    background: var(--admin-purple-soft);
    color: #e9d5ff;
    border: 1px solid rgba(168, 85, 247, 0.2);
  }

  .cs-analysis-list {
    margin: 0;
    padding-left: 1.15rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--admin-muted);
  }

  .cs-analysis-list li { margin-bottom: 0.3rem; }

  .cs-analysis-raw-wrap {
    margin-top: 1.1rem;
    padding: 0.65rem 0.85rem;
    border-radius: var(--admin-radius-sm);
    border: 1px dashed rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.15);
  }

  .cs-analysis-raw-wrap summary {
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--admin-muted);
    list-style: none;
  }

  .cs-analysis-raw-wrap summary::-webkit-details-marker { display: none; }

  .cs-analysis-raw-wrap pre {
    margin-top: 0.65rem;
    max-height: 14rem;
    overflow: auto;
    font-size: 0.75rem;
    border-radius: 8px;
  }

  textarea#cs-analysis-raw {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
