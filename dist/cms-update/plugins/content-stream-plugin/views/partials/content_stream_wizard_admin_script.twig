<script>
(function () {
  var form = document.getElementById('cs-brief-form');
  var progress = document.getElementById('cs-progress');
  var errWrap = document.getElementById('cs-error-wrap');
  var errText = document.getElementById('cs-error-text');
  var step1 = document.getElementById('cs-wizard-step1');
  var step2 = document.getElementById('cs-wizard-step2');
  var step3 = document.getElementById('cs-wizard-step3');
  var step4 = document.getElementById('cs-wizard-step4');
  var stepLabel = document.getElementById('cs-wizard-step-label');
  var analysisCards = document.getElementById('cs-analysis-cards');
  var analysisRaw = document.getElementById('cs-analysis-raw');
  var analysisJsonFallback = document.getElementById('cs-analysis-json-fallback');
  var resultDomain = document.getElementById('cs-result-domain');
  var resultDomainMetrics = document.getElementById('cs-result-domain-metrics');
  var submitBtn = document.getElementById('cs-brief-submit');
  var toMetricsBtn = document.getElementById('cs-wizard-to-metrics');
  var toEngineBtn = document.getElementById('cs-wizard-to-engine');
  var backStep1Btn = document.getElementById('cs-wizard-back-step1');
  var backStep2Btn = document.getElementById('cs-wizard-back-step2');
  var backStep3Btn = document.getElementById('cs-wizard-back-step3');
  var crumb1 = document.getElementById('cs-wizard-crumb-1');
  var crumb2 = document.getElementById('cs-wizard-crumb-2');
  var crumb3 = document.getElementById('cs-wizard-crumb-3');
  var crumb4 = document.getElementById('cs-wizard-crumb-4');
  if (!form || !step1 || !step2 || !step3 || !step4 || !window.fetch) return;

  function syncDomainLabels(text) {
    var t = text == null ? '' : String(text);
    if (resultDomain) resultDomain.textContent = t;
    if (resultDomainMetrics) resultDomainMetrics.textContent = t;
  }

  function esc(s) {
    var d = document.createElement('div');
    d.textContent = s == null ? '' : String(s);
    return d.innerHTML;
  }

  function syncTechnicalPre() {
    if (!analysisJsonFallback || !analysisRaw) return;
    var t = (analysisRaw.value || '').trim();
    if (t === '') {
      analysisJsonFallback.textContent = '';
      return;
    }
    try {
      analysisJsonFallback.textContent = JSON.stringify(JSON.parse(t), null, 2);
    } catch (e) {
      analysisJsonFallback.textContent = t;
    }
  }

  function renderAnalysisCards(obj) {
    if (!analysisCards) return;
    if (!obj || typeof obj !== 'object' || Array.isArray(obj)) {
      analysisCards.innerHTML = '';
      return;
    }

    var knownOrder = [
      ['business_name', 'Business name', 'string'],
      ['website_url', 'Website', 'url'],
      ['business_summary', 'Business summary', 'textwide'],
      ['vertical_niche', 'Vertical / niche', 'string'],
      ['industry', 'Industry', 'string'],
      ['business_type', 'Business type', 'string'],
      ['brand_tone', 'Brand tone', 'string']
    ];

    var known = {};
    knownOrder.forEach(function (row) {
      known[row[0]] = true;
    });
    known.target_audience = true;
    known.primary_use_cases = true;
    known.core_products_or_services = true;
    known.locations_served = true;
    known.top_seo_topics = true;
    known.seed_keywords = true;
    known.evidence = true;

    var parts = [];
    knownOrder.forEach(function (row) {
      var k = row[0];
      var label = row[1];
      var kind = row[2];
      var v = obj[k];
      if (v == null || v === '') return;
      if (kind === 'url' && typeof v === 'string') {
        var u = v.trim();
        if (u === '') return;
        var href = /^https?:\/\//i.test(u) ? u : 'https://' + u;
        parts.push(
          '<div class="cs-analysis-card"><h3>' +
            esc(label) +
            '</h3><p class="cs-analysis-body"><a class="admin-link" href="' +
            esc(href) +
            '" target="_blank" rel="noopener">' +
            esc(u) +
            '</a></p></div>'
        );
        return;
      }
      if (kind === 'textwide') {
        parts.push(
          '<div class="cs-analysis-card cs-analysis-card--wide"><h3>' +
            esc(label) +
            '</h3><p class="cs-analysis-body">' +
            esc(String(v)) +
            '</p></div>'
        );
        return;
      }
      parts.push(
        '<div class="cs-analysis-card"><h3>' +
          esc(label) +
          '</h3><p class="cs-analysis-body">' +
          esc(String(v)) +
          '</p></div>'
      );
    });

    function listCard(key, label) {
      var arr = obj[key];
      if (!Array.isArray(arr) || arr.length === 0) return;
      var lis = arr
        .map(function (x) {
          return '<li>' + esc(String(x)) + '</li>';
        })
        .join('');
      parts.push(
        '<div class="cs-analysis-card cs-analysis-card--wide"><h3>' +
          esc(label) +
          '</h3><ul class="cs-analysis-list">' +
          lis +
          '</ul></div>'
      );
    }

    listCard('target_audience', 'Target audience');
    listCard('primary_use_cases', 'Primary use cases');
    listCard('core_products_or_services', 'Products & services');
    listCard('locations_served', 'Locations served');
    listCard('top_seo_topics', 'SEO topic ideas');
    listCard('seed_keywords', 'Seed keywords');
    listCard('evidence', 'On-page evidence');

    Object.keys(obj).forEach(function (k) {
      if (known[k]) return;
      var v = obj[k];
      if (v == null) return;
      if (typeof v === 'object') {
        parts.push(
          '<div class="cs-analysis-card cs-analysis-card--wide"><h3>' +
            esc(k) +
            '</h3><pre class="admin-code-block" style="font-size:0.75rem;max-height:10rem;overflow:auto;margin:0">' +
            esc(JSON.stringify(v, null, 2)) +
            '</pre></div>'
        );
      } else if (String(v).trim() !== '') {
        parts.push(
          '<div class="cs-analysis-card"><h3>' +
            esc(k) +
            '</h3><p class="cs-analysis-body">' +
            esc(String(v)) +
            '</p></div>'
        );
      }
    });

    analysisCards.innerHTML =
      '<div class="cs-analysis-grid">' + parts.join('') + '</div>';
  }

  function getAnalysisObject() {
    if (!analysisRaw) return {};
    try {
      return JSON.parse(analysisRaw.value || '{}');
    } catch (e) {
      return {};
    }
  }

  function setAnalysisPayload(data) {
    var obj = null;
    if (data && data.analysis !== null && data.analysis !== undefined && typeof data.analysis === 'object') {
      obj = data.analysis;
    } else if (data && data.brief) {
      try {
        obj = JSON.parse(String(data.brief));
      } catch (e) {
        obj = null;
      }
    }
    if (!obj) {
      if (analysisRaw) analysisRaw.value = '';
      renderAnalysisCards(null);
      syncTechnicalPre();
      return;
    }
    try {
      if (analysisRaw) analysisRaw.value = JSON.stringify(obj);
    } catch (e) {
      if (analysisRaw) analysisRaw.value = '';
    }
    renderAnalysisCards(obj);
    syncTechnicalPre();
  }

  function updateCrumbs(activeStep) {
    [crumb1, crumb2, crumb3, crumb4].forEach(function (c) {
      if (!c) return;
      c.classList.remove('is-active', 'is-done');
    });
    if (activeStep === 1) {
      if (crumb1) crumb1.classList.add('is-active');
    } else if (activeStep === 2) {
      if (crumb1) crumb1.classList.add('is-done');
      if (crumb2) crumb2.classList.add('is-active');
    } else if (activeStep === 3) {
      if (crumb1) crumb1.classList.add('is-done');
      if (crumb2) crumb2.classList.add('is-done');
      if (crumb3) crumb3.classList.add('is-active');
    } else if (activeStep === 4) {
      if (crumb1) crumb1.classList.add('is-done');
      if (crumb2) crumb2.classList.add('is-done');
      if (crumb3) crumb3.classList.add('is-done');
      if (crumb4) crumb4.classList.add('is-active');
    }
  }

  function scrollWizardHint() {
    if (stepLabel) stepLabel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function showStep1() {
    step1.hidden = false;
    step2.hidden = true;
    step3.hidden = true;
    step4.hidden = true;
    if (stepLabel) {
      stepLabel.innerHTML =
        '<span class="cs-wizard-step-kicker">Step 1 of 4</span>' +
        '<span class="cs-wizard-step-title">Enter the company domain</span>';
    }
    if (progress) progress.hidden = true;
    updateCrumbs(1);
    requestAnimationFrame(scrollWizardHint);
  }

  function showStep2() {
    step1.hidden = true;
    step2.hidden = false;
    step3.hidden = true;
    step4.hidden = true;
    if (stepLabel) {
      stepLabel.innerHTML =
        '<span class="cs-wizard-step-kicker">Step 2 of 4</span>' +
        '<span class="cs-wizard-step-title">Review the analysis</span>';
    }
    if (progress) progress.hidden = true;
    updateCrumbs(2);
    requestAnimationFrame(scrollWizardHint);
  }

  function showStep3() {
    step1.hidden = true;
    step2.hidden = true;
    step3.hidden = false;
    step4.hidden = true;
    if (stepLabel) {
      stepLabel.innerHTML =
        '<span class="cs-wizard-step-kicker">Step 3 of 4</span>' +
        '<span class="cs-wizard-step-title">Keyword metrics from DataForSEO</span>';
    }
    if (progress) progress.hidden = true;
    updateCrumbs(3);
    requestAnimationFrame(function () {
      scrollWizardHint();
      var kwBtn = document.getElementById('cs-fetch-keyword-metrics');
      if (kwBtn && !kwBtn.disabled) kwBtn.focus();
    });
  }

  function showStep4() {
    step1.hidden = true;
    step2.hidden = true;
    step3.hidden = true;
    step4.hidden = false;
    if (stepLabel) {
      stepLabel.innerHTML =
        '<span class="cs-wizard-step-kicker">Step 4 of 4</span>' +
        '<span class="cs-wizard-step-title">Monthly blog plan</span>';
    }
    if (progress) progress.hidden = true;
    updateCrumbs(4);
    requestAnimationFrame(function () {
      scrollWizardHint();
      var genBtn = document.getElementById('cs-engine-generate');
      if (genBtn && !genBtn.disabled) genBtn.focus();
    });
  }

  function resetKeywordMetricsUi() {
    var kwProg = document.getElementById('cs-keyword-progress');
    var kwErr = document.getElementById('cs-keyword-error-wrap');
    var kwErrT = document.getElementById('cs-keyword-error-text');
    var kwWrap = document.getElementById('cs-keyword-table-wrap');
    var kwBody = document.getElementById('cs-keyword-tbody');
    if (kwProg) kwProg.hidden = true;
    if (kwErr) kwErr.hidden = true;
    if (kwErrT) kwErrT.textContent = '';
    if (kwWrap) kwWrap.hidden = true;
    if (kwBody) kwBody.innerHTML = '';
    var kwBtn = document.getElementById('cs-fetch-keyword-metrics');
    if (kwBtn && !kwBtn.disabled) {
      kwBtn.removeAttribute('aria-busy');
    }
  }

  function resetKeywordEngineUi() {
    var engProg = document.getElementById('cs-engine-progress');
    var engErr = document.getElementById('cs-engine-error-wrap');
    var engErrT = document.getElementById('cs-engine-error-text');
    var engWrap = document.getElementById('cs-engine-table-wrap');
    var engBody = document.getElementById('cs-engine-tbody');
    var meta = document.getElementById('cs-engine-plan-meta');
    if (engProg) engProg.hidden = true;
    if (engErr) engErr.hidden = true;
    if (engErrT) engErrT.textContent = '';
    if (engWrap) engWrap.hidden = true;
    if (engBody) engBody.innerHTML = '';
    var engHtml = document.getElementById('cs-engine-html-result');
    if (engHtml) {
      engHtml.innerHTML = '';
      engHtml.hidden = true;
    }
    if (meta) {
      meta.textContent = '';
      meta.hidden = true;
    }
    var genBtn = document.getElementById('cs-engine-generate');
    if (genBtn && !genBtn.disabled) {
      genBtn.removeAttribute('aria-busy');
    }
  }

  function restartWizard() {
    if (errWrap) {
      errWrap.hidden = true;
      if (errText) errText.textContent = '';
    }
    if (analysisRaw) analysisRaw.value = '';
    renderAnalysisCards(null);
    syncTechnicalPre();
    syncDomainLabels('');
    resetKeywordMetricsUi();
    resetKeywordEngineUi();
    showStep1();
    var input = document.getElementById('cs_domain');
    if (input) {
      input.focus();
      input.select();
    }
  }

  if (analysisRaw && analysisRaw.value.trim() !== '') {
    try {
      renderAnalysisCards(JSON.parse(analysisRaw.value));
    } catch (e) {
      renderAnalysisCards(null);
    }
    syncTechnicalPre();
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.setAttribute('aria-busy', 'true');
    }
    if (errWrap) {
      errWrap.hidden = true;
      if (errText) errText.textContent = '';
    }
    if (progress) progress.hidden = false;

    var csrfField = form.querySelector('input[name="_csrf_token"]');
    var csrfVal = csrfField && csrfField.value ? String(csrfField.value) : '';
    var domainEl = document.getElementById('cs_domain');
    var domainVal = domainEl ? String(domainEl.value || '') : '';
    var params = new URLSearchParams();
    params.set('_csrf_token', csrfVal);
    params.set('domain', domainVal);

    fetch(form.action, {
      method: 'POST',
      headers: {
        Accept: 'application/json',
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': csrfVal
      },
      body: params.toString(),
      credentials: 'same-origin'
    })
      .then(function (r) {
        if (!r.ok) {
          return r.json().catch(function () {
            return { error: 'Request failed (' + r.status + ').' };
          }).then(function (j) {
            throw new Error(j.message || j.error || 'Request failed.');
          });
        }
        return r.json();
      })
      .then(function (data) {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.removeAttribute('aria-busy');
        }
        var err = data && data.error ? String(data.error).trim() : '';
        if (err !== '') {
          if (progress) progress.hidden = true;
          if (errWrap && errText) {
            errText.textContent = err;
            errWrap.hidden = false;
          }
          showStep1();
          return;
        }
        var hasPayload =
          (data && data.analysis && typeof data.analysis === 'object') ||
          (data && data.brief && String(data.brief).trim() !== '');
        if (!hasPayload) {
          if (progress) progress.hidden = true;
          if (errWrap && errText) {
            errText.textContent = 'No analysis was returned. Try again.';
            errWrap.hidden = false;
          }
          showStep1();
          return;
        }
        setAnalysisPayload(data);
        if (data.domain) syncDomainLabels(String(data.domain));
        if (progress) progress.hidden = true;
        resetKeywordEngineUi();
        showStep2();
      })
      .catch(function (err) {
        if (progress) progress.hidden = true;
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.removeAttribute('aria-busy');
        }
        if (errWrap && errText) {
          var msg =
            err && typeof err.message === 'string' && err.message.trim() !== ''
              ? err.message
              : 'Network error. Check your connection and try again.';
          errText.textContent = msg;
          errWrap.hidden = false;
        }
        showStep1();
      });
  });

  if (toMetricsBtn) {
    toMetricsBtn.addEventListener('click', function () {
      var o = getAnalysisObject();
      if (!o || typeof o !== 'object' || Object.keys(o).length === 0) return;
      showStep3();
    });
  }

  if (toEngineBtn) {
    toEngineBtn.addEventListener('click', function () {
      showStep4();
    });
  }

  if (backStep1Btn) {
    backStep1Btn.addEventListener('click', function () {
      showStep1();
    });
  }

  if (backStep2Btn) {
    backStep2Btn.addEventListener('click', function () {
      showStep2();
    });
  }

  if (backStep3Btn) {
    backStep3Btn.addEventListener('click', function () {
      showStep3();
    });
  }

  document.querySelectorAll('.cs-wizard-restart').forEach(function (btn) {
    btn.addEventListener('click', restartWizard);
  });

  var kwBtn = document.getElementById('cs-fetch-keyword-metrics');
  if (kwBtn && window.fetch) {
    kwBtn.addEventListener('click', function () {
      var url = kwBtn.getAttribute('data-metrics-url') || '';
      var csrf = kwBtn.getAttribute('data-csrf') || '';
      if (!url) return;

      var analysis = getAnalysisObject();
      if (!analysis || Object.keys(analysis).length === 0) {
        var kwErr = document.getElementById('cs-keyword-error-wrap');
        var kwErrT = document.getElementById('cs-keyword-error-text');
        if (kwErrT) kwErrT.textContent = 'No analysis loaded. Run the domain step first.';
        if (kwErr) kwErr.hidden = false;
        return;
      }

      var kwProg = document.getElementById('cs-keyword-progress');
      var kwErr = document.getElementById('cs-keyword-error-wrap');
      var kwErrT = document.getElementById('cs-keyword-error-text');
      var kwWrap = document.getElementById('cs-keyword-table-wrap');
      var kwBody = document.getElementById('cs-keyword-tbody');

      if (kwErr) kwErr.hidden = true;
      if (kwErrT) kwErrT.textContent = '';
      if (kwWrap) kwWrap.hidden = true;
      if (kwBody) kwBody.innerHTML = '';
      if (kwProg) kwProg.hidden = false;
      kwBtn.disabled = true;
      kwBtn.setAttribute('aria-busy', 'true');

      fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
          'X-CSRF-Token': csrf
        },
        body: JSON.stringify({ analysis: analysis }),
        credentials: 'same-origin'
      })
        .then(function (r) {
          return r.json().catch(function () {
            return { error: 'Invalid JSON response.' };
          });
        })
        .then(function (data) {
          if (kwProg) kwProg.hidden = true;
          kwBtn.disabled = false;
          kwBtn.removeAttribute('aria-busy');

          var err = data && data.error ? String(data.error).trim() : '';
          if (err !== '') {
            if (kwErrT) kwErrT.textContent = err;
            if (kwErr) kwErr.hidden = false;
            return;
          }

          var rows = data && Array.isArray(data.rows) ? data.rows : [];
          if (rows.length === 0 || !kwBody) {
            if (kwErrT) kwErrT.textContent = 'No metric rows returned.';
            if (kwErr) kwErr.hidden = false;
            return;
          }

          rows.forEach(function (row) {
            var tr = document.createElement('tr');
            var vol = row.search_volume != null ? String(row.search_volume) : '—';
            var cpc = row.cpc != null && !isNaN(Number(row.cpc)) ? Number(row.cpc).toFixed(2) : '—';
            var comp = row.competition != null ? String(row.competition) : '';
            var compIdx = row.competition_index != null ? String(row.competition_index) : '';
            var compCell = '—';
            if (comp && compIdx) compCell = comp + ' (' + compIdx + ')';
            else if (comp) compCell = comp;
            else if (compIdx) compCell = compIdx;
            var diff = row.difficulty != null ? String(row.difficulty) : '—';
            var vars = Array.isArray(row.variations) ? row.variations.join(', ') : '';
            tr.innerHTML =
              '<td>' + esc(row.keyword || '') + '</td>' +
              '<td class="admin-table-muted">' + esc(vol) + '</td>' +
              '<td class="admin-table-muted">' + esc(cpc) + '</td>' +
              '<td class="admin-table-muted">' + esc(compCell) + '</td>' +
              '<td class="admin-table-muted">' + esc(diff) + '</td>' +
              '<td style="max-width:18rem;font-size:0.8125rem;line-height:1.45">' + esc(vars) + '</td>';
            kwBody.appendChild(tr);
          });
          if (kwWrap) kwWrap.hidden = false;
        })
        .catch(function () {
          if (kwProg) kwProg.hidden = true;
          kwBtn.disabled = false;
          kwBtn.removeAttribute('aria-busy');
          if (kwErrT) kwErrT.textContent = 'Network error. Try again.';
          if (kwErr) kwErr.hidden = false;
        });
    });
  }

  var engBtn = document.getElementById('cs-engine-generate');
  if (engBtn && window.fetch) {
    engBtn.addEventListener('click', function () {
      var url = engBtn.getAttribute('data-generate-url') || '';
      var csrf = engBtn.getAttribute('data-csrf') || '';
      var monthEl = document.getElementById('cs-engine-month');
      var labelEl = document.getElementById('cs-engine-label');
      if (!url || !monthEl || engBtn.disabled) return;

      var analysis = getAnalysisObject();
      if (!analysis || Object.keys(analysis).length === 0) {
        var eWrap = document.getElementById('cs-engine-error-wrap');
        var eText = document.getElementById('cs-engine-error-text');
        if (eText) eText.textContent = 'No analysis loaded. Go back and run the domain step.';
        if (eWrap) eWrap.hidden = false;
        return;
      }

      var ym = (monthEl.value || '').trim();
      if (!/^\d{4}-\d{2}$/.test(ym)) {
        var ew = document.getElementById('cs-engine-error-wrap');
        var et = document.getElementById('cs-engine-error-text');
        if (et) et.textContent = 'Pick a calendar month.';
        if (ew) ew.hidden = false;
        return;
      }

      var engProg = document.getElementById('cs-engine-progress');
      var engErr = document.getElementById('cs-engine-error-wrap');
      var engErrT = document.getElementById('cs-engine-error-text');
      var engWrap = document.getElementById('cs-engine-table-wrap');
      var engBody = document.getElementById('cs-engine-tbody');
      var meta = document.getElementById('cs-engine-plan-meta');

      if (engErr) engErr.hidden = true;
      if (engErrT) engErrT.textContent = '';
      if (engWrap) engWrap.hidden = true;
      if (engBody) engBody.innerHTML = '';
      if (meta) meta.hidden = true;
      if (engProg) engProg.hidden = false;
      engBtn.disabled = true;
      engBtn.setAttribute('aria-busy', 'true');

      fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'text/html, application/json;q=0.8',
          'X-Requested-With': 'XMLHttpRequest',
          'X-CSRF-Token': csrf
        },
        body: JSON.stringify({
          year_month: ym,
          label: labelEl ? String(labelEl.value || '').trim() : '',
          analysis: analysis,
          response_format: 'html'
        }),
        credentials: 'same-origin'
      })
        .then(function (r) {
          return r.text().then(function (text) {
            return { ok: r.ok, status: r.status, ct: (r.headers.get('content-type') || '').toLowerCase(), text: text };
          });
        })
        .then(function (box) {
          if (engProg) engProg.hidden = true;
          engBtn.disabled = false;
          engBtn.removeAttribute('aria-busy');

          var htmlHost = document.getElementById('cs-engine-html-result');
          if (box.ct.indexOf('text/html') !== -1 && htmlHost) {
            htmlHost.innerHTML = box.text;
            htmlHost.hidden = false;
            if (engWrap) engWrap.hidden = true;
            if (engErr) engErr.hidden = true;
            if (engErrT) engErrT.textContent = '';
            if (meta) {
              meta.hidden = true;
              meta.textContent = '';
            }
            requestAnimationFrame(function () {
              htmlHost.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });
            return;
          }

          var data;
          try {
            data = JSON.parse(box.text);
          } catch (e) {
            data = {
              error: 'non_json',
              message:
                'Unexpected response (HTTP ' +
                box.status +
                '). Refresh the page and sign in again if your session expired.'
            };
          }

          var userMsg = data && typeof data.message === 'string' ? data.message.trim() : '';
          var errField = data && data.error != null ? String(data.error).trim() : '';
          var errLine = userMsg !== '' ? userMsg : errField;
          if (errLine !== '') {
            if (engErrT) engErrT.textContent = errLine;
            if (engErr) engErr.hidden = false;
            return;
          }

          var plan = data && data.plan ? data.plan : null;
          var items = data && Array.isArray(data.items) ? data.items : [];
          if (!plan || items.length === 0 || !engBody) {
            if (engErrT) engErrT.textContent = 'No plan returned.';
            if (engErr) engErr.hidden = false;
            return;
          }

          if (meta) {
            var bits = [plan.plan_month || ym];
            if (plan.label) bits.push(plan.label);
            if (plan.domain) bits.push(plan.domain);
            meta.textContent = bits.join(' · ');
            meta.hidden = false;
          }

          items.forEach(function (row) {
            var tr = document.createElement('tr');
            var day = row.day_index != null ? String(row.day_index) : '—';
            var kw = esc(row.primary_keyword || '');
            var intent = esc(row.search_intent || '—');
            var score = row.opportunity_score != null ? esc(String(row.opportunity_score)) : '—';
            var title = esc(row.title || '');
            var metaDesc = row.meta_description
              ? '<p class="admin-field-hint" style="margin:0 0 0.5rem;font-size:0.8125rem">' + esc(row.meta_description) + '</p>'
              : '';
            var rat = row.score_rationale
              ? '<p class="admin-field-hint" style="margin:0 0 0.5rem;font-size:0.8125rem"><em>' + esc(row.score_rationale) + '</em></p>'
              : '';
            var lines = row.outline_lines || [];
            var ul = '';
            if (Array.isArray(lines) && lines.length > 0) {
              ul = '<ul style="margin:0;padding-left:1.25rem;font-size:0.8125rem;line-height:1.5">';
              lines.forEach(function (h) {
                ul += '<li>' + esc(String(h)) + '</li>';
              });
              ul += '</ul>';
            }
            tr.innerHTML =
              '<td class="admin-table-muted">' + esc(day) + '</td>' +
              '<td style="max-width:11rem;font-size:0.8125rem">' + kw + '</td>' +
              '<td class="admin-table-muted">' + intent + '</td>' +
              '<td class="admin-table-muted">' + score + '</td>' +
              '<td style="max-width:36rem">' +
              '<strong style="display:block;margin-bottom:0.35rem">' +
              title +
              '</strong>' +
              metaDesc +
              rat +
              ul +
              '</td>';
            engBody.appendChild(tr);
          });
          if (engWrap) engWrap.hidden = false;
        })
        .catch(function () {
          if (engProg) engProg.hidden = true;
          engBtn.disabled = false;
          engBtn.removeAttribute('aria-busy');
          if (engErrT) engErrT.textContent = 'Network error. Try again.';
          if (engErr) engErr.hidden = false;
        });
    });
  }
})();
</script>
