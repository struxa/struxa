{% extends 'layouts/base.twig' %}

{% block title %}{{ page_title|e }}{% if review %} — {{ settings.site_name|default('FL350')|e }}{% endif %}{% endblock %}
{% block meta_description %}{{ (review.meta_description ?? page_title)|e }}{% endblock %}

{% block head_extra %}
  {{ parent() }}
  <style>
    .adrv-hero {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      color: #fff;
      padding: 64px 0 72px;
      background:
        radial-gradient(ellipse at 85% -10%, rgba(245, 158, 11, .22) 0%, transparent 55%),
        radial-gradient(ellipse at 10% 110%, rgba(110, 231, 183, .12) 0%, transparent 50%),
        linear-gradient(120deg, #06172f 0%, #08254d 60%, #1557e8 100%);
      border-bottom: 1px solid rgba(255, 255, 255, .06);
    }
    .adrv-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      background-image: radial-gradient(rgba(255,255,255,.05) 1px, transparent 1px);
      background-size: 28px 28px;
      mask-image: linear-gradient(180deg, rgba(0,0,0,.9), transparent 80%);
      pointer-events: none;
      z-index: -1;
    }
    .adrv-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, .08);
      border: 1px solid rgba(255, 255, 255, .12);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .8);
      margin: 0 0 14px;
    }
    .adrv-eyebrow i { color: #fcd34d; font-size: 11px; }
    .adrv-h1 {
      margin: 0 0 12px;
      font-size: clamp(34px, 5.2vw, 54px);
      line-height: 1.05;
      letter-spacing: -0.04em;
    }
    .adrv-h1 .accent {
      background: linear-gradient(120deg, #fcd34d 0%, #f59e0b 50%, #fb923c 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .adrv-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-top: 18px;
      color: rgba(255, 255, 255, .82);
      font-size: 14px;
    }
    .adrv-meta span { display: inline-flex; align-items: center; gap: 6px; }
    .adrv-meta i { color: #fcd34d; font-size: 12px; }

    .adrv-article {
      max-width: 780px;
      margin: 40px auto 80px;
      padding: 0 20px;
      color: #0f172a;
      font-size: 17px;
      line-height: 1.75;
    }
    .adrv-article > p:first-of-type {
      font-size: 19px;
      line-height: 1.6;
      color: #1f2937;
    }
    .adrv-article h2 {
      margin: 2.2em 0 0.7em;
      font-size: 26px;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: #0f172a;
      position: relative;
      padding-left: 14px;
    }
    .adrv-article h2::before {
      content: "";
      position: absolute;
      left: 0; top: 0.3em; bottom: 0.3em;
      width: 4px;
      background: linear-gradient(180deg, #1d62f0, #0b4cdb);
      border-radius: 4px;
    }
    .adrv-article h3 {
      margin: 1.8em 0 0.5em;
      font-size: 19px;
      font-weight: 700;
      color: #0f172a;
    }
    .adrv-article p { margin: 0 0 1.2em; }
    .adrv-article ul, .adrv-article ol { margin: 0 0 1.4em; padding-left: 1.3em; }
    .adrv-article li { margin: 0 0 0.4em; }
    .adrv-article a { color: #1557e8; text-decoration: underline; text-underline-offset: 3px; }
    .adrv-article strong { color: #0f172a; font-weight: 700; }

    .adrv-footer-cta {
      max-width: 780px;
      margin: 0 auto 80px;
      padding: 24px 28px;
      background: linear-gradient(135deg, #fffaf0 0%, #fef3c7 100%);
      border: 1px solid #fde68a;
      border-radius: 16px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      justify-content: space-between;
    }
    .adrv-footer-cta p { margin: 0; color: #78350f; font-weight: 600; }
    .adrv-footer-cta .btn-primary {
      background: linear-gradient(180deg, #1d62f0, #0b4cdb);
      color: #fff;
      padding: 10px 20px;
      border-radius: 999px;
      font-weight: 700;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .adrv-404 {
      max-width: 600px;
      margin: 60px auto;
      padding: 0 20px;
      text-align: center;
      color: #475569;
    }
    .adrv-404 h1 { font-size: 36px; color: #0f172a; margin: 0 0 12px; letter-spacing: -0.03em; }
    .adrv-404 a { color: #1557e8; }
  </style>
{% endblock %}

{% block body %}
  {% if review %}
    <section class="adrv-hero">
      <div class="container">
        <p class="adrv-eyebrow"><i class="fa-solid fa-plane-departure"></i> Avios Destination Review</p>
        <h1 class="adrv-h1">Avios flights to <span class="accent">{{ review.destination|e }}</span></h1>
        <div class="adrv-meta">
          <span><i class="fa-solid fa-location-dot"></i> LHR → {{ review.iata|e }}</span>
          <span><i class="fa-regular fa-calendar"></i> Updated {{ review.updated_at|date('j M Y') }}</span>
        </div>
      </div>
    </section>

    <article class="adrv-article" id="main-content">
      {{ review.content_html|raw }}
    </article>

    <aside class="adrv-footer-cta">
      <p>Want to know exactly how many Avios you need to fly to {{ review.destination|e }}?</p>
      <a class="btn-primary" href="/#how-many-avios">Open the Avios calculator →</a>
    </aside>

  {% else %}
    <section class="adrv-404" id="main-content">
      <h1>Destination not found</h1>
      <p>This review hasn't been generated yet (or the URL is mistyped). Try the <a href="/destinations">full destinations index</a>.</p>
    </section>
  {% endif %}
{% endblock %}
