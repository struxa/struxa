{# Shared body for content_type_cards (core + Queue wrapper). Expects: section, site_url, archive_section_class_extra (optional), archive_head_variant (optional). #}
{% set _slug = section.content_type_slug|default('')|trim %}
{% set pack = content_type_cards(_slug, section.limit|default('6')) %}
{% if pack.type %}
  {% set _catalog_slugs = ['products', 'store', 'catalog', 'shop'] %}
  {% set _layout = section.layout_style|default('auto') %}
  {% set _use_catalog = _layout == 'catalog' or (_layout == 'auto' and pack.type.slug in _catalog_slugs) %}
  {% set _empty = section.empty_message|default('')|trim %}
  {% set _read = section.read_more_label|default('')|trim %}
  {% set _tag = section.card_tag_fallback|default('')|trim %}
  {% set _view_all_url = '' %}
  {% if section.show_view_all|default(true) %}
    {% set _path = section.view_all_path|default('')|trim %}
    {% if _path == '' %}
      {% set _view_all_url = site_url ~ '/' ~ pack.type.slug %}
    {% elseif _path matches '/^https?:\\/\\//i' %}
      {% set _view_all_url = _path %}
    {% elseif _path|slice(0, 1) == '/' %}
      {% set _view_all_url = site_url ~ _path %}
    {% else %}
      {% set _view_all_url = site_url ~ '/' ~ _path %}
    {% endif %}
  {% endif %}
  {% include 'content/_index_grid.twig' with {
    section_modifier: _use_catalog ? 'product-catalog' : 'blog-archive',
    eyebrow_label: section.eyebrow|default('')|trim != '' ? section.eyebrow : (_use_catalog ? 'Apps & platforms' : 'Archive'),
    blog_archive_title: section.title|default(''),
    archive_heading_tag: 'h2',
    blog_archive_intro_html: section.intro_html|default(''),
    content_index_description: '',
    empty_message: _empty != '' ? _empty : (_use_catalog ? 'No products yet. Import a products blueprint or publish your first entry.' : 'No published entries yet.'),
    read_more_label: _read != '' ? _read : (_use_catalog ? 'View product →' : 'Read more →'),
    newer_label: 'Newer',
    older_label: 'Older',
    card_tag_fallback: _tag != '' ? _tag : (_use_catalog ? 'Product' : 'Article'),
    content_type: pack.type,
    index_entries: pack.entries,
    index_page: 1,
    index_total_pages: 1,
    view_all_url: _view_all_url,
    view_all_label: section.view_all_label|default('View all'),
    archive_section_class_extra: archive_section_class_extra|default(''),
    archive_head_variant: archive_head_variant|default('archive'),
    archive_hide_pager: true,
  } %}
{% endif %}
