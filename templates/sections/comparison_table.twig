<section class="strux-section strux-compare strux-bg--{{ options.background|default('default')|e('html_attr') }}" data-section="comparison_table">
  <div class="strux-section-inner strux-section-inner--{{ options.padding|default('comfortable')|e('html_attr') }}">
    <h2 class="strux-section-title">{{ section.title|default('')|e }}</h2>
    <div class="strux-compare__wrap">
      <table class="strux-compare__table">
        <thead>
          <tr>
            <th scope="col" class="strux-compare__feature-col"></th>
            {% for col in section.columns_json|default([]) %}
              <th scope="col">{{ col|e }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for row in section.rows_json|default([]) %}
            <tr>
              <th scope="row">{{ row.feature|default('')|e }}</th>
              {% for cell in row.cells|default([]) %}
                <td>{{ cell|e }}</td>
              {% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>
