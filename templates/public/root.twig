{# Canonical public document layout (PublicLayoutContract::PUBLIC_ROOT). Core + plugins should extend this or base.twig (alias). Themes use layouts/base.twig for storefront chrome. #}
<!DOCTYPE html>
<html lang="{{ settings.site_html_lang|default('en')|e('html_attr') }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      {%- if struxa_seo|default(false) -%}
        {{- struxa_html_title|default('')|e -}}
      {%- else -%}
        {%- block title -%}{{ settings.default_meta_title|default(settings.site_name)|e }}{%- endblock -%}
      {%- endif -%}
    </title>
    <meta
      name="description"
      content="{%- if struxa_seo|default(false) -%}{{ struxa_meta_description|default('')|e('html_attr') }}{%- else -%}{%- block meta_description -%}{{ settings.default_meta_description|default('')|e }}{%- endblock -%}{%- endif -%}"
    />
    {% block meta_extra %}
      {% if struxa_seo|default(false) %}
        {% include 'public/_struxa_social_head.twig' %}
      {% endif %}
    {% endblock %}
    <link rel="canonical" href="{% if struxa_seo|default(false) %}{{ struxa_canonical_url|default('')|e('html_attr') }}{% else %}{% block canonical_href %}{{ site_url }}/{% endblock %}{% endif %}" />
    <meta name="theme-color" content="#151a2e" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="{{ settings.favicon_href|default('/favicon.svg')|e('html_attr') }}" />
    <link rel="apple-touch-icon" href="{{ settings.favicon_href|default('/favicon.svg')|e('html_attr') }}" />
    <link rel="manifest" href="/site.webmanifest" />
    {% if not struxa_seo|default(false) %}
      <meta property="og:type" content="website" />
      <meta property="og:site_name" content="{{ settings.site_name|e }}" />
      <meta property="og:locale" content="{{ settings.site_og_locale|default('en_US')|e('html_attr') }}" />
      <meta property="og:title" content="{% block og_title %}{{ settings.default_meta_title|default(settings.site_name)|e }}{% endblock %}" />
      <meta
        property="og:description"
        content="{% block og_description %}{{ settings.default_meta_description|default('')|e }}{% endblock %}"
      />
      <meta
        property="og:image"
        content="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1200&h=630&fit=crop&auto=format&q=85"
      />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
      <meta property="og:image:alt" content="Dashboard and analytics interface preview" />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content="{% block twitter_title %}{{ settings.default_meta_title|default(settings.site_name)|e }}{% endblock %}" />
      <meta
        name="twitter:description"
        content="{% block twitter_description %}{{ settings.default_meta_description|default('')|e }}{% endblock %}"
      />
      <meta
        name="twitter:image"
        content="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1200&h=630&fit=crop&auto=format&q=85"
      />
      <meta name="twitter:image:alt" content="Dashboard and analytics interface preview" />
    {% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="{{ theme_asset('css/app.css') }}" />
    {% block head_extra %}{% endblock %}
  </head>
  <body>
    {% include 'partials/_shell.twig' %}
    {% include 'partials/_header.twig' %}

    {% block body %}{% endblock %}

    <script src="/js/main.js" type="module"></script>
    <script>
      (function () {
        var t = {{ csrf_token()|json_encode|raw }};
        document.querySelectorAll('form').forEach(function (f) {
          var m = (f.getAttribute('method') || 'get').toLowerCase();
          if (m !== 'post') return;
          if (f.querySelector('input[name="_csrf_token"]')) return;
          var i = document.createElement('input');
          i.type = 'hidden';
          i.name = '_csrf_token';
          i.value = t;
          f.appendChild(i);
        });
      })();
    </script>
    {% block scripts_extra %}{% endblock %}
  </body>
</html>
