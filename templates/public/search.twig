{% extends theme_layout() %}

{% block title %}Search — {{ settings.site_name|default('')|e }}{% endblock %}
{% block meta_description %}Search published content on {{ settings.site_name|default('this site')|e }}.{% endblock %}
{% block canonical_href %}{{ site_url }}/search{% endblock %}

{% block body %}
  <main id="main-content" class="st-page st-page--search">
    <div class="st-page__inner">
      <header class="st-search-page__head">
        <h1 class="st-search-page__title">Search</h1>
        <p class="st-search-page__lead">Find articles and entries published on this site.</p>
      </header>

      <form class="st-search-page__form" action="{{ url_for('public.search') }}" method="get" role="search">
        <label class="sr-only" for="search-q">Search</label>
        <div class="st-search-page__field">
          <svg class="st-search-page__field-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-3.5-3.5" />
          </svg>
          <input
            type="search"
            name="q"
            id="search-q"
            class="st-search-page__input"
            value="{{ search_query_raw|e('html_attr') }}"
            autocomplete="off"
            spellcheck="false"
            autofocus
            minlength="{{ search_min_length }}"
            maxlength="{{ search_max_length }}"
            placeholder="Search…"
          />
        </div>
        <button type="submit" class="st-btn st-btn--primary">Search</button>
      </form>

      {% if search_too_short %}
        <p class="st-search-page__notice">Enter at least {{ search_min_length }} characters.</p>
      {% endif %}

      {% if search_query != '' %}
        <p class="st-search-page__meta">
          {% if search_result.total == 0 %}
            No results for <strong>{{ search_query|e }}</strong>.
          {% else %}
            {{ search_result.total }} result{{ search_result.total == 1 ? '' : 's' }} for <strong>{{ search_query|e }}</strong>{% if search_result.total_pages > 1 %} · Page {{ search_result.page }} of {{ search_result.total_pages }}{% endif %}
          {% endif %}
        </p>
      {% endif %}

      {% if search_result.hits is not empty %}
        <ol class="st-search-page__results">
          {% for hit in search_result.hits %}
            <li class="st-search-page__hit">
              <div class="st-search-page__hit-head">
                <h2 class="st-search-page__hit-title">
                  <a href="{{ hit.url|e('html_attr') }}">{{ hit.title|e }}</a>
                </h2>
                <span class="st-search-page__hit-type">{{ hit.type_name|e }}</span>
              </div>
              {% if hit.snippet != '' %}
                <p class="st-search-page__hit-snippet">{{ hit.snippet|e }}</p>
              {% endif %}
              <a class="st-search-page__hit-url" href="{{ hit.url|e('html_attr') }}">{{ hit.url|e }}</a>
            </li>
          {% endfor %}
        </ol>

        {% if search_result.total_pages > 1 %}
          <nav class="st-search-page__pager" aria-label="Search pagination">
            {% if search_result.page > 1 %}
              <a class="st-btn st-btn--ghost" href="?q={{ search_query|url_encode }}&amp;page={{ search_result.page - 1 }}">← Previous</a>
            {% endif %}
            {% if search_result.page < search_result.total_pages %}
              <a class="st-btn st-btn--ghost" href="?q={{ search_query|url_encode }}&amp;page={{ search_result.page + 1 }}">Next →</a>
            {% endif %}
          </nav>
        {% endif %}
      {% endif %}
    </div>
  </main>
{% endblock %}
