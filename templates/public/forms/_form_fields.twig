{% set _return = return_to|default('') %}
{% set _pages = form_pages|default([]) %}
{% set _multipage = form_is_multipage|default(false) %}
{% set _is_quiz = form_is_quiz|default(false) %}
<section class="struxa-form-wrap" aria-labelledby="struxa-form-{{ form.id|default('x') }}-title" data-struxa-form-root>
  {% if section is defined and section.title|default('') != '' %}
    <h2 id="struxa-form-{{ form.id|default('x') }}-title" class="struxa-form-heading">{{ section.title|e }}</h2>
  {% endif %}
  {% if section is defined and section.lead|default('') != '' %}
    <p class="struxa-form-lead">{{ section.lead|e|nl2br }}</p>
  {% endif %}

  {% if flash_error|default('') != '' %}
    <div class="struxa-form-flash struxa-form-flash--error" role="alert">{{ flash_error|e }}</div>
  {% endif %}
  {% if flash_success|default('') != '' %}
    <div class="struxa-form-flash struxa-form-flash--success" role="status">{{ flash_success|e }}</div>
  {% endif %}

  {% if _multipage %}
    <div class="struxa-form-progress" data-struxa-form-progress aria-hidden="true">
      {% for page in _pages %}
        <span class="struxa-form-progress-dot{% if loop.first %} is-active{% endif %}" data-page="{{ page.page }}"></span>
      {% endfor %}
    </div>
  {% endif %}

  <form class="struxa-form" method="post" action="{{ action_url|e('html_attr') }}" enctype="multipart/form-data" novalidate data-struxa-form>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
    <input type="hidden" name="return_to" value="{{ _return|e('html_attr') }}" id="struxa-form-return-to" />

    {% for field in honeypot_fields|default([]) %}
      {% include 'public/forms/_field.twig' with { field: field, form: form } only %}
    {% endfor %}

    {% if _multipage %}
      {% for page in _pages %}
        <div class="struxa-form-page{% if loop.first %} is-active{% endif %}" data-struxa-form-page="{{ page.page }}" {% if not loop.first %}hidden{% endif %}>
          <h3 class="struxa-form-page-title">{{ page.title|e }}</h3>
          {% for field in page.fields %}
            {% include 'public/forms/_field.twig' with { field: field, form: form } only %}
          {% endfor %}
        </div>
      {% endfor %}
    {% else %}
      {% for field in fields %}
        {% include 'public/forms/_field.twig' with { field: field, form: form } only %}
      {% endfor %}
    {% endif %}

    <div class="struxa-form-actions" data-struxa-form-actions>
      {% if _multipage %}
        <button type="button" class="struxa-form-btn struxa-form-btn--ghost struxa-form-prev" data-struxa-form-prev hidden>{{ form.prev_label|default('Previous')|e }}</button>
        <button type="button" class="struxa-form-btn struxa-form-submit struxa-form-next" data-struxa-form-next>{{ form.next_label|default('Next')|e }}</button>
        <button type="submit" class="struxa-form-btn struxa-form-submit" data-struxa-form-submit hidden>{{ form.submit_label|default('Submit')|e }}</button>
      {% else %}
        <button type="submit" class="struxa-form-btn struxa-form-submit">{{ form.submit_label|default('Submit')|e }}</button>
      {% endif %}
    </div>
  </form>
</section>
<script src="{{ asset('js/forms-public.js') }}" defer></script>
<script>
  (function () {
    var el = document.getElementById('struxa-form-return-to');
    if (el && el.value === '' && location.pathname.charAt(0) === '/') {
      el.value = location.pathname + location.search + location.hash;
    }
  })();
</script>
