{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}Themes{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Themes</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Installed themes live in <code class="admin-inline-code">/themes/</code>. The active theme controls public layouts, CSS, and Twig overrides; the admin panel always uses core templates.</p>
  {% if struxa_catalog_settings_url|default('') != '' %}
    <p class="admin-hero-sub admin-hero-sub--tight">To ship a new theme version: <a class="admin-link" href="{{ struxa_catalog_settings_url|e('html_attr') }}">Struxa catalog → Publish bundled theme</a>, then <strong>Reinstall from catalog</strong> below.</p>
  {% endif %}
  {% if theme_update_count|default(0) > 0 %}
    <p class="admin-hero-sub admin-hero-sub--tight">{{ theme_update_count }} theme update(s) available from the catalog or GitHub.</p>
  {% endif %}
{% endblock %}

{% block admin_content %}
  <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:1.25rem">
    <p class="admin-hint" style="margin:0">Install from the catalog or <a class="admin-link" href="{{ url_for('admin.themes.browse') }}#install-zip">upload a ZIP</a>.</p>
    <a class="admin-btn-primary" href="{{ url_for('admin.themes.browse') }}">Browse catalog</a>
  </div>

  {% if theme_rows is empty %}
    {{ ui.empty_state(
      'No themes found',
      'Add a folder under themes/ with theme.json, views/, and assets/. Activate one to style the public site.',
      '',
      '',
      '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>'
    ) }}
  {% else %}
    <div class="admin-theme-grid">
      {% for row in theme_rows %}
        {% set t = row.theme %}
        {% set upd = row.update %}
        <article class="admin-card admin-theme-card">
          <div class="admin-theme-card-preview">
            {% if t.screenshot %}
              <img src="{{ url_for('admin.themes.screenshot', { slug: t.slug }) }}" alt="" width="640" height="400" loading="lazy" decoding="async" />
            {% else %}
              <div class="admin-theme-card-placeholder">No screenshot</div>
            {% endif %}
            {% if active_theme_slug == t.slug %}
              <span class="admin-pill admin-pill--accent admin-theme-active-badge">Active</span>
            {% endif %}
            {% if upd and upd.update_available %}
              <span class="admin-pill admin-badge--review admin-theme-active-badge" style="top:auto;bottom:0.75rem">Update</span>
            {% endif %}
          </div>
          <div class="admin-theme-card-body">
            <h2 class="admin-card-title" style="margin-top:0">{{ t.name|e }}</h2>
            <p class="admin-hint" style="margin:0 0 0.5rem">
              {{ t.slug|e }} · v{{ t.version|e }}
              {% if upd and upd.update_available and upd.latest_version %}
                · <span class="admin-plugin-update-hint">v{{ upd.latest_version|e }} available{% if upd.source %} ({{ upd.source|e }}){% endif %}</span>
              {% elseif upd and upd.latest_version and not upd.update_available %}
                · <span class="admin-text-muted">remote v{{ upd.latest_version|e }}{% if upd.source %} ({{ upd.source|e }}){% endif %}</span>
              {% endif %}
              · {{ t.author|e }}
            </p>
            {% if t.description %}
              <p class="admin-theme-desc">{{ t.description|e }}</p>
            {% endif %}
            {% if upd and upd.error and not upd.update_available %}
              <p class="admin-plugin-compat-blocked-hint">Update check: {{ upd.error|e }}</p>
            {% endif %}
            {% if t.homepage or t.repositoryUrl or t.license or t.category or t.tags is not empty %}
              <p class="admin-hint" style="margin:0.5rem 0 0;line-height:1.5">
                {% if t.category %}<span class="admin-pill">{{ t.category|e }}</span>{% endif %}
                {% if t.license %}<span class="admin-pill">{{ t.license|e }}</span>{% endif %}
                {% if t.minCmsVersion %}<span class="admin-pill">Min CMS {{ t.minCmsVersion|e }}</span>{% endif %}
                {% if t.testedUpTo %}<span class="admin-pill">Tested {{ t.testedUpTo|e }}</span>{% endif %}
                {% if t.homepage %}<a class="admin-link" href="{{ t.homepage|e('html_attr') }}" target="_blank" rel="noopener">Homepage</a>{% endif %}
                {% if t.repositoryUrl %} · <a class="admin-link" href="{{ t.repositoryUrl|e('html_attr') }}" target="_blank" rel="noopener">Repo</a>{% endif %}
                {% if t.supportUrl %} · <a class="admin-link" href="{{ t.supportUrl|e('html_attr') }}" target="_blank" rel="noopener">Support</a>{% endif %}
                {% if t.tags is not empty %}<span style="display:block;margin-top:0.35rem">{{ t.tags|join(', ')|e }}</span>{% endif %}
              </p>
            {% endif %}
            {% if t.settingsSchema %}
              <p class="admin-hint" style="margin-top:0.75rem"><strong>Theme settings</strong> (schema only for now): {{ t.settingsSchema|keys|join(', ')|e }}</p>
            {% endif %}
            <div class="admin-theme-card-actions">
              {% if upd and upd.update_available and upd.can_update %}
                <form
                  method="post"
                  action="{{ url_for('admin.themes.update') }}"
                  onsubmit="return confirm('Update {{ t.slug|e('js') }} to v{{ upd.latest_version|e('js') }}?\n\nThe themes/{{ t.slug|e('js') }}/ folder will be replaced.');"
                >
                  <input type="hidden" name="theme_slug" value="{{ t.slug|e('html_attr') }}" />
                  <button type="submit" class="admin-btn-primary">Update to v{{ upd.latest_version|e }}</button>
                </form>
              {% elseif upd and upd.update_available and not upd.can_update %}
                <p class="admin-plugin-compat-blocked-hint">Update detected but no download source is configured.</p>
              {% endif %}
              {% if upd and upd.catalog_has_package and upd.latest_version and not (upd.update_available and upd.can_update) %}
                <form
                  method="post"
                  action="{{ url_for('admin.themes.reinstall_catalog') }}"
                  class="admin-theme-reinstall-form"
                  onsubmit="return confirm('Reinstall {{ t.slug|e('js') }} from the catalog ZIP (v{{ upd.latest_version|e('js') }})?\n\nThe themes/{{ t.slug|e('js') }}/ folder will be replaced.');"
                >
                  <input type="hidden" name="theme_slug" value="{{ t.slug|e('html_attr') }}" />
                  <button type="submit" class="admin-btn-secondary">Reinstall from catalog (v{{ upd.latest_version|e }})</button>
                </form>
              {% endif %}
              {% if active_theme_slug != t.slug %}
                <form method="post" action="{{ url_for('admin.themes.activate') }}" class="admin-theme-activate-form">
                  <input type="hidden" name="theme_slug" value="{{ t.slug|e('html_attr') }}" />
                  <button type="submit" class="admin-btn-primary">Activate</button>
                </form>
              {% else %}
                <p class="admin-hint admin-theme-card-actions-note">This theme is serving the public site.</p>
              {% endif %}
              {% if t.slug != 'struxa-theme' and active_theme_slug != t.slug %}
                <form
                  method="post"
                  action="{{ url_for('admin.themes.remove') }}"
                  class="admin-theme-remove-form"
                  onsubmit="return confirm('Remove theme {{ t.slug|e('js') }} permanently? The themes/{{ t.slug|e('js') }}/ folder will be deleted. This cannot be undone.');"
                >
                  <input type="hidden" name="theme_slug" value="{{ t.slug|e('html_attr') }}" />
                  <button type="submit" class="admin-btn-danger">Remove theme…</button>
                </form>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
