{% extends 'admin/base.twig' %}

{% block admin_title %}Edit form — {{ form_row.name|e }}{% endblock %}

{% block admin_head %}
  <script src="{{ asset('js/admin-forms-builder.js') }}" defer></script>
{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ form_row.name|e }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    Slug <code class="admin-inline-code">{{ form_row.slug|e }}</code>
    {% if form_row.status == 'published' %}
      · <a href="{{ public_url|e('html_attr') }}" target="_blank" rel="noopener">Public URL</a>
    {% endif %}
  </p>
{% endblock %}

{% block admin_content %}
  <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem">
    <div style="display:flex;gap:0.4rem;flex-wrap:wrap">
      <a class="admin-btn admin-btn--ghost" href="{{ url_for('admin.forms.index') }}">All forms</a>
      <a class="admin-btn admin-btn--ghost" href="{{ url_for('admin.forms.entries', { id: form_row.id }) }}">Entries</a>
    </div>
    <form method="post" action="{{ url_for('admin.forms.delete', { id: form_row.id }) }}" onsubmit="return confirm('Delete this form and all entries?');">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
      <button class="admin-btn admin-btn--danger admin-btn--sm" type="submit">Delete form</button>
    </form>
  </div>

  <div class="admin-forms-layout">
    <section class="admin-card admin-forms-builder">
      <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:0.75rem">
        <h2 class="admin-card-title" style="margin:0">Fields</h2>
        <span class="admin-hint">Drag to reorder</span>
      </div>

      {% if field_rows is empty %}
        <p class="admin-hint">No fields yet. Add your first field below.</p>
      {% else %}
        {% for field in field_rows %}
          <form id="delete-field-{{ field.id }}" method="post" action="{{ url_for('admin.forms.fields.delete', { id: form_row.id, fieldId: field.id }) }}" hidden>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          </form>
        {% endfor %}
        <form method="post" action="{{ url_for('admin.forms.fields.reorder', { id: form_row.id }) }}" id="forms-field-reorder-form">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <ul class="forms-field-list" id="forms-field-list" data-reorder-form="forms-field-reorder-form">
            {% for field in field_rows %}
              <li class="forms-field-item" draggable="true" data-field-id="{{ field.id }}">
                <span class="forms-field-drag" aria-hidden="true">⋮⋮</span>
                <input type="hidden" name="field_order[]" value="{{ field.id }}" />
                <div class="forms-field-meta">
                  <strong>{{ field.label|e }}</strong>
                  <span class="admin-hint">{{ field_types[field.field_type]|default(field.field_type)|e }} · <code>{{ field.field_key|e }}</code>{% if field.required %} · required{% endif %}</span>
                </div>
                <button class="admin-btn admin-btn--ghost admin-btn--sm" type="submit" form="delete-field-{{ field.id }}" onclick="return confirm('Remove this field?');">Remove</button>
              </li>
            {% endfor %}
          </ul>
        </form>
      {% endif %}

      <hr style="margin:1.25rem 0;border:none;border-top:1px solid var(--admin-border,rgba(255,255,255,.08))" />

      <h3 class="admin-card-title" id="add-field">Add field</h3>
      <form method="post" action="{{ url_for('admin.forms.fields.add', { id: form_row.id }) }}" class="admin-form-stack">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <div class="admin-form-row">
          <label class="admin-label">
            <span>Label</span>
            <input class="admin-input" type="text" name="label" required maxlength="200" />
          </label>
          <label class="admin-label">
            <span>Type</span>
            <select class="admin-input" name="field_type" id="forms-new-field-type">
              {% for typeKey, typeLabel in field_types %}
                <option value="{{ typeKey|e('html_attr') }}">{{ typeLabel|e }}</option>
              {% endfor %}
            </select>
          </label>
        </div>
        <div class="admin-form-row">
          <label class="admin-label">
            <span>Field key (optional)</span>
            <input class="admin-input" type="text" name="field_key" maxlength="80" placeholder="email" />
          </label>
          <label class="admin-label">
            <span>Placeholder</span>
            <input class="admin-input" type="text" name="placeholder" maxlength="255" />
          </label>
        </div>
        <label class="admin-label forms-choice-options" id="forms-choice-options" hidden>
          <span>Options (one per line)</span>
          <textarea class="admin-input" name="options" rows="4" placeholder="Option A&#10;Option B"></textarea>
        </label>
        <label class="admin-label">
          <span>Help text</span>
          <input class="admin-input" type="text" name="help_text" maxlength="500" />
        </label>
        <label class="admin-checkbox">
          <input type="checkbox" name="required" value="1" />
          Required field
        </label>
        <button class="admin-btn admin-btn--primary" type="submit">Add field</button>
      </form>
    </section>

    <aside class="admin-card admin-forms-settings">
      <h2 class="admin-card-title">Settings</h2>
      <form method="post" action="{{ url_for('admin.forms.update', { id: form_row.id }) }}" class="admin-form-stack">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <label class="admin-label">
          <span>Name</span>
          <input class="admin-input" type="text" name="name" value="{{ form_row.name|e('html_attr') }}" required maxlength="200" />
        </label>
        <label class="admin-label">
          <span>Slug</span>
          <input class="admin-input" type="text" name="slug" value="{{ form_row.slug|e('html_attr') }}" required maxlength="120" />
        </label>
        <label class="admin-label">
          <span>Status</span>
          <select class="admin-input" name="status">
            <option value="draft" {{ form_row.status == 'draft' ? 'selected' : '' }}>Draft</option>
            <option value="published" {{ form_row.status == 'published' ? 'selected' : '' }}>Published</option>
          </select>
        </label>
        <label class="admin-label">
          <span>Description (internal)</span>
          <textarea class="admin-input" name="description" rows="2">{{ form_row.description|default('')|e }}</textarea>
        </label>
        <label class="admin-label">
          <span>Submit button label</span>
          <input class="admin-input" type="text" name="submit_label" value="{{ form_row.submit_label|default('Submit')|e('html_attr') }}" maxlength="80" />
        </label>

        <h3 class="admin-card-title">After submit</h3>
        <label class="admin-label">
          <span>Confirmation</span>
          <select class="admin-input" name="confirmation_type" id="forms-confirmation-type">
            <option value="message" {{ form_row.confirmation_type|default('message') == 'message' ? 'selected' : '' }}>Show message</option>
            <option value="redirect" {{ form_row.confirmation_type|default('message') == 'redirect' ? 'selected' : '' }}>Redirect</option>
          </select>
        </label>
        <label class="admin-label" id="forms-confirmation-message-wrap">
          <span>Message</span>
          <textarea class="admin-input" name="confirmation_message" rows="3">{{ form_row.confirmation_message|default('Thanks — your submission was received.')|e }}</textarea>
        </label>
        <label class="admin-label" id="forms-confirmation-redirect-wrap" hidden>
          <span>Redirect URL</span>
          <input class="admin-input" type="text" name="confirmation_redirect_url" value="{{ form_row.confirmation_redirect_url|default('')|e('html_attr') }}" placeholder="/thank-you" />
        </label>

        <h3 class="admin-card-title">Notifications</h3>
        <label class="admin-checkbox">
          <input type="checkbox" name="notify_enabled" value="1" {{ form_row.notify_enabled|default(1) ? 'checked' : '' }} />
          Email admins on new submission
        </label>
        <label class="admin-label">
          <span>Notification emails</span>
          <input class="admin-input" type="text" name="notify_emails" value="{{ form_row.notify_emails|default('')|e('html_attr') }}" placeholder="you@example.com, team@example.com" />
        </label>
        <label class="admin-label">
          <span>Email subject</span>
          <input class="admin-input" type="text" name="notify_subject" value="{{ form_row.notify_subject|default('')|e('html_attr') }}" maxlength="255" />
        </label>

        <h3 class="admin-card-title">Spam protection</h3>
        <label class="admin-checkbox">
          <input type="checkbox" name="honeypot_enabled" value="1" {{ form_row.honeypot_enabled|default(1) ? 'checked' : '' }} />
          Honeypot field (recommended)
        </label>

        <button class="admin-btn admin-btn--primary" type="submit">Save settings</button>
      </form>

      <div class="admin-hint" style="margin-top:1rem">
        Embed on a page: add a <strong>Form embed</strong> block and set slug to <code>{{ form_row.slug|e }}</code>.
      </div>
    </aside>
  </div>

  <style>
    .admin-forms-layout { display: grid; gap: 1rem; grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.9fr); align-items: start; }
    @media (max-width: 960px) { .admin-forms-layout { grid-template-columns: 1fr; } }
    .forms-field-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
    .forms-field-item { display: flex; align-items: center; gap: 0.65rem; padding: 0.75rem; border: 1px solid var(--admin-border,rgba(255,255,255,.08)); border-radius: 0.55rem; background: rgba(255,255,255,.02); }
    .forms-field-item.is-dragging { opacity: 0.55; }
    .forms-field-drag { cursor: grab; color: var(--admin-muted,#94a3b8); user-select: none; }
    .forms-field-meta { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.15rem; }
  </style>
{% endblock %}
