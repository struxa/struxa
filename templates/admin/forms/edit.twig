{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}Edit form — {{ form_row.name|e }}{% endblock %}
{% block admin_body_class %}admin-body--form-edit{% endblock %}

{% block admin_head %}
  <script src="{{ asset('js/admin-forms-builder.js') }}" defer></script>
{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ form_row.name|e }}</h1>
{% endblock %}

{% block admin_breadcrumbs %}
  {% include 'admin/partials/_breadcrumbs.twig' with {
    breadcrumbs: [
      { label: 'Forms', url: url_for('admin.forms.index') },
      { label: form_row.name|length > 42 ? form_row.name|slice(0, 39) ~ '…' : form_row.name },
    ],
  } %}
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-fb-hero-meta">
    {% if form_row.status == 'published' %}
      {{ ui.status_badge('published') }}
    {% else %}
      {{ ui.status_badge('draft') }}
    {% endif %}
    <span class="admin-fb-hero-chip">{{ field_rows|length }} field{% if field_rows|length != 1 %}s{% endif %}</span>
    {% if is_quiz %}<span class="admin-fb-hero-chip admin-fb-hero-chip--quiz">Quiz</span>{% endif %}
    <span class="admin-fb-hero-slug">/{{ form_row.slug|e }}</span>
    <span class="admin-fb-hero-links">
      <a class="admin-link" href="{{ url_for('admin.forms.entries', { id: form_row.id }) }}">Entries</a>
      {% if form_row.status == 'published' %}
        · <a class="admin-link" href="{{ public_url|e('html_attr') }}" target="_blank" rel="noopener">View live</a>
      {% endif %}
    </span>
  </p>
{% endblock %}

{% block admin_content %}
  <div class="admin-page-edit-layout admin-fb-layout">
    <div class="admin-page-edit-main admin-fb-main">
      <section
        class="admin-card admin-fb-shell"
        id="admin-forms-builder"
        data-reorder-url="{{ url_for('admin.forms.fields.reorder', { id: form_row.id })|e('html_attr') }}"
        data-csrf="{{ csrf_token()|e('html_attr') }}"
      >
        <header class="admin-fb-shell-head">
          <div class="admin-fb-shell-head-text">
            <h2 class="admin-fb-shell-title">Form builder</h2>
            <p class="admin-hint admin-fb-shell-lead">Drag fields to reorder. Pick a type below to add more.</p>
          </div>
          <p class="admin-fb-status" id="admin-fb-status" hidden aria-live="polite"></p>
        </header>

        <div class="admin-fb-palette-bar" aria-label="Field types">
          <p class="admin-fb-palette-bar-label">Add</p>
          <div class="admin-fb-palette-scroll">
            {% for typeKey, typeLabel in field_types %}
              {% if typeKey not in ['honeypot'] %}
                <button type="button" class="admin-fb-palette-chip" data-fb-palette-type="{{ typeKey|e('html_attr') }}" data-fb-palette-label="{{ typeLabel|e('html_attr') }}">
                  {% include 'admin/forms/_field_type_icon.twig' with { type: typeKey } %}
                  <span>{{ typeLabel|e }}</span>
                </button>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <form method="post" action="{{ url_for('admin.forms.fields.reorder', { id: form_row.id }) }}" id="forms-field-reorder-form" hidden>
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        </form>

        <div class="admin-fb-sheet-wrap">
          <div class="admin-fb-sheet">
            <div class="admin-fb-sheet-header">
              <span class="admin-fb-sheet-kicker">Preview</span>
              <strong class="admin-fb-sheet-title">{{ form_row.name|e }}</strong>
              {% if form_row.description|default('')|trim != '' %}
                <p class="admin-fb-sheet-desc">{{ form_row.description|e }}</p>
              {% endif %}
            </div>

            {% if field_rows is empty %}
              <div class="admin-fb-empty" id="admin-fb-empty">
                <div class="admin-fb-empty-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="4" width="16" height="16" rx="3"/><path d="M8 9h8M8 13h5"/></svg>
                </div>
                <p class="admin-fb-empty-title">Your form is empty</p>
                <p class="admin-fb-empty-text">Choose a field type above, then name it in the panel below.</p>
              </div>
            {% endif %}

            <ul class="admin-fb-list" id="forms-field-list" role="list"{% if field_rows is empty %} hidden{% endif %}>
              {% for field in field_rows %}
                {% include 'admin/forms/_field_row.twig' with {
                  form_id: form_row.id,
                  field: field,
                  field_types: field_types,
                  field_key_options: field_key_options,
                  is_quiz: is_quiz
                } %}
              {% endfor %}
            </ul>

            <div class="admin-fb-sheet-submit" aria-hidden="true">
              <span class="admin-fb-mock admin-fb-mock--button">{{ form_row.submit_label|default('Submit')|e }}</span>
            </div>
          </div>
        </div>

        <div class="admin-fb-add-panel" id="admin-fb-add-panel">
          <div class="admin-fb-add-panel-head">
            <div class="admin-fb-add-type-chip" id="admin-fb-add-type-chip">
              {% include 'admin/forms/_field_type_icon.twig' with { type: 'text' } %}
              <span id="admin-fb-add-type-label">Single line text</span>
            </div>
            <h3 class="admin-fb-add-panel-title" id="admin-fb-add-title">New field</h3>
          </div>
          <form method="post" action="{{ url_for('admin.forms.fields.add', { id: form_row.id }) }}" class="admin-fb-add-form" id="forms-add-field-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
            <input type="hidden" name="field_type" id="forms-new-field-type" value="text" />
            <div class="admin-form-grid admin-form-grid--2col-tight">
              <label class="admin-label">
                <span>Field label</span>
                <input class="admin-input" type="text" name="label" id="forms-new-field-label" required maxlength="200" placeholder="e.g. Email address" />
              </label>
              <label class="admin-label">
                <span>Field key (optional)</span>
                <input class="admin-input" type="text" name="field_key" maxlength="80" placeholder="email" />
              </label>
              <label class="admin-label">
                <span>Placeholder</span>
                <input class="admin-input" type="text" name="placeholder" maxlength="255" />
              </label>
              <label class="admin-label">
                <span>Page number</span>
                <input class="admin-input" type="number" name="page_number" min="1" value="{{ max_page_number|default(1) }}" />
              </label>
            </div>
            <label class="admin-label forms-choice-options" id="forms-choice-options" hidden>
              <span>Options (one per line)</span>
              <textarea class="admin-textarea" name="options" rows="4" placeholder="Option A&#10;Option B"></textarea>
            </label>
            <label class="admin-label">
              <span>Help text</span>
              <input class="admin-input" type="text" name="help_text" maxlength="500" />
            </label>
            <div class="admin-form-grid admin-form-grid--2col-tight forms-file-options" id="forms-file-options-wrap" hidden>
              <label class="admin-label">
                <span>Max file size (MB)</span>
                <input class="admin-input" type="number" name="file_max_mb" min="1" max="20" value="5" />
              </label>
              <label class="admin-label">
                <span>Allowed extensions</span>
                <input class="admin-input" type="text" name="file_extensions" value="pdf,jpg,png,doc,docx" />
              </label>
            </div>
            {% if is_quiz %}
              <div class="admin-form-grid admin-form-grid--2col-tight forms-quiz-options" id="forms-quiz-options-wrap" hidden>
                <label class="admin-label">
                  <span>Quiz points</span>
                  <input class="admin-input" type="number" name="quiz_points" min="1" value="1" />
                </label>
                <label class="admin-label">
                  <span>Correct answer</span>
                  <input class="admin-input" type="text" name="quiz_correct" placeholder="Must match an option exactly" />
                </label>
              </div>
            {% endif %}
            <div class="admin-fb-add-actions">
              <label class="admin-checkbox">
                <input type="checkbox" name="required" value="1" />
                Required field
              </label>
              <button class="admin-btn admin-btn--primary" type="submit">Add to form</button>
            </div>
          </form>
        </div>
      </section>
    </div>

    <aside class="admin-page-edit-aside admin-fb-aside" aria-label="Form settings">
      <div class="admin-card admin-page-edit-aside-card admin-fb-settings-card">
        <div class="admin-fb-settings-head">
          <h2 class="admin-card-title">Settings</h2>
          <p class="admin-hint">Publish, confirmations, and notifications</p>
        </div>
        {% include 'admin/forms/_settings_panel.twig' with { form_row: form_row, is_quiz: is_quiz } %}
        <div class="admin-page-edit-aside-actions admin-fb-settings-actions">
          <button class="admin-btn admin-btn--primary" type="submit" form="forms-settings-form">Save settings</button>
          <form method="post" action="{{ url_for('admin.forms.delete', { id: form_row.id }) }}" onsubmit="return confirm('Delete this form and all entries?');">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
            <button class="admin-btn admin-btn--danger admin-btn--sm" type="submit">Delete form</button>
          </form>
        </div>
        <div class="admin-fb-embed-callout">
          <p class="admin-fb-embed-callout-title">Embed this form</p>
          <p class="admin-hint">Add a <strong>Form embed</strong> block on any page and set slug to <code>{{ form_row.slug|e }}</code>.</p>
        </div>
      </div>
    </aside>
  </div>
{% endblock %}
