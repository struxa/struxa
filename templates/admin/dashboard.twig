{% extends 'admin/base.twig' %}
{% set s = dashboard_stats|default({}) %}
{% set site = settings.site_name|default('Studio') %}

{% block admin_title %}Dashboard{% endblock %}

{% block admin_body_class %}admin-body--dash-ref admin-body--dashboard{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">
    Welcome back, {{ cms_user.display_name|default(cms_user.email|split('@')|first|default('there')) }}<span class="admin-hero-emoji" aria-hidden="true"> 👋</span>
  </h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    Here’s what’s happening across <strong class="admin-hero-strong">{{ site|e }}</strong> today.
  </p>
{% endblock %}

{% block admin_hero_meta %}
  <div class="admin-hero-chips" aria-label="Session summary">
    <span class="admin-hero-chip">{{ "now"|date("l, F j") }}</span>
    {% if cms_user.role_labels is defined and cms_user.role_labels is not empty %}
      <span class="admin-hero-chip">{{ cms_user.role_labels|join(', ')|e }}</span>
    {% elseif cms_user.role is defined and cms_user.role %}
      <span class="admin-hero-chip">{{ cms_user.role|capitalize|e }}</span>
    {% endif %}
    <span class="admin-hero-chip">Struxa v{{ cms_version|e }}</span>
    {% set draft_total = (s.pages_draft|default(0)) + (s.entries_draft|default(0)) %}
    {% if draft_total > 0 %}
      <span class="admin-hero-chip admin-hero-chip--accent">{{ draft_total }} draft{{ draft_total == 1 ? '' : 's' }}</span>
    {% endif %}
    {% if (s.entries_in_review|default(0)) > 0 %}
      <span class="admin-hero-chip admin-hero-chip--warn">{{ s.entries_in_review }} in review</span>
    {% endif %}
  </div>
{% endblock %}

{% block admin_hero_actions %}
  {% if cms_can('manage_pages') %}
    <a class="admin-dash-cta admin-dash-cta--primary admin-dash-cta--hero" href="{{ url_for('admin.pages.new') }}">
      <span class="admin-dash-cta-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_page.twig' %}</span>
      New page
    </a>
  {% endif %}
  {% if cms_can('manage_media') %}
    <a class="admin-dash-cta admin-dash-cta--hero" href="{{ url_for('admin.media.upload') }}">
      <span class="admin-dash-cta-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_upload.twig' %}</span>
      Upload
    </a>
  {% endif %}
  {% if cms_can('create_content') %}
    <a class="admin-dash-cta admin-dash-cta--hero" href="{{ url_for('admin.content.entries.new_picker') }}">
      <span class="admin-dash-cta-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_pen.twig' %}</span>
      New entry
    </a>
  {% endif %}
  {% if cms_can('manage_content_types') %}
    <a class="admin-dash-cta admin-dash-cta--hero" href="{{ url_for('admin.content_types.new') }}">
      <span class="admin-dash-cta-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_layers.twig' %}</span>
      Content type
    </a>
  {% endif %}
{% endblock %}

{% block admin_content %}
  {% import 'admin/_ui_macros.twig' as ui %}

  <div class="admin-dash">
    {% set _up = cms_update_status|default({}) %}
    {% if _up.update_available|default(false) %}
      <div class="admin-dash-update-callout" role="status">
        <div class="admin-dash-update-callout-copy">
          <strong class="admin-dash-update-callout-title">New CMS version available</strong>
          <p class="admin-dash-update-callout-meta">
            You’re on <code class="admin-inline-code">{{ _up.current_version|default(cms_version)|e }}</code>
            · latest is <code class="admin-inline-code">{{ _up.latest_version|e }}</code>
            {% if _up.summary|default('') != '' %} — {{ _up.summary|e }}{% endif %}
          </p>
        </div>
        <div class="admin-dash-update-callout-actions">
          {% if _up.release_url|default('') != '' %}
            <a class="admin-btn-ghost" href="{{ _up.release_url|e('html_attr') }}" rel="noopener noreferrer" target="_blank">Release notes</a>
          {% endif %}
          <a class="admin-btn-primary admin-dash-update-callout-primary" href="{{ url_for('admin.updates.index') }}">View updates</a>
        </div>
      </div>
    {% elseif _up.ok|default(true) == false %}
      <div class="admin-dash-update-callout admin-dash-update-callout--muted" role="status">
        <p class="admin-dash-update-callout-meta" style="margin:0">
          Could not verify CMS updates{% if _up.error|default('') != '' %}: {{ _up.error|e }}{% endif %}.
          <a class="admin-link" href="{{ url_for('admin.updates.index', {}, { fresh: 1 }) }}">Check now</a>
        </p>
      </div>
    {% endif %}

    <section class="admin-dash-section" aria-labelledby="dash-metrics">
      <div class="admin-dash-section-head">
        <h2 class="admin-dash-section-heading-block" id="dash-metrics">
          <span class="admin-dash-section-kicker">Overview</span>
          At a glance
        </h2>
        <p class="admin-dash-section-lead">Live totals across pages, entries, and media.</p>
      </div>
      <div class="admin-metrics admin-metrics--dash" role="list">
        <article class="admin-metric admin-metric--dash admin-metric--tone-pages" role="listitem">
          <div class="admin-metric-dash-top">
            <span class="admin-metric-dash-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_page.twig' %}</span>
            <p class="admin-metric-label">Pages</p>
          </div>
          <p class="admin-metric-value">{{ s.pages|default(0) }}</p>
          <p class="admin-metric-meta">{{ s.pages_published|default(0) }} live · {{ s.pages_draft|default(0) }} draft</p>
          {% if cms_can('manage_pages') %}
            <a class="admin-metric-link" href="{{ url_for('admin.pages.index') }}">Open pages</a>
          {% endif %}
        </article>
        <article class="admin-metric admin-metric--dash admin-metric--tone-entries" role="listitem">
          <div class="admin-metric-dash-top">
            <span class="admin-metric-dash-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_layers.twig' %}</span>
            <p class="admin-metric-label">Entries</p>
          </div>
          <p class="admin-metric-value">{{ s.entries|default(0) }}</p>
          <p class="admin-metric-meta">{{ s.entries_published|default(0) }} published · {{ s.entries_draft|default(0) }} draft</p>
          {% if cms_can('manage_content_types') or cms_can('create_content') %}
            <a class="admin-metric-link" href="{{ url_for('admin.content_types.index') }}">Content types</a>
          {% endif %}
        </article>
        <article class="admin-metric admin-metric--dash admin-metric--tone-review" role="listitem">
          <div class="admin-metric-dash-top">
            <span class="admin-metric-dash-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_review.twig' %}</span>
            <p class="admin-metric-label">In review</p>
          </div>
          <p class="admin-metric-value">{{ s.entries_in_review|default(0) }}</p>
          <p class="admin-metric-meta">Awaiting editorial review</p>
          {% if cms_can('review_content') %}
            <a class="admin-metric-link" href="{{ url_for('admin.content_types.index') }}">Review queue</a>
          {% endif %}
        </article>
        <article class="admin-metric admin-metric--dash admin-metric--tone-media" role="listitem">
          <div class="admin-metric-dash-top">
            <span class="admin-metric-dash-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_image.twig' %}</span>
            <p class="admin-metric-label">Media</p>
          </div>
          <p class="admin-metric-value">{{ s.media|default(0) }}</p>
          <p class="admin-metric-meta">Files in library</p>
          {% if cms_can('manage_media') %}
            <a class="admin-metric-link" href="{{ url_for('admin.media.index') }}">Media library</a>
          {% endif %}
        </article>
        <article class="admin-metric admin-metric--dash admin-metric--tone-plugins" role="listitem">
          <div class="admin-metric-dash-top">
            <span class="admin-metric-dash-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_plugin.twig' %}</span>
            <p class="admin-metric-label">Plugins</p>
          </div>
          <p class="admin-metric-value">{{ s.active_plugins|default(0) }}</p>
          <p class="admin-metric-meta">Active extensions</p>
          {% if cms_can('manage_plugins') %}
            <a class="admin-metric-link" href="{{ url_for('admin.extensions.plugins.index') }}">Extensions</a>
          {% endif %}
        </article>
        <article class="admin-metric admin-metric--dash admin-metric--tone-types" role="listitem">
          <div class="admin-metric-dash-top">
            <span class="admin-metric-dash-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_grid.twig' %}</span>
            <p class="admin-metric-label">Content types</p>
          </div>
          <p class="admin-metric-value">{{ s.content_types|default(0) }}</p>
          <p class="admin-metric-meta">Structured models</p>
          {% if cms_can('manage_content_types') %}
            <a class="admin-metric-link" href="{{ url_for('admin.content_types.index') }}">Type library</a>
          {% endif %}
        </article>
      </div>
    </section>

    {% if (s.pages|default(0)) == 0 and (s.entries|default(0)) == 0 %}
      <section class="admin-dash-section" aria-labelledby="dash-start">
        <div class="admin-dash-section-head">
          <h2 class="admin-dash-section-heading-block" id="dash-start">
            <span class="admin-dash-section-kicker">Onboarding</span>
            Start here
          </h2>
          <p class="admin-dash-section-lead">Clean slate — add a page, a content type, or media to get moving.</p>
        </div>
        <div class="admin-dash-onboarding">
          <ul class="admin-dash-checklist">
            <li>
              <span class="admin-dash-check {{ (s.pages|default(0)) > 0 ? 'admin-dash-check--done' : '' }}" aria-hidden="true"></span>
              <div>
                <strong>Add a page</strong>
                <div class="admin-dash-muted">Home, landing, or legal — public at <code class="admin-inline-code">/p/slug</code>.</div>
                {% if cms_can('manage_pages') and (s.pages|default(0)) == 0 %}
                  <a class="admin-link" href="{{ url_for('admin.pages.new') }}">Create page</a>
                {% endif %}
              </div>
            </li>
            <li>
              <span class="admin-dash-check {{ (s.content_types|default(0)) > 0 ? 'admin-dash-check--done' : '' }}" aria-hidden="true"></span>
              <div>
                <strong>Define a content type</strong>
                <div class="admin-dash-muted">Blog posts, products, team — then add fields and entries.</div>
                {% if cms_can('manage_content_types') and (s.content_types|default(0)) == 0 %}
                  <a class="admin-link" href="{{ url_for('admin.content_types.new') }}">New content type</a>
                {% endif %}
              </div>
            </li>
            <li>
              <span class="admin-dash-check {{ (s.media|default(0)) > 0 ? 'admin-dash-check--done' : '' }}" aria-hidden="true"></span>
              <div>
                <strong>Upload media</strong>
                <div class="admin-dash-muted">Reuse assets across pages and entries.</div>
                {% if cms_can('manage_media') and (s.media|default(0)) == 0 %}
                  <a class="admin-link" href="{{ url_for('admin.media.upload') }}">Upload file</a>
                {% endif %}
              </div>
            </li>
          </ul>
        </div>
      </section>
    {% endif %}

    <div class="admin-dash-bento">
      <section class="admin-dash-card admin-dash-card--elevated admin-dash-bento__workflow" aria-labelledby="dash-workflow">
        <h3 class="admin-dash-card-title" id="dash-workflow">Drafts &amp; review</h3>
        <p class="admin-dash-card-lead">Open work across pages and structured content.</p>
        <ul class="admin-dash-pulse">
          <li>
            <span class="admin-dash-pulse-label">Page drafts</span>
            <span class="admin-dash-pulse-value">{{ s.pages_draft|default(0) }}</span>
          </li>
          <li>
            <span class="admin-dash-pulse-label">Entry drafts</span>
            <span class="admin-dash-pulse-value">{{ s.entries_draft|default(0) }}</span>
          </li>
          <li>
            <span class="admin-dash-pulse-label">In review</span>
            <span class="admin-dash-pulse-value admin-dash-pulse-value--accent">{{ s.entries_in_review|default(0) }}</span>
          </li>
        </ul>
        {% if (s.entries_in_review|default(0)) > 0 and (cms_can('review_content') or cms_can('edit_content')) %}
          <p class="admin-dash-card-foot">Open a type and filter by status to clear the queue.</p>
          <a class="admin-metric-link" href="{{ url_for('admin.content_types.index') }}">Go to content types →</a>
        {% endif %}
      </section>

      <section class="admin-dash-card admin-dash-card--elevated admin-dash-bento__shortcuts" aria-labelledby="dash-quick">
        <h3 class="admin-dash-card-title" id="dash-quick">Shortcuts</h3>
        <p class="admin-dash-card-lead">Frequent admin destinations in one tap.</p>
        <div class="admin-dash-tiles">
          {% if cms_can('manage_settings') %}
            <a class="admin-dash-tile" href="{{ url_for('admin.settings') }}"><span class="admin-dash-tile-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_gear.twig' %}</span><span class="admin-dash-tile-text">Settings</span></a>
          {% endif %}
          {% if cms_can('manage_menus') %}
            <a class="admin-dash-tile" href="{{ url_for('admin.menus.index') }}"><span class="admin-dash-tile-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_menu.twig' %}</span><span class="admin-dash-tile-text">Menus</span></a>
          {% endif %}
          {% if cms_can('manage_themes') %}
            <a class="admin-dash-tile" href="{{ url_for('admin.themes.index') }}"><span class="admin-dash-tile-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_theme.twig' %}</span><span class="admin-dash-tile-text">Themes</span></a>
          {% endif %}
          {% if cms_can('manage_portability') %}
            <a class="admin-dash-tile" href="{{ url_for('admin.tools.blueprints') }}"><span class="admin-dash-tile-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_blueprint.twig' %}</span><span class="admin-dash-tile-text">Blueprints</span></a>
            <a class="admin-dash-tile" href="{{ url_for('admin.tools.import_export') }}"><span class="admin-dash-tile-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_swap.twig' %}</span><span class="admin-dash-tile-text">Import / export</span></a>
          {% endif %}
          {% if cms_can('view_activity') %}
            <a class="admin-dash-tile" href="{{ url_for('admin.activity.index') }}"><span class="admin-dash-tile-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_activity.twig' %}</span><span class="admin-dash-tile-text">Activity</span></a>
          {% endif %}
        </div>
        {% if not cms_can('manage_settings') and not cms_can('manage_menus') and not cms_can('manage_themes') and not cms_can('manage_portability') and not cms_can('view_activity') %}
          <p class="admin-hint admin-dash-tiles-empty">No shortcuts for your role — use the sidebar to navigate.</p>
        {% endif %}
      </section>

      <section class="admin-dash-card admin-dash-card--elevated admin-dash-bento__activity" aria-labelledby="dash-activity">
        <div class="admin-dash-card-head-row">
          <h3 class="admin-dash-card-title" id="dash-activity">Recent activity</h3>
          {% if cms_can('view_activity') %}
            <a class="admin-dash-card-head-link" href="{{ url_for('admin.activity.index') }}">Full log</a>
          {% endif %}
        </div>
        {% if s.recent_activity is empty %}
          <p class="admin-dash-empty">No events yet — saves, publishes, and sign-ins will show up here.</p>
        {% else %}
          <div class="admin-dash-timeline-wrap">
            <ol class="admin-dash-timeline">
              {% for log in s.recent_activity %}
                <li class="admin-dash-timeline-item">
                  <span class="admin-dash-timeline-dot" aria-hidden="true"></span>
                  <div class="admin-dash-timeline-body">
                    <div class="admin-dash-timeline-title">{{ log.event_type|default('event')|replace({'_': ' '})|e }}</div>
                    {% if log.subject_type %}
                      <div class="admin-dash-timeline-sub">{{ log.subject_type|e }}{% if log.subject_id %} #{{ log.subject_id }}{% endif %}</div>
                    {% endif %}
                    <div class="admin-dash-timeline-meta">
                      {{ log.created_at|default('')|slice(0, 16)|replace({'T': ' '}) }}
                      {% if log.user_display_name or log.user_email %}
                        · {{ (log.user_display_name|default(log.user_email))|e }}
                      {% endif %}
                    </div>
                  </div>
                </li>
              {% endfor %}
            </ol>
          </div>
        {% endif %}
      </section>

      <section class="admin-dash-card admin-dash-card--elevated admin-dash-bento__entries" aria-labelledby="dash-recent-entries">
        <h3 class="admin-dash-card-title" id="dash-recent-entries">Latest entries</h3>
        {% if s.recent_entries is empty %}
          <p class="admin-dash-empty">Nothing edited yet.</p>
        {% else %}
          <ul class="admin-dash-entry-list">
            {% for e in s.recent_entries %}
              <li class="admin-dash-entry-row">
                <div class="admin-dash-entry-main">
                  {% if cms_can('edit_content') or cms_can('review_content') %}
                    <a class="admin-dash-entry-title" href="{{ url_for('admin.content_types.entries.edit', { id: e.type_id, entryId: e.id }) }}">{{ e.title|default('(untitled)')|e }}</a>
                  {% else %}
                    <span class="admin-dash-entry-title admin-dash-entry-title--plain">{{ e.title|default('(untitled)')|e }}</span>
                  {% endif %}
                  <span class="admin-dash-entry-meta">{{ e.type_name|default('')|e }} · {{ e.updated_at|default('')|slice(0, 16)|replace({'T': ' '}) }}</span>
                </div>
                {{ ui.status_badge(e.status|default('')) }}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </section>

      <section class="admin-dash-card admin-dash-card--elevated admin-dash-bento__types" aria-labelledby="dash-by-type">
        <h3 class="admin-dash-card-title" id="dash-by-type">Entries by type</h3>
        {% if s.entries_by_type is empty %}
          <p class="admin-dash-empty">Create a content type to see entry counts.</p>
        {% else %}
          <ul class="admin-dash-type-bars">
            {% set max_cnt = 1 %}
            {% for row in s.entries_by_type %}
              {% set max_cnt = max(row.count, max_cnt) %}
            {% endfor %}
            {% for row in s.entries_by_type %}
              <li class="admin-dash-type-bar">
                <div class="admin-dash-type-bar-head">
                  <span class="admin-dash-type-name">{{ row.name|e }}</span>
                  <span class="admin-dash-type-count">{{ row.count }}</span>
                </div>
                <div class="admin-dash-type-track" role="presentation">
                  <span class="admin-dash-type-fill" style="width: {{ max_cnt > 0 ? ((row.count / max_cnt) * 100)|round : 0 }}%"></span>
                </div>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </section>
    </div>

  </div>
{% endblock %}
