{% extends 'admin/base.twig' %}
{% set s = dashboard_stats|default({}) %}
{% set site = settings.site_name|default('Studio') %}
{% set display_name = cms_user.display_name|default(cms_user.email|split('@')|first|default('there')) %}
{% set draft_total = (s.pages_draft|default(0)) + (s.entries_draft|default(0)) %}
{% set published_total = (s.pages_published|default(0)) + (s.entries_published|default(0)) %}
{% set role_label = cms_user.role_labels is defined and cms_user.role_labels is not empty ? cms_user.role_labels|join(', ') : (cms_user.role|default('')|capitalize) %}

{% block admin_title %}Dashboard{% endblock %}

{% block admin_body_class %}admin-body--dash-ref admin-body--dashboard{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title admin-hero-title--dash">Welcome back, {{ display_name }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">
    <span class="admin-dash-hero-site">{{ site|e }}</span> · {{ "now"|date("l, F j") }}
  </p>
{% endblock %}

{% block admin_hero_meta %}
  <div class="admin-hero-chips" aria-label="Session summary">
    {% if role_label %}
      <span class="admin-hero-chip">{{ role_label|e }}</span>
    {% endif %}
    <span class="admin-hero-chip">Struxa v{{ cms_version|e }}</span>
    {% if draft_total > 0 %}
      <span class="admin-hero-chip admin-hero-chip--accent">{{ draft_total }} draft{{ draft_total == 1 ? '' : 's' }}</span>
    {% endif %}
    {% if (s.entries_in_review|default(0)) > 0 %}
      <span class="admin-hero-chip admin-hero-chip--warn">{{ s.entries_in_review }} in review</span>
    {% endif %}
  </div>
{% endblock %}

{% block admin_hero_actions %}
  {% if cms_can('manage_pages') %}
    <a class="admin-dash-cta admin-dash-cta--primary admin-dash-cta--hero" href="{{ url_for('admin.pages.new') }}">
      <span class="admin-dash-cta-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_page.twig' %}</span>
      New page
    </a>
  {% endif %}
  {% if cms_can('manage_media') %}
    <a class="admin-dash-cta admin-dash-cta--hero" href="{{ url_for('admin.media.index') }}">
      <span class="admin-dash-cta-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_upload.twig' %}</span>
      Upload
    </a>
  {% endif %}
  {% if cms_can('create_content') %}
    <a class="admin-dash-cta admin-dash-cta--hero" href="{{ url_for('admin.content.entries.new_picker') }}">
      <span class="admin-dash-cta-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_pen.twig' %}</span>
      New entry
    </a>
  {% endif %}
{% endblock %}

{% block admin_content %}
  {% import 'admin/_ui_macros.twig' as ui %}

  <div class="admin-dash-shell" aria-label="Dashboard">

    {% set _up = cms_update_status|default({}) %}
    {% if _up.update_available|default(false) %}
      <div class="admin-dash-alert admin-dash-alert--update" role="status">
        <span class="admin-dash-alert-pulse" aria-hidden="true"></span>
        <div class="admin-dash-alert-body">
          <strong class="admin-dash-alert-title">Update ready — Struxa {{ _up.latest_version|e }}</strong>
          <p class="admin-dash-alert-meta">
            Running {{ _up.current_version|default(cms_version)|e }}
            {% if _up.summary|default('') != '' %} · {{ _up.summary|e }}{% endif %}
          </p>
        </div>
        <div class="admin-dash-alert-actions">
          {% if _up.release_url|default('') != '' %}
            <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ _up.release_url|e('html_attr') }}" rel="noopener noreferrer" target="_blank">Notes</a>
          {% endif %}
          <a class="admin-btn-primary" href="{{ url_for('admin.updates.index') }}">Update now</a>
        </div>
      </div>
    {% elseif _up.ok|default(true) == false %}
      <div class="admin-dash-alert admin-dash-alert--muted" role="status">
        <p class="admin-dash-alert-meta" style="margin:0">
          Could not verify CMS updates{% if _up.error|default('') != '' %}: {{ _up.error|e }}{% endif %}.
          <a class="admin-link" href="{{ url_for('admin.updates.index', {}, { fresh: 1 }) }}">Check now</a>
        </p>
      </div>
    {% endif %}

    <div class="admin-dash-kpis" role="list" aria-label="Key metrics">
      {% if cms_can('manage_pages') %}
        <a class="admin-dash-kpi admin-dash-kpi--pages" href="{{ url_for('admin.pages.index') }}" role="listitem">
      {% else %}
        <article class="admin-dash-kpi admin-dash-kpi--pages" role="listitem">
      {% endif %}
        <div class="admin-dash-kpi-text">
          <span class="admin-dash-kpi-label">Pages</span>
          <span class="admin-dash-kpi-value">{{ s.pages|default(0) }}</span>
          <span class="admin-dash-kpi-meta">{{ s.pages_published|default(0) }} live · {{ s.pages_draft|default(0) }} draft</span>
        </div>
        <span class="admin-dash-kpi-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_page.twig' %}</span>
      {% if cms_can('manage_pages') %}</a>{% else %}</article>{% endif %}

      {% if cms_can('manage_content_types') or cms_can('create_content') %}
        <a class="admin-dash-kpi admin-dash-kpi--entries" href="{{ url_for('admin.content_types.index') }}" role="listitem">
      {% else %}
        <article class="admin-dash-kpi admin-dash-kpi--entries" role="listitem">
      {% endif %}
        <div class="admin-dash-kpi-text">
          <span class="admin-dash-kpi-label">Entries</span>
          <span class="admin-dash-kpi-value">{{ s.entries|default(0) }}</span>
          <span class="admin-dash-kpi-meta">{{ s.entries_published|default(0) }} published · {{ s.entries_draft|default(0) }} draft</span>
        </div>
        <span class="admin-dash-kpi-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_layers.twig' %}</span>
      {% if cms_can('manage_content_types') or cms_can('create_content') %}</a>{% else %}</article>{% endif %}

      {% if cms_can('manage_media') %}
        <a class="admin-dash-kpi admin-dash-kpi--media" href="{{ url_for('admin.media.index') }}" role="listitem">
      {% else %}
        <article class="admin-dash-kpi admin-dash-kpi--media" role="listitem">
      {% endif %}
        <div class="admin-dash-kpi-text">
          <span class="admin-dash-kpi-label">Media</span>
          <span class="admin-dash-kpi-value">{{ s.media|default(0) }}</span>
          <span class="admin-dash-kpi-meta">Assets in library</span>
        </div>
        <span class="admin-dash-kpi-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_image.twig' %}</span>
      {% if cms_can('manage_media') %}</a>{% else %}</article>{% endif %}

      {% if cms_can('review_content') %}
        <a class="admin-dash-kpi admin-dash-kpi--review{% if (s.entries_in_review|default(0)) > 0 %} is-hot{% endif %}" href="{{ url_for('admin.content_types.index') }}" role="listitem">
      {% else %}
        <article class="admin-dash-kpi admin-dash-kpi--review{% if (s.entries_in_review|default(0)) > 0 %} is-hot{% endif %}" role="listitem">
      {% endif %}
        <div class="admin-dash-kpi-text">
          <span class="admin-dash-kpi-label">In review</span>
          <span class="admin-dash-kpi-value">{{ s.entries_in_review|default(0) }}</span>
          <span class="admin-dash-kpi-meta">Awaiting sign-off</span>
        </div>
        <span class="admin-dash-kpi-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_review.twig' %}</span>
      {% if cms_can('review_content') %}</a>{% else %}</article>{% endif %}
    </div>

    <div class="admin-dash-layout">
      <aside class="admin-dash-aside" aria-label="Overview">
        <section class="admin-dash-profile" aria-labelledby="dash-profile-title">
          <div class="admin-dash-profile-banner" aria-hidden="true"></div>
          <div class="admin-dash-profile-body">
            <div class="admin-dash-profile-avatar" aria-hidden="true">{{ display_name|slice(0, 1)|upper }}</div>
            <div class="admin-dash-profile-main">
              <h2 class="admin-dash-profile-name" id="dash-profile-title">{{ display_name|e }}</h2>
              {% if role_label %}
                <p class="admin-dash-profile-role">{{ role_label|e }}</p>
              {% endif %}
              <p class="admin-dash-profile-site">{{ site|e }}</p>
            </div>
            <dl class="admin-dash-profile-stats">
              <div class="admin-dash-profile-stat">
                <dt>Published</dt>
                <dd>{{ published_total }}</dd>
              </div>
              <div class="admin-dash-profile-stat">
                <dt>Drafts</dt>
                <dd>{{ draft_total }}</dd>
              </div>
            </dl>
            <div class="admin-dash-profile-foot">
              <span class="admin-dash-profile-chip">{{ s.content_types|default(0) }} types</span>
              <span class="admin-dash-profile-chip">{{ s.active_plugins|default(0) }} plugins</span>
            </div>
          </div>
        </section>

        <section class="admin-dash-card admin-dash-card--workflow" aria-labelledby="dash-workflow">
          <header class="admin-dash-card-head">
            <h3 class="admin-dash-card-title" id="dash-workflow">Drafts &amp; review</h3>
          </header>
          <div class="admin-dash-pulse-grid">
            <div class="admin-dash-pulse-pill">
              <span class="admin-dash-pulse-pill-value">{{ s.pages_draft|default(0) }}</span>
              <span class="admin-dash-pulse-pill-label">Page drafts</span>
            </div>
            <div class="admin-dash-pulse-pill">
              <span class="admin-dash-pulse-pill-value">{{ s.entries_draft|default(0) }}</span>
              <span class="admin-dash-pulse-pill-label">Entry drafts</span>
            </div>
            <div class="admin-dash-pulse-pill admin-dash-pulse-pill--hot">
              <span class="admin-dash-pulse-pill-value">{{ s.entries_in_review|default(0) }}</span>
              <span class="admin-dash-pulse-pill-label">In review</span>
            </div>
          </div>
          {% if (s.entries_in_review|default(0)) > 0 and (cms_can('review_content') or cms_can('edit_content')) %}
            <footer class="admin-dash-card-foot">
              <a class="admin-dash-card-link" href="{{ url_for('admin.content_types.index') }}">Open review queue →</a>
            </footer>
          {% endif %}
        </section>

        {% if cms_can('manage_plugins') or cms_can('manage_content_types') %}
          <section class="admin-dash-card admin-dash-card--compact" aria-label="More counts">
            <ul class="admin-dash-mini-metrics">
              {% if cms_can('manage_plugins') %}
                <li>
                  <a href="{{ url_for('admin.extensions.plugins.index') }}">
                    <span class="admin-dash-mini-value">{{ s.active_plugins|default(0) }}</span>
                    <span class="admin-dash-mini-label">Plugins</span>
                  </a>
                </li>
              {% endif %}
              {% if cms_can('manage_content_types') %}
                <li>
                  <a href="{{ url_for('admin.content_types.index') }}">
                    <span class="admin-dash-mini-value">{{ s.content_types|default(0) }}</span>
                    <span class="admin-dash-mini-label">Content types</span>
                  </a>
                </li>
              {% endif %}
            </ul>
          </section>
        {% endif %}
      </aside>

      <div class="admin-dash-main">
        {% if (s.pages|default(0)) == 0 and (s.entries|default(0)) == 0 %}
          <section class="admin-dash-card admin-dash-card--onboard" aria-labelledby="dash-start">
            <header class="admin-dash-card-head">
              <h3 class="admin-dash-card-title" id="dash-start">Launch your site</h3>
              <p class="admin-dash-card-lead">Three steps to go from empty to live content.</p>
            </header>
            <ol class="admin-dash-onboard-steps">
              <li class="admin-dash-onboard-step {{ (s.pages|default(0)) > 0 ? 'is-done' : '' }}">
                <span class="admin-dash-onboard-num" aria-hidden="true">1</span>
                <div>
                  <strong>Add a page</strong>
                  <p>Home, landing, or legal — public at <code class="admin-inline-code">/p/slug</code>.</p>
                  {% if cms_can('manage_pages') and (s.pages|default(0)) == 0 %}
                    <a class="admin-dash-onboard-link" href="{{ url_for('admin.pages.new') }}">Create page →</a>
                  {% endif %}
                </div>
              </li>
              <li class="admin-dash-onboard-step {{ (s.content_types|default(0)) > 0 ? 'is-done' : '' }}">
                <span class="admin-dash-onboard-num" aria-hidden="true">2</span>
                <div>
                  <strong>Define a content type</strong>
                  <p>Blog posts, products, team — then add fields and entries.</p>
                  {% if cms_can('manage_content_types') and (s.content_types|default(0)) == 0 %}
                    <a class="admin-dash-onboard-link" href="{{ url_for('admin.content_types.new') }}">New content type →</a>
                  {% endif %}
                </div>
              </li>
              <li class="admin-dash-onboard-step {{ (s.media|default(0)) > 0 ? 'is-done' : '' }}">
                <span class="admin-dash-onboard-num" aria-hidden="true">3</span>
                <div>
                  <strong>Upload media</strong>
                  <p>Reuse assets across pages and entries.</p>
                  {% if cms_can('manage_media') and (s.media|default(0)) == 0 %}
                    <a class="admin-dash-onboard-link" href="{{ url_for('admin.media.index') }}">Open media library →</a>
                  {% endif %}
                </div>
              </li>
            </ol>
          </section>
        {% endif %}

        <section class="admin-dash-card admin-dash-card--activity" aria-labelledby="dash-activity">
          <header class="admin-dash-card-head admin-dash-card-head--row">
            <div>
              <h3 class="admin-dash-card-title" id="dash-activity">Recent activity</h3>
              <p class="admin-dash-card-lead">Saves, publishes, and sign-ins across the site.</p>
            </div>
            {% if cms_can('view_activity') %}
              <a class="admin-dash-card-link" href="{{ url_for('admin.activity.index') }}">View all</a>
            {% endif %}
          </header>
          {% if s.recent_activity is empty %}
            <p class="admin-dash-empty">No events yet — activity will show up here as you work.</p>
          {% else %}
            <ol class="admin-dash-timeline">
              {% for log in s.recent_activity %}
                <li class="admin-dash-timeline-item">
                  <time class="admin-dash-timeline-date" datetime="{{ log.created_at|default('')|e('html_attr') }}">
                    {{ log.created_at|default('')|slice(5, 11)|replace({'-': ' '}) }}
                  </time>
                  <div class="admin-dash-timeline-body">
                    <p class="admin-dash-timeline-title">{{ log.event_type|default('event')|replace({'_': ' '})|e }}</p>
                    {% if log.subject_type %}
                      <p class="admin-dash-timeline-sub">{{ log.subject_type|e }}{% if log.subject_id %} #{{ log.subject_id }}{% endif %}</p>
                    {% endif %}
                    {% if log.user_display_name or log.user_email %}
                      <p class="admin-dash-timeline-meta">{{ (log.user_display_name|default(log.user_email))|e }}</p>
                    {% endif %}
                  </div>
                </li>
              {% endfor %}
            </ol>
          {% endif %}
        </section>

        <section class="admin-dash-card admin-dash-card--chart" aria-labelledby="dash-by-type">
          <header class="admin-dash-card-head">
            <h3 class="admin-dash-card-title" id="dash-by-type">Entries by content type</h3>
            <p class="admin-dash-card-lead">Distribution across your structured models.</p>
          </header>
          {% if s.entries_by_type is empty %}
            <p class="admin-dash-empty">Create a content type to see entry counts.</p>
          {% else %}
            <ul class="admin-dash-chart">
              {% set max_cnt = 1 %}
              {% for row in s.entries_by_type %}
                {% set max_cnt = max(row.count, max_cnt) %}
              {% endfor %}
              {% for row in s.entries_by_type %}
                {% set pct = max_cnt > 0 ? ((row.count / max_cnt) * 100)|round : 0 %}
                <li class="admin-dash-chart-row">
                  <div class="admin-dash-chart-head">
                    <span class="admin-dash-chart-name">{{ row.name|e }}</span>
                    <span class="admin-dash-chart-count">{{ row.count }}</span>
                  </div>
                  <div class="admin-dash-chart-track" role="presentation">
                    <span class="admin-dash-chart-fill" style="--dash-fill: {{ pct }}%"></span>
                  </div>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </section>
      </div>

      <aside class="admin-dash-rail" aria-label="Shortcuts and latest">
        <section class="admin-dash-card admin-dash-card--shortcuts" aria-labelledby="dash-quick">
          <header class="admin-dash-card-head">
            <h3 class="admin-dash-card-title" id="dash-quick">Quick links</h3>
          </header>
          <nav class="admin-dash-links" aria-label="Shortcuts">
            {% if cms_can('manage_settings') %}
              <a class="admin-dash-link" href="{{ url_for('admin.settings') }}">
                <span class="admin-dash-link-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_gear.twig' %}</span>
                Settings
              </a>
            {% endif %}
            {% if cms_can('manage_menus') %}
              <a class="admin-dash-link" href="{{ url_for('admin.menus.index') }}">
                <span class="admin-dash-link-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_menu.twig' %}</span>
                Menus
              </a>
            {% endif %}
            {% if cms_can('manage_themes') %}
              <a class="admin-dash-link" href="{{ url_for('admin.themes.index') }}">
                <span class="admin-dash-link-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_theme.twig' %}</span>
                Themes
              </a>
            {% endif %}
            {% if cms_can('manage_portability') %}
              <a class="admin-dash-link" href="{{ url_for('admin.tools.blueprints') }}">
                <span class="admin-dash-link-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_blueprint.twig' %}</span>
                Blueprints
              </a>
              <a class="admin-dash-link" href="{{ url_for('admin.tools.import_export') }}">
                <span class="admin-dash-link-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_swap.twig' %}</span>
                Import / export
              </a>
            {% endif %}
            {% if cms_can('view_activity') %}
              <a class="admin-dash-link" href="{{ url_for('admin.activity.index') }}">
                <span class="admin-dash-link-icon" aria-hidden="true">{% include 'admin/dashboard/_icon_activity.twig' %}</span>
                Activity log
              </a>
            {% endif %}
          </nav>
          {% if not cms_can('manage_settings') and not cms_can('manage_menus') and not cms_can('manage_themes') and not cms_can('manage_portability') and not cms_can('view_activity') %}
            <p class="admin-dash-empty">No shortcuts for your role — use the sidebar.</p>
          {% endif %}
        </section>

        <section class="admin-dash-card admin-dash-card--entries" aria-labelledby="dash-recent-entries">
          <header class="admin-dash-card-head">
            <h3 class="admin-dash-card-title" id="dash-recent-entries">Recently edited</h3>
          </header>
          {% if s.recent_entries is empty %}
            <p class="admin-dash-empty">Nothing edited yet.</p>
          {% else %}
            <ul class="admin-dash-entry-list">
              {% for e in s.recent_entries %}
                <li class="admin-dash-entry-row">
                  <div class="admin-dash-entry-main">
                    {% if cms_can('edit_content') or cms_can('review_content') %}
                      <a class="admin-dash-entry-title" href="{{ url_for('admin.content_types.entries.edit', { id: e.type_id, entryId: e.id }) }}">{{ e.title|default('(untitled)')|e }}</a>
                    {% else %}
                      <span class="admin-dash-entry-title admin-dash-entry-title--plain">{{ e.title|default('(untitled)')|e }}</span>
                    {% endif %}
                    <span class="admin-dash-entry-meta">{{ e.type_name|default('')|e }} · {{ e.updated_at|default('')|slice(0, 16)|replace({'T': ' '}) }}</span>
                  </div>
                  {{ ui.status_badge(e.status|default('')) }}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </section>
      </aside>
    </div>
  </div>
{% endblock %}
