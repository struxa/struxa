{# Shared block builder panel — pages and content entries #}
{% set _standalone = builder_panel_standalone|default(false) %}
{% set _post_suffix = _standalone ? '?embed=standalone' : '' %}
{% set _builder_action = builder_action_url|default('') ~ _post_suffix %}
{% set _palette_groups = section_palette_grouped|default([]) %}
{% set _list_id = builder_list_id|default('block-builder-list') %}
{% set _root_id = builder_root_id|default('admin-block-builder') %}
{% set _edit_route = builder_section_edit_route %}
{% set _route_params = builder_route_params|default({}) %}

<div
  class="admin-pb"
  id="{{ _root_id|e('html_attr') }}"
  data-builder-url="{{ _builder_action|e('html_attr') }}"
  data-csrf="{{ csrf_token()|e('html_attr') }}"
>
  <div class="admin-pb-toolbar">
    <div class="admin-pb-toolbar-copy">
      <h2 class="admin-pb-toolbar-title">{{ builder_title|default('Block builder')|e }}</h2>
      <p class="admin-pb-toolbar-lead">{{ builder_lead|default('Compose with reusable blocks. Drag to reorder — order saves automatically.')|e }}</p>
    </div>
    <div class="admin-pb-toolbar-actions">
      <button type="button" class="admin-btn-primary" id="admin-pb-open-palette" aria-haspopup="dialog" aria-controls="admin-pb-palette">
        Add block
      </button>
      {% if builder_settings_url|default('') %}
        <a class="admin-btn-ghost" href="{{ builder_settings_url|e('html_attr') }}">{{ builder_settings_label|default('Back to settings')|e }}</a>
      {% endif %}
      {% if builder_full_builder_url|default('') %}
        <a class="admin-btn-ghost" href="{{ builder_full_builder_url|e('html_attr') }}" target="_blank" rel="noopener">Open full builder</a>
      {% endif %}
      {% if builder_view_live_url|default('') %}
        <a class="admin-btn-ghost" href="{{ builder_view_live_url|e('html_attr') }}" target="_blank" rel="noopener">View live</a>
      {% endif %}
    </div>
  </div>

  <p class="admin-pb-status" id="admin-pb-status" role="status" hidden></p>

  {% if section_rows is empty %}
    <div class="admin-pb-empty">
      <p class="admin-pb-empty-title">Start with a block</p>
      <p class="admin-pb-empty-text">{{ builder_empty_text|default('Add a hero, feature grid, FAQ, or rich text block.')|e }}</p>
      <button type="button" class="admin-btn-primary" data-admin-pb-open-palette>Add your first block</button>
    </div>
  {% else %}
    <ul id="{{ _list_id|e('html_attr') }}" class="admin-pb-list" role="list">
      {% for row in section_rows %}
        {% set label = section_labels[row.sectionKey]|default(row.sectionKey) %}
        {% set block_icon = section_icons[row.sectionKey]|default('block') %}
        {% set d = row.data %}
        {% set preview = d.headline|default(d.title|default(d.eyebrow|default(''))) %}
        {% set _edit_params = _route_params|merge({ sectionId: row.id }) %}
        <li class="admin-pb-row" data-section-row="{{ row.id }}" draggable="true">
          <span class="admin-pb-row-drag" aria-hidden="true" title="Drag to reorder">⠿</span>
          <div class="admin-pb-row-icon">
            {% include 'admin/pages/_block_icon.twig' with { icon: block_icon } %}
          </div>
          <div class="admin-pb-row-body">
            <div class="admin-pb-row-head">
              <strong class="admin-pb-row-label">{{ label|e }}</strong>
              <span class="admin-pb-row-key">{{ row.sectionKey|e }}</span>
            </div>
            {% if preview %}
              <p class="admin-pb-row-preview">{{ preview|e }}</p>
            {% endif %}
          </div>
          <div class="admin-pb-row-actions">
            <button type="button" class="admin-btn-ghost admin-btn-ghost--sm" data-admin-pb-edit="{{ row.id }}" data-admin-pb-edit-url="{{ url_for(_edit_route, _edit_params)|e('html_attr') }}">Edit</button>
            <a class="admin-btn-ghost admin-btn-ghost--sm admin-pb-row-edit-full" href="{{ url_for(_edit_route, _edit_params) }}" hidden>Edit full page</a>
            <form method="post" action="{{ _builder_action|e('html_attr') }}" class="admin-inline-form">
              <input type="hidden" name="_action" value="duplicate" />
              <input type="hidden" name="section_id" value="{{ row.id }}" />
              <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm">Duplicate</button>
            </form>
            <button type="button" class="admin-btn-ghost admin-btn-ghost--sm" data-admin-pb-save-pattern="{{ row.id }}">Save as pattern</button>
            <form method="post" action="{{ _builder_action|e('html_attr') }}" class="admin-inline-form" onsubmit="return confirm('Remove this block?');">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="section_id" value="{{ row.id }}" />
              <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm admin-pb-row-delete">Delete</button>
            </form>
          </div>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  <form id="block-builder-reorder-form" method="post" action="{{ _builder_action|e('html_attr') }}" hidden aria-hidden="true">
    <input type="hidden" name="_action" value="reorder" />
  </form>

  <div class="admin-pb-palette" id="admin-pb-palette" hidden role="dialog" aria-modal="true" aria-labelledby="admin-pb-palette-title">
    <button type="button" class="admin-pb-palette-backdrop" id="admin-pb-palette-close" aria-label="Close block picker"></button>
    <div class="admin-pb-palette-panel">
      <header class="admin-pb-palette-head">
        <h3 class="admin-pb-palette-title" id="admin-pb-palette-title">Add a block</h3>
        <button type="button" class="admin-pb-palette-x" id="admin-pb-palette-dismiss" aria-label="Close">×</button>
      </header>
      <div class="admin-pb-palette-body">
        {% if section_patterns|default([])|length > 0 %}
          <section class="admin-pb-palette-group" aria-label="Saved patterns">
            <h4 class="admin-pb-palette-group-title">Saved patterns</h4>
            <div class="admin-pb-palette-grid">
              {% for pattern in section_patterns %}
                <form method="post" action="{{ _builder_action|e('html_attr') }}" class="admin-pb-palette-card-form">
                  <input type="hidden" name="_action" value="add_from_pattern" />
                  <input type="hidden" name="pattern_id" value="{{ pattern.id }}" />
                  <button type="submit" class="admin-pb-palette-card admin-pb-palette-card--pattern">
                    <span class="admin-pb-palette-card-icon">{% include 'admin/pages/_block_icon.twig' with { icon: section_icons[pattern.sectionKey]|default('block') } %}</span>
                    <span class="admin-pb-palette-card-label">{{ pattern.name|e }}</span>
                    <span class="admin-pb-palette-card-desc">{{ section_labels[pattern.sectionKey]|default(pattern.sectionKey)|e }}{% if pattern.description %} — {{ pattern.description|e }}{% endif %}</span>
                  </button>
                </form>
              {% endfor %}
            </div>
          </section>
        {% endif %}
        {% for group in _palette_groups %}
          <section class="admin-pb-palette-group" aria-label="{{ group.label|e('html_attr') }}">
            <h4 class="admin-pb-palette-group-title">{{ group.label|e }}</h4>
            <div class="admin-pb-palette-grid">
              {% for block in group.blocks %}
                <form method="post" action="{{ _builder_action|e('html_attr') }}" class="admin-pb-palette-card-form">
                  <input type="hidden" name="_action" value="add" />
                  <input type="hidden" name="section_key" value="{{ block.key|e('html_attr') }}" />
                  <button type="submit" class="admin-pb-palette-card">
                    <span class="admin-pb-palette-card-icon">{% include 'admin/pages/_block_icon.twig' with { icon: block.icon } %}</span>
                    <span class="admin-pb-palette-card-label">{{ block.label|e }}</span>
                    {% if block.description %}
                      <span class="admin-pb-palette-card-desc">{{ block.description|e }}</span>
                    {% endif %}
                  </button>
                </form>
              {% endfor %}
            </div>
          </section>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="admin-pb-drawer" id="admin-pb-drawer" hidden role="dialog" aria-modal="true" aria-labelledby="admin-pb-drawer-title">
    <button type="button" class="admin-pb-drawer-backdrop" data-admin-pb-drawer-close aria-label="Close editor"></button>
    <div class="admin-pb-drawer-panel" id="admin-pb-drawer-panel">
      <p class="admin-pb-drawer-loading" id="admin-pb-drawer-loading">Loading…</p>
    </div>
  </div>

  <dialog class="admin-pb-pattern-dialog" id="admin-pb-pattern-dialog">
    <form method="post" action="{{ _builder_action|e('html_attr') }}" class="admin-form">
      <input type="hidden" name="_action" value="save_as_pattern" />
      <input type="hidden" name="section_id" id="admin-pb-pattern-section-id" value="" />
      <input type="hidden" name="pattern_host" value="{{ builder_host|default('page')|e('html_attr') }}" />
      <h3 class="admin-pb-pattern-dialog-title">Save as pattern</h3>
      <p class="admin-hint">Reuse this block’s content and options on other pages or entries (depending on scope).</p>
      <div class="admin-field admin-field--full" style="margin-top:0.75rem">
        <label class="admin-label" for="admin-pb-pattern-name">Pattern name</label>
        <input class="admin-input" id="admin-pb-pattern-name" name="pattern_name" type="text" required maxlength="120" />
      </div>
      <div class="admin-field admin-field--full">
        <label class="admin-label" for="admin-pb-pattern-description">Description (optional)</label>
        <textarea class="admin-textarea" id="admin-pb-pattern-description" name="pattern_description" rows="2" maxlength="500"></textarea>
      </div>
      <div class="admin-form-actions" style="margin-top:1rem">
        <button type="submit" class="admin-btn-primary">Save pattern</button>
        <button type="button" class="admin-btn-ghost" id="admin-pb-pattern-cancel">Cancel</button>
      </div>
    </form>
  </dialog>
</div>
