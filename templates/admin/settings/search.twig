{% extends 'admin/base.twig' %}

{% block admin_title %}Storefront search{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Storefront search</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">A public search page for published content entries — opt-in, scoped, and safe by default.</p>
{% endblock %}

{% block admin_hero_actions %}
  {% if search_enabled %}
    <a class="admin-btn-ghost" href="{{ url_for('public.search') }}" target="_blank" rel="noopener">Open /search</a>
  {% endif %}
{% endblock %}

{% block admin_breadcrumbs %}
  {% include 'admin/partials/_breadcrumbs.twig' with {
    breadcrumbs: [
      { label: 'Site', href: url_for('admin.settings') },
      { label: 'Storefront search' },
    ],
  } %}
{% endblock %}

{% block admin_content %}
  {% set enabled_types = search_type_rows|filter(t => t.enabled)|length %}
  {% set total_types = search_type_rows|length %}

  <div class="admin-settings-page admin-settings-page--search">
    <div class="admin-settings-intro admin-settings-intro--search">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">What this does</p>
        <p class="admin-settings-intro-text">
          When enabled, visitors can search your site at <code class="admin-inline-code">/search</code>.
          Results come only from <strong class="admin-settings-intro-strong">published content entries</strong> on the content types you choose below —
          not pages, drafts, or types without a public URL. Search is <strong class="admin-settings-intro-strong">off by default</strong> so nothing is exposed until you turn it on and pick types.
        </p>
      </div>
      {% if search_enabled %}
        <span class="admin-pill admin-pill--ok admin-search-status-pill">Live at /search</span>
      {% else %}
        <span class="admin-pill admin-search-status-pill">Disabled</span>
      {% endif %}
    </div>

    <div class="admin-metrics admin-hub-metrics" aria-label="Search summary">
      <article class="admin-metric{% if search_enabled %} admin-metric--health-good{% endif %}">
        <p class="admin-metric-label">Public search</p>
        <p class="admin-metric-value admin-metric-value--sm">{{ search_enabled ? 'On' : 'Off' }}</p>
        <p class="admin-metric-meta">{% if search_enabled %}Visitors can use /search{% else %}Page returns 404{% endif %}</p>
      </article>
      <article class="admin-metric{% if enabled_types == 0 and search_enabled %} admin-metric--hot{% endif %}">
        <p class="admin-metric-label">Searchable types</p>
        <p class="admin-metric-value">{{ enabled_types }}</p>
        <p class="admin-metric-meta">{% if total_types > 0 %}of {{ total_types }} with public routes{% else %}No public types yet{% endif %}</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Results per page</p>
        <p class="admin-metric-value">{{ search_per_page }}</p>
        <p class="admin-metric-meta">{{ search_min_per_page }}–{{ search_max_per_page }} allowed</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Field matching</p>
        <p class="admin-metric-value admin-metric-value--sm">{{ search_include_fields ? 'On' : 'Off' }}</p>
        <p class="admin-metric-meta">Custom text / rich-text fields</p>
      </article>
    </div>

    <nav class="admin-settings-toc" aria-label="Search settings sections">
      <a class="admin-settings-toc-link" href="#search-general">General</a>
      <a class="admin-settings-toc-link" href="#search-types">Content types</a>
      <a class="admin-settings-toc-link" href="#search-how">How it works</a>
    </nav>

    <form method="post" action="{{ url_for('admin.settings.search.save') }}" class="admin-form admin-settings-form">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />

      <div class="admin-settings-stack">
        <section id="search-general" class="admin-card admin-settings-card admin-settings-section" tabindex="-1">
          <h2 class="admin-settings-card-title">General</h2>
          <p class="admin-settings-card-desc">Turn the public search page on or off and control how many results appear per page.</p>
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="enabled" value="1" {% if search_enabled %}checked{% endif %} />
                Enable storefront search at <code class="admin-inline-code">/search</code>
              </label>
              <p class="admin-hint">When off, <code class="admin-inline-code">/search</code> returns a 404 — even if types are selected. Add a link in your theme header or footer once this is on.</p>
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="include_fields" value="1" {% if search_include_fields %}checked{% endif %} />
                Also match text, textarea, and rich-text custom fields
              </label>
              <p class="admin-hint">When enabled, search looks inside field values as well as entry title and SEO fields. Turn off for faster queries if you only need titles and meta descriptions.</p>
            </div>
            <div class="admin-field">
              <label class="admin-label" for="search-per-page">Results per page</label>
              <input
                class="admin-input"
                type="number"
                id="search-per-page"
                name="per_page"
                min="{{ search_min_per_page }}"
                max="{{ search_max_per_page }}"
                value="{{ search_per_page }}"
              />
              <p class="admin-hint">Paginated results on the public search page.</p>
            </div>
          </div>
        </section>

        <section id="search-types" class="admin-card admin-settings-card admin-settings-section" tabindex="-1">
          <header class="admin-settings-card-head-row">
            <div>
              <h2 class="admin-settings-card-title">Searchable content types</h2>
              <p class="admin-settings-card-desc" style="margin-bottom:0">
                Only types with a public route can appear here. Anything unchecked is invisible to search — even if entries are published.
              </p>
            </div>
            {% if total_types > 0 %}
              <span class="admin-pill{% if enabled_types == 0 %} admin-pill--warn{% endif %}">{{ enabled_types }} selected</span>
            {% endif %}
          </header>

          {% if search_type_rows is empty %}
            <div class="admin-callout admin-callout--warn" style="margin-top:0.85rem">
              <p class="admin-callout-title">No public content types yet</p>
              <p class="admin-prose">
                Enable a content type's public route under
                <a class="admin-link" href="{{ url_for('admin.content_types.index') }}">Content → Content types</a>,
                then return here to include it in search.
              </p>
            </div>
          {% else %}
            <div class="admin-search-type-grid" role="group" aria-label="Searchable content types">
              {% for t in search_type_rows %}
                <label class="admin-search-type-card{% if t.enabled %} is-selected{% endif %}">
                  <input type="checkbox" name="type_ids[]" value="{{ t.id }}" {% if t.enabled %}checked{% endif %} />
                  <span class="admin-search-type-card-body">
                    <strong class="admin-search-type-name">{{ t.name|e }}</strong>
                    <span class="admin-search-type-slug">/{{ t.slug|e }}</span>
                  </span>
                </label>
              {% endfor %}
            </div>
            <p class="admin-hint admin-settings-card-footnote">
              Typical setup: enable search, then tick types like <em>Blog posts</em> or <em>Products</em>. Leave internal types (e.g. team members used only in blocks) unchecked.
            </p>
          {% endif %}
        </section>

        <section id="search-how" class="admin-card admin-settings-card admin-settings-section admin-search-how" tabindex="-1">
          <h2 class="admin-settings-card-title">How search behaves</h2>
          <p class="admin-settings-card-desc">What visitors see and what stays hidden.</p>
          <dl class="admin-search-how-dl">
            <div class="admin-search-how-row">
              <dt>What is searched</dt>
              <dd>Published <strong>content entries</strong> on the types you select. Entry title, SEO title, and meta description always match. Optional custom text fields when field matching is on.</dd>
            </div>
            <div class="admin-search-how-row">
              <dt>What is excluded</dt>
              <dd>Drafts, scheduled-future, deleted, or <code class="admin-inline-code">noindex</code> entries. Static <strong>pages</strong> are not included. Types without a public URL never appear.</dd>
            </div>
            <div class="admin-search-how-row">
              <dt>Visitor experience</dt>
              <dd>Public page at <code class="admin-inline-code">/search?q=…</code>. Queries must be 2–80 characters. Results show title, snippet, content type, and link. Paginated when there are more than your per-page limit.</dd>
            </div>
            <div class="admin-search-how-row">
              <dt>Safety limits</dt>
              <dd>Rate-limited per IP (30 searches/minute). Queries are sanitized; SQL uses prepared statements with escaped <code class="admin-inline-code">LIKE</code> wildcards. The search page is marked <code class="admin-inline-code">noindex</code> for robots.</dd>
            </div>
          </dl>
        </section>
      </div>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn-primary">Save settings</button>
        {% if search_enabled %}
          <a href="{{ url_for('public.search') }}" class="admin-link" target="_blank" rel="noopener">Preview /search ↗</a>
        {% endif %}
      </div>
    </form>
  </div>
{% endblock %}
