{% extends 'admin/base.twig' %}

{% block admin_title %}Mobile app{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Mobile app</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">Configure the public bootstrap API used by the Struxa client app when someone adds this site URL.</p>
{% endblock %}

{% block admin_hero_actions %}
  {% if mobile_enabled %}
    <a class="admin-btn-ghost" href="{{ mobile_bootstrap_url|e('html_attr') }}" target="_blank" rel="noopener">Open bootstrap JSON</a>
  {% endif %}
{% endblock %}

{% block admin_breadcrumbs %}
  {% include 'admin/partials/_breadcrumbs.twig' with {
    breadcrumbs: [
      { label: 'Site', href: url_for('admin.settings') },
      { label: 'Mobile app' },
    ],
  } %}
{% endblock %}

{% block admin_content %}
  <div class="admin-settings-page admin-settings-page--mobile">
    <div class="admin-settings-intro admin-settings-intro--mobile">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect x="5" y="2" width="14" height="20" rx="2" />
          <path d="M12 18h.01" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">What this does</p>
        <p class="admin-settings-intro-text">
          The Struxa mobile app loads <code class="admin-inline-code">GET /api/v1/mobile/bootstrap</code> after a user enters your site URL.
          The response includes branding, feature flags, navigation, and content types — no API key required.
          Discovery is also available at <code class="admin-inline-code">/.well-known/struxa.json</code>.
        </p>
      </div>
      {% if mobile_enabled %}
        <span class="admin-pill admin-pill--ok">Bootstrap live</span>
      {% else %}
        <span class="admin-pill">Disabled</span>
      {% endif %}
    </div>

    <div class="admin-metrics admin-hub-metrics" aria-label="Mobile app summary">
      <article class="admin-metric{% if mobile_enabled %} admin-metric--health-good{% endif %}">
        <p class="admin-metric-label">Bootstrap API</p>
        <p class="admin-metric-value admin-metric-value--sm">{{ mobile_enabled ? 'On' : 'Off' }}</p>
        <p class="admin-metric-meta">Public JSON for client apps</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Content types</p>
        <p class="admin-metric-value">{{ mobile_preview.content_types|default([])|length }}</p>
        <p class="admin-metric-meta">With public routes</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Tab bar</p>
        <p class="admin-metric-value">{{ mobile_preview.mobile.tabs|default([])|length }}</p>
        <p class="admin-metric-meta">Default or custom tabs</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Schema</p>
        <p class="admin-metric-value admin-metric-value--sm">v{{ mobile_preview.schema_version|default(1) }}</p>
        <p class="admin-metric-meta">Bootstrap payload version</p>
      </article>
    </div>

    <nav class="admin-settings-toc" aria-label="Mobile app settings sections">
      <a class="admin-settings-toc-link" href="#mobile-general">General</a>
      <a class="admin-settings-toc-link" href="#mobile-copy">Welcome copy</a>
      <a class="admin-settings-toc-link" href="#mobile-advanced">Advanced</a>
      <a class="admin-settings-toc-link" href="#mobile-endpoints">Endpoints</a>
    </nav>

    <form method="post" action="{{ url_for('admin.settings.mobile.save') }}" class="admin-form admin-settings-form">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />

      <div class="admin-settings-stack">
        <section id="mobile-general" class="admin-card admin-settings-card admin-settings-section" tabindex="-1">
          <h2 class="admin-settings-card-title">General</h2>
          <p class="admin-settings-card-desc">Turn the bootstrap endpoint on or off for client apps connecting to this site.</p>
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="enabled" value="1" {% if mobile_enabled %}checked{% endif %} />
                Enable mobile app bootstrap
              </label>
              <p class="admin-hint">When off, bootstrap and well-known discovery return 403/404. Existing REST/GraphQL APIs are unchanged.</p>
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="include_footer_nav" value="1" {% if mobile_include_footer_nav %}checked{% endif %} />
                Include footer menu in bootstrap navigation
              </label>
              <p class="admin-hint">Header menu is always included. Footer is optional for secondary links.</p>
            </div>
          </div>
        </section>

        <section id="mobile-copy" class="admin-card admin-settings-card admin-settings-section" tabindex="-1">
          <h2 class="admin-settings-card-title">Welcome copy</h2>
          <p class="admin-settings-card-desc">Optional overrides for the in-app welcome screen. Leave blank to use site name and tagline from Site settings.</p>
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="mobile-welcome-title">Welcome title</label>
              <input class="admin-input" type="text" id="mobile-welcome-title" name="welcome_title" maxlength="120" value="{{ mobile_welcome_title|e('html_attr') }}" placeholder="Uses site name when empty" />
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="mobile-welcome-message">Welcome message</label>
              <textarea class="admin-textarea" id="mobile-welcome-message" name="welcome_message" rows="3" maxlength="500" placeholder="Uses site tagline when empty">{{ mobile_welcome_message|e }}</textarea>
            </div>
          </div>
        </section>

        <section id="mobile-advanced" class="admin-card admin-settings-card admin-settings-section" tabindex="-1">
          <h2 class="admin-settings-card-title">Tab bar (advanced)</h2>
          <p class="admin-settings-card-desc">Optional JSON override for bottom tabs. Leave empty for automatic tabs based on commerce, search, and content types.</p>
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="mobile-tabs-json">Custom tabs JSON</label>
              <textarea class="admin-textarea admin-textarea--mono" id="mobile-tabs-json" name="tabs_json" rows="6" placeholder='[{"id":"home","label":"Home","type":"home"},{"id":"shop","label":"Shop","type":"shop"}]'>{{ mobile_tabs_json|e }}</textarea>
              <p class="admin-hint">Each tab needs <code class="admin-inline-code">id</code>, <code class="admin-inline-code">label</code>, and <code class="admin-inline-code">type</code> (e.g. home, content, search, shop). Max 8 tabs.</p>
            </div>
          </div>
        </section>

        <section id="mobile-endpoints" class="admin-card admin-settings-card admin-settings-section" tabindex="-1">
          <h2 class="admin-settings-card-title">Endpoints</h2>
          <p class="admin-settings-card-desc">Use these URLs when testing with the Struxa client app or curl.</p>
          <dl class="admin-search-how-dl">
            <div class="admin-search-how-row">
              <dt>Bootstrap</dt>
              <dd><code class="admin-inline-code">{{ mobile_bootstrap_url|e }}</code></dd>
            </div>
            <div class="admin-search-how-row">
              <dt>Discovery</dt>
              <dd><code class="admin-inline-code">{{ mobile_well_known_url|e }}</code></dd>
            </div>
            <div class="admin-search-how-row">
              <dt>REST API</dt>
              <dd><code class="admin-inline-code">{{ mobile_bootstrap_url|replace({'/api/v1/mobile/bootstrap': '/api/v1'})|e }}</code> — requires API key (Phase 3+)</dd>
            </div>
          </dl>
          {% if mobile_preview %}
            <details class="admin-details" style="margin-top:1rem">
              <summary class="admin-details-summary">Preview current bootstrap payload</summary>
              <pre class="admin-code-block admin-code-block--scroll" style="margin-top:0.75rem; max-height:24rem;">{{ mobile_preview_json|e }}</pre>
            </details>
          {% endif %}
        </section>
      </div>

      <div class="admin-form-actions">
        <button type="submit" class="admin-btn-primary">Save settings</button>
        {% if mobile_enabled %}
          <a href="{{ mobile_bootstrap_url|e('html_attr') }}" class="admin-link" target="_blank" rel="noopener">Preview JSON ↗</a>
        {% endif %}
      </div>
    </form>
  </div>
{% endblock %}
