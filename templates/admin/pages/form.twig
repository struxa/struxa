{% extends 'admin/base.twig' %}

{% set is_edit = form_mode == 'edit' %}
{% set f_title = old is not null ? old.title : (page ? page.title : '') %}
{% set f_slug = old is not null ? old.slug : (page ? page.slug : '') %}
{% set f_content = old is not null ? old.content : (page ? page.content : '') %}
{% set f_status = old is not null ? old.status : (page ? page.status : 'draft') %}
{% set f_seo_title = old is not null ? old.seo_title|default('') : (page ? page.seoTitle|default('') : '') %}
{% set f_seo_desc = old is not null ? old.seo_description|default('') : (page ? page.seoDescription|default('') : '') %}
{% set f_tags = old is not null ? old.tags|default('') : (page ? page.tagsEditString() : '') %}
{% set page_pub_raw = old is not null ? old.published_at|default('') : (page ? (page.publishedAt ?? '') : '') %}
{% set page_sched_pub_raw = old is not null ? old.scheduled_publish_at|default('') : (page ? (page.scheduledPublishAt ?? '') : '') %}
{% set page_sched_unpub_raw = old is not null ? old.scheduled_unpublish_at|default('') : (page ? (page.scheduledUnpublishAt ?? '') : '') %}
{% set page_pub_dt = page_pub_raw ? page_pub_raw|replace({' ': 'T'})|slice(0, 16) : '' %}
{% set page_sched_pub_dt = page_sched_pub_raw ? page_sched_pub_raw|replace({' ': 'T'})|slice(0, 16) : '' %}
{% set page_sched_unpub_dt = page_sched_unpub_raw ? page_sched_unpub_raw|replace({' ': 'T'})|slice(0, 16) : '' %}
{% set f_comments_disabled = old is not null ? old.comments_disabled|default(false) : (page ? page.commentsDisabled : false) %}
{% set f_fid = '' %}
{% if old is not null %}
  {% set f_fid = (old.featured_image_id_typed|default('')|trim != '') ? old.featured_image_id_typed : (old.featured_image_id ?? '') %}
{% elseif page is not null and page.featuredImageId is not null %}
  {% set f_fid = page.featuredImageId %}
{% endif %}
{% set wf = workflow_statuses|default(['draft','in_review','approved','published','archived']) %}
{% set seo_ctx = {
  canonical_url: old is not null ? old.canonical_url|default('') : (page ? page.canonicalUrl|default('') : ''),
  seo_noindex: old is not null ? old.seo_noindex|default(false) : (page ? page.seoNoindex : false),
  og_title: old is not null ? old.og_title|default('') : (page ? page.ogTitle|default('') : ''),
  og_description: old is not null ? old.og_description|default('') : (page ? page.ogDescription|default('') : ''),
  og_image_id: old is not null ? old.og_image_id|default('') : (page and page.ogImageId ? page.ogImageId : ''),
  twitter_title: old is not null ? old.twitter_title|default('') : (page ? page.twitterTitle|default('') : ''),
  twitter_description: old is not null ? old.twitter_description|default('') : (page ? page.twitterDescription|default('') : ''),
  twitter_image_id: old is not null ? old.twitter_image_id|default('') : (page and page.twitterImageId ? page.twitterImageId : ''),
  schema_json: old is not null ? old.schema_json|default('') : (page ? page.schemaJson|default('') : ''),
  focus_keyphrase: old is not null ? old.focus_keyphrase|default('') : (page ? page.focusKeyphrase|default('') : '')
} %}

{% block admin_title %}{{ is_edit ? 'Edit page' : 'New page' }}{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ is_edit ? 'Edit page' : 'New page' }}</h1>
{% endblock %}

{% block admin_hero_sub %}{% endblock %}

{% block admin_breadcrumbs %}
  {% set _page_label = is_edit ? (f_title|default('Page')|length > 48 ? f_title|slice(0, 45) ~ '…' : f_title) : 'New page' %}
  {% include 'admin/partials/_breadcrumbs.twig' with {
    breadcrumbs: [
      { label: 'Pages', url: url_for('admin.pages.index') },
      { label: _page_label },
    ],
  } %}
{% endblock %}

{% block admin_content %}
  {% if is_edit %}
    {% include 'admin/partials/_edit_session.twig' %}
  {% endif %}
  <div class="admin-page-edit-layout">
    <div class="admin-page-edit-main admin-page-edit-main--composed">
      <form id="page-edit-form" class="admin-form admin-form--wide admin-form--page-aside-inner admin-page-edit-form--composed" method="post" action="{{ is_edit ? url_for('admin.pages.update', { id: page.id }) : url_for('admin.pages.store') }}">
        <div class="admin-page-edit-title-slug admin-page-edit--order-title">
          <div class="admin-field admin-field--full {{ errors.title is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="page-title">Title <span class="admin-req">*</span></label>
            <input class="admin-input" id="page-title" name="title" type="text" maxlength="255" value="{{ f_title|e }}" required />
            {% if errors.title is defined %}<p class="admin-field-error">{{ errors.title|e }}</p>{% endif %}
          </div>
          <div class="admin-field admin-field--full {{ errors.slug is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="page-slug">Slug</label>
            <input class="admin-input" id="page-slug" name="slug" type="text" value="{{ f_slug|e }}" placeholder="auto from title" autocomplete="off" />
            <p class="admin-hint">Lowercase, numbers, hyphens. Blank = from title.</p>
            {% if errors.slug is defined %}<p class="admin-field-error">{{ errors.slug|e }}</p>{% endif %}
          </div>
        </div>

        <div class="admin-field admin-field--full admin-page-edit--order-editor {{ errors.content is defined ? 'admin-field--error' : '' }}">
          <label class="admin-label" for="page-content">Body content</label>
          <p class="admin-hint admin-editor-hint-visual" style="margin-top:0">Optional if the page uses the <strong>Page builder</strong> below. Tip: select text for the floating bar; <strong>Formats → Paragraph styles</strong> for lead and callout blocks; paste a YouTube or X (Twitter) URL on its own line to embed it, or use <em>Insert → Media</em>.</p>
          <p class="admin-hint admin-editor-hint-html" style="margin-top:0;display:none" hidden>Raw HTML — switches back to <strong>Rich text</strong> to use the visual toolbar. Save works in either mode.</p>
          <div class="admin-page-editor" id="page-editor-root">
            <div class="admin-editor-mode-bar">
              <span class="admin-editor-mode-label" id="editor-mode-label">Body</span>
              <div class="admin-editor-mode-toggle" role="tablist" aria-labelledby="editor-mode-label">
                <button type="button" class="admin-editor-mode-btn is-active" role="tab" id="editor-mode-visual" aria-selected="true" aria-controls="page-editor-surface" data-editor-mode="visual">Rich text</button>
                <button type="button" class="admin-editor-mode-btn" role="tab" id="editor-mode-html" aria-selected="false" aria-controls="page-editor-surface" data-editor-mode="html">HTML source</button>
              </div>
              {% if media_picker_enabled|default(false) %}
                <button type="button" class="admin-btn-ghost admin-editor-media-btn" id="admin-page-media-open" title="Upload or choose from library">
                  <svg class="admin-editor-media-btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <path d="M21 15l-5-5L5 21" />
                  </svg>
                  Media library
                </button>
              {% endif %}
            </div>
            <div class="admin-page-editor-surface" id="page-editor-surface">
              <textarea class="admin-textarea admin-textarea--rte" id="page-content" name="content" rows="20">{{ f_content|e }}</textarea>
            </div>
          </div>
          {% if errors.content is defined %}<p class="admin-field-error">{{ errors.content|e }}</p>{% endif %}
        </div>

        {% set seo_errors_open = errors.seo_title is defined or errors.seo_description is defined or errors.focus_keyphrase is defined or errors.tags is defined or errors.canonical_url is defined or errors.seo_noindex is defined or errors.og_title is defined or errors.og_description is defined or errors.og_image_id is defined or errors.twitter_title is defined or errors.twitter_description is defined or errors.twitter_image_id is defined or errors.schema_json is defined or errors.published_at is defined or errors.scheduled_publish_at is defined or errors.scheduled_unpublish_at is defined %}
        {% set seo_extended_errors_open = errors.canonical_url is defined or errors.seo_noindex is defined or errors.og_title is defined or errors.og_description is defined or errors.og_image_id is defined or errors.twitter_title is defined or errors.twitter_description is defined or errors.twitter_image_id is defined or errors.schema_json is defined %}
        <details class="admin-card admin-seo-suite-panel admin-page-edit-seo admin-page-edit--order-seo"{% if seo_errors_open %} open{% endif %} aria-labelledby="page-seo-heading">
          <summary class="admin-seo-suite-summary">
            <span class="admin-card-title" id="page-seo-heading" style="margin:0;display:inline">SEO &amp; tags</span>
            <span class="admin-hint" style="margin-left:0.5rem;font-weight:400">Title, snippet, tags, and social metadata</span>
          </summary>
          <div class="admin-seo-suite-body" style="margin-top:1rem">
            <p class="admin-hint" style="margin-top:0">Optional. Empty SEO fields fall back to the page title and a short excerpt from the body. Tags are stored as slugs (comma-separated); they appear on the public page and in a <code class="admin-inline-code">keywords</code> meta tag.</p>
            <div class="admin-form-grid" style="margin-top: 1rem">
              <div class="admin-field admin-field--full {{ errors.seo_title is defined ? 'admin-field--error' : '' }}">
                <label class="admin-label" for="page-seo-title">SEO title</label>
                <input class="admin-input" id="page-seo-title" name="seo_title" type="text" maxlength="255" value="{{ f_seo_title|e }}" placeholder="Override &lt;title&gt; (optional)" />
                {% if errors.seo_title is defined %}<p class="admin-field-error">{{ errors.seo_title|e }}</p>{% endif %}
              </div>
              <div class="admin-field admin-field--full {{ errors.seo_description is defined ? 'admin-field--error' : '' }}">
                <label class="admin-label" for="page-seo-desc">SEO description</label>
                <textarea class="admin-textarea" id="page-seo-desc" name="seo_description" rows="2" maxlength="500" placeholder="Search snippet (optional)">{{ f_seo_desc|e }}</textarea>
                {% if errors.seo_description is defined %}<p class="admin-field-error">{{ errors.seo_description|e }}</p>{% endif %}
              </div>
              <div class="admin-field admin-field--full {{ errors.tags is defined ? 'admin-field--error' : '' }}">
                <label class="admin-label" for="page-tags">Tags</label>
                <input class="admin-input" id="page-tags" name="tags" type="text" value="{{ f_tags|e }}" maxlength="2000" placeholder="e.g. Product, Company news, Launch" autocomplete="off" />
                <p class="admin-hint">Comma-separated. Slugs are generated automatically (max {{ constant('App\\Page\\PageTagParser::MAX_TAGS') }} tags).</p>
                {% if errors.tags is defined %}<p class="admin-field-error">{{ errors.tags|e }}</p>{% endif %}
              </div>
            </div>
            {% include 'admin/seo/_analysis_panel.twig' with {
              seo_ctx: seo_ctx,
              errors: errors,
              seo_analysis_ctx: {
                focus_keyphrase: seo_ctx.focus_keyphrase,
                site_url: site_url|default(''),
                path_prefix: '/p/' ~ (f_slug|default('')),
                entity_kind: 'page',
                entity_id: is_edit ? page.id : ''
              }
            } %}
            {% include 'admin/seo/_extended_panel.twig' with { seo_ctx: seo_ctx, errors: errors, media_images: seo_media_select|default([]), include_basic_seo: false, panel_open: seo_extended_errors_open } %}
          </div>
        </details>
      </form>

      <details id="page-builder" class="admin-card admin-seo-suite-panel admin-page-edit-builder admin-page-edit--order-builder"{% if is_edit %} open{% endif %} aria-label="Page builder">
        <summary class="admin-seo-suite-summary">
          <span class="admin-card-title" style="margin:0;display:inline">Page builder</span>
          <span class="admin-hint" style="margin-left:0.5rem;font-weight:400">Blocks &amp; layout</span>
        </summary>
        <div class="admin-seo-suite-body" style="margin-top:1rem">
          {% if is_edit %}
            {% include 'admin/pages/_builder_panel.twig' with {
              page: page,
              section_rows: page_builder_section_rows,
              section_palette: page_builder_section_palette,
              section_palette_grouped: page_builder_section_palette_grouped,
              section_labels: page_builder_section_labels,
              section_icons: page_builder_section_icons,
              page_builder_section_patterns: page_builder_section_patterns|default([]),
              page_builder_host: page_builder_host|default('page'),
              builder_panel_standalone: false,
            } %}
          {% else %}
            <p class="admin-hint" style="margin:0">Save the page once to add and reorder sections here.</p>
          {% endif %}
        </div>
      </details>

      <div class="admin-sticky-save-bar" role="region" aria-label="Save page">
        <div class="admin-sticky-save-inner">
          <button type="submit" form="page-edit-form" class="admin-btn-primary" data-admin-save-primary name="after_save" value="stay">{{ is_edit ? 'Save changes' : 'Create page' }}</button>
          <button type="submit" form="page-edit-form" class="admin-btn-ghost admin-sticky-save-view" name="after_save" value="view" title="Save and open the live page when published">Save &amp; view</button>
        </div>
      </div>
    </div>

      <aside class="admin-page-edit-aside" aria-label="Page details">
        <div class="admin-card admin-page-edit-aside-card">
          <h2 class="admin-card-title" style="margin-bottom: 1rem; font-size: 0.8125rem">Page details</h2>
          <div class="admin-page-featured {{ errors.featured_image_id is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label admin-page-featured-label" for="page-featured-picker-trigger">Featured image</label>
            <input type="hidden" form="page-edit-form" name="featured_image_id" id="page-featured-image-id" value="{{ f_fid|e('html_attr') }}" autocomplete="off" />
            <button type="button" class="admin-page-featured-hit" id="page-featured-picker-trigger" {% if not media_picker_enabled|default(false) %}disabled title="Requires Manage media permission"{% else %}title="Open media library to upload or choose an image"{% endif %} aria-label="Choose featured image from media library">
              <span class="admin-page-featured-placeholder" id="page-featured-placeholder"{% if page_edit_featured_url|default('')|trim != '' %} hidden{% endif %}>
                <span class="admin-page-featured-placeholder-art" aria-hidden="true"></span>
                <span class="admin-page-featured-placeholder-title">No featured image</span>
                <span class="admin-page-featured-placeholder-sub">{% if media_picker_enabled|default(false) %}Click to upload or choose from library{% else %}Assign <strong>Manage media</strong> to enable the library here{% endif %}</span>
              </span>
              <img id="page-featured-preview" class="admin-page-featured-preview" {% if page_edit_featured_url|default('')|trim != '' %}src="{{ page_edit_featured_url|e('html_attr') }}" {% endif %}alt="" width="640" height="360"{% if page_edit_featured_url|default('')|trim != '' %} loading="lazy" decoding="async"{% endif %}{% if page_edit_featured_url|default('')|trim == '' %} hidden{% endif %} />
            </button>
            {% if media_picker_enabled|default(false) %}
              <button type="button" class="admin-link admin-page-featured-clear" id="page-featured-clear">Remove image</button>
            {% endif %}
            {% if errors.featured_image_id is defined %}<p class="admin-field-error">{{ errors.featured_image_id|e }}</p>{% endif %}
            {% if not media_picker_enabled|default(false) %}
              <p class="admin-hint admin-page-featured-hint">Assign <strong>Manage media</strong> to use the library here.</p>
            {% endif %}
          </div>

          <div class="admin-field {{ errors.status is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="page-status">Status <span class="admin-req">*</span></label>
            <select class="admin-select" id="page-status" name="status" form="page-edit-form" required>
              {% for s in wf %}
                <option value="{{ s|e }}" {{ f_status == s ? 'selected' : '' }}>{{ s|replace({'_': ' '})|title }}</option>
              {% endfor %}
            </select>
            {% if errors.status is defined %}<p class="admin-field-error">{{ errors.status|e }}</p>{% endif %}
          </div>

          <div class="admin-field admin-field--full">
            <label class="admin-check">
              <input type="checkbox" name="comments_disabled" value="1" form="page-edit-form" {{ f_comments_disabled ? 'checked' : '' }} />
              <span>Disable comments on this page</span>
            </label>
            <p class="admin-hint">Only applies when public comments are enabled under System → Comments.</p>
          </div>

          <div class="admin-field admin-field--full {{ errors.published_at is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="page-published-at">Published at</label>
            <input class="admin-input" id="page-published-at" name="published_at" type="datetime-local" value="{{ page_pub_dt|e('html_attr') }}" form="page-edit-form" />
            <p class="admin-hint">Optional. When set in the future, the page stays hidden from the public site until that time (embargo).</p>
            {% if errors.published_at is defined %}<p class="admin-field-error">{{ errors.published_at|e }}</p>{% endif %}
          </div>
          <div class="admin-field admin-field--full {{ errors.scheduled_publish_at is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="page-sched-pub">Schedule publish</label>
            <input class="admin-input" id="page-sched-pub" name="scheduled_publish_at" type="datetime-local" value="{{ page_sched_pub_dt|e('html_attr') }}" form="page-edit-form" />
            <p class="admin-hint">Optional. When the clock passes this time, status moves to published automatically (cron or web traffic). Clear when not needed.</p>
            {% if errors.scheduled_publish_at is defined %}<p class="admin-field-error">{{ errors.scheduled_publish_at|e }}</p>{% endif %}
          </div>
          <div class="admin-field admin-field--full {{ errors.scheduled_unpublish_at is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="page-sched-unpub">Schedule unpublish</label>
            <input class="admin-input" id="page-sched-unpub" name="scheduled_unpublish_at" type="datetime-local" value="{{ page_sched_unpub_dt|e('html_attr') }}" form="page-edit-form" />
            <p class="admin-hint">Optional. When published, the page returns to draft at this time. Run <code class="admin-inline-code">php bin/cms.php schedule:run</code> on a timer for reliability.</p>
            {% if errors.scheduled_unpublish_at is defined %}<p class="admin-field-error">{{ errors.scheduled_unpublish_at|e }}</p>{% endif %}
          </div>

          <div class="admin-page-edit-aside-actions">
            <button class="admin-btn-primary" type="submit" form="page-edit-form" data-admin-save-primary name="after_save" value="stay">{{ is_edit ? 'Save changes' : 'Create page' }}</button>
            <button type="submit" form="page-edit-form" class="admin-btn-ghost" name="after_save" value="view">Save &amp; view</button>
            <button type="button" class="admin-btn-ghost" id="page-preview-btn" form="page-edit-form" data-preview-url="{{ is_edit ? url_for('admin.pages.preview', { id: page.id }) : url_for('admin.pages.preview_new') }}">Preview in new tab</button>
            <a class="admin-btn-ghost admin-page-edit-aside-cancel" href="{{ url_for('admin.pages.index') }}">Back to list</a>
          </div>
        </div>

        {% if is_edit %}
          <div class="admin-card admin-page-edit-aside-card admin-page-edit-revisions-card">
            <h2 class="admin-card-title admin-page-edit-revisions-title">Recent revisions</h2>
            {% set rev_preview = page_edit_revisions_preview|default([]) %}
            {% if rev_preview is empty %}
              <p class="admin-hint admin-page-edit-revisions-empty">No revisions stored yet. Saving the page creates a snapshot you can compare or restore.</p>
            {% else %}
              <ul class="admin-page-edit-revisions-list">
                {% for row in rev_preview %}
                  <li class="admin-page-edit-revisions-item">
                    <div class="admin-page-edit-revisions-meta">
                      <span class="admin-page-edit-revisions-when">{{ row.created_at|e }}</span>
                      <span class="admin-badge admin-badge--muted admin-page-edit-revisions-status">{{ row.status|e }}</span>
                    </div>
                    <div class="admin-page-edit-revisions-by">{{ row.author_email|default('—')|e }}</div>
                    <a class="admin-link admin-page-edit-revisions-compare" href="{{ url_for('admin.pages.revision_compare', { id: page.id }) }}?from={{ row.id }}&amp;to=current">Changes</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
            {% if page_edit_revisions_has_more|default(false) %}
              <a class="admin-btn-ghost admin-page-edit-revisions-more" href="{{ url_for('admin.pages.revisions', { id: page.id }) }}">Show more revisions</a>
            {% elseif rev_preview is not empty %}
              <a class="admin-link admin-page-edit-revisions-all" href="{{ url_for('admin.pages.revisions', { id: page.id }) }}">View all revisions</a>
            {% endif %}
          </div>

          <div class="admin-card admin-page-edit-aside-card admin-page-edit-preview-card">
            <h2 class="admin-card-title admin-page-edit-revisions-title">Stakeholder preview</h2>
            <p class="admin-hint">Time-limited public link for this page (saved content only). The full URL appears once in the green banner after you generate it.</p>
            <form method="post" action="{{ url_for('admin.pages.preview_link', { id: page.id }) }}" style="margin-top:0.5rem">
              <div class="admin-field">
                <label class="admin-label" for="page-preview-ttl">Link lifetime</label>
                <select class="admin-select" id="page-preview-ttl" name="preview_link_ttl">
                  <option value="3600">1 hour</option>
                  <option value="86400" selected>24 hours</option>
                  <option value="604800">7 days</option>
                </select>
              </div>
              <button type="submit" class="admin-btn-ghost" style="margin-top:0.5rem">Generate preview link</button>
            </form>
          </div>
        {% endif %}
      </aside>
  </div>

  {% if media_picker_enabled|default(false) %}
    <script type="application/json" id="admin-page-media-picker-config">{{ {
      enabled: true,
      csrfToken: csrf_token(),
      listUrl: url_for('admin.media.api.images'),
      uploadUrl: url_for('admin.media.api.upload'),
      maxMb: media_picker_max_mb|default(5),
      textareaId: 'page-content',
      initialImages: media_picker_initial|default([]),
      featuredImage: {
        inputId: 'page-featured-image-id',
        previewId: 'page-featured-preview',
        placeholderId: 'page-featured-placeholder',
        triggerId: 'page-featured-picker-trigger',
        clearId: 'page-featured-clear'
      }
    }|json_encode|raw }}</script>

    <div id="admin-page-media-modal" class="admin-media-modal" hidden role="dialog" aria-modal="true" aria-labelledby="admin-page-media-title">
      <div class="admin-media-modal-backdrop" id="admin-page-media-backdrop"></div>
      <div class="admin-media-modal-panel">
        <header class="admin-media-modal-head">
          <h2 class="admin-media-modal-title" id="admin-page-media-title">Media library</h2>
          <button type="button" class="admin-media-modal-close" id="admin-page-media-close" aria-label="Close">×</button>
        </header>
        <div class="admin-media-modal-body">
          <div class="admin-media-modal-drop" id="admin-page-media-drop" tabindex="0" role="button" aria-label="Drop an image here or click to upload">
            <input type="file" id="admin-page-media-file" class="admin-media-modal-file" accept="image/jpeg,image/png,image/webp,image/gif" hidden />
            <p class="admin-media-modal-drop-title">Drop image here</p>
            <p class="admin-media-modal-drop-hint">or click to browse · JPG, PNG, WebP, GIF · max {{ media_picker_max_mb|default(5) }} MB</p>
          </div>
          <p class="admin-media-modal-status" id="admin-page-media-status" role="status"></p>
          <div class="admin-media-modal-toolbar">
            <button type="button" class="admin-btn-ghost admin-btn-ghost--sm" id="admin-page-media-refresh">Refresh list</button>
          </div>
          <div class="admin-media-modal-grid" id="admin-page-media-grid"></div>
        </div>
      </div>
    </div>
  {% endif %}
{% endblock %}

{% block admin_scripts %}
  <script>window.CMS_RICHTEXT_OEMBED_URL = {{ url_for('admin.richtext.oembed')|json_encode|raw }};</script>
  <script src="/js/admin-rich-text-oembed.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tinymce@7.9.2/tinymce.min.js" referrerpolicy="origin"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var taId = 'page-content';
      var ta = document.getElementById(taId);
      if (!ta || typeof tinymce === 'undefined') return;

      var surface = document.getElementById('page-editor-surface');
      var btnVisual = document.getElementById('editor-mode-visual');
      var btnHtml = document.getElementById('editor-mode-html');
      if (!surface || !btnVisual || !btnHtml) return;
      var hintVisual = document.querySelector('.admin-editor-hint-visual');
      var hintHtml = document.querySelector('.admin-editor-hint-html');
      var form = document.getElementById('page-edit-form') || ta.closest('form');
      /* Only the first TinyMCE init should sync the “clean” baseline — re-init after HTML mode must not clear real edits. */
      var cmsUxTinyBaselineOnce = false;

      function showHints(isHtml) {
        if (hintVisual) {
          hintVisual.style.display = isHtml ? 'none' : '';
          if (isHtml) hintVisual.setAttribute('hidden', '');
          else hintVisual.removeAttribute('hidden');
        }
        if (hintHtml) {
          hintHtml.style.display = isHtml ? '' : 'none';
          if (isHtml) hintHtml.removeAttribute('hidden');
          else hintHtml.setAttribute('hidden', '');
        }
      }

      function getConfig() {
        var cfg = {
          license_key: 'gpl',
          base_url: 'https://cdn.jsdelivr.net/npm/tinymce@7.9.2',
          suffix: '.min',
          selector: '#' + taId,
          promotion: false,
          branding: false,
          skin: 'oxide-dark',
          content_css: ['/css/tinymce-content.css'],
          content_style: 'html{background:#12161f!important;}body.mce-content-body,body{background:#12161f!important;color:#e4e4e7!important;}',
          min_height: 520,
          max_height: 960,
          menubar: 'edit insert view format tools table help',
          statusbar: true,
          resize: true,
          browser_spellcheck: true,
          link_context_toolbar: true,
          image_advtab: true,
          image_caption: false,
          object_resizing: true,
          resize_img_proportional: true,
          table_toolbar: 'tableprops tabledelete | tableinsertrowbefore tableinsertrowafter tabledeleterow | tableinsertcolbefore tableinsertcolafter tabledeletecol',
          table_appearance_options: true,
          table_grid: true,
          table_advtab: true,
          table_cell_advtab: true,
          table_row_advtab: true,
          table_resize_bars: true,
          table_default_attributes: { border: '1' },
          table_default_styles: { 'border-collapse': 'collapse', width: '100%' },
          media_live_embeds: true,
          media_alt_source: false,
          paste_data_images: false,
          relative_urls: false,
          remove_script_host: false,
          convert_urls: true,
          link_default_target: '_blank',
          link_default_protocol: 'https',
          importcss_append: true,
          importcss_selector_filter: /\.cms-/,
          quickbars_selection_toolbar: 'bold italic underline | styles | quicklink | alignleft aligncenter alignright | bullist numlist | blockquote removeformat',
          quickbars_insert_toolbar: 'image media quicktable | hr accordion | codesample charmap',
          contextmenu: 'link image table',
          block_formats: 'Paragraph=p; Heading 1=h1; Heading 2=h2; Heading 3=h3; Heading 4=h4; Heading 5=h5; Heading 6=h6; Preformatted=pre',
          style_formats_merge: true,
          style_formats: [
            {
              title: 'Paragraph styles',
              items: [
                { title: 'Lead / intro', selector: 'p', classes: 'cms-intro' },
                { title: 'Callout box', block: 'div', classes: 'cms-callout', wrapper: true },
                { title: 'Caption line', inline: 'span', classes: 'cms-caption' },
              ],
            },
          ],
          plugins: [
            'accordion', 'advlist', 'anchor', 'autolink', 'autoresize', 'autosave', 'charmap', 'code', 'codesample',
            'directionality', 'emoticons', 'fullscreen', 'help', 'image', 'importcss', 'insertdatetime', 'link', 'lists',
            'media', 'nonbreaking', 'pagebreak', 'preview', 'quickbars', 'searchreplace', 'table', 'visualblocks',
            'visualchars', 'wordcount',
          ].join(' '),
          toolbar: [
            'undo redo | blocks | styles | bold italic underline strikethrough subscript superscript | forecolor backcolor | alignleft aligncenter alignright alignjustify',
            'bullist numlist outdent indent | link unlink anchor | image media | accordion | table tableprops tablemergecells | codesample | charmap emoticons nonbreaking hr pagebreak insertdatetime',
            'searchreplace | visualblocks visualchars | ltr rtl | preview | code fullscreen | removeformat | help',
          ].join(' | '),
          toolbar_mode: 'sliding',
          toolbar_sticky: true,
          /* Admin shell already guards navigation; TinyMCE’s prompt duplicates it and fights empty body + builder-only pages. */
          autosave_ask_before_unload: false,
          autosave_interval: '25s',
          autosave_retention: '2d',
          autosave_prefix: 'cms-page-{% if is_edit %}{{ page.id }}{% else %}new{% endif %}-',
          codesample_languages: [
            { text: 'HTML/XML', value: 'markup' },
            { text: 'JavaScript', value: 'javascript' },
            { text: 'CSS', value: 'css' },
            { text: 'PHP', value: 'php' },
            { text: 'JSON', value: 'json' },
            { text: 'SQL', value: 'sql' },
            { text: 'Bash', value: 'bash' },
            { text: 'Python', value: 'python' },
          ],
          emoticons_database: 'emojis',
          pagebreak_separator: '<!-- pagebreak -->',
          init_instance_callback: function () {
            if (cmsUxTinyBaselineOnce) return;
            cmsUxTinyBaselineOnce = true;
            requestAnimationFrame(function () {
              if (window.adminFormUx && typeof window.adminFormUx.clearDirtyForForm === 'function') {
                var f = document.getElementById('page-edit-form');
                if (f) window.adminFormUx.clearDirtyForForm(f);
              }
            });
          },
          setup: function (editor) {
            editor.on('change input undo redo', function () {
              editor.save();
            });
          },
        };
        if (window.cmsRichTextOembed && typeof window.cmsRichTextOembed.applyToConfig === 'function') {
          window.cmsRichTextOembed.applyToConfig(cfg);
        }
        return cfg;
      }

      function setMode(mode) {
        var isHtml = mode === 'html';
        if (isHtml) {
          var ed = tinymce.get(taId);
          if (ed) {
            ta.value = ed.getContent();
            ed.remove();
          }
          ta.style.display = 'block';
          ta.classList.add('admin-textarea--html-mode');
          if (surface) surface.classList.add('is-html-mode');
          btnVisual.classList.remove('is-active');
          btnHtml.classList.add('is-active');
          btnVisual.setAttribute('aria-selected', 'false');
          btnHtml.setAttribute('aria-selected', 'true');
          showHints(true);
          ta.focus();
        } else {
          if (surface) surface.classList.remove('is-html-mode');
          ta.classList.remove('admin-textarea--html-mode');
          ta.style.display = '';
          btnHtml.classList.remove('is-active');
          btnVisual.classList.add('is-active');
          btnVisual.setAttribute('aria-selected', 'true');
          btnHtml.setAttribute('aria-selected', 'false');
          showHints(false);
          if (!tinymce.get(taId)) {
            tinymce.init(getConfig());
          }
        }
      }

      btnVisual.addEventListener('click', function () {
        setMode('visual');
      });
      btnHtml.addEventListener('click', function () {
        setMode('html');
      });

      if (form) {
        form.addEventListener('submit', function () {
          var ed = tinymce.get(taId);
          if (ed) ed.save();
        });
      }

      showHints(false);
      tinymce.init(getConfig());
    });
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var btn = document.getElementById('page-preview-btn');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var url = btn.getAttribute('data-preview-url');
        if (!url) return;
        var form = document.getElementById('page-edit-form');
        if (!form) return;
        var taId = 'page-content';
        if (typeof tinymce !== 'undefined') {
          var ed = tinymce.get(taId);
          if (ed) ed.save();
        }
        var names = ['title', 'slug', 'content', 'status', 'seo_title', 'seo_description', 'tags', 'featured_image_id', 'canonical_url', 'seo_noindex', 'og_title', 'og_description', 'og_image_id', 'twitter_title', 'twitter_description', 'twitter_image_id', 'schema_json'];
        var f = document.createElement('form');
        f.method = 'post';
        f.action = url;
        f.target = '_blank';
        f.setAttribute('rel', 'noopener noreferrer');
        names.forEach(function (name) {
          var el = form.elements.namedItem(name);
          if (!el) return;
          var i = document.createElement('input');
          i.type = 'hidden';
          i.name = name;
          i.value = el.value;
          f.appendChild(i);
        });
        document.body.appendChild(f);
        f.submit();
        document.body.removeChild(f);
      });
    });
  </script>
  {% if media_picker_enabled|default(false) %}
    <script src="/js/admin-page-media-picker.js" defer></script>
  {% endif %}
  {% if is_edit %}
    <script src="{{ asset('js/admin-page-builder.js') }}" defer></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        if (location.hash !== '#page-builder') return;
        var d = document.getElementById('page-builder');
        if (d && d.tagName === 'DETAILS') d.open = true;
        d && d.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    </script>
  {% endif %}
{% endblock %}
