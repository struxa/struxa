{% extends 'admin/base.twig' %}

{% block admin_title %}Compare — {{ page.title|e }}{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">What changed?</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.pages.revisions', { id: page.id }) }}">← Revisions</a>
    · <a class="admin-link" href="{{ url_for('admin.pages.edit', { id: page.id }) }}">Edit page</a>
  </p>
  <p class="admin-hero-sub admin-revision-compare-labels">
    <span class="admin-revision-compare-from"><strong>From:</strong> {{ from_label|e }}{% if from_revision.author_email %} · {{ from_revision.author_email|e }}{% endif %}</span>
    <span class="admin-revision-compare-arrow" aria-hidden="true">→</span>
    <span class="admin-revision-compare-to"><strong>To:</strong> {{ to_label|e }}{% if to_revision and to_revision.author_email %} · {{ to_revision.author_email|e }}{% endif %}</span>
  </p>
{% endblock %}

{% block admin_content %}
  <div class="admin-settings-page admin-settings-page--portability">
    {% include 'admin/revisions/_compare_picker.twig' with {
      compare_form_action: compare_form_action,
      revision_rows: revision_rows,
      from_id: from_id,
      to_target: to_target
    } %}

    {% if not compare.has_changes %}
      <div class="admin-card admin-flash admin-flash--info" role="status">
        <p>No differences between these two versions for tracked fields.</p>
      </div>
    {% endif %}

    {% include 'admin/revisions/_changes_table.twig' with {
      metadata_changes: compare.metadata_changes,
      sections: compare.sections,
      change_count: compare.change_count,
      body_diff: compare.body_diff,
      body_diff_label: 'Body line diff'
    } %}

    <section class="admin-card admin-revision-restore-card">
      <h2 class="admin-settings-card-title">Restore older version</h2>
      <p class="admin-settings-card-desc">
        Roll back to the <strong>From</strong> snapshot ({{ from_label|e }}). The page as it is now is saved as a new revision first.
      </p>
      <form method="post" action="{{ url_for('admin.pages.revision_restore', { id: page.id, revId: restore_revision_id }) }}" onsubmit="return confirm('Restore the From version? Current content will be snapshotted, then replaced.');">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <div class="admin-form-actions">
          <button type="submit" class="admin-btn-primary">Restore this version</button>
          <a class="admin-btn-ghost" href="{{ url_for('admin.pages.edit', { id: page.id }) }}">Keep current</a>
        </div>
      </form>
    </section>
  </div>
{% endblock %}
