{% extends 'admin/base.twig' %}

{% block admin_title %}Revisions — {{ page.title|e }}{% endblock %}

{% block admin_hero_title %}<h1 class="admin-hero-title">Revisions</h1>{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.pages.edit', { id: page.id }) }}">← {{ page.title|e }}</a>
  </p>
{% endblock %}

{% block admin_content %}
  <div class="admin-card">
    {% if revision_rows is empty %}
      <p class="admin-hint">No revisions stored yet.</p>
    {% else %}
      <div class="admin-table-wrap">
        <p class="admin-hint" style="margin-bottom:0.75rem">Compare two saved revisions by opening one revision’s compare link and adding <code class="admin-inline-code">?other=</code> plus the other revision’s ID.</p>
        <table class="admin-table">
          <thead>
            <tr>
              <th>When</th>
              <th>Status</th>
              <th>Blocks</th>
              <th>By</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for row in revision_rows %}
              <tr>
                <td>{{ row.created_at|e }}</td>
                <td><span class="admin-badge admin-badge--muted">{{ row.status|e }}</span></td>
                <td class="admin-table-muted">
                  {% if row.section_count is not null %}
                    {{ row.section_count }} block{{ row.section_count == 1 ? '' : 's' }}
                  {% else %}
                    —
                  {% endif %}
                </td>
                <td class="admin-table-muted">{{ row.author_email|default('—')|e }}</td>
                <td>
                  <a class="admin-link" href="{{ url_for('admin.pages.revision_compare', { id: page.id, revId: row.id }) }}">Compare</a>
                  <form method="post" action="{{ url_for('admin.pages.revision_restore', { id: page.id, revId: row.id }) }}" style="display:inline;margin-left:0.75rem" onsubmit="return confirm('Restore this revision? Current content will be snapshotted first.');">
                    <button type="submit" class="admin-btn-ghost">Restore</button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
{% endblock %}
