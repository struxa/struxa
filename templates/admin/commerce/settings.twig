{% extends 'admin/base.twig' %}

{% block admin_title %}Commerce settings{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Commerce settings</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">Stripe Checkout, tax, shipping, and storefront options for your product content type.</p>
{% endblock %}

{% block admin_hero_actions %}
  <a class="admin-btn-ghost" href="{{ url_for('public.commerce.shop') }}" target="_blank" rel="noopener">View shop</a>
  <a class="admin-btn-primary" href="{{ url_for('admin.commerce.orders') }}">Orders</a>
{% endblock %}

{% block admin_content %}
  <div class="admin-settings-page admin-settings-page--commerce">
    <div class="admin-settings-intro admin-settings-intro--commerce">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <path d="M3 6h18" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">Sell content-type entries with Stripe</p>
        <p class="admin-settings-intro-text">
          Products use field keys <code class="admin-inline-code">price_cents</code>, <code class="admin-inline-code">purchasable</code>, optional <code class="admin-inline-code">stripe_price_id</code>, <code class="admin-inline-code">stock_qty</code>, and digital delivery fields. Import the <strong class="admin-settings-intro-strong">Product store</strong> blueprint or add fields manually.
        </p>
      </div>
    </div>

    <nav class="admin-settings-toc" aria-label="Commerce sections">
      <a class="admin-settings-toc-link" href="#commerce-store">Store</a>
      <a class="admin-settings-toc-link" href="#commerce-tax">Tax</a>
      <a class="admin-settings-toc-link" href="#commerce-shipping">Shipping</a>
      <a class="admin-settings-toc-link" href="#commerce-inventory">Inventory</a>
      <a class="admin-settings-toc-link" href="#commerce-shop">Shop page</a>
      <a class="admin-settings-toc-link" href="#commerce-stripe">Stripe</a>
      <a class="admin-settings-toc-link" href="{{ url_for('admin.commerce.coupons') }}">Coupons</a>
      <a class="admin-settings-toc-link" href="{{ url_for('admin.commerce.shipping_zones') }}">Shipping zones</a>
      <a class="admin-settings-toc-link" href="{{ url_for('admin.commerce.tax_rates') }}">Tax rates</a>
      <a class="admin-settings-toc-link" href="{{ url_for('admin.commerce.inventory') }}">Inventory report</a>
      <a class="admin-settings-toc-link" href="{{ url_for('admin.tools.blueprints') }}">Blueprints</a>
    </nav>

    <form class="admin-form admin-settings-form" method="post" action="{{ url_for('admin.commerce.settings.save') }}">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
      <div class="admin-settings-stack">
        <section id="commerce-store" class="admin-card admin-settings-card admin-settings-section" tabindex="-1">
          <h2 class="admin-settings-card-title">Store</h2>
          <p class="admin-settings-card-desc">Enable checkout and choose which content type holds your products.</p>
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="commerce_enabled" value="1" {% if commerce_enabled %}checked{% endif %} />
                Enable commerce (Stripe Checkout on product entries)
              </label>
            </div>
            <div class="admin-field">
              <label class="admin-label" for="commerce_product_type_slug">Product content type slug</label>
              <input class="admin-input" id="commerce_product_type_slug" name="commerce_product_type_slug" value="{{ commerce_product_type_slug|e('html_attr') }}" required pattern="[a-z0-9]+(?:-[a-z0-9]+)*" />
              <p class="admin-hint">Default: <code class="admin-inline-code">product</code>.</p>
            </div>
            <div class="admin-field">
              <label class="admin-label" for="commerce_currency">Default currency</label>
              <input class="admin-input" id="commerce_currency" name="commerce_currency" value="{{ commerce_currency|e('html_attr') }}" required maxlength="3" pattern="[a-z]{3}" />
              <p class="admin-hint">ISO code for Stripe prices (e.g. <code class="admin-inline-code">gbp</code>).</p>
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="commerce_notify_email">Order notification email</label>
              <input class="admin-input" id="commerce_notify_email" name="commerce_notify_email" type="email" value="{{ commerce_notify_email|e('html_attr') }}" placeholder="orders@example.com" />
              <p class="admin-hint">Optional admin copy when an order is paid.</p>
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="commerce_send_order_emails" value="1" {% if commerce_send_order_emails %}checked{% endif %} />
                Send customer order confirmation emails (includes digital download links when configured)
              </label>
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="commerce_track_inventory" value="1" {% if commerce_track_inventory %}checked{% endif %} />
                Track inventory via <code class="admin-inline-code">stock_qty</code> on products
              </label>
            </div>
          </div>
        </section>

        <div class="admin-settings-row2">
          <section id="commerce-tax" class="admin-card admin-settings-card admin-settings-section admin-settings-card--fill" tabindex="-1">
            <h2 class="admin-settings-card-title">Tax</h2>
            <p class="admin-settings-card-desc">Flat rate, per-country tables, or Stripe Tax at checkout.</p>
            <div class="admin-form-grid">
              <div class="admin-field admin-field--full">
                <label class="admin-label admin-settings-check-label">
                  <input type="checkbox" name="commerce_tax_enabled" value="1" {% if commerce_tax_enabled %}checked{% endif %} />
                  Apply tax at checkout
                </label>
              </div>
              <div class="admin-field admin-field--full">
                <label class="admin-label" for="commerce_tax_mode">Tax mode</label>
                <select class="admin-select" id="commerce_tax_mode" name="commerce_tax_mode">
                  <option value="flat" {% if commerce_tax_mode == 'flat' %}selected{% endif %}>Flat rate (single rate for all orders)</option>
                  <option value="country" {% if commerce_tax_mode == 'country' %}selected{% endif %}>Per country (manage under Tax rates)</option>
                  <option value="stripe" {% if commerce_tax_mode == 'stripe' %}selected{% endif %}>Stripe Tax (automatic at Checkout)</option>
                </select>
              </div>
              <div class="admin-field admin-field--full">
                <label class="admin-label" for="commerce_tax_rate_bps">Default flat tax rate (basis points)</label>
                <input class="admin-input" id="commerce_tax_rate_bps" name="commerce_tax_rate_bps" type="number" min="0" max="10000" value="{{ commerce_tax_rate_bps|e('html_attr') }}" />
                <p class="admin-hint">2000 = 20%. Used in flat mode or when no country rate matches.</p>
              </div>
            </div>
            <p class="admin-hint admin-settings-card-footnote"><a class="admin-link" href="{{ url_for('admin.commerce.tax_rates') }}">Manage country tax rates →</a></p>
          </section>

          <section id="commerce-shipping" class="admin-card admin-settings-card admin-settings-section admin-settings-card--fill" tabindex="-1">
            <h2 class="admin-settings-card-title">Shipping</h2>
            <p class="admin-settings-card-desc">Flat rate or zone-based shipping. Customers choose ship-to country on the cart.</p>
            <div class="admin-form-grid">
              <div class="admin-field admin-field--full">
                <label class="admin-label admin-settings-check-label">
                  <input type="checkbox" name="commerce_shipping_enabled" value="1" {% if commerce_shipping_enabled %}checked{% endif %} />
                  Charge shipping at checkout
                </label>
              </div>
              <div class="admin-field admin-field--full">
                <label class="admin-label admin-settings-check-label">
                  <input type="checkbox" name="commerce_use_shipping_zones" value="1" {% if commerce_use_shipping_zones %}checked{% endif %} />
                  Use shipping zones (instead of single flat rate below)
                </label>
              </div>
              <div class="admin-field admin-field--full">
                <label class="admin-label" for="commerce_shipping_label">Shipping label</label>
                <input class="admin-input" id="commerce_shipping_label" name="commerce_shipping_label" value="{{ commerce_shipping_label|e('html_attr') }}" />
              </div>
              <div class="admin-field">
                <label class="admin-label" for="commerce_shipping_flat_cents">Flat shipping (cents)</label>
                <input class="admin-input" id="commerce_shipping_flat_cents" name="commerce_shipping_flat_cents" type="number" min="0" value="{{ commerce_shipping_flat_cents|e('html_attr') }}" />
                <p class="admin-hint">499 = £4.99</p>
              </div>
              <div class="admin-field">
                <label class="admin-label" for="commerce_free_shipping_min_cents">Free shipping min (cents)</label>
                <input class="admin-input" id="commerce_free_shipping_min_cents" name="commerce_free_shipping_min_cents" type="number" min="0" value="{{ commerce_free_shipping_min_cents|e('html_attr') }}" />
                <p class="admin-hint">After discount; 0 = never free.</p>
              </div>
              <div class="admin-field admin-field--full">
                <label class="admin-label" for="commerce_shipping_countries">Shipping countries (ISO)</label>
                <input class="admin-input" id="commerce_shipping_countries" name="commerce_shipping_countries" value="{{ commerce_shipping_countries|e('html_attr') }}" placeholder="GB, US, IE" />
              </div>
            </div>
            <p class="admin-hint admin-settings-card-footnote"><a class="admin-link" href="{{ url_for('admin.commerce.shipping_zones') }}">Manage shipping zones →</a></p>
          </section>
        </div>

        <div class="admin-settings-row2">
          <section id="commerce-inventory" class="admin-card admin-settings-card admin-settings-section admin-settings-card--fill" tabindex="-1">
            <h2 class="admin-settings-card-title">Inventory alerts</h2>
            <p class="admin-settings-card-desc">Low-stock report threshold for tracked products.</p>
            <div class="admin-form-grid">
              <div class="admin-field admin-field--full">
                <label class="admin-label" for="commerce_low_stock_threshold">Low stock threshold</label>
                <input class="admin-input" id="commerce_low_stock_threshold" name="commerce_low_stock_threshold" type="number" min="0" value="{{ commerce_low_stock_threshold|e('html_attr') }}" />
                <p class="admin-hint">Products at or below this value appear on the <a class="admin-link" href="{{ url_for('admin.commerce.inventory') }}">Inventory</a> report.</p>
              </div>
            </div>
          </section>

          <section id="commerce-shop" class="admin-card admin-settings-card admin-settings-section admin-settings-card--fill" tabindex="-1">
            <h2 class="admin-settings-card-title">Shop page</h2>
            <p class="admin-settings-card-desc">Public catalog at <code class="admin-inline-code">/shop</code> for the configured product type.</p>
            <div class="admin-form-grid">
              <div class="admin-field admin-field--full">
                <label class="admin-label" for="commerce_shop_title">Shop page title</label>
                <input class="admin-input" id="commerce_shop_title" name="commerce_shop_title" value="{{ commerce_shop_title|e('html_attr') }}" />
              </div>
              <div class="admin-field admin-field--full">
                <label class="admin-label" for="commerce_shop_description">Shop page description</label>
                <textarea class="admin-textarea" id="commerce_shop_description" name="commerce_shop_description" rows="2">{{ commerce_shop_description|e }}</textarea>
              </div>
            </div>
          </section>
        </div>
      </div>

      <div class="admin-form-sticky-bar admin-settings-sticky">
        <div class="admin-form-sticky-inner admin-settings-sticky-inner">
          <button class="admin-btn-primary" type="submit">Save store settings</button>
          <span class="admin-hint admin-settings-sticky-hint">Tax, shipping, inventory, and shop options save together.</span>
        </div>
      </div>
    </form>

    <section id="commerce-stripe" class="admin-card admin-settings-card admin-settings-section admin-settings-card--stripe" tabindex="-1" style="margin-top:1.1rem">
      <div class="admin-settings-card-head-row">
        <div>
          <h2 class="admin-settings-card-title">Stripe</h2>
          <p class="admin-settings-card-desc" style="margin-bottom:0">Webhook URL: <code class="admin-inline-code">{{ webhook_url|e }}</code></p>
        </div>
        <div class="admin-stripe-key-badges" aria-label="Key status">
          <span class="admin-pill admin-pill--{{ stripe_keys.secret.stored ? 'ok' : 'muted' }}">Secret {{ stripe_keys.secret.stored ? 'set' : 'missing' }}</span>
          <span class="admin-pill admin-pill--{{ stripe_keys.publishable.stored ? 'ok' : 'muted' }}">Publishable {{ stripe_keys.publishable.stored ? 'set' : 'missing' }}</span>
          <span class="admin-pill admin-pill--{{ stripe_keys.webhook.stored ? 'ok' : 'muted' }}">Webhook {{ stripe_keys.webhook.stored ? 'set' : 'missing' }}</span>
        </div>
      </div>
      <p class="admin-hint" style="margin:0.75rem 0 0">Subscribe to <strong>checkout.session.completed</strong> and <strong>checkout.session.expired</strong>.</p>
      <form class="admin-form" method="post" action="{{ url_for('admin.commerce.settings.stripe') }}" style="margin-top:1.15rem">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <div class="admin-form-grid">
          <div class="admin-field admin-field--full">
            <label class="admin-label" for="stripe_secret_key">Secret key</label>
            {% if stripe_keys.secret.stored %}
              <p class="admin-hint admin-key-mask">Stored: {{ stripe_keys.secret.masked|e }}</p>
            {% endif %}
            <input class="admin-input" id="stripe_secret_key" name="stripe_secret_key" type="password" autocomplete="off" placeholder="sk_live_… or sk_test_…" />
            <label class="admin-label admin-settings-check-label" style="margin-top:0.5rem">
              <input type="checkbox" name="stripe_secret_clear" value="1" /> Remove stored secret key
            </label>
          </div>
          <div class="admin-field admin-field--full">
            <label class="admin-label" for="stripe_publishable_key">Publishable key</label>
            {% if stripe_keys.publishable.stored %}
              <p class="admin-hint admin-key-mask">Stored: {{ stripe_keys.publishable.masked|e }}</p>
            {% endif %}
            <input class="admin-input" id="stripe_publishable_key" name="stripe_publishable_key" type="text" autocomplete="off" placeholder="pk_live_… or pk_test_…" />
            <label class="admin-label admin-settings-check-label" style="margin-top:0.5rem">
              <input type="checkbox" name="stripe_publishable_clear" value="1" /> Remove publishable key
            </label>
          </div>
          <div class="admin-field admin-field--full">
            <label class="admin-label" for="stripe_webhook_secret">Webhook signing secret</label>
            {% if stripe_keys.webhook.stored %}
              <p class="admin-hint admin-key-mask">Stored: {{ stripe_keys.webhook.masked|e }}</p>
            {% endif %}
            <input class="admin-input" id="stripe_webhook_secret" name="stripe_webhook_secret" type="password" autocomplete="off" placeholder="whsec_…" />
            <label class="admin-label admin-settings-check-label" style="margin-top:0.5rem">
              <input type="checkbox" name="stripe_webhook_clear" value="1" /> Remove webhook secret
            </label>
          </div>
        </div>
        <div class="admin-form-actions" style="margin-top:0.75rem">
          <button class="admin-btn-primary" type="submit">Save Stripe keys</button>
        </div>
      </form>
    </section>
  </div>
{% endblock %}
