{% extends 'admin/base.twig' %}

{% block admin_title %}Search{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Search</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Find pages, content entries, and media across all statuses. Also available from the sidebar and <kbd class="admin-cmd-kbd">⌘K</kbd>.</p>
{% endblock %}

{% block admin_content %}
  {% set r = search_result|default({}) %}

  <div class="admin-settings-page admin-search-page">
    <section class="admin-card admin-settings-card admin-search-form-card">
      <form method="get" action="{{ url_for('admin.content.search') }}" class="admin-form admin-search-form">
        <div class="admin-search-form-row">
          <label class="admin-search-form-label" for="admin-search-q">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
            <span class="admin-search-form-title">Search the admin</span>
          </label>
          <div class="admin-search-form-inputs">
            <input
              class="admin-input admin-search-input"
              type="search"
              id="admin-search-q"
              name="q"
              value="{{ search_query|default('')|e('html_attr') }}"
              placeholder="Page title, entry slug, media filename…"
              autofocus
              minlength="2"
              maxlength="80"
              required
            />
            <button type="submit" class="admin-btn-primary">Search</button>
          </div>
        </div>
        <p class="admin-hint admin-search-form-hint">
          {% set parts = [] %}
          {% if search_can_pages|default(false) %}{% set parts = parts|merge(['pages']) %}{% endif %}
          {% if search_can_entries|default(false) %}{% set parts = parts|merge(['entries']) %}{% endif %}
          {% if search_can_media|default(false) %}{% set parts = parts|merge(['media']) %}{% endif %}
          {% if parts is not empty %}
            Searching {{ parts|join(', ') }}.
          {% else %}
            You do not have permission to search content.
          {% endif %}
        </p>
      </form>
    </section>

    {% if search_query|default('') != '' %}
      {% if r.total|default(0) == 0 %}
        <section class="admin-card admin-settings-card admin-search-empty">
          <p class="admin-settings-intro-title" style="margin:0">No matches</p>
          <p class="admin-hint" style="margin:0.35rem 0 0">Nothing found for <strong>{{ search_query|e }}</strong>. Try a shorter keyword or different spelling.</p>
        </section>
      {% else %}
        <section class="admin-card admin-settings-card admin-search-results-card">
          <header class="admin-settings-card-head-row">
            <div>
              <h2 class="admin-settings-card-title">{{ r.total }} result{{ r.total == 1 ? '' : 's' }}</h2>
              <p class="admin-settings-card-desc" style="margin-bottom:0">
                {% if r.pages_total|default(0) > 0 %}{{ r.pages_total }} page{{ r.pages_total == 1 ? '' : 's' }}{% endif %}
                {% if r.entries_total|default(0) > 0 %}{% if r.pages_total|default(0) > 0 %} · {% endif %}{{ r.entries_total }} entr{{ r.entries_total == 1 ? 'y' : 'ies' }}{% endif %}
                {% if r.media_total|default(0) > 0 %}{% if r.pages_total|default(0) > 0 or r.entries_total|default(0) > 0 %} · {% endif %}{{ r.media_total }} media file{{ r.media_total == 1 ? '' : 's' }}{% endif %}
              </p>
            </div>
          </header>
          <ul class="admin-search-results">
            {% for hit in r.hits|default([]) %}
              <li class="admin-search-hit">
                <div class="admin-search-hit-main">
                  <div class="admin-search-hit-badges">
                    <span class="admin-pill admin-pill--accent">
                      {% if hit.kind == 'page' %}Page{% elseif hit.kind == 'media' %}Media{% else %}{{ hit.type_name|default('Entry')|e }}{% endif %}
                    </span>
                    <span class="admin-pill">{{ hit.status|e }}</span>
                  </div>
                  <h3 class="admin-search-hit-title">
                    <a class="admin-link" href="{{ hit.edit_url|default('#')|e('html_attr') }}">{{ hit.title|e }}</a>
                  </h3>
                  <p class="admin-search-hit-slug"><code class="admin-inline-code">{{ hit.slug|e }}</code></p>
                  {% if hit.snippet|default('') != '' %}
                    <p class="admin-search-hit-snippet">{{ hit.snippet|e }}</p>
                  {% endif %}
                </div>
                <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ hit.edit_url|default('#')|e('html_attr') }}">Open</a>
              </li>
            {% endfor %}
          </ul>

          {% if r.total_pages|default(1) > 1 %}
            <nav class="admin-pagination admin-search-pagination" aria-label="Search results pages">
              {% if r.page|default(1) > 1 %}
                <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for('admin.content.search') }}?q={{ search_query|url_encode }}&amp;page={{ r.page - 1 }}">Previous</a>
              {% endif %}
              <span class="admin-hint">Page {{ r.page|default(1) }} of {{ r.total_pages|default(1) }}</span>
              {% if r.page|default(1) < r.total_pages|default(1) %}
                <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for('admin.content.search') }}?q={{ search_query|url_encode }}&amp;page={{ r.page + 1 }}">Next</a>
              {% endif %}
            </nav>
          {% endif %}
        </section>
      {% endif %}
    {% endif %}
  </div>
{% endblock %}
