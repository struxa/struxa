{# Floating AI assistant (chat + create draft). Shown when user may access AI draft tools. #}
<div
  id="admin-ai-chat"
  class="admin-ai-chat"
  data-csrf="{{ csrf_token() }}"
  data-bootstrap-url="{{ url_for('admin.tools.ai_blog.api.bootstrap') }}"
  hidden
>
  <button type="button" class="admin-ai-chat-launcher" id="admin-ai-chat-launcher" aria-expanded="false" aria-controls="admin-ai-chat-panel" aria-label="Open AI writing assistant" aria-hidden="false">
    <svg class="admin-ai-chat-launcher-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3a6 6 0 0 0 6 6v3a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V9a6 6 0 0 0 6-6z" />
      <path d="M9 18h6v3H9z" />
    </svg>
  </button>
  <div class="admin-ai-chat-panel" id="admin-ai-chat-panel" role="dialog" aria-label="AI writing assistant" aria-hidden="true" hidden>
    <header class="admin-ai-chat-head">
      <span class="admin-ai-chat-title">Writing assistant</span>
      <div class="admin-ai-chat-head-actions">
        <a href="{{ url_for('admin.tools.ai_blog') }}" class="admin-ai-chat-head-link" id="admin-ai-chat-settings-link" hidden>Settings</a>
        <button type="button" class="admin-ai-chat-icon-btn" id="admin-ai-chat-clear" title="Clear conversation" aria-label="Clear conversation" hidden>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6h14z"/></svg>
        </button>
        <button type="button" class="admin-ai-chat-icon-btn" id="admin-ai-chat-minimize" title="Minimize to corner" aria-label="Minimize assistant to corner">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 12h12"/></svg>
        </button>
      </div>
    </header>
    <p class="admin-ai-chat-banner" id="admin-ai-chat-banner" hidden></p>
    <p class="admin-ai-chat-inline-error" id="admin-ai-chat-inline-error" role="alert" hidden></p>
    <p class="admin-ai-chat-draft-hint" id="admin-ai-chat-draft-hint" hidden>
      <strong>Next step:</strong> this chat only plans your article. Choose a <strong>content type</strong> under the message box, then click <strong>Create draft entry</strong> to generate a real draft in the editor (nothing is saved until then).
    </p>
    <div class="admin-ai-chat-messages" id="admin-ai-chat-messages" tabindex="-1"></div>
    <form class="admin-ai-chat-compose" id="admin-ai-chat-form" hidden>
      <label class="admin-ai-chat-vh" for="admin-ai-chat-input">Message</label>
      <textarea id="admin-ai-chat-input" class="admin-ai-chat-input" rows="2" placeholder="Ask about angle, outline, audience…" autocomplete="off"></textarea>
      <button type="submit" class="admin-btn-primary admin-ai-chat-send" id="admin-ai-chat-send">Send</button>
    </form>
    <div class="admin-ai-chat-draft" id="admin-ai-chat-draft" hidden>
      <label class="admin-label" for="admin-ai-chat-type">Create draft as</label>
      <select id="admin-ai-chat-type" class="admin-input"></select>
      <label class="admin-label" for="admin-ai-chat-tone">Tone hint (optional)</label>
      <input type="text" id="admin-ai-chat-tone" class="admin-input" placeholder="e.g. concise, UK English" autocomplete="off" />
      <button type="button" class="admin-btn-primary admin-ai-chat-draft-btn" id="admin-ai-chat-draft-btn">Create draft entry</button>
    </div>
  </div>
</div>
