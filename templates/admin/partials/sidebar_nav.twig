{# Collapsible groups; open when current section matches #}
{% set nav = admin_nav|default('') %}

<nav class="admin-nav admin-nav--grouped" aria-label="Admin" id="admin-primary-nav">
  <div class="admin-nav-pins" aria-label="Quick access">
    <p class="admin-nav-section-label">Pinned</p>
    <a href="{{ url_for('admin.dashboard') }}" class="admin-nav-pin {{ nav == 'dashboard' ? 'is-active' : '' }}">
      <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1" /><rect width="7" height="7" x="14" y="3" rx="1" /><rect width="7" height="7" x="14" y="14" rx="1" /><rect width="7" height="7" x="3" y="14" rx="1" /></svg>
      Dashboard
    </a>
    {% if cms_can('manage_pages') %}
      <a href="{{ url_for('admin.pages.index') }}" class="admin-nav-pin {{ nav == 'pages' ? 'is-active' : '' }}">
        <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
        Pages
      </a>
    {% endif %}
    {% if cms_can('manage_content_types') or cms_can('create_content') or cms_can('edit_content') %}
      <a href="{{ url_for('admin.content_types.index') }}" class="admin-nav-pin {{ nav == 'content_types' ? 'is-active' : '' }}">
        <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Content
      </a>
    {% endif %}
  </div>

  <a href="{{ url_for('admin.updates.index') }}" class="admin-nav-pin {{ nav == 'updates' ? 'is-active' : '' }}">
    <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
      <path d="M13.73 21a2 2 0 0 1-3.46 0" />
    </svg>
    Updates
  </a>

  {% if cms_can('create_content') or cms_can('manage_settings') or cms_can('manage_comments') %}
    <details class="admin-nav-group" {{ nav in ['ai_blog','ai_comments'] ? 'open' : '' }}>
      <summary class="admin-nav-group-title">AI</summary>
      <div class="admin-nav-group-items">
        {% if cms_can('create_content') or cms_can('manage_settings') %}
          <a href="{{ url_for('admin.tools.ai_blog') }}" class="{{ nav == 'ai_blog' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 3a6 6 0 0 0 6 6v3a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V9a6 6 0 0 0 6-6z"/><path d="M9 18h6v3H9z"/></svg>
            AI draft
          </a>
        {% endif %}
        {% if cms_can('manage_comments') %}
          <a href="{{ url_for('admin.tools.ai_comments') }}" class="{{ nav == 'ai_comments' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            AI comments
          </a>
        {% endif %}
      </div>
    </details>
  {% endif %}

  {% if cms_can('manage_security') %}
    <details class="admin-nav-group" {{ nav == 'security_ip_block' ? 'open' : '' }}>
      <summary class="admin-nav-group-title">Security</summary>
      <div class="admin-nav-group-items">
        <a href="{{ url_for('admin.security.ip_block') }}" class="{{ nav == 'security_ip_block' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          IP blocking
        </a>
      </div>
    </details>
  {% endif %}

  {% if cms_can('manage_users') or cms_can('manage_roles') or cms_can('view_activity') or cms_can('manage_comments') or cms_can('manage_settings') %}
    <details class="admin-nav-group" {{ nav in ['users','roles','activity','comments','system_api_keys'] ? 'open' : '' }}>
      <summary class="admin-nav-group-title">System</summary>
      <div class="admin-nav-group-items">
        {% if cms_can('manage_users') %}
          <a href="{{ url_for('admin.users.index') }}" class="{{ nav == 'users' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Users
          </a>
        {% endif %}
        {% if cms_can('manage_roles') %}
          <a href="{{ url_for('admin.roles.index') }}" class="{{ nav == 'roles' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Roles
          </a>
        {% endif %}
        {% if cms_can('view_activity') %}
          <a href="{{ url_for('admin.activity.index') }}" class="{{ nav == 'activity' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Activity
          </a>
        {% endif %}
        {% if cms_can('manage_comments') %}
          <a href="{{ url_for('admin.comments.index') }}" class="{{ nav == 'comments' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Comments
          </a>
        {% endif %}
        {% if cms_can('manage_settings') %}
          <a href="{{ url_for('admin.system.api_keys') }}" class="{{ nav == 'system_api_keys' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 10h-7M10 14h11M3 10h3m-3 4h7"/><circle cx="8" cy="10" r="2"/><circle cx="14" cy="14" r="2"/></svg>
            API keys
          </a>
        {% endif %}
      </div>
    </details>
  {% endif %}

  <details class="admin-nav-group" {{ nav in ['pages','content_types','media','forms','seo_sitemap'] ? 'open' : '' }}>
    <summary class="admin-nav-group-title">Content</summary>
    <div class="admin-nav-group-items">
      {# Pages: use sidebar pin only (avoids duplicate nav) #}
      {% if cms_can('manage_content_types') or cms_can('create_content') or cms_can('edit_content') or cms_can('review_content') or cms_can('publish_content') %}
        <a href="{{ url_for('admin.content_types.index') }}" class="{{ nav == 'content_types' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          Content types
        </a>
      {% endif %}
      {% if cms_can('manage_forms') %}
        <a href="{{ url_for('admin.forms.index') }}" class="{{ nav == 'forms' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 9h10M7 13h6"/></svg>
          Forms
        </a>
      {% endif %}
      {% if cms_can('manage_media') %}
        <a href="{{ url_for('admin.media.index') }}" class="{{ nav == 'media' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          Media library
        </a>
      {% endif %}
      {% if cms_can('manage_settings') %}
        <a href="{{ url_for('admin.seo.overview') }}" class="{{ nav == 'seo_overview' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
          SEO overview
        </a>
        <a href="{{ url_for('admin.seo.sitemap') }}" class="{{ nav == 'seo_sitemap' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
          Sitemap
        </a>
      {% endif %}
    </div>
  </details>

  {% if cms_can('manage_settings') or cms_can('view_link_analytics') %}
    <details class="admin-nav-group" {{ nav in ['settings','seo_overview','seo_redirects','seo_not_found','cache_tools','maintenance_tools','analytics_external_links','settings_search'] ? 'open' : '' }}>
      <summary class="admin-nav-group-title">Site</summary>
      <div class="admin-nav-group-items">
        {% if cms_can('manage_settings') %}
          <a href="{{ url_for('admin.settings') }}" class="{{ nav == 'settings' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            Settings
          </a>
          <a href="{{ url_for('admin.seo.redirects') }}" class="{{ nav == 'seo_redirects' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M4 12h16M10 6l-6 6 6 6"/></svg>
            Redirects
          </a>
          <a href="{{ url_for('admin.seo.not_found') }}" class="{{ nav == 'seo_not_found' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            404 log
          </a>
          <a href="{{ url_for('admin.tools.cache') }}" class="{{ nav == 'cache_tools' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Performance
          </a>
          <a href="{{ url_for('admin.tools.maintenance') }}" class="{{ nav == 'maintenance_tools' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/><circle cx="12" cy="12" r="3"/></svg>
            Maintenance
          </a>
          <a href="{{ url_for('admin.settings.search') }}" class="{{ nav == 'settings_search' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
            Search
          </a>
        {% endif %}
        {% if cms_can('view_link_analytics') %}
          <a href="{{ url_for('admin.analytics.external_links') }}" class="{{ nav == 'analytics_external_links' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.72"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.72-1.72"/></svg>
            External links
          </a>
        {% endif %}
      </div>
    </details>
  {% endif %}

  {% if cms_can('manage_themes') or cms_can('manage_menus') %}
    <details class="admin-nav-group" {{ nav in ['themes','menus'] ? 'open' : '' }}>
      <summary class="admin-nav-group-title">Appearance</summary>
      <div class="admin-nav-group-items">
        {% if cms_can('manage_themes') %}
          <a href="{{ url_for('admin.themes.index') }}" class="{{ nav == 'themes' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
            Themes
          </a>
        {% endif %}
        {% if cms_can('manage_menus') %}
          <a href="{{ url_for('admin.menus.index') }}" class="{{ nav == 'menus' ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="14" y2="18"/></svg>
            Menus
          </a>
        {% endif %}
      </div>
    </details>
  {% endif %}

  {% if cms_can('manage_plugins') %}
    {% set plugins_list_path_raw = url_for('admin.extensions.plugins.index')|split('?')|first %}
    {% set plugins_list_path = plugins_list_path_raw == '' or plugins_list_path_raw == '/' ? '/' : plugins_list_path_raw|trim('/', 'right') %}
    {% set extensions_nav_open = nav == 'extensions_plugins' %}
    {% if not extensions_nav_open and request_path == plugins_list_path %}
      {% set extensions_nav_open = true %}
    {% endif %}
    {% for nav_item in plugin_admin_nav_items|default([]) %}
      {% set plugin_item_path_raw = url_for(nav_item.route_name, nav_item.route_params|default({}))|split('?')|first %}
      {% set plugin_item_path = plugin_item_path_raw == '' or plugin_item_path_raw == '/' ? '/' : plugin_item_path_raw|trim('/', 'right') %}
      {% if not extensions_nav_open and (request_path == plugin_item_path or (plugin_item_path != '/' and request_path starts with (plugin_item_path ~ '/'))) %}
        {% set extensions_nav_open = true %}
      {% endif %}
    {% endfor %}
    {% for group in plugin_admin_nav_groups|default([]) %}
      {% for child in group.items %}
        {% set plugin_item_path_raw = url_for(child.route_name, child.route_params|default({}))|split('?')|first %}
        {% set plugin_item_path = plugin_item_path_raw == '' or plugin_item_path_raw == '/' ? '/' : plugin_item_path_raw|trim('/', 'right') %}
        {% if not extensions_nav_open and (request_path == plugin_item_path or (plugin_item_path != '/' and request_path starts with (plugin_item_path ~ '/'))) %}
          {% set extensions_nav_open = true %}
        {% endif %}
      {% endfor %}
    {% endfor %}
    <details class="admin-nav-group" {{ extensions_nav_open ? 'open' : '' }}>
      <summary class="admin-nav-group-title">Extensions</summary>
      <div class="admin-nav-group-items">
        <a href="{{ url_for('admin.extensions.plugins.index') }}" class="{{ request_path == plugins_list_path ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Plugins
        </a>
        {% for nav_item in plugin_admin_nav_items|default([]) %}
          {% set plugin_item_path_raw = url_for(nav_item.route_name, nav_item.route_params|default({}))|split('?')|first %}
          {% set plugin_item_path = plugin_item_path_raw == '' or plugin_item_path_raw == '/' ? '/' : plugin_item_path_raw|trim('/', 'right') %}
          <a href="{{ url_for(nav_item.route_name, nav_item.route_params|default({})) }}" class="{{ request_path == plugin_item_path or (plugin_item_path != '/' and request_path starts with (plugin_item_path ~ '/')) ? 'is-active' : '' }}">
            <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
            {{ nav_item.label|e }}
          </a>
        {% endfor %}
        {% for group in plugin_admin_nav_groups|default([]) %}
          {% set group_open = false %}
          {% for child in group.items %}
            {% set plugin_item_path_raw = url_for(child.route_name, child.route_params|default({}))|split('?')|first %}
            {% set plugin_item_path = plugin_item_path_raw == '' or plugin_item_path_raw == '/' ? '/' : plugin_item_path_raw|trim('/', 'right') %}
            {% if request_path == plugin_item_path or (plugin_item_path != '/' and request_path starts with (plugin_item_path ~ '/')) %}
              {% set group_open = true %}
            {% endif %}
          {% endfor %}
          <details class="admin-nav-group admin-nav-group--nested" {{ group_open ? 'open' : '' }}>
            <summary class="admin-nav-group-title admin-nav-group-title--nested">{{ group.label|e }}</summary>
            <div class="admin-nav-group-items admin-nav-group-items--nested">
              {% for child in group.items %}
                {% set plugin_item_path_raw = url_for(child.route_name, child.route_params|default({}))|split('?')|first %}
                {% set plugin_item_path = plugin_item_path_raw == '' or plugin_item_path_raw == '/' ? '/' : plugin_item_path_raw|trim('/', 'right') %}
                <a href="{{ url_for(child.route_name, child.route_params|default({})) }}" class="{{ request_path == plugin_item_path or (plugin_item_path != '/' and request_path starts with (plugin_item_path ~ '/')) ? 'is-active' : '' }}">
                  <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
                  {{ child.label|e }}
                </a>
              {% endfor %}
            </div>
          </details>
        {% endfor %}
      </div>
    </details>
  {% endif %}

  {% if cms_can('manage_portability') %}
    <details class="admin-nav-group" {{ nav in ['tools_blueprints','tools_import_export','tools_api_keys'] ? 'open' : '' }}>
      <summary class="admin-nav-group-title">Tools</summary>
      <div class="admin-nav-group-items">
        <a href="{{ url_for('admin.tools.blueprints') }}" class="{{ nav == 'tools_blueprints' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Blueprints
        </a>
        <a href="{{ url_for('admin.tools.import_export') }}" class="{{ nav == 'tools_import_export' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Import / Export
        </a>
        <a href="{{ url_for('admin.tools.api_keys') }}" class="{{ nav == 'tools_api_keys' ? 'is-active' : '' }}">
          <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
          API keys
        </a>
      </div>
    </details>
  {% endif %}
</nav>
