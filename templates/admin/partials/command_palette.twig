<div class="admin-cmd" id="admin-cmd-palette" hidden role="dialog" aria-modal="true" aria-label="Admin search"{% if cms_can('manage_pages') or cms_can('create_content') or cms_can('edit_content') or cms_can('review_content') or cms_can('manage_content_types') or cms_can('manage_media') %} data-suggest-url="{{ url_for('admin.content.search.suggest')|e('html_attr') }}" data-search-url="{{ url_for('admin.content.search')|e('html_attr') }}"{% endif %}>
  <button type="button" class="admin-cmd-backdrop" tabindex="-1" aria-label="Close"></button>
  <div class="admin-cmd-panel">
    <div class="admin-cmd-search-wrap">
      <svg class="admin-cmd-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input
        type="search"
        class="admin-cmd-input"
        id="admin-cmd-input"
        placeholder="Search pages, entries, media…"
        autocomplete="off"
        spellcheck="false"
        aria-autocomplete="list"
        aria-controls="admin-cmd-results"
      />
      <kbd class="admin-cmd-kbd admin-cmd-kbd--corner" aria-hidden="true">esc</kbd>
    </div>
    <ul class="admin-cmd-list" id="admin-cmd-results" role="listbox"></ul>
    <p class="admin-cmd-foot">
      <span><kbd class="admin-cmd-kbd">↑</kbd><kbd class="admin-cmd-kbd">↓</kbd> navigate</span>
      <span><kbd class="admin-cmd-kbd">↵</kbd> open</span>
      <span class="admin-cmd-foot-mod"><kbd class="admin-cmd-kbd admin-cmd-kbd--mod">⌘</kbd><kbd class="admin-cmd-kbd">K</kbd> toggle</span>
    </p>
  </div>
</div>
