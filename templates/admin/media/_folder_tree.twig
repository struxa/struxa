{% macro folder_tree(nodes, current_filter, mq_base, depth, return_folder, search_q, media_view, media_sort, per_page, page) %}
  {% import _self as folders %}
  {% for node in nodes %}
    {% set folder_mq = mq_base|merge({ folder: node.id }) %}
    {% set is_active = current_filter and current_filter.mode == 'folder' and current_filter.folderId == node.id %}
    <li class="admin-media-folder-item" style="--folder-depth: {{ depth }}">
      <div class="admin-media-folder-row{% if is_active %} is-active{% endif %}">
        <a href="{{ url_for('admin.media.index', {}, folder_mq) }}" class="admin-media-folder-link">
          <svg class="admin-media-folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          <span class="admin-media-folder-name">{{ node.name|e }}</span>
          {% if node.file_count|default(0) > 0 %}
            <span class="admin-media-folder-count">{{ node.file_count }}</span>
          {% endif %}
        </a>
        <details class="admin-actions-menu admin-media-folder-menu">
          <summary class="admin-actions-menu-trigger" aria-label="Folder actions for {{ node.name|e('html_attr') }}">⋯</summary>
          <div class="admin-actions-menu-panel admin-media-folder-menu-panel">
            {% include 'admin/media/_folder_rename_form.twig' with {
              folder: node,
              return_folder: return_folder,
              search_q: search_q,
              media_view: media_view,
              media_sort: media_sort,
              per_page: per_page,
              page: page
            } %}
            <form method="post" action="{{ url_for('admin.media.folders.delete', { id: node.id }) }}" class="admin-media-folder-delete-form" onsubmit="return confirm('Delete folder “{{ node.name|e('js') }}”?\n\nSubfolders are removed. Files inside become unfiled.');">
              {% include 'admin/media/_folder_return_fields.twig' with {
                return_folder: return_folder,
                search_q: search_q,
                media_view: media_view,
                media_sort: media_sort,
                per_page: per_page,
                page: page
              } %}
              <button type="submit" class="admin-actions-danger">Delete folder</button>
            </form>
          </div>
        </details>
      </div>
      {% if node.children|default([]) is not empty %}
        <ul class="admin-media-folder-children" role="list">
          {{ folders.folder_tree(node.children, current_filter, mq_base, depth + 1, return_folder, search_q, media_view, media_sort, per_page, page) }}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
{% endmacro %}
