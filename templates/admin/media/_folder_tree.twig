{% macro folder_tree(nodes, current_filter, mq_base, depth) %}
  {% import _self as folders %}
  {% for node in nodes %}
    {% set folder_mq = mq_base|merge({ folder: node.id }) %}
    {% set is_active = current_filter.mode == 'folder' and current_filter.folderId == node.id %}
    <li class="admin-media-folder-item" style="--folder-depth: {{ depth }}">
      <div class="admin-media-folder-row{% if is_active %} is-active{% endif %}">
        <a href="{{ url_for('admin.media.index', {}, folder_mq) }}" class="admin-media-folder-link">
          <svg class="admin-media-folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          <span class="admin-media-folder-name">{{ node.name|e }}</span>
          {% if node.file_count|default(0) > 0 %}
            <span class="admin-media-folder-count">{{ node.file_count }}</span>
          {% endif %}
        </a>
        <details class="admin-actions-menu admin-media-folder-menu">
          <summary class="admin-actions-menu-trigger" aria-label="Folder actions for {{ node.name|e('html_attr') }}">⋯</summary>
          <div class="admin-actions-menu-panel">
            <form method="post" action="{{ url_for('admin.media.folders.edit', { id: node.id }) }}" class="admin-media-folder-rename-form">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
              <input type="hidden" name="return_folder" value="{{ current_filter.mode == 'folder' ? current_filter.folderId : (current_filter.mode == 'unfiled' ? 'unfiled' : '') }}" />
              <input type="hidden" name="return_q" value="{{ search_q|default('')|e('html_attr') }}" />
              <input type="hidden" name="return_view" value="{{ media_view|default('gallery')|e('html_attr') }}" />
              <input type="hidden" name="return_sort" value="{{ media_sort|default('newest')|e('html_attr') }}" />
              <input type="hidden" name="return_per_page" value="{{ per_page|default(24) }}" />
              <input type="hidden" name="return_page" value="{{ page|default(1) }}" />
              <label class="admin-media-folder-rename-label">
                <span>Rename</span>
                <input class="admin-input admin-input--sm" type="text" name="name" value="{{ node.name|e('html_attr') }}" maxlength="160" required />
              </label>
              <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm">Save name</button>
            </form>
            <form method="post" action="{{ url_for('admin.media.folders.delete', { id: node.id }) }}" onsubmit="return confirm('Delete folder “{{ node.name|e('js') }}”?\n\nSubfolders are removed. Files inside become unfiled.');">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
              <input type="hidden" name="return_folder" value="{{ current_filter.mode == 'folder' ? current_filter.folderId : (current_filter.mode == 'unfiled' ? 'unfiled' : '') }}" />
              <button type="submit" class="admin-actions-danger">Delete folder</button>
            </form>
          </div>
        </details>
      </div>
      {% if node.children|default([]) is not empty %}
        <ul class="admin-media-folder-children" role="list">
          {{ folders.folder_tree(node.children, current_filter, mq_base, depth + 1) }}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
{% endmacro %}
