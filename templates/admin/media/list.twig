{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}Media library{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Media library</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">Upload, browse, and reuse images across pages, entries, and theme settings.</p>
{% endblock %}

{% block admin_hero_actions %}{% endblock %}

{% block admin_body_class %}admin-body--media{% endblock %}

{% block admin_content %}
  {% set stats = media_stats|default({ total_files: 0, total_bytes: 0, image_files: 0 }) %}
  {% set total_bytes = stats.total_bytes|default(0) %}

  {% set compress_caps = media_compress_caps|default({ available: false, hint: 'Compression unavailable.' }) %}
  {% set current_filter = media_folder_filter|default(null) %}
  {% set mq_base = media_mq_base|default({}) %}
  {% set return_folder = current_filter and current_filter.mode == 'folder' ? current_filter.folderId : (current_filter and current_filter.mode == 'unfiled' ? 'unfiled' : '') %}

  <div class="admin-media-page" id="admin-media-page">
    <script type="application/json" id="admin-media-library-config">
      {{- {
        uploadUrl: url_for('admin.media.api.upload'),
        compressUrl: url_for('admin.media.compress_setting'),
        maxMb: max_upload_mb,
        compressEnabled: media_compress_enabled|default(false),
        gdAvailable: compress_caps.available|default(false),
        folderId: media_upload_folder_id|default(null)
      }|json_encode|raw -}}
    </script>

    <section class="admin-media-hero" aria-label="Library overview">
      <div class="admin-media-hero-stats">
        <article class="admin-media-stat">
          <span class="admin-media-stat-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </span>
          <span class="admin-media-stat-value">{{ stats.total_files|default(0) }}</span>
          <span class="admin-media-stat-label">Files</span>
        </article>
        <article class="admin-media-stat">
          <span class="admin-media-stat-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </span>
          <span class="admin-media-stat-value">{{ stats.image_files|default(0) }}</span>
          <span class="admin-media-stat-label">Images</span>
        </article>
        <article class="admin-media-stat">
          <span class="admin-media-stat-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </span>
          <span class="admin-media-stat-value">
            {% if total_bytes < 1024 %}{{ total_bytes }} B
            {% elseif total_bytes < 1048576 %}{{ (total_bytes / 1024)|round(1) }} KB
            {% else %}{{ (total_bytes / 1048576)|round(2) }} MB{% endif %}
          </span>
          <span class="admin-media-stat-label">Storage used</span>
        </article>
      </div>

      <div class="admin-media-workspace">
      <section
        class="admin-media-compress-panel{% if media_compress_enabled|default(false) %} is-on{% endif %}{% if not compress_caps.available|default(false) %} is-unavailable{% endif %}"
        aria-label="Upload compression"
      >
        <div class="admin-media-compress-panel-glow" aria-hidden="true"></div>
        <div class="admin-media-compress-panel-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v12" />
            <path d="m7 10 5 5 5-5" />
            <path d="M5 21h14" />
          </svg>
        </div>
        <div class="admin-media-compress-panel-copy">
          <div class="admin-media-compress-panel-head">
            <h2 class="admin-media-compress-panel-title">Smart compression</h2>
            <span class="admin-media-compress-badge" id="admin-media-compress-badge">
              {% if media_compress_enabled|default(false) %}Active{% else %}Off{% endif %}
            </span>
          </div>
          <p class="admin-media-compress-hint" id="admin-media-compress-hint">
            {% if media_compress_enabled|default(false) %}
              {% if compress_caps.webp_encode|default(false) %}WebP re-encode on upload{% else %}JPEG/PNG re-encode on upload{% endif %} · max {{ media_compress_max_edge|default(3840) }}px edge
            {% elseif not compress_caps.available|default(false) %}
              {{ compress_caps.hint|default('PHP GD extension required for compression.')|e }}
            {% else %}
              Shrink uploads with WebP and modern codecs — toggle on to optimize new files automatically.
            {% endif %}
          </p>
        </div>
        <div class="admin-media-compress-panel-action">
          <label class="admin-switch admin-switch--lg" title="Optimize uploads with WebP and modern codecs">
            <input
              type="checkbox"
              id="admin-media-compress-toggle"
              {% if media_compress_enabled|default(false) %}checked{% endif %}
              {% if not compress_caps.available|default(false) %}disabled{% endif %}
            />
            <span class="admin-switch-track" aria-hidden="true"><span class="admin-switch-thumb"></span></span>
            <span class="admin-switch-label">Compress on upload</span>
          </label>
        </div>
      </section>

      <section class="admin-media-upload-panel" aria-label="Upload">
      <div class="admin-media-upload-drop" id="admin-media-upload-drop" tabindex="0" role="button" aria-label="Drop images here or click to upload">
        <input type="file" id="admin-media-upload-file" class="admin-media-upload-file" accept="image/jpeg,image/png,image/webp,image/gif" multiple hidden />
        <div class="admin-media-upload-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="17 8 12 3 7 8" />
            <line x1="12" y1="3" x2="12" y2="15" />
          </svg>
        </div>
        <p class="admin-media-upload-title">Drop images here</p>
        <p class="admin-media-upload-hint">or click to browse · JPG, PNG, WebP, GIF · max {{ max_upload_mb }} MB each</p>
      </div>
      <p class="admin-media-upload-status" id="admin-media-upload-status" role="status" hidden></p>
      <div class="admin-media-upload-progress" id="admin-media-upload-progress" hidden aria-hidden="true">
        <div class="admin-media-upload-progress-bar" id="admin-media-upload-progress-bar"></div>
      </div>
      </section>
      </div>
    </section>

    <div class="admin-media-library-layout">
      <aside class="admin-media-folders" aria-label="Folders">
        <div class="admin-media-folders-head">
          <h2 class="admin-media-folders-title">Folders</h2>
        </div>
        <nav class="admin-media-folders-nav">
          <a href="{{ url_for('admin.media.index', {}, media_mq_all|default({})) }}" class="admin-media-folder-link admin-media-folder-link--root{% if current_filter is null or current_filter.mode == 'all' %} is-active{% endif %}">
            <svg class="admin-media-folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            <span class="admin-media-folder-name">All files</span>
          </a>
          <a href="{{ url_for('admin.media.index', {}, mq_base|merge({ folder: 'unfiled' })) }}" class="admin-media-folder-link admin-media-folder-link--root{% if current_filter and current_filter.mode == 'unfiled' %} is-active{% endif %}">
            <svg class="admin-media-folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <span class="admin-media-folder-name">Unfiled</span>
            {% if media_unfiled_count|default(0) > 0 %}
              <span class="admin-media-folder-count">{{ media_unfiled_count }}</span>
            {% endif %}
          </a>
          {% if media_folder_tree|default([]) is not empty %}
            <ul class="admin-media-folder-tree" role="list">
              {% from 'admin/media/_folder_tree.twig' import folder_tree %}
              {{ folder_tree(media_folder_tree, current_filter, mq_base, 0) }}
            </ul>
          {% endif %}
        </nav>
        <form class="admin-media-folder-create" method="post" action="{{ url_for('admin.media.folders.create') }}">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <input type="hidden" name="return_folder" value="{{ return_folder|e('html_attr') }}" />
          <input type="hidden" name="return_q" value="{{ search_q|default('')|e('html_attr') }}" />
          <input type="hidden" name="return_view" value="{{ media_view|default('gallery')|e('html_attr') }}" />
          <input type="hidden" name="return_sort" value="{{ media_sort|default('newest')|e('html_attr') }}" />
          <input type="hidden" name="return_per_page" value="{{ per_page|default(24) }}" />
          <input type="hidden" name="return_page" value="{{ page|default(1) }}" />
          {% if current_filter and current_filter.mode == 'folder' and current_filter.folderId %}
            <input type="hidden" name="parent_id" value="{{ current_filter.folderId }}" />
          {% endif %}
          <label class="admin-media-folder-create-label">
            <span class="admin-media-folder-create-name">New folder{% if media_current_folder %} in {{ media_current_folder.name|e }}{% endif %}</span>
            <input class="admin-input admin-input--sm" type="text" name="name" placeholder="Folder name" maxlength="160" required />
          </label>
          <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm">Create</button>
        </form>
      </aside>

      <div class="admin-media-library-main">
    {% if media_current_folder %}
      <nav class="admin-media-folder-breadcrumbs" aria-label="Folder location">
        <a class="admin-link" href="{{ url_for('admin.media.index', {}, media_mq_all|default({})) }}">All files</a>
        {% for crumb in media_folder_breadcrumbs|default([]) %}
          <span class="admin-media-folder-crumb-sep" aria-hidden="true">/</span>
          {% if loop.last %}
            <span class="admin-media-folder-crumb-current">{{ crumb.name|e }}</span>
          {% else %}
            <a class="admin-link" href="{{ url_for('admin.media.index', {}, mq_base|merge({ folder: crumb.id })) }}">{{ crumb.name|e }}</a>
          {% endif %}
        {% endfor %}
      </nav>
    {% endif %}

    <div class="admin-media-toolbar-card">
    <div class="admin-media-toolbar admin-toolbar admin-toolbar--spread">
      <div class="admin-media-toolbar-start">
        <form class="admin-media-view-toggle" method="get" action="{{ url_for('admin.media.index') }}" aria-label="Library layout">
          {% if search_q %}
            <input type="hidden" name="q" value="{{ search_q|e('html_attr') }}" />
          {% endif %}
          {% if current_filter and current_filter.mode == 'unfiled' %}
            <input type="hidden" name="folder" value="unfiled" />
          {% elseif current_filter and current_filter.mode == 'folder' and current_filter.folderId %}
            <input type="hidden" name="folder" value="{{ current_filter.folderId }}" />
          {% endif %}
          {% if page > 1 %}
            <input type="hidden" name="page" value="{{ page }}" />
          {% endif %}
          {% if media_sort|default('newest') != 'newest' %}
            <input type="hidden" name="sort" value="{{ media_sort|e('html_attr') }}" />
          {% endif %}
          {% if per_page|default(24) != 24 %}
            <input type="hidden" name="per_page" value="{{ per_page }}" />
          {% endif %}
          <button
            type="submit"
            name="view"
            value="gallery"
            class="admin-media-view-btn{% if media_view != 'list' %} is-active{% endif %}"
            {% if media_view != 'list' %}aria-current="page"{% endif %}
          >Gallery</button>
          <button
            type="submit"
            name="view"
            value="list"
            class="admin-media-view-btn{% if media_view == 'list' %} is-active{% endif %}"
            {% if media_view == 'list' %}aria-current="page"{% endif %}
          >List</button>
        </form>
        <form class="admin-media-filter-form" method="get" action="{{ url_for('admin.media.index') }}" aria-label="Sort and page size">
          {% if search_q %}
            <input type="hidden" name="q" value="{{ search_q|e('html_attr') }}" />
          {% endif %}
          {% if current_filter and current_filter.mode == 'unfiled' %}
            <input type="hidden" name="folder" value="unfiled" />
          {% elseif current_filter and current_filter.mode == 'folder' and current_filter.folderId %}
            <input type="hidden" name="folder" value="{{ current_filter.folderId }}" />
          {% endif %}
          {% if media_view == 'list' %}
            <input type="hidden" name="view" value="list" />
          {% endif %}
          <label class="admin-media-filter-label">
            <span class="admin-media-filter-name">Sort</span>
            <select class="admin-select admin-select--sm" name="sort" onchange="this.form.submit()">
              <option value="newest" {{ media_sort|default('newest') == 'newest' ? 'selected' : '' }}>Newest</option>
              <option value="oldest" {{ media_sort|default('newest') == 'oldest' ? 'selected' : '' }}>Oldest</option>
              <option value="name" {{ media_sort|default('newest') == 'name' ? 'selected' : '' }}>Name A–Z</option>
              <option value="size" {{ media_sort|default('newest') == 'size' ? 'selected' : '' }}>Largest</option>
            </select>
          </label>
          <label class="admin-media-filter-label">
            <span class="admin-media-filter-name">Per page</span>
            <select class="admin-select admin-select--sm" name="per_page" onchange="this.form.submit()">
              {% for n in per_page_choices|default([24, 48, 96]) %}
                <option value="{{ n }}" {{ per_page|default(24) == n ? 'selected' : '' }}>{{ n }}</option>
              {% endfor %}
            </select>
          </label>
        </form>
      </div>
      <form class="admin-media-search" method="get" action="{{ url_for('admin.media.index') }}">
        {% if current_filter and current_filter.mode == 'unfiled' %}
          <input type="hidden" name="folder" value="unfiled" />
        {% elseif current_filter and current_filter.mode == 'folder' and current_filter.folderId %}
          <input type="hidden" name="folder" value="{{ current_filter.folderId }}" />
        {% endif %}
        {% if media_view == 'list' %}
          <input type="hidden" name="view" value="list" />
        {% endif %}
        {% if media_sort|default('newest') != 'newest' %}
          <input type="hidden" name="sort" value="{{ media_sort|e('html_attr') }}" />
        {% endif %}
        {% if per_page|default(24) != 24 %}
          <input type="hidden" name="per_page" value="{{ per_page }}" />
        {% endif %}
        <input class="admin-input admin-media-search-input admin-search-field" type="search" id="admin-media-search-input" name="q" value="{{ search_q|e('html_attr') }}" placeholder="Search filenames… (/)" autocomplete="off" />
        <button type="submit" class="admin-btn-ghost admin-media-search-btn">Search</button>
        {% if search_q %}
          <a class="admin-link" href="{{ url_for('admin.media.index', {}, current_filter and current_filter.mode != 'all' ? mq_base : media_mq_all|default({})) }}">Clear</a>
        {% endif %}
      </form>
    </div>
    </div>

    {% if media_rows is empty %}
      {{ ui.empty_state(
        search_q ? 'No matches' : 'No files yet',
        search_q ? 'Try another search term or clear filters.' : 'Drag images into the upload zone above.',
        null,
        null,
        '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>'
      ) }}
    {% else %}
      {% set mq = mq_base|default({}) %}

      <form id="admin-media-bulk-form" method="post" action="{{ url_for('admin.media.bulk_delete') }}" class="admin-media-bulk-form" hidden aria-hidden="true">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <input type="hidden" name="return_page" value="{{ page }}" />
        <input type="hidden" name="return_q" value="{{ search_q|e('html_attr') }}" />
        <input type="hidden" name="return_view" value="{{ media_view|e('html_attr') }}" />
        <input type="hidden" name="return_sort" value="{{ media_sort|default('newest')|e('html_attr') }}" />
        <input type="hidden" name="return_per_page" value="{{ per_page|default(24) }}" />
        <input type="hidden" name="return_folder" value="{{ return_folder|e('html_attr') }}" />
      </form>

      <form id="admin-media-bulk-move-form" method="post" action="{{ url_for('admin.media.bulk_move') }}" class="admin-media-bulk-form" hidden aria-hidden="true">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <input type="hidden" name="return_page" value="{{ page }}" />
        <input type="hidden" name="return_q" value="{{ search_q|e('html_attr') }}" />
        <input type="hidden" name="return_view" value="{{ media_view|e('html_attr') }}" />
        <input type="hidden" name="return_sort" value="{{ media_sort|default('newest')|e('html_attr') }}" />
        <input type="hidden" name="return_per_page" value="{{ per_page|default(24) }}" />
        <input type="hidden" name="return_folder" value="{{ return_folder|e('html_attr') }}" />
        <input type="hidden" name="target_folder_id" id="admin-media-bulk-move-target" value="" />
      </form>

      <div class="admin-media-bulk-bar admin-toolbar admin-toolbar--spread" id="admin-media-bulk-bar">
        <div class="admin-media-bulk-start">
          <label class="admin-media-bulk-select-all">
            <input type="checkbox" id="admin-media-select-all" autocomplete="off" />
            <span>Select all on page</span>
          </label>
          <span class="admin-media-bulk-count" id="admin-media-bulk-count" hidden></span>
        </div>
        <button
          type="submit"
          form="admin-media-bulk-form"
          class="admin-btn-danger admin-media-bulk-delete"
          id="admin-media-bulk-delete"
          disabled
        >Delete selected</button>
        <div class="admin-media-bulk-move">
          <label class="admin-media-bulk-move-label">
            <span class="admin-table-muted">Move to</span>
            <select class="admin-select admin-select--sm" id="admin-media-bulk-move-select" disabled>
              <option value="unfiled">Unfiled</option>
              {% for opt in media_folder_options|default([]) %}
                <option value="{{ opt.id }}">{{ opt.label|e }}</option>
              {% endfor %}
            </select>
          </label>
          <button type="button" class="admin-btn-ghost admin-media-bulk-move-btn" id="admin-media-bulk-move" disabled>Move</button>
        </div>
      </div>

      <p class="admin-media-count">
        {{ total }} file{% if total != 1 %}s{% endif %}{% if search_q %} matching “{{ search_q|e }}”{% endif %}
        {% if total_pages > 1 %} · showing {{ ((page - 1) * per_page) + 1 }}–{{ page * per_page > total ? total : page * per_page }} · page {{ page }} of {{ total_pages }}{% endif %}
      </p>

      {% if media_view == 'list' %}
        <div class="admin-table-wrap admin-table-wrap--media">
          <table class="admin-table">
            <thead>
              <tr>
                <th class="admin-table-col-select" scope="col">
                  <span class="admin-table-muted">Sel</span>
                </th>
                <th class="admin-table-col-thumb" scope="col">Preview</th>
                <th scope="col">File</th>
                <th scope="col">Type</th>
                <th scope="col">Size</th>
                <th scope="col">Uploaded</th>
                <th scope="col">By</th>
                <th class="admin-table-col-actions" scope="col"><span class="admin-table-muted">Actions</span></th>
              </tr>
            </thead>
            <tbody>
              {% for row in media_rows %}
                {% set is_img = row.mime_type|slice(0, 6) == 'image/' %}
                {% set thumb = media_url(row.id) %}
                <tr>
                  <td>
                    <input
                      type="checkbox"
                      form="admin-media-bulk-form"
                      name="ids[]"
                      value="{{ row.id }}"
                      class="admin-media-row-cb"
                      autocomplete="off"
                      aria-label="Select {{ row.original_name|e('html_attr') }}"
                    />
                  </td>
                  <td>
                    {% if is_img and thumb != '' %}
                      <button
                        type="button"
                        class="admin-media-thumb-link admin-media-preview-trigger"
                        title="Preview"
                        data-preview-src="{{ thumb|e('html_attr') }}"
                        data-preview-name="{{ row.original_name|e('html_attr') }}"
                        data-preview-edit="{{ url_for('admin.media.edit', { id: row.id })|e('html_attr') }}"
                        {% if row.path %}data-preview-copy="{{ row.path|e('html_attr') }}"{% endif %}
                      >
                        <img src="{{ thumb|e('html_attr') }}" alt="" class="admin-media-thumb" width="56" height="56" loading="lazy" decoding="async" />
                      </button>
                    {% else %}
                      <span class="admin-media-thumb admin-media-thumb--placeholder" title="No preview">?</span>
                    {% endif %}
                  </td>
                  <td>
                    <strong class="admin-media-name">{{ row.original_name|e }}</strong>
                    <div class="admin-table-muted admin-media-stored">{{ row.filename|e }}</div>
                  </td>
                  <td class="admin-table-muted"><span class="admin-badge admin-badge--muted">{{ row.extension|upper|e }}</span></td>
                  <td class="admin-table-muted">
                    {% set b = row.file_size %}
                    {% if b < 1024 %}{{ b }} B{% elseif b < 1048576 %}{{ (b / 1024)|round(1) }} KB{% else %}{{ (b / 1048576)|round(2) }} MB{% endif %}
                  </td>
                  <td class="admin-table-muted">{{ row.created_at|slice(0, 16)|replace({'T': ' '}) }}</td>
                  <td class="admin-table-muted">{{ row.uploader_email|default('—')|e }}</td>
                  <td class="admin-table-actions">
                    <div class="admin-media-row-actions">
                      {% if row.path %}
                        <button type="button" class="admin-btn-ghost admin-btn-ghost--sm admin-media-copy" data-copy-url="{{ row.path|e('html_attr') }}">Copy URL</button>
                      {% endif %}
                      <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for('admin.media.edit', { id: row.id }) }}">Edit</a>
                    </div>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% else %}
        <ul class="admin-media-gallery admin-media-gallery--rich" role="list">
          {% for row in media_rows %}
            {% set is_img = row.mime_type|slice(0, 6) == 'image/' %}
            {% set thumb = media_url(row.id) %}
            <li class="admin-media-gallery-card" data-media-id="{{ row.id }}">
              <label class="admin-media-gallery-select" title="Select {{ row.original_name|e('html_attr') }}">
                <input
                  type="checkbox"
                  form="admin-media-bulk-form"
                  name="ids[]"
                  value="{{ row.id }}"
                  class="admin-media-row-cb"
                  autocomplete="off"
                  aria-label="Select {{ row.original_name|e('html_attr') }}"
                />
              </label>
              <div class="admin-media-gallery-visual">
                {% if is_img and thumb != '' %}
                  <button
                    type="button"
                    class="admin-media-gallery-preview admin-media-preview-trigger"
                    title="Preview {{ row.original_name|e('html_attr') }}"
                    data-preview-src="{{ thumb|e('html_attr') }}"
                    data-preview-name="{{ row.original_name|e('html_attr') }}"
                    data-preview-edit="{{ url_for('admin.media.edit', { id: row.id })|e('html_attr') }}"
                    {% if row.path %}data-preview-copy="{{ row.path|e('html_attr') }}"{% endif %}
                  >
                    <img src="{{ thumb|e('html_attr') }}" alt="" class="admin-media-gallery-img" width="480" height="480" loading="lazy" decoding="async" />
                  </button>
                {% else %}
                  <span class="admin-media-gallery-placeholder" title="No preview">?</span>
                {% endif %}
                <div class="admin-media-gallery-overlay">
                  <a href="{{ url_for('admin.media.edit', { id: row.id }) }}" class="admin-media-gallery-action">Edit</a>
                  {% if row.path %}
                    <button type="button" class="admin-media-gallery-action admin-media-copy" data-copy-url="{{ row.path|e('html_attr') }}">Copy URL</button>
                  {% endif %}
                </div>
              </div>
              <div class="admin-media-gallery-body">
                <a href="{{ url_for('admin.media.edit', { id: row.id }) }}" class="admin-media-gallery-title" title="{{ row.original_name|e('html_attr') }}">{{ row.original_name|e }}</a>
                <div class="admin-media-gallery-meta">
                  <span class="admin-badge admin-badge--muted">{{ row.extension|upper|e }}</span>
                  {% set b = row.file_size %}
                  <span class="admin-media-gallery-size">
                    {% if b < 1024 %}{{ b }} B{% elseif b < 1048576 %}{{ (b / 1024)|round(1) }} KB{% else %}{{ (b / 1048576)|round(2) }} MB{% endif %}
                  </span>
                  {% if row.width and row.height %}
                    <span class="admin-media-gallery-dims">{{ row.width }}×{{ row.height }}</span>
                  {% endif %}
                </div>
                <div class="admin-media-gallery-foot">
                  <span class="admin-table-muted admin-media-gallery-date">{{ row.created_at|slice(0, 10) }}</span>
                  <details class="admin-actions-menu">
                    <summary class="admin-actions-menu-trigger" aria-label="Actions for {{ row.original_name|e('html_attr') }}">⋯</summary>
                    <div class="admin-actions-menu-panel">
                      <a href="{{ url_for('admin.media.edit', { id: row.id }) }}">Edit metadata</a>
                      <form method="post" action="{{ url_for('admin.media.delete', { id: row.id }) }}" onsubmit="return confirm('Delete this file permanently?');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                        <button type="submit" class="admin-actions-danger">Delete</button>
                      </form>
                    </div>
                  </details>
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      {{ ui.pagination('admin.media.index', page, total_pages, mq, 'Media library pages') }}
    {% endif %}
      </div>{# .admin-media-library-main #}
    </div>{# .admin-media-library-layout #}

    <div id="admin-media-lightbox" class="admin-media-lightbox" hidden role="dialog" aria-modal="true" aria-labelledby="admin-media-lightbox-title">
      <button type="button" class="admin-media-lightbox-backdrop" id="admin-media-lightbox-backdrop" aria-label="Close preview"></button>
      <div class="admin-media-lightbox-panel">
        <header class="admin-media-lightbox-head">
          <h2 class="admin-media-lightbox-title" id="admin-media-lightbox-title">Preview</h2>
          <button type="button" class="admin-media-lightbox-close" id="admin-media-lightbox-close" aria-label="Close">×</button>
        </header>
        <div class="admin-media-lightbox-body">
          <img id="admin-media-lightbox-img" class="admin-media-lightbox-img" src="" alt="" />
        </div>
        <footer class="admin-media-lightbox-foot">
          <a class="admin-btn-ghost admin-btn-ghost--sm" id="admin-media-lightbox-edit" href="#">Edit metadata</a>
          <button type="button" class="admin-btn-ghost admin-btn-ghost--sm admin-media-copy" id="admin-media-lightbox-copy">Copy URL</button>
        </footer>
      </div>
    </div>
  </div>
{% endblock %}

{% block admin_scripts %}
  <script src="{{ asset('js/admin-media-library.js') }}" defer></script>
{% endblock %}
