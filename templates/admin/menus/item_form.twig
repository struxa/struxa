{% extends 'admin/base.twig' %}

{% block admin_title %}{{ item ? 'Edit link' : 'Add link' }}{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ item ? 'Edit menu link' : 'Add menu link' }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.menus.edit', { id: menu.id }) }}">Back to {{ menu.name|e }}</a>
  </p>
{% endblock %}

{% block admin_content %}
  {% set o = old is defined and old is not empty ? old : null %}
  {% set lbl = o ? o.label : (item ? item.label : '') %}
  {% set u = o ? o.url : (item ? item.url : '') %}
  {% set pid = o ? o.page_id : (item and item.pageId ? (item.pageId ~ '') : '') %}
  {% set so = o ? o.sort_order : (item ? (item.sortOrder ~ '') : '0') %}
  {% set tg = o ? o.target : (item ? item.target : '_self') %}
  {% set cc = o ? o.css_class : (item ? item.cssClass : '') %}

  <form class="admin-form" method="post" action="{{ item ? url_for('admin.menus.items.update', { id: menu.id, itemId: item.id }) : url_for('admin.menus.items.store', { id: menu.id }) }}">
    <div class="admin-form-grid">
      <div class="admin-field admin-field--full {{ errors.label is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="label">Label <span class="admin-req">*</span></label>
        <input class="admin-input" type="text" id="label" name="label" value="{{ lbl|e('html_attr') }}" maxlength="191" required />
        {% if errors.label is defined %}<p class="admin-field-error">{{ errors.label|e }}</p>{% endif %}
      </div>
      <div class="admin-field admin-field--full {{ errors.page_id is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="page_id">Internal page</label>
        <select class="admin-select" id="page_id" name="page_id">
          <option value="">— Custom URL only —</option>
          {% for p in page_options %}
            <option value="{{ p.id }}" {{ pid == (p.id ~ '') ? 'selected' : '' }}>{{ p.title|e }}</option>
          {% endfor %}
        </select>
        <p class="admin-hint">If set, the public site links to the published page. Otherwise use a custom URL below.</p>
        {% if errors.page_id is defined %}<p class="admin-field-error">{{ errors.page_id|e }}</p>{% endif %}
      </div>
      <div class="admin-field admin-field--full {{ errors.url is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="url">Custom URL</label>
        <input class="admin-input" type="text" id="url" name="url" value="{{ u|e('html_attr') }}" maxlength="2000" placeholder="/pricing or https://…" />
        {% if errors.url is defined %}<p class="admin-field-error">{{ errors.url|e }}</p>{% endif %}
      </div>
      <div class="admin-field {{ errors.sort_order is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="sort_order">Sort order</label>
        <input class="admin-input" type="number" id="sort_order" name="sort_order" value="{{ so|e('html_attr') }}" min="0" step="1" />
        {% if errors.sort_order is defined %}<p class="admin-field-error">{{ errors.sort_order|e }}</p>{% endif %}
      </div>
      <div class="admin-field {{ errors.target is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="target">Open in</label>
        <select class="admin-select" id="target" name="target">
          <option value="_self" {{ tg == '_self' ? 'selected' : '' }}>Same tab</option>
          <option value="_blank" {{ tg == '_blank' ? 'selected' : '' }}>New tab</option>
        </select>
        {% if errors.target is defined %}<p class="admin-field-error">{{ errors.target|e }}</p>{% endif %}
      </div>
      <div class="admin-field admin-field--full {{ errors.css_class is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="css_class">CSS class (optional)</label>
        <input class="admin-input" type="text" id="css_class" name="css_class" value="{{ cc|e('html_attr') }}" maxlength="191" placeholder="nav-link nav-link--violet" />
        {% if errors.css_class is defined %}<p class="admin-field-error">{{ errors.css_class|e }}</p>{% endif %}
      </div>
    </div>
    <div class="admin-form-actions">
      <button type="submit" class="admin-btn-primary">{{ item ? 'Update link' : 'Add link' }}</button>
      <a class="admin-link" href="{{ url_for('admin.menus.edit', { id: menu.id }) }}">Cancel</a>
    </div>
  </form>
{% endblock %}
