{% extends 'admin/base.twig' %}

{% block admin_title %}Edit menu{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Edit menu</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">
    <a class="admin-link" href="{{ url_for('admin.menus.index') }}">← Menus</a>
    <span class="admin-hero-sub-dot" aria-hidden="true">·</span>
    <code class="admin-inline-code">{{ menu.location|e }}</code>
    <span class="admin-hero-sub-dot" aria-hidden="true">·</span>
    <span class="admin-table-muted">{{ menu.name|e }}</span>
  </p>
{% endblock %}

{% block admin_content %}
  {% set mn = menu_old|default(null) %}
  {% set me = menu_errors|default({}) %}

  <div class="admin-settings-page admin-menu-edit-page">
    <section class="admin-card admin-settings-card admin-menu-edit-card">
      <h2 class="admin-settings-card-title">Menu details</h2>
      <p class="admin-settings-card-desc">Name is internal; placement chooses where the theme renders this menu.</p>
      <form class="admin-form" method="post" action="{{ url_for('admin.menus.update', { id: menu.id }) }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <div class="admin-form-grid admin-form-grid--2col-tight">
          <div class="admin-field admin-field--full {{ me.name is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="name">Menu name <span class="admin-req">*</span></label>
            <input class="admin-input" type="text" id="name" name="name" value="{{ mn ? mn.name|e('html_attr') : menu.name|e('html_attr') }}" maxlength="160" required />
            {% if me.name is defined %}<p class="admin-field-error">{{ me.name|e }}</p>{% endif %}
          </div>
          <div class="admin-field admin-field--full {{ me.location is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="location">Placement <span class="admin-req">*</span></label>
            {% set loc = mn ? mn.location : menu.location %}
            <select class="admin-select" id="location" name="location" required>
              <option value="header" {{ loc == 'header' ? 'selected' : '' }}>Header</option>
              <option value="footer" {{ loc == 'footer' ? 'selected' : '' }}>Footer</option>
            </select>
            {% if me.location is defined %}<p class="admin-field-error">{{ me.location|e }}</p>{% endif %}
          </div>
        </div>
        <div class="admin-form-actions admin-form-actions--inline">
          <button type="submit" class="admin-btn-primary">Save menu</button>
        </div>
      </form>
    </section>

    <section class="admin-card admin-settings-card admin-menu-edit-card">
      <header class="admin-settings-card-head-row">
        <div>
          <h2 class="admin-settings-card-title">Links</h2>
          <p class="admin-settings-card-desc" style="margin-bottom:0">Drag the handle to reorder, then save. Add pages or custom URLs as needed.</p>
        </div>
        <a class="admin-btn-primary" href="{{ url_for('admin.menus.items.new', { id: menu.id }) }}">Add link</a>
      </header>

      {% if menu_items is empty %}
        <p class="admin-hint admin-settings-card-footnote">Use <strong>Add link</strong> to attach a page or external URL.</p>
      {% else %}
        <form id="menu-reorder-form" method="post" action="{{ url_for('admin.menus.items.reorder', { id: menu.id }) }}" hidden aria-hidden="true">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        </form>
        <ul class="admin-menu-sort" id="admin-menu-sort-list" role="list">
          {% for it in menu_items %}
            <li class="admin-menu-sort-item" data-item-id="{{ it.id }}" role="listitem">
              <button type="button" class="admin-menu-sort-handle" tabindex="-1" aria-hidden="true" title="Drag to reorder">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="9" cy="6" r="1.5"/><circle cx="15" cy="6" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="9" cy="18" r="1.5"/><circle cx="15" cy="18" r="1.5"/></svg>
              </button>
              <div class="admin-menu-sort-body">
                <strong class="admin-menu-sort-label">{{ it.label|e }}</strong>
                {% if it.pageId %}
                  <span class="admin-menu-sort-meta">Page #{{ it.pageId }}</span>
                {% elseif it.url %}
                  <code class="admin-inline-code admin-menu-sort-meta">{{ it.url|e }}</code>
                {% endif %}
              </div>
              <div class="admin-menu-sort-actions">
                <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for('admin.menus.items.edit', { id: menu.id, itemId: it.id }) }}">Edit</a>
                <form class="admin-inline-form" method="post" action="{{ url_for('admin.menus.items.delete', { id: menu.id, itemId: it.id }) }}" onsubmit="return confirm('Remove this link?');">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                  <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm admin-btn-danger-text">Remove</button>
                </form>
              </div>
            </li>
          {% endfor %}
        </ul>
        <div class="admin-form-actions admin-form-actions--inline">
          <button type="button" class="admin-btn-primary" id="admin-menu-sort-save">Save order</button>
        </div>
      {% endif %}
    </section>

    <section class="admin-card admin-settings-card admin-menu-edit-card admin-menu-edit-card--danger">
      <h2 class="admin-settings-card-title">Danger zone</h2>
      <p class="admin-settings-card-desc">Deleting removes this menu and every link. This cannot be undone.</p>
      <form class="admin-inline-form" method="post" action="{{ url_for('admin.menus.delete', { id: menu.id }) }}" onsubmit="return confirm('Delete this menu and all links?');">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <button type="submit" class="admin-btn-danger">Delete menu</button>
      </form>
    </section>
  </div>
{% endblock %}

{% block admin_scripts %}
  {% if menu_items is not empty %}
    <script src="{{ asset('js/admin-menus-reorder.js') }}" defer></script>
  {% endif %}
{% endblock %}
