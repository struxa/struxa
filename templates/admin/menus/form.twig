{% extends 'admin/base.twig' %}

{% block admin_title %}New menu{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">New menu</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub"><a class="admin-link" href="{{ url_for('admin.menus.index') }}">Back to menus</a></p>
{% endblock %}

{% block admin_content %}
  <form class="admin-form" method="post" action="{{ url_for('admin.menus.store') }}">
    <div class="admin-form-grid">
      <div class="admin-field admin-field--full {{ errors.name is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="name">Menu name <span class="admin-req">*</span></label>
        <input class="admin-input" type="text" id="name" name="name" value="{{ old.name|default('')|e('html_attr') }}" maxlength="160" required />
        {% if errors.name is defined %}<p class="admin-field-error">{{ errors.name|e }}</p>{% endif %}
      </div>
      <div class="admin-field admin-field--full {{ errors.location is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="location">Placement <span class="admin-req">*</span></label>
        {% set loc = old.location|default('header') %}
        <select class="admin-select" id="location" name="location" required>
          <option value="header" {{ loc == 'header' ? 'selected' : '' }}>Header</option>
          <option value="footer" {{ loc == 'footer' ? 'selected' : '' }}>Footer</option>
        </select>
        {% if errors.location is defined %}<p class="admin-field-error">{{ errors.location|e }}</p>{% endif %}
      </div>
    </div>
    <div class="admin-form-actions">
      <button type="submit" class="admin-btn-primary">Create menu</button>
      <a class="admin-link" href="{{ url_for('admin.menus.index') }}">Cancel</a>
    </div>
  </form>
{% endblock %}
