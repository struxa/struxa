{# Reusable admin UI fragments — {% import 'admin/_ui_macros.twig' as ui %} #}

{% macro status_badge(status) %}
  {% set st = status|default('') %}
  {% set badge = 'admin-badge admin-badge--muted' %}
  {% if st == 'published' %}{% set badge = 'admin-badge admin-badge--ok' %}
  {% elseif st == 'draft' %}{% set badge = 'admin-badge admin-badge--draft' %}
  {% elseif st == 'in_review' %}{% set badge = 'admin-badge admin-badge--review' %}
  {% elseif st == 'approved' %}{% set badge = 'admin-badge admin-badge--approved' %}
  {% elseif st == 'archived' %}{% set badge = 'admin-badge admin-badge--archived' %}
  {% endif %}
  <span class="{{ badge }}">{{ st|replace({'_': ' '})|e }}</span>
{% endmacro %}

{% macro empty_state(title, text, primary_href, primary_label, icon) %}
  <div class="admin-empty admin-empty--premium" role="status">
    <div class="admin-empty-icon" aria-hidden="true">{{ icon|default('')|raw }}</div>
    <p class="admin-empty-title">{{ title|e }}</p>
    <p class="admin-empty-text">{{ text|e }}</p>
    {% if primary_href and primary_label %}
      <a class="admin-btn-primary admin-empty-cta" href="{{ primary_href|e('html_attr') }}">{{ primary_label|e }}</a>
    {% endif %}
  </div>
{% endmacro %}

{% macro pagination(route_name, page, total_pages, query = {}, aria_label = 'Pagination') %}
  {% if total_pages > 1 %}
    <nav class="admin-pagination admin-pagination--numbered" aria-label="{{ aria_label|e('html_attr') }}">
      {% if page > 1 %}
        <a class="admin-pagination-btn" href="{{ url_for(route_name, {}, query|merge({ page: 1 })) }}" aria-label="First page">First</a>
        <a class="admin-pagination-btn" href="{{ url_for(route_name, {}, query|merge({ page: page - 1 })) }}">Previous</a>
      {% endif %}
      {% for p in 1..total_pages %}
        {% if total_pages <= 9 or p == 1 or p == total_pages or (p >= page - 2 and p <= page + 2) %}
          {% if p == page %}
            <span class="admin-pagination-num is-current" aria-current="page">{{ p }}</span>
          {% else %}
            <a class="admin-pagination-num" href="{{ url_for(route_name, {}, query|merge({ page: p })) }}">{{ p }}</a>
          {% endif %}
        {% endif %}
      {% endfor %}
      {% if page < total_pages %}
        <a class="admin-pagination-btn" href="{{ url_for(route_name, {}, query|merge({ page: page + 1 })) }}">Next</a>
        <a class="admin-pagination-btn" href="{{ url_for(route_name, {}, query|merge({ page: total_pages })) }}" aria-label="Last page">Last</a>
      {% endif %}
      <span class="admin-pagination-status">{{ page }} / {{ total_pages }}</span>
    </nav>
  {% endif %}
{% endmacro %}
