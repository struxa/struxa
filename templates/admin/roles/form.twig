{% extends 'admin/base.twig' %}

{% set is_edit = form_mode == 'edit' %}
{% set o = old ?? {} %}
{% set r = role %}

{% block admin_title %}{{ is_edit ? 'Edit role' : 'New role' }}{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ is_edit ? 'Edit role' : 'New role' }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">
    <a class="admin-link" href="{{ url_for('admin.roles.index') }}">← Roles</a>
    {% if is_edit %}
      <span class="admin-hero-sub-dot" aria-hidden="true">·</span>
      <code class="admin-inline-code">{{ r.slug|e }}</code>
      {% if r.is_system %}<span class="admin-badge admin-badge--muted" style="margin-left:0.35rem">System</span>{% endif %}
    {% endif %}
  </p>
{% endblock %}

{% block admin_content %}
  <form class="admin-form admin-role-edit-form" method="post" action="{{ is_edit ? url_for('admin.roles.update', { id: r.id }) : url_for('admin.roles.store') }}">
    <div class="admin-role-edit-stack">
      <section class="admin-card admin-settings-card admin-role-edit-card">
        <h2 class="admin-settings-card-title">Role details</h2>
        <p class="admin-settings-card-desc">Human-readable name and URL-safe slug. System roles keep a fixed slug; you can still adjust permissions.</p>
        <div class="admin-form-grid">
          <div class="admin-field admin-field--full {{ errors.name is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="r-name">Name <span class="admin-req">*</span></label>
            <input class="admin-input" id="r-name" name="name" type="text" value="{{ o.name|default(r ? r.name : '')|e }}" required />
            {% if errors.name is defined %}<p class="admin-field-error">{{ errors.name|e }}</p>{% endif %}
          </div>
          <div class="admin-field admin-field--full {{ errors.slug is defined ? 'admin-field--error' : '' }}">
            <label class="admin-label" for="r-slug">Slug <span class="admin-req">*</span></label>
            <input class="admin-input" id="r-slug" name="slug" type="text" value="{{ o.slug|default(r ? r.slug : '')|e }}" {{ r and r.is_system ? 'readonly' : '' }} required />
            {% if errors.slug is defined %}<p class="admin-field-error">{{ errors.slug|e }}</p>{% endif %}
            {% if r and r.is_system %}<p class="admin-hint">System role — slug cannot be changed.</p>{% endif %}
          </div>
          <div class="admin-field admin-field--full">
            <label class="admin-label" for="r-desc">Description</label>
            <textarea class="admin-textarea" id="r-desc" name="description" rows="3" placeholder="Optional note for other admins">{{ o.description|default(r ? (r.description ?? '') : '')|e }}</textarea>
          </div>
        </div>
      </section>

      <section class="admin-card admin-settings-card admin-role-edit-card">
        <h2 class="admin-settings-card-title">Permissions</h2>
        <p class="admin-settings-card-desc">Grant only what this role needs. Users inherit permissions from every role assigned to them.</p>
        <div class="admin-role-perm-panel" role="group" aria-label="Permission checklist">
          {% for p in all_permissions %}
            <label class="admin-role-perm-row">
              <input type="checkbox" name="permission_ids[]" value="{{ p.id }}" {{ p.id in selected_perm_ids ? 'checked' : '' }} />
              <span class="admin-role-perm-body">
                <span class="admin-role-perm-name">{{ p.name|e }}</span>
                <code class="admin-inline-code admin-role-perm-slug">{{ p.slug|e }}</code>
              </span>
            </label>
          {% endfor %}
        </div>
      </section>
    </div>

    <div class="admin-form-sticky-bar admin-role-edit-sticky">
      <div class="admin-form-sticky-inner">
        <button class="admin-btn-primary" type="submit">Save role</button>
        <a class="admin-btn-ghost" href="{{ url_for('admin.roles.index') }}">Cancel</a>
      </div>
    </div>
  </form>
{% endblock %}
