{% extends 'admin/base.twig' %}

{% block admin_title %}Blueprints{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Blueprints</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">Full-site structure packages — content types, fields, taxonomies, menus, and settings as JSON.</p>
{% endblock %}

{% block admin_content %}
  <div class="admin-settings-page admin-settings-page--portability">
    {% include 'admin/tools/_portability_subnav.twig' with { portability_nav_active: 'blueprints' } %}

    <div class="admin-settings-intro admin-settings-intro--blueprints">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">Clone or bootstrap a site structure</p>
        <p class="admin-settings-intro-text">
          Blueprints are JSON <strong class="admin-settings-intro-strong">recipes</strong> stored in
          <code class="admin-inline-code">storage/blueprints/</code> or downloaded from this screen.
          <strong class="admin-settings-intro-strong">Validate first</strong>, then apply — merge mode adds missing slugs without overwriting existing rows.
          For partial exports (menus only, etc.) use <a class="admin-link" href="{{ url_for('admin.tools.import_export') }}">Import / export</a>.
        </p>
      </div>
    </div>

    <div class="admin-metrics admin-hub-metrics" aria-label="Blueprint summary">
      <article class="admin-metric">
        <p class="admin-metric-label">Stored files</p>
        <p class="admin-metric-value">{{ blueprint_files|length }}</p>
        <p class="admin-metric-meta"><code class="admin-inline-code">storage/blueprints/</code></p>
      </article>
      {% if site_profile %}
        <article class="admin-metric">
          <p class="admin-metric-label">CMS version</p>
          <p class="admin-metric-value admin-metric-value--sm">{{ site_profile.cms_version_installed|e }}</p>
          <p class="admin-metric-meta">Runtime {{ cms_version|e }}</p>
        </article>
      {% endif %}
    </div>

    <div class="admin-settings-stack">
      {% if site_profile %}
        <div class="admin-settings-row2">
          <section class="admin-card admin-settings-card admin-settings-card--fill admin-settings-section" id="blueprint-profile">
            <h2 class="admin-settings-card-title">Site profile</h2>
            <p class="admin-settings-card-desc">UUID and install metadata included in exported packages.</p>
            <dl class="admin-hub-info-dl">
              <div class="admin-hub-info-row">
                <dt>Site UUID</dt>
                <dd><code class="admin-inline-code">{{ site_profile.site_uuid|e }}</code></dd>
              </div>
              <div class="admin-hub-info-row">
                <dt>Created</dt>
                <dd>{{ site_profile.created_at|e }}</dd>
              </div>
            </dl>
            <form class="admin-form admin-settings-form" method="post" action="{{ url_for('admin.tools.site_profile') }}">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
              <div class="admin-form-grid">
                <div class="admin-field">
                  <label class="admin-label" for="pn">Project name</label>
                  <input class="admin-input" id="pn" name="project_name" type="text" value="{{ site_profile.project_name|default('')|e }}" maxlength="200" />
                </div>
                <div class="admin-field">
                  <label class="admin-label" for="env">Environment label</label>
                  <input class="admin-input" id="env" name="environment_label" type="text" value="{{ site_profile.environment_label|default('')|e }}" placeholder="production, staging…" maxlength="64" />
                </div>
              </div>
              <div class="admin-form-actions">
                <button type="submit" class="admin-btn-primary">Save profile</button>
              </div>
            </form>
          </section>

          <section class="admin-card admin-settings-card admin-settings-card--fill admin-settings-section" id="blueprint-files">
            <h2 class="admin-settings-card-title">Stored blueprints</h2>
            <p class="admin-settings-card-desc">JSON files on the server — import recipes, not live database content.</p>
            {% if blueprint_files is empty %}
              <p class="admin-hint admin-settings-card-footnote">No files yet. Export below or save a snapshot to this folder.</p>
            {% else %}
              <div class="admin-table-wrap" style="margin-top:0.85rem">
                <table class="admin-table admin-table--comfortable">
                  <thead><tr><th>File</th><th>Label</th><th>Size</th></tr></thead>
                  <tbody>
                    {% for f in blueprint_files %}
                      <tr>
                        <td><code class="admin-inline-code">{{ f.filename|e }}</code></td>
                        <td>{{ f.label|e }}</td>
                        <td class="admin-table-muted">{{ f.bytes }} B</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% endif %}
          </section>
        </div>
      {% endif %}

      <section class="admin-card admin-settings-card admin-settings-section" id="blueprint-export">
        <h2 class="admin-settings-card-title">Export current structure</h2>
        <p class="admin-settings-card-desc">Download a blueprint JSON or save a copy to <code class="admin-inline-code">storage/blueprints/</code>.</p>
        <form class="admin-form admin-settings-form" method="post" action="{{ url_for('admin.tools.blueprints.export_download') }}">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="ex-label">Blueprint label</label>
              <input class="admin-input" id="ex-label" name="label" type="text" value="My site blueprint" maxlength="160" />
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="include_entries" value="1" />
                Include sample content entries (up to 100 per type)
              </label>
            </div>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="admin-btn-primary">Download JSON</button>
          </div>
        </form>
        <form class="admin-form admin-settings-form admin-hub-form-divider" method="post" action="{{ url_for('admin.tools.blueprints.save') }}">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <div class="admin-form-grid">
            <div class="admin-field">
              <label class="admin-label" for="sv-label">Save as label</label>
              <input class="admin-input" id="sv-label" name="label" type="text" value="saved-blueprint" />
            </div>
            <div class="admin-field">
              <label class="admin-label" for="sv-base">Filename (no .json)</label>
              <input class="admin-input" id="sv-base" name="basename" type="text" placeholder="auto from label" pattern="[a-z0-9][a-z0-9\-]*" />
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="include_entries" value="1" />
                Include entries
              </label>
            </div>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="admin-btn-ghost">Save to storage/blueprints</button>
          </div>
        </form>
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="blueprint-import">
        <h2 class="admin-settings-card-title">Import blueprint</h2>
        <p class="admin-settings-card-desc">
          <strong>Validate only</strong> checks JSON and previews changes without writing.
          <strong>Apply to database</strong> runs the import. With merge, existing slugs are kept and only missing pieces are added.
        </p>
        <form class="admin-form admin-settings-form" method="post" action="{{ url_for('admin.tools.blueprints.import') }}" enctype="multipart/form-data">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="imp-file">JSON file</label>
              <input class="admin-input" id="imp-file" name="json_file" type="file" accept=".json,application/json" />
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="imp-ta">Or paste JSON</label>
              <textarea class="admin-textarea" id="imp-ta" name="json_text" rows="8" placeholder="{ &quot;cms_blueprint_version&quot;: &quot;1.0&quot;, … }"></textarea>
            </div>
          </div>
          <div class="admin-scope-grid">
            <input type="hidden" name="merge" value="0" />
            <label class="admin-scope-option"><input type="checkbox" name="merge" value="1" checked /> Merge (recommended — keep existing slugs)</label>
            <label class="admin-scope-option"><input type="checkbox" name="apply_theme" value="1" /> Apply <code class="admin-inline-code">active_theme_slug</code> if theme exists</label>
            <label class="admin-scope-option"><input type="checkbox" name="import_entries" value="1" /> Import content entries from file</label>
          </div>
          <div class="admin-form-actions admin-form-actions--split">
            <button type="submit" name="import_mode" value="dry_run" class="admin-btn-ghost">Validate only</button>
            <button type="submit" name="import_mode" value="apply" class="admin-btn-primary">Apply to database</button>
          </div>
        </form>
      </section>
    </div>
  </div>
{% endblock %}
