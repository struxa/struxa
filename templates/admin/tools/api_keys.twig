{% extends 'admin/base.twig' %}

{% block admin_title %}API keys{% endblock %}

{% block admin_hero_title %}<h1 class="admin-hero-title">Public API keys</h1>{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Keys authenticate <code class="admin-inline-code">/api/v1</code> requests (Bearer or <code class="admin-inline-code">X-Api-Key</code>). Format: <code class="admin-inline-code">prefix.secret</code>. You can also set a single shared key in <code class="admin-inline-code">CMS_PUBLIC_API_KEY</code>.</p>
{% endblock %}

{% block admin_content %}
  {% if new_secret %}
    <div class="admin-card admin-flash admin-flash--success" role="status" style="margin-bottom:1.25rem">
      <p class="admin-card-title" style="margin-top:0">New key (copy now)</p>
      <p class="admin-hint">This value is not stored and cannot be retrieved later.</p>
      <pre class="admin-inline-code" style="white-space:pre-wrap;word-break:break-all;margin:0.5rem 0 0;padding:0.75rem;background:rgba(0,0,0,0.06);border-radius:6px">{{ new_secret|e }}</pre>
    </div>
  {% endif %}

  <section class="admin-card" style="margin-bottom:1.25rem">
    <h2 class="admin-card-title">Create key</h2>
    <form class="admin-form" method="post" action="{{ url_for('admin.tools.api_keys.create') }}">
      <div class="admin-field admin-field--full">
        <label class="admin-label" for="apk_name">Label</label>
        <input class="admin-input" id="apk_name" name="name" type="text" required maxlength="160" placeholder="e.g. Marketing site" />
      </div>
      <p class="admin-label">Scopes</p>
      <div style="display:grid;gap:0.35rem;margin:0.35rem 0 0.75rem">
        <label><input type="checkbox" name="scopes[]" value="read" checked /> read — published content and pages</label>
        <label><input type="checkbox" name="scopes[]" value="read_drafts" /> read_drafts — non-published entries, types without a public URL</label>
        <label><input type="checkbox" name="scopes[]" value="write" /> write — create and update entries via POST/PATCH</label>
      </div>
      <button type="submit" class="admin-btn-primary">Generate key</button>
    </form>
  </section>

  <section class="admin-card">
    <h2 class="admin-card-title">Existing keys</h2>
    {% if api_keys is empty %}
      <p class="admin-hint">No database keys yet. Use env <code class="admin-inline-code">CMS_PUBLIC_API_KEY</code> or create a key above.</p>
    {% else %}
      <div class="admin-table-wrap" style="overflow-x:auto">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Label</th>
              <th>Prefix</th>
              <th>Scopes</th>
              <th>Last used</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for row in api_keys %}
              <tr>
                <td>{{ row.name|e }}</td>
                <td><code class="admin-inline-code">{{ row.prefix|e }}</code></td>
                <td>{{ row.scopes_list|join(', ')|e }}</td>
                <td>{% if row.last_used_at %}{{ row.last_used_at|e }}{% else %}—{% endif %}</td>
                <td>{% if row.revoked_at %}Revoked{% else %}Active{% endif %}</td>
                <td>
                  {% if not row.revoked_at %}
                    <form method="post" action="{{ url_for('admin.tools.api_keys.revoke', { id: row.id }) }}" style="display:inline" onsubmit="return confirm('Revoke this key? Clients using it will fail immediately.');">
                      <button type="submit" class="admin-btn-ghost">Revoke</button>
                    </form>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </section>
{% endblock %}
