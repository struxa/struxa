{% extends 'admin/base.twig' %}

{% block admin_title %}Site health{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Site health</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">Pass/fail checks for PHP, database, storage, scheduling, security, and active plugins.</p>
{% endblock %}

{% block admin_breadcrumbs %}
  {% include 'admin/partials/_breadcrumbs.twig' with {
    breadcrumbs: [
      { label: 'Site health' },
    ],
  } %}
{% endblock %}

{% block admin_content %}
  {% set overall = health_overall|default('good') %}
  {% set counts = health_counts|default({}) %}
  {% set status_labels = health_status_labels|default({}) %}
  {% set group_labels = health_group_labels|default({}) %}
  {% set good_n = counts.good|default(0) %}
  {% set rec_n = counts.recommended|default(0) %}
  {% set crit_n = counts.critical|default(0) %}

  <div class="admin-settings-page admin-settings-page--tools">
    {% include 'admin/tools/_subnav.twig' with { tools_nav_active: 'site_health' } %}

    <div class="admin-settings-intro admin-settings-intro--health">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">
          {% if overall == 'good' %}
            This install looks healthy
          {% elseif overall == 'recommended' %}
            No critical blockers — review recommendations
          {% else %}
            Critical issues need attention
          {% endif %}
        </p>
        <p class="admin-settings-intro-text">
          {% if overall == 'good' %}
            Review recommended items when you have time. Checks run against your server, database, and active plugins — not your page content.
          {% elseif overall == 'recommended' %}
            Address recommended improvements before production traffic. Critical checks are clear.
          {% else %}
            Fix critical failures before you rely on this site in production. Use the action links in each row when available.
          {% endif %}
        </p>
      </div>
      <span class="admin-pill admin-health-pill admin-health-pill--{{ overall|e('html_attr') }} admin-tools-overall-pill">
        {{ status_labels[overall]|default(overall|title) }}
      </span>
    </div>

    <div class="admin-metrics admin-hub-metrics" aria-label="Health summary">
      <article class="admin-metric admin-metric--health-good">
        <p class="admin-metric-label">Good</p>
        <p class="admin-metric-value">{{ good_n }}</p>
        <p class="admin-metric-meta">Checks passed</p>
      </article>
      <article class="admin-metric admin-metric--health-rec{% if rec_n > 0 %} admin-metric--hot{% endif %}">
        <p class="admin-metric-label">Recommended</p>
        <p class="admin-metric-value">{{ rec_n }}</p>
        <p class="admin-metric-meta">Worth improving</p>
      </article>
      <article class="admin-metric admin-metric--health-crit{% if crit_n > 0 %} admin-metric--danger{% endif %}">
        <p class="admin-metric-label">Critical</p>
        <p class="admin-metric-value">{{ crit_n }}</p>
        <p class="admin-metric-meta">Needs action</p>
      </article>
    </div>

    <div class="admin-settings-stack">
      {% for group_key, checks in health_groups|default({}) %}
        {% set group_crit = checks|filter(c => c.status == 'critical')|length %}
        {% set group_rec = checks|filter(c => c.status == 'recommended')|length %}
        <section class="admin-card admin-settings-card admin-settings-section" id="health-{{ group_key|e('html_attr') }}">
          <header class="admin-settings-card-head-row">
            <div>
              <h2 class="admin-settings-card-title">{{ group_labels[group_key]|default(group_key|title) }}</h2>
              <p class="admin-settings-card-desc" style="margin-bottom:0">{{ checks|length }} check(s) in this group.</p>
            </div>
            {% if group_crit > 0 %}
              <span class="admin-pill admin-health-pill admin-health-pill--critical">{{ group_crit }} critical</span>
            {% elseif group_rec > 0 %}
              <span class="admin-pill admin-health-pill admin-health-pill--recommended">{{ group_rec }} recommended</span>
            {% else %}
              <span class="admin-pill admin-pill--ok">All clear</span>
            {% endif %}
          </header>
          <div class="admin-table-wrap" style="margin-top:0.85rem">
            <table class="admin-table admin-table--comfortable admin-health-table">
              <thead>
                <tr>
                  <th scope="col">Check</th>
                  <th scope="col">Status</th>
                  <th scope="col">Details</th>
                  <th scope="col" class="admin-table-col-actions"><span class="admin-table-muted">Action</span></th>
                </tr>
              </thead>
              <tbody>
                {% for check in checks %}
                  <tr>
                    <td><strong class="admin-table-primary">{{ check.label|e }}</strong></td>
                    <td>
                      <span class="admin-pill admin-health-pill admin-health-pill--{{ check.status|e('html_attr') }}">
                        {{ status_labels[check.status]|default(check.status|title) }}
                      </span>
                    </td>
                    <td class="admin-health-detail">
                      <p class="admin-health-message">{{ check.message|e }}</p>
                      {% if check.detail|default('') != '' %}
                        <pre class="admin-health-detail-pre">{{ check.detail|e }}</pre>
                      {% endif %}
                    </td>
                    <td class="admin-table-actions">
                      {% if check.actionRoute|default('') != '' %}
                        <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for(check.actionRoute, check.actionRouteParams|default({})) }}">
                          {{ check.actionLabel|default('Open')|e }}
                        </a>
                      {% else %}
                        <span class="admin-table-muted">—</span>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>
      {% endfor %}

      {% set stack = health_stack|default({}) %}
      {% set stack_cms = stack.cms|default(null) %}
      {% set stack_theme = stack.theme|default(null) %}
      {% set stack_plugins = stack.plugins|default([]) %}

      <section class="admin-card admin-settings-card admin-settings-section" id="health-stack-versions">
        <header class="admin-settings-card-head-row">
          <div>
            <h2 class="admin-settings-card-title">Stack versions &amp; sync</h2>
            <p class="admin-settings-card-desc" style="margin-bottom:0">
              Installed CMS, active theme, and plugins compared with on-disk metadata and update feeds.
            </p>
          </div>
        </header>

        <div class="admin-table-wrap" style="margin-top:0.85rem">
          <table class="admin-table admin-table--comfortable admin-health-table admin-health-stack-table">
            <thead>
              <tr>
                <th scope="col">Component</th>
                <th scope="col">Installed</th>
                <th scope="col">Latest</th>
                <th scope="col">Sync</th>
                <th scope="col">Details</th>
                <th scope="col" class="admin-table-col-actions"><span class="admin-table-muted">Action</span></th>
              </tr>
            </thead>
            <tbody>
              {% if stack_cms %}
                {% set sync = stack_cms.sync_status|default('ok') %}
                {% set pill = sync in ['missing_on_disk', 'not_registered'] ? 'critical' : (sync == 'ok' ? 'good' : 'recommended') %}
                <tr>
                  <td><strong class="admin-table-primary">{{ stack_cms.name|e }}</strong><br><span class="admin-table-muted">{{ stack_cms.slug|e }}</span></td>
                  <td><code class="admin-inline-code">{{ stack_cms.installed_version|e }}</code></td>
                  <td>
                    {% if stack_cms.latest_version|default('') != '' %}
                      <code class="admin-inline-code">{{ stack_cms.latest_version|e }}</code>
                    {% else %}
                      <span class="admin-table-muted">—</span>
                    {% endif %}
                  </td>
                  <td><span class="admin-pill admin-health-pill admin-health-pill--{{ pill|e('html_attr') }}">{{ stack_cms.sync_label|e }}</span></td>
                  <td class="admin-health-detail"><p class="admin-health-message">{{ stack_cms.detail|e }}</p></td>
                  <td class="admin-table-actions">
                    {% if stack_cms.action_route|default('') != '' %}
                      <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for(stack_cms.action_route) }}">{{ stack_cms.action_label|default('Open')|e }}</a>
                    {% else %}
                      <span class="admin-table-muted">—</span>
                    {% endif %}
                  </td>
                </tr>
              {% endif %}
              {% if stack_theme %}
                {% set sync = stack_theme.sync_status|default('ok') %}
                {% set pill = sync in ['missing_on_disk', 'not_registered'] ? 'critical' : (sync == 'ok' ? 'good' : 'recommended') %}
                <tr>
                  <td><strong class="admin-table-primary">{{ stack_theme.name|e }}</strong><br><span class="admin-table-muted">Theme · {{ stack_theme.slug|e }}</span></td>
                  <td><code class="admin-inline-code">{{ stack_theme.installed_version|e }}</code></td>
                  <td>
                    {% if stack_theme.latest_version|default('') != '' %}
                      <code class="admin-inline-code">{{ stack_theme.latest_version|e }}</code>
                    {% else %}
                      <span class="admin-table-muted">—</span>
                    {% endif %}
                  </td>
                  <td><span class="admin-pill admin-health-pill admin-health-pill--{{ pill|e('html_attr') }}">{{ stack_theme.sync_label|e }}</span></td>
                  <td class="admin-health-detail"><p class="admin-health-message">{{ stack_theme.detail|e }}</p></td>
                  <td class="admin-table-actions">
                    {% if stack_theme.action_route|default('') != '' %}
                      <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for(stack_theme.action_route) }}">{{ stack_theme.action_label|default('Open')|e }}</a>
                    {% else %}
                      <span class="admin-table-muted">—</span>
                    {% endif %}
                  </td>
                </tr>
              {% endif %}
              {% for row in stack_plugins %}
                {% set sync = row.sync_status|default('ok') %}
                {% set pill = sync in ['missing_on_disk', 'not_registered'] ? 'critical' : (sync == 'ok' ? 'good' : 'recommended') %}
                <tr>
                  <td>
                    <strong class="admin-table-primary">{{ row.name|e }}</strong>
                    <br>
                    <span class="admin-table-muted">
                      Plugin · {{ row.slug|e }}{% if row.active %} · active{% else %} · inactive{% endif %}
                    </span>
                  </td>
                  <td>
                    <code class="admin-inline-code">{{ row.installed_version|e }}</code>
                    {% if row.disk_version|default('') != '' and row.disk_version != row.installed_version %}
                      <br><span class="admin-table-muted">disk {{ row.disk_version|e }}</span>
                    {% endif %}
                  </td>
                  <td><span class="admin-table-muted">—</span></td>
                  <td><span class="admin-pill admin-health-pill admin-health-pill--{{ pill|e('html_attr') }}">{{ row.sync_label|e }}</span></td>
                  <td class="admin-health-detail"><p class="admin-health-message">{{ row.detail|e }}</p></td>
                  <td class="admin-table-actions">
                    {% if row.action_route|default('') != '' %}
                      <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for(row.action_route) }}">{{ row.action_label|default('Open')|e }}</a>
                    {% else %}
                      <span class="admin-table-muted">—</span>
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <p class="admin-hint admin-settings-card-footnote">
          Run <code class="admin-inline-code">composer smoke:staging</code> against staging (set <code class="admin-inline-code">STRUXA_SMOKE_BASE_URL</code>) to verify public routes.
          Plugin ZIP versions are compared on disk vs the database; CMS and theme rows may show catalog/GitHub latest when reachable.
        </p>
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="health-system-info">
        <h2 class="admin-settings-card-title">System info</h2>
        <p class="admin-settings-card-desc">Runtime versions and paths reported by the health service.</p>
        <dl class="admin-health-info-dl admin-tools-info-dl">
          {% for label, value in health_report.info|default({}) %}
            <div class="admin-health-info-row">
              <dt>{{ label|e }}</dt>
              <dd><code class="admin-inline-code">{{ value|e }}</code></dd>
            </div>
          {% endfor %}
        </dl>
        <p class="admin-hint admin-settings-card-footnote">
          Related:
          <a class="admin-link" href="{{ url_for('admin.tools.cache') }}">Performance</a> ·
          <a class="admin-link" href="{{ url_for('admin.tools.maintenance') }}">Maintenance</a> ·
          <a class="admin-link" href="{{ url_for('admin.updates.index') }}">CMS updates</a>
        </p>
      </section>
    </div>
  </div>
{% endblock %}
