{% extends 'admin/base.twig' %}

{% block admin_title %}CMS updates{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">CMS updates</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Compare your install to the public feed. Status refreshes every few minutes — use <strong>Check now</strong> to bypass the cache.</p>
{% endblock %}

{% block admin_content %}
  {% set st = cms_update_page_status|default({}) %}
  <div
    class="admin-settings-page admin-updates-page"
    id="admin-updates-root"
    data-poll-url="{{ cms_update_poll_url|e('html_attr') }}"
    data-apply-url="{{ cms_update_apply_url|default('')|e('html_attr') }}"
    data-auto-allowed="{{ cms_auto_update_allowed|default(false) ? '1' : '0' }}"
    data-csrf="{{ csrf_token()|e('html_attr') }}"
  >
    <div class="admin-settings-intro admin-settings-intro--updates">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">Struxa release channel</p>
        <p class="admin-settings-intro-text">
          Installed build vs remote feed. When a newer version is available, download the ZIP or run an in-place update
          (if enabled in <code class="admin-inline-code">.env</code>).
        </p>
      </div>
      <span class="admin-pill admin-hub-status-pill" id="admin-updates-status-pill">
        {% if st.update_available|default(false) %}
          <span class="admin-pill admin-pill--warn">Update available</span>
        {% elseif st.ok|default(false) %}
          <span class="admin-pill admin-pill--ok">Up to date</span>
        {% else %}
          <span class="admin-pill admin-pill--muted">Check failed</span>
        {% endif %}
      </span>
    </div>

    <div class="admin-metrics admin-hub-metrics admin-updates-metrics" aria-label="Version summary">
      <article class="admin-metric">
        <p class="admin-metric-label">Installed</p>
        <p class="admin-metric-value admin-metric-value--mono" id="admin-updates-installed-metric">
          <code class="admin-inline-code">{{ st.current_version|default(cms_version)|e }}</code>
        </p>
        <p class="admin-metric-meta">This server</p>
      </article>
      <article class="admin-metric{% if st.update_available|default(false) %} admin-metric--health-rec{% elseif st.ok|default(false) %} admin-metric--health-good{% endif %}">
        <p class="admin-metric-label">Latest remote</p>
        <p class="admin-metric-value admin-metric-value--mono" id="admin-updates-latest-metric">
          {% if st.ok|default(false) and st.latest_version|default('') != '' %}
            <code class="admin-inline-code">{{ st.latest_version|e }}</code>
          {% elseif st.ok|default(false) %}
            —
          {% else %}
            ?
          {% endif %}
        </p>
        <p class="admin-metric-meta">From update feed</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Feed source</p>
        <p class="admin-metric-value admin-metric-value--sm">{{ st.source|default('feed')|e }}</p>
        <p class="admin-metric-meta">{% if st.source|default('feed') == 'github' %}GitHub{% else %}JSON / PHP{% endif %}</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Auto update</p>
        <p class="admin-metric-value admin-metric-value--sm">{{ cms_auto_update_allowed|default(false) ? 'Enabled' : 'Off' }}</p>
        <p class="admin-metric-meta"><code class="admin-inline-code">STRUXA_ALLOW_AUTO_UPDATE</code></p>
      </article>
    </div>

    <div class="admin-settings-stack">
      <section class="admin-card admin-settings-card admin-updates-release-card">
        <header class="admin-settings-card-head-row">
          <div>
            <h2 class="admin-settings-card-title" id="admin-updates-release-title">{{ st.title|default('Release notes')|e }}</h2>
            <p class="admin-settings-card-desc" style="margin-bottom:0" id="admin-updates-status-line">
              {% if st.update_available|default(false) %}
                A newer Struxa build is available for this site.
              {% elseif st.ok|default(false) %}
                Your install matches the latest feed version.
              {% else %}
                Could not reach the update feed — check URL and server outbound HTTP.
              {% endif %}
            </p>
          </div>
          <div class="admin-updates-actions">
            <a class="admin-btn-ghost" href="{{ url_for('admin.updates.index', {}, { fresh: 1 }) }}">Check now</a>
            <span class="admin-table-muted admin-updates-poll-hint" id="admin-updates-poll-hint">Auto-refresh every 3 min</span>
          </div>
        </header>

        <div class="admin-updates-summary" id="admin-updates-summary">
          {% if st.summary|default('') != '' %}
            <p class="admin-updates-summary-text">{{ st.summary|e }}</p>
          {% endif %}
          {% if st.release_url|default('') != '' %}
            <p class="admin-updates-links" id="admin-updates-release-wrap">
              <a class="admin-link" href="{{ st.release_url|e('html_attr') }}" rel="noopener noreferrer" target="_blank">Full release notes →</a>
            </p>
          {% endif %}
          {% if st.error|default('') != '' %}
            <p class="admin-form-error admin-updates-error" id="admin-updates-error">{{ st.error|e }}</p>
          {% endif %}
        </div>

        <div class="admin-updates-cta" id="admin-updates-cta">
          <a
            id="admin-updates-download-btn"
            class="admin-btn-primary{% if st.download_url|default('') == '' %} admin-updates-cta--hidden{% endif %}"
            href="{{ (st.download_url|default('') != '' ? st.download_url : '#')|e('html_attr') }}"
            rel="noopener noreferrer"
            target="_blank"
          >Download update (ZIP)</a>
          {% if cms_auto_update_allowed|default(false) %}
            <button
              type="button"
              class="admin-btn-primary"
              id="admin-updates-apply-btn"
              {% if not st.update_available|default(false) or st.download_url|default('') == '' %}disabled{% endif %}
            >Update automatically</button>
          {% endif %}
        </div>
        {% if cms_auto_update_allowed|default(false) %}
          <p class="admin-hint admin-updates-apply-disabled-hint" id="admin-updates-apply-disabled-hint" hidden></p>
        {% else %}
          <p class="admin-hint admin-updates-auto-hint">Enable in-place updates with <code class="admin-inline-code">STRUXA_ALLOW_AUTO_UPDATE=1</code> in <code class="admin-inline-code">.env</code> (staff only; back up first).</p>
        {% endif %}

        <div id="admin-updates-apply-progress" class="admin-updates-apply-progress" hidden aria-live="polite">
          <p class="admin-updates-apply-progress-title">Updating CMS…</p>
          <div class="admin-updates-apply-progress-track" role="progressbar" aria-valuetext="Working">
            <div class="admin-updates-apply-progress-fill" aria-hidden="true"></div>
          </div>
          <p class="admin-updates-apply-progress-hint">
            Downloading the package, merging files, then Composer, migrations, and plugin installs. Keep this tab open.
          </p>
        </div>
        <div id="admin-updates-apply-panel" class="admin-updates-apply-panel" hidden role="region" aria-label="Update result"></div>
      </section>

      <section class="admin-card admin-settings-card admin-updates-feed-card">
        <h2 class="admin-settings-card-title">Update feed</h2>
        <p class="admin-hint admin-updates-feed-hint">
          {% if st.source|default('feed') == 'github' %}
            GitHub: <code class="admin-inline-code admin-tools-code-break">{{ st.feed_url|default('')|e }}</code>
            · <code class="admin-inline-code">STRUXA_UPDATES_GITHUB_REPO=owner/repo</code>
          {% else %}
            Feed URL: <code class="admin-inline-code admin-tools-code-break">{{ st.feed_url|default('')|e }}</code>
            · override with <code class="admin-inline-code">STRUXA_UPDATES_JSON_URL</code> or <code class="admin-inline-code">STRUXA_UPDATES_GITHUB_REPO</code>
          {% endif %}
        </p>
        <p class="admin-hint" style="margin-bottom:0">
          Example public feed:
          <a class="admin-link" href="https://struxapoint.com/dist/struxa-updates-json.php" rel="noopener noreferrer" target="_blank">struxa-updates-json.php</a>
        </p>
        <dl class="admin-updates-dl admin-updates-dl--compact" aria-hidden="true" style="display:none">
          <div class="admin-updates-dl-row">
            <dt>Installed</dt>
            <dd id="admin-updates-installed"><code class="admin-inline-code">{{ st.current_version|default(cms_version)|e }}</code></dd>
          </div>
          <div class="admin-updates-dl-row">
            <dt>Latest</dt>
            <dd id="admin-updates-latest"></dd>
          </div>
        </dl>
      </section>
    </div>
  </div>

  <script>
    (function () {
      var root = document.getElementById('admin-updates-root');
      if (!root) return;
      var url = root.getAttribute('data-poll-url');
      if (!url) return;
      var pollMs = 180000;
      var installedEl = document.getElementById('admin-updates-installed');
      var latestEl = document.getElementById('admin-updates-latest');
      var statusEl = document.getElementById('admin-updates-status-line');
      var statusPill = document.getElementById('admin-updates-status-pill');
      var installedMetric = document.getElementById('admin-updates-installed-metric');
      var latestMetric = document.getElementById('admin-updates-latest-metric');
      var summaryEl = document.getElementById('admin-updates-summary');
      var hintEl = document.getElementById('admin-updates-poll-hint');
      var autoAllowed = root.getAttribute('data-auto-allowed') === '1';
      var applyUrl = root.getAttribute('data-apply-url');
      var csrf = root.getAttribute('data-csrf') || '';
      var downloadBtn = document.getElementById('admin-updates-download-btn');
      var applyBtn = document.getElementById('admin-updates-apply-btn');
      var applyProgress = document.getElementById('admin-updates-apply-progress');
      var applyPanel = document.getElementById('admin-updates-apply-panel');
      var applyDisabledHint = document.getElementById('admin-updates-apply-disabled-hint');
      var statusPollAbort = null;

      function esc(s) {
        if (!s) return '';
        var d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      function renderApplyPanel(data) {
        var ok = !!(data && data.ok);
        var parts = [];
        if (ok) {
          var ver = data.applied_version ? String(data.applied_version) : '';
          parts.push('<div class="admin-updates-apply-banner admin-updates-apply-banner--success">');
          parts.push('<p class="admin-updates-apply-banner-title">Update complete' + (ver ? ' — Struxa ' + esc(ver) : '') + '</p>');
          parts.push('<p class="admin-updates-apply-banner-text">New files are in place. Reload if the version row still shows the old number.</p>');
          parts.push('</div>');
          if (data.steps && data.steps.length) {
            parts.push('<ol class="admin-updates-apply-steps">');
            data.steps.forEach(function (s) {
              var st = s.status === 'warn' || s.status === 'error' ? s.status : 'ok';
              parts.push('<li class="admin-updates-apply-step admin-updates-apply-step--' + st + '">');
              parts.push('<span class="admin-updates-apply-step-marker" aria-hidden="true"></span>');
              parts.push('<div class="admin-updates-apply-step-main">');
              parts.push('<span class="admin-updates-apply-step-label">' + esc(s.label || '') + '</span>');
              if (s.detail) parts.push('<pre class="admin-updates-apply-step-detail">' + esc(s.detail) + '</pre>');
              parts.push('</div></li>');
            });
            parts.push('</ol>');
          }
        } else {
          parts.push('<div class="admin-updates-apply-banner admin-updates-apply-banner--error">');
          parts.push('<p class="admin-updates-apply-banner-title">Update did not complete</p>');
          parts.push('<p class="admin-updates-apply-banner-text">' + esc((data && data.message) || 'Something went wrong.') + '</p>');
          parts.push('</div>');
        }
        return parts.join('');
      }

      function apply(data) {
        if (!data || typeof data !== 'object') return;
        var verHtml = data.current_version ? '<code class="admin-inline-code">' + esc(String(data.current_version)) + '</code>' : '';
        if (installedEl) installedEl.innerHTML = verHtml;
        if (installedMetric) installedMetric.innerHTML = verHtml;
        if (latestEl) {
          if (data.ok && data.latest_version) {
            latestEl.innerHTML = '<code class="admin-inline-code">' + esc(String(data.latest_version)) + '</code>';
          } else if (data.ok) {
            latestEl.innerHTML = '<span class="admin-table-muted">—</span>';
          } else {
            latestEl.innerHTML = '<span class="admin-table-muted">Unavailable</span>';
          }
        }
        if (latestMetric) {
          if (data.ok && data.latest_version) {
            latestMetric.innerHTML = '<code class="admin-inline-code">' + esc(String(data.latest_version)) + '</code>';
          } else if (data.ok) {
            latestMetric.textContent = '—';
          } else {
            latestMetric.textContent = '?';
          }
        }
        if (statusEl) {
          if (data.update_available) {
            statusEl.textContent = 'A newer Struxa build is available for this site.';
          } else if (data.ok) {
            statusEl.textContent = 'Your install matches the latest feed version.';
          } else {
            statusEl.textContent = 'Could not reach the update feed — check URL and server outbound HTTP.';
          }
        }
        if (statusPill) {
          if (data.update_available) {
            statusPill.innerHTML = '<span class="admin-pill admin-pill--warn">Update available</span>';
          } else if (data.ok) {
            statusPill.innerHTML = '<span class="admin-pill admin-pill--ok">Up to date</span>';
          } else {
            statusPill.innerHTML = '<span class="admin-pill admin-pill--muted">Check failed</span>';
          }
        }
        if (summaryEl) {
          var parts = [];
          if (data.title) parts.push('<p class="admin-updates-summary-text"><strong>' + esc(data.title) + '</strong></p>');
          if (data.summary) parts.push('<p class="admin-updates-summary-text">' + esc(data.summary) + '</p>');
          if (data.release_url) {
            parts.push('<p class="admin-updates-links"><a class="admin-link" href="' + esc(data.release_url) + '" rel="noopener noreferrer" target="_blank">Full release notes →</a></p>');
          }
          if (data.error) parts.push('<p class="admin-form-error admin-updates-error">' + esc(data.error) + '</p>');
          if (parts.length) summaryEl.innerHTML = parts.join('');
        }
        if (downloadBtn) {
          if (data.download_url) {
            downloadBtn.href = data.download_url;
            downloadBtn.classList.remove('admin-updates-cta--hidden');
          } else {
            downloadBtn.classList.add('admin-updates-cta--hidden');
          }
        }
        if (applyBtn) applyBtn.disabled = !(autoAllowed && data.ok && data.update_available && data.download_url);
      }

      function tick(forceFresh) {
        if (document.hidden) return;
        if (statusPollAbort) statusPollAbort.abort();
        statusPollAbort = new AbortController();
        var myCtrl = statusPollAbort;
        var fetchUrl = url + (forceFresh ? (url.indexOf('?') >= 0 ? '&' : '?') + 'fresh=1' : '');
        fetch(fetchUrl, { headers: { Accept: 'application/json' }, credentials: 'same-origin', signal: myCtrl.signal })
          .then(function (r) { return r.json(); })
          .then(apply)
          .catch(function (err) { if (err && err.name === 'AbortError') return; })
          .finally(function () { if (statusPollAbort === myCtrl) statusPollAbort = null; });
      }

      tick();
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) setInterval(tick, pollMs);
      document.addEventListener('visibilitychange', function () { if (!document.hidden) tick(); });

      if (applyBtn && applyUrl) {
        applyBtn.addEventListener('click', function () {
          if (applyBtn.disabled) return;
          if (!confirm('Apply this update now? CMS files will be overwritten from the ZIP (except .env, storage/, public/uploads/, and plugins/*/vendor/). Continue?')) return;
          applyBtn.disabled = true;
          if (applyPanel) { applyPanel.hidden = true; applyPanel.innerHTML = ''; }
          if (applyProgress) { applyProgress.hidden = false; applyProgress.setAttribute('aria-busy', 'true'); }
          fetch(applyUrl, {
            method: 'POST',
            headers: { Accept: 'application/json', 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': csrf },
            credentials: 'same-origin',
            body: '_csrf_token=' + encodeURIComponent(csrf),
          })
            .then(function (r) { return r.json().then(function (data) { return { data: data }; }); })
            .then(function (res) {
              if (applyProgress) { applyProgress.hidden = true; applyProgress.setAttribute('aria-busy', 'false'); }
              if (applyPanel) { applyPanel.innerHTML = renderApplyPanel(res.data); applyPanel.hidden = false; }
              if (res.data.ok && res.data.status) { apply(res.data.status); tick(true); }
              if (!res.data.ok) applyBtn.disabled = false;
            })
            .catch(function () {
              if (applyProgress) { applyProgress.hidden = true; }
              if (applyPanel) {
                applyPanel.innerHTML = renderApplyPanel({ ok: false, message: 'Request failed (network or timeout).' });
                applyPanel.hidden = false;
              }
              applyBtn.disabled = false;
            });
        });
      }
    })();
  </script>
{% endblock %}
