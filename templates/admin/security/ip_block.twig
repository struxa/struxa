{% extends 'admin/base.twig' %}

{% block admin_title %}IP blocking{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">IP blocking</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">Block abusive client IPs from the storefront and admin.</p>
{% endblock %}

{% block admin_content %}
  {% set hit_log = ip_block_hit_log_rows|default([]) %}
  {% set block_count = ip_block_rows|length %}

  <div class="admin-settings-page admin-settings-page--security">
    <div class="admin-settings-intro admin-settings-intro--security">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">Network-level access control</p>
        <p class="admin-settings-intro-text">
          Blocked clients receive a rejection before your app handles the request — both storefront and admin.
          Client IP follows <code class="admin-inline-code">CMS_TRUSTED_PROXY_IPS</code> when behind a reverse proxy.
          Rules apply within about a minute due to a short server cache.
        </p>
      </div>
      {% if block_count > 0 %}
        <span class="admin-pill admin-hub-status-pill">{{ block_count }} rule{{ block_count == 1 ? '' : 's' }}</span>
      {% endif %}
    </div>

    <div class="admin-metrics admin-hub-metrics" aria-label="IP block summary">
      <article class="admin-metric{% if block_count > 0 %} admin-metric--health-good{% endif %}">
        <p class="admin-metric-label">Active blocks</p>
        <p class="admin-metric-value">{{ block_count }}</p>
        <p class="admin-metric-meta">IPs or CIDR ranges</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Recent hits</p>
        <p class="admin-metric-value">{{ hit_log|length }}</p>
        <p class="admin-metric-meta">Blocked attempts (30d)</p>
      </article>
    </div>

    <div class="admin-settings-stack">
      <section class="admin-card admin-settings-card admin-settings-section admin-callout admin-callout--warn" id="ip-block-warn" style="margin:0">
        <p class="admin-callout-title">Before you block</p>
        <ul class="admin-hub-warn-list">
          <li>Blocking your own IP locks you out of admin and the storefront. Remove the row from <code class="admin-inline-code">cms_ip_blocks</code> in the database, or ask another admin to delete the rule.</li>
          <li>Single IPv4 or IPv6 addresses match exactly. IPv4 CIDR (e.g. <code class="admin-inline-code">203.0.113.0/24</code>) is supported; IPv6 CIDR is not.</li>
        </ul>
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="ip-block-add">
        <h2 class="admin-settings-card-title">Add block</h2>
        <p class="admin-settings-card-desc">Enter an exact IP or an IPv4 CIDR range. Optional note helps you remember why it was added.</p>
        <form method="post" action="{{ url_for('admin.security.ip_block_add') }}" class="admin-form admin-settings-form">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <div class="admin-form-grid">
            <div class="admin-field">
              <label class="admin-label" for="ip-pattern">IP or IPv4 CIDR</label>
              <input type="text" id="ip-pattern" name="pattern" class="admin-input" placeholder="203.0.113.42 or 203.0.113.0/24" autocomplete="off" required />
            </div>
            <div class="admin-field">
              <label class="admin-label" for="ip-note">Note (optional)</label>
              <input type="text" id="ip-note" name="note" class="admin-input" placeholder="e.g. repeat scanner" maxlength="255" />
            </div>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="admin-btn-primary">Add block</button>
          </div>
        </form>
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="ip-block-rules">
        <header class="admin-settings-card-head-row">
          <div>
            <h2 class="admin-settings-card-title">Blocked addresses</h2>
            <p class="admin-settings-card-desc" style="margin-bottom:0">Active rules — remove when no longer needed.</p>
          </div>
        </header>
        {% if ip_block_rows is empty %}
          <p class="admin-hint admin-settings-card-footnote">No IP blocks yet.</p>
        {% else %}
          <div class="admin-table-wrap" style="margin-top:0.85rem;overflow-x:auto">
            <table class="admin-table admin-table--comfortable">
              <thead>
                <tr>
                  <th scope="col">Pattern</th>
                  <th scope="col">Note</th>
                  <th scope="col">Added</th>
                  <th scope="col"></th>
                </tr>
              </thead>
              <tbody>
                {% for row in ip_block_rows %}
                  <tr>
                    <td><code class="admin-inline-code">{{ row.pattern|e }}</code></td>
                    <td class="admin-table-muted">{{ row.note|default('—')|e }}</td>
                    <td class="admin-table-muted">{{ row.created_at|e }}</td>
                    <td class="admin-table-actions">
                      <form method="post" action="{{ url_for('admin.security.ip_block_delete') }}" class="admin-inline-form" onsubmit="return confirm('Remove this block?');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                        <input type="hidden" name="id" value="{{ row.id }}" />
                        <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm">Remove</button>
                      </form>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="ip-block-hits">
        <header class="admin-settings-card-head-row">
          <div>
            <h2 class="admin-settings-card-title">Blocked traffic (recent)</h2>
            <p class="admin-settings-card-desc" style="margin-bottom:0">
              Counts per client IP per clock hour (UTC). Writes are throttled so heavy scans do not hammer the database — figures are approximate but show ongoing attempts.
            </p>
          </div>
        </header>
        {% if hit_log is empty %}
          <p class="admin-hint admin-settings-card-footnote">No blocked traffic recorded in the last 30 days.</p>
        {% else %}
          <div class="admin-table-wrap" style="margin-top:0.85rem;overflow-x:auto">
            <table class="admin-table admin-table--comfortable">
              <thead>
                <tr>
                  <th scope="col">Last activity</th>
                  <th scope="col">Client IP</th>
                  <th scope="col">Hour (UTC)</th>
                  <th scope="col">Hits</th>
                  <th scope="col">Last path</th>
                  <th scope="col">User-Agent</th>
                </tr>
              </thead>
              <tbody>
                {% for row in hit_log %}
                  <tr>
                    <td class="admin-table-muted">{{ row.last_seen_at|e }}</td>
                    <td><code class="admin-inline-code">{{ row.client_ip|e }}</code></td>
                    <td class="admin-table-muted"><code class="admin-inline-code">{{ row.bucket_utc|e }}</code></td>
                    <td><strong class="admin-table-primary">{{ row.hit_count }}</strong></td>
                    <td class="admin-table-muted admin-tools-code-break"><code class="admin-inline-code">{{ row.last_path|default('—')|e }}</code></td>
                    <td class="admin-table-muted admin-table-sub">{{ row.last_user_agent|default('—')|e }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
        <form method="post" action="{{ url_for('admin.security.ip_block_hit_log_purge') }}" class="admin-hub-inline-purge-form" style="margin-top:1rem" onsubmit="return confirm('Delete hit log rows older than the selected age?');">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <label class="admin-hint admin-hub-inline-label">
            Remove log rows older than
            <select name="older_than_days" class="admin-input admin-input--inline">
              <option value="7">7 days</option>
              <option value="30" selected>30 days</option>
              <option value="90">90 days</option>
              <option value="180">180 days</option>
              <option value="365">365 days</option>
            </select>
          </label>
          <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm">Purge old rows</button>
        </form>
      </section>
    </div>
  </div>
{% endblock %}
