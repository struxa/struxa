{# Content type icon — expects icon (optional slug), slug, name #}
{% set raw = icon|default('')|trim|lower %}
{% if raw == '' %}
  {% set raw = slug|default('')|trim|lower %}
{% endif %}
{% set key = raw|replace({'-outline': '', '-sharp': '', '-filled': '', '_': '-'}) %}
{% set letter = name|default('?')|trim|slice(0, 1)|upper %}

<span class="admin-ct-icon" aria-hidden="true">
  {% if key in ['post', 'blog', 'article', 'news', 'document', 'docs', 'content'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8M8 17h5"/></svg>
  {% elseif key in ['cube', 'box', 'product', 'products', 'catalog', 'shop', 'store', 'inventory'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.3 7 12 12l8.7-5M12 22V12"/></svg>
  {% elseif key in ['people', 'person', 'team', 'user', 'users', 'member', 'members', 'staff'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
  {% elseif key in ['page', 'file', 'doc'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>
  {% elseif key in ['image', 'photo', 'media', 'gallery'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="10.5" r="1.5"/><path d="m21 17-5.5-5.5L8 19"/></svg>
  {% elseif key in ['cart', 'basket', 'checkout'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
  {% elseif key in ['tag', 'tags', 'category', 'taxonomy'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M20.59 13.41 11 3H4v7l9.59 9.59a2 2 0 0 0 2.82 0l4.18-4.18a2 2 0 0 0 0-2.82z"/><circle cx="7.5" cy="7.5" r="1.5"/></svg>
  {% elseif key in ['folder', 'collection'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
  {% elseif key in ['calendar', 'event', 'events'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
  {% elseif key in ['megaphone', 'announcement', 'promo'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11 12v6a2 2 0 0 0 4 0v-6"/></svg>
  {% elseif key in ['star', 'testimonial', 'review', 'reviews'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
  {% elseif key in ['grid', 'blocks', 'layout'] %}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
  {% elseif key != '' %}
    <span class="admin-ct-icon-letter">{{ letter|e }}</span>
  {% else %}
    <span class="admin-ct-icon-letter">{{ letter|e }}</span>
  {% endif %}
</span>
