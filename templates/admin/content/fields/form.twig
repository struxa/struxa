{% extends 'admin/base.twig' %}

{% set is_edit = field is not null %}
{% set o = old ?? {} %}
{% set fl = o.label|default(field ? field.label : '') %}
{% set fk = o.field_key|default(field ? field.fieldKey : '') %}
{% set ft = o.field_type|default(field ? field.fieldType : 'text') %}
{% set ph = o.placeholder|default(field ? (field.placeholder ?? '') : '') %}
{% set ht = o.help_text|default(field ? (field.helpText ?? '') : '') %}
{% set ir = o.is_required is defined ? o.is_required : (field ? field.isRequired : false) %}
{% set dv = o.default_value|default(field ? (field.defaultValue ?? '') : '') %}
{% set oj = o.options_json is defined ? o.options_json : (field and field.optionsJson ? field.optionsJson : '') %}
{% set so = o.sort_order is defined ? o.sort_order : (field ? field.sortOrder : 0) %}

{% set field_types = ['text', 'textarea', 'richtext', 'number', 'boolean', 'select', 'image', 'date', 'url', 'entry_refs'] %}

{% block admin_title %}{{ is_edit ? 'Edit field' : 'New field' }} — {{ content_type.name|e }}{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ is_edit ? 'Edit field' : 'New field' }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.content_types.fields.index', { id: content_type.id }) }}">← Fields</a>
    · {{ content_type.name|e }}
  </p>
{% endblock %}

{% block admin_content %}
  <form class="admin-form" method="post" action="{{ is_edit ? url_for('admin.content_types.fields.update', { id: content_type.id, fieldId: field.id }) : url_for('admin.content_types.fields.store', { id: content_type.id }) }}">
    <div class="admin-form-grid">
      <div class="admin-field {{ errors.label is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="fld-label">Label <span class="admin-req">*</span></label>
        <input class="admin-input" id="fld-label" name="label" type="text" maxlength="191" value="{{ fl|e }}" required />
        {% if errors.label is defined %}<p class="admin-field-error">{{ errors.label|e }}</p>{% endif %}
      </div>

      <div class="admin-field {{ errors.field_key is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="fld-key">Field key <span class="admin-req">*</span></label>
        <input class="admin-input" id="fld-key" name="field_key" type="text" value="{{ fk|e }}" pattern="[a-z][a-z0-9_]{1,62}" autocomplete="off" required />
        <p class="admin-hint">Lowercase, start with a letter; letters, numbers, underscores.</p>
        {% if errors.field_key is defined %}<p class="admin-field-error">{{ errors.field_key|e }}</p>{% endif %}
      </div>

      <div class="admin-field {{ errors.field_type is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="fld-type">Field type <span class="admin-req">*</span></label>
        <select class="admin-select" id="fld-type" name="field_type" required>
          {% for t in field_types %}
            <option value="{{ t|e }}" {{ ft == t ? 'selected' : '' }}>{{ t|e }}</option>
          {% endfor %}
        </select>
        {% if errors.field_type is defined %}<p class="admin-field-error">{{ errors.field_type|e }}</p>{% endif %}
      </div>

      <div class="admin-field {{ errors.sort_order is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="fld-sort">Sort order</label>
        <input class="admin-input" id="fld-sort" name="sort_order" type="number" min="0" step="1" value="{{ so }}" />
        {% if errors.sort_order is defined %}<p class="admin-field-error">{{ errors.sort_order|e }}</p>{% endif %}
      </div>

      <div class="admin-field admin-field--full">
        <label class="admin-label" for="fld-placeholder">Placeholder</label>
        <input class="admin-input" id="fld-placeholder" name="placeholder" type="text" maxlength="255" value="{{ ph|e }}" />
      </div>

      <div class="admin-field admin-field--full">
        <label class="admin-label" for="fld-help">Help text</label>
        <textarea class="admin-textarea" id="fld-help" name="help_text" rows="2">{{ ht|e }}</textarea>
      </div>

      <div class="admin-field admin-field--full">
        <label class="admin-check">
          <input type="checkbox" name="is_required" value="1" {{ ir ? 'checked' : '' }} />
          <span>Required</span>
        </label>
      </div>

      <div class="admin-field admin-field--full">
        <label class="admin-label" for="fld-default">Default value</label>
        <textarea class="admin-textarea" id="fld-default" name="default_value" rows="2">{{ dv|e }}</textarea>
        <p class="admin-hint">Shown when a new entry has no value yet (simple types only).</p>
      </div>

      <div class="admin-field admin-field--full {{ errors.options_json is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="fld-options">{% if ft == 'select' %}Select options{% elseif ft == 'entry_refs' %}Entry link options{% else %}Field options (JSON){% endif %}</label>
        <textarea class="admin-textarea" id="fld-options" name="options_json" rows="5" placeholder="{% if ft == 'select' %}[{&quot;value&quot;:&quot;a&quot;,&quot;label&quot;:&quot;Option A&quot;}] or one value per line{% elseif ft == 'entry_refs' %}{&quot;target_content_type_id&quot;: 0, &quot;max_refs&quot;: 25, &quot;require_public_targets&quot;: true}{% endif %}">{{ oj|e }}</textarea>
        {% if ft == 'select' %}
        <p class="admin-hint">Required when type is <strong>select</strong>. JSON array of <code>value</code>/<code>label</code> objects, or one option per line.</p>
        {% elseif ft == 'entry_refs' %}
        <p class="admin-hint">Optional JSON object: <code>target_content_type_id</code> (numeric type id, or 0 for any routable type), <code>max_refs</code> (1–100, default 25), <code>require_public_targets</code> (boolean, default true — publishing blocks targets that are not yet publicly visible).</p>
        {% else %}
        <p class="admin-hint">Used for <strong>select</strong> (choices) and <strong>entry_refs</strong> (link rules). Leave blank for other types.</p>
        {% endif %}
        {% if errors.options_json is defined %}<p class="admin-field-error">{{ errors.options_json|e }}</p>{% endif %}
      </div>
    </div>

    <div class="admin-form-actions">
      <button class="admin-btn-primary" type="submit">{{ is_edit ? 'Save field' : 'Add field' }}</button>
      <a class="admin-btn-ghost" href="{{ url_for('admin.content_types.fields.index', { id: content_type.id }) }}">Cancel</a>
    </div>
  </form>
{% endblock %}
