{% extends 'admin/base.twig' %}

{% set snap_entry = snapshot.entry|default({}) %}
{% set snap_vals = snapshot.values|default({}) %}
{% set is_rev_vs_rev = revision_right is defined and revision_right is not null %}
{% set snap_right_entry = is_rev_vs_rev ? (snapshot_right.entry|default({})) : {} %}
{% set snap_right_vals = is_rev_vs_rev ? (snapshot_right.values|default({})) : {} %}

{% block admin_title %}Compare entry revision{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ is_rev_vs_rev ? 'Compare two revisions' : 'Compare revision to current' }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.content_types.entries.revisions', { id: content_type.id, entryId: entry.id }) }}">← Revisions</a>
    · {{ revision.created_at|e }}
    {% if not is_rev_vs_rev %}
      · <span class="admin-hint">Compare two saved revisions: add <code class="admin-inline-code">?other=</code> and another revision ID to this URL.</span>
    {% endif %}
  </p>
{% endblock %}

{% block admin_content %}
  <div class="admin-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;align-items:start">
    {% if is_rev_vs_rev %}
      <div class="admin-card">
        <h2 class="admin-card-title">Revision #{{ revision.id }} (left in diff)</h2>
        <p class="admin-hint">{{ snap_entry.status|default('')|e }} · {{ snap_entry.slug|default('')|e }}</p>
        <h3 style="margin:0.75rem 0 0.35rem">{{ snap_entry.title|default('')|e }}</h3>
        <p class="admin-hint">Field values (IDs):</p>
        <pre style="white-space:pre-wrap;font-size:0.85rem;opacity:0.9">{{ snap_vals|json_encode(384)|e }}</pre>
      </div>
      <div class="admin-card">
        <h2 class="admin-card-title">Revision #{{ revision_right.id }} (right in diff)</h2>
        <p class="admin-hint">{{ snap_right_entry.status|default('')|e }} · {{ snap_right_entry.slug|default('')|e }}</p>
        <h3 style="margin:0.75rem 0 0.35rem">{{ snap_right_entry.title|default('')|e }}</h3>
        <p class="admin-hint">Field values (IDs):</p>
        <pre style="white-space:pre-wrap;font-size:0.85rem;opacity:0.9">{{ snap_right_vals|json_encode(384)|e }}</pre>
      </div>
    {% else %}
      <div class="admin-card">
        <h2 class="admin-card-title">Revision #{{ revision.id }} (left in diff)</h2>
        <p class="admin-hint">{{ snap_entry.status|default('')|e }} · {{ snap_entry.slug|default('')|e }}</p>
        <h3 style="margin:0.75rem 0 0.35rem">{{ snap_entry.title|default('')|e }}</h3>
        <p class="admin-hint">Field values (IDs):</p>
        <pre style="white-space:pre-wrap;font-size:0.85rem;opacity:0.9">{{ snap_vals|json_encode(384)|e }}</pre>
      </div>
      <div class="admin-card">
        <h2 class="admin-card-title">Current (right in diff)</h2>
        <p class="admin-hint">{{ entry.status|e }} · {{ entry.slug|e }}</p>
        <h3 style="margin:0.75rem 0 0.35rem">{{ entry.title|e }}</h3>
        <p class="admin-hint">Field values (IDs):</p>
        <pre style="white-space:pre-wrap;font-size:0.85rem;opacity:0.9">{{ current_value_map|json_encode(384)|e }}</pre>
      </div>
    {% endif %}
  </div>

  <div class="admin-card" style="margin-top:1.25rem">
    <h2 class="admin-card-title">Values unified diff (lines)</h2>
    <p class="admin-hint" style="margin-top:0">Lines prefixed with <code class="admin-inline-code">-</code> / <code class="admin-inline-code">+</code> are removed / added going from the <strong>left</strong> column to the <strong>right</strong> column above (pretty-printed JSON of field ID → value).</p>
    <pre class="admin-revision-diff" style="margin-top:0.75rem;white-space:pre-wrap;font:0.8rem/1.4 ui-monospace,Menlo,Consolas,monospace;background:var(--admin-surface-2,#f1f5f9);padding:1rem;border-radius:8px;overflow:auto;max-height:28rem">{{ revision_unified_diff|default('')|e }}</pre>
  </div>
{% endblock %}
