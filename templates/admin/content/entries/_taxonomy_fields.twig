{% for tx in taxonomies %}
  {% set sel = selected_by_taxonomy[tx.id] ?? selected_by_taxonomy[tx.id ~ ''] ?? [] %}
  {% set rows = taxonomy_term_rows[tx.id] ?? [] %}
  <div class="admin-field admin-field--full {{ attribute(errors, 'taxonomy_' ~ tx.id) is defined ? 'admin-field--error' : '' }}">
    <span class="admin-label">{{ tx.name|e }} <span class="admin-hint" style="font-weight:400">({{ tx.slug|e }} · {{ tx.taxonomyType|e }}{% if tx.isHierarchical %}, hierarchical{% endif %})</span></span>
    {% if rows is empty %}
      <p class="admin-hint">No terms yet — <a class="admin-link" href="{{ url_for('admin.content_types.taxonomies.terms.index', { id: content_type.id, taxId: tx.id }) }}">add terms</a>.</p>
    {% else %}
      <div class="admin-taxonomy-term-list" style="display:flex;flex-direction:column;gap:0.35rem;margin-top:0.35rem">
        {% for row in rows %}
          {% set term = row.term %}
          {% set depth = row.depth %}
          <label class="admin-check" style="padding-left:{{ depth * 1.25 }}rem">
            <input type="checkbox" name="taxonomy_terms[{{ tx.id }}][]" value="{{ term.id }}" {{ term.id in sel ? 'checked' : '' }} />
            <span>{{ term.name|e }}</span>
          </label>
        {% endfor %}
      </div>
    {% endif %}
    {% if attribute(errors, 'taxonomy_' ~ tx.id) is defined %}
      <p class="admin-field-error">{{ attribute(errors, 'taxonomy_' ~ tx.id)|e }}</p>
    {% endif %}
  </div>
{% endfor %}
