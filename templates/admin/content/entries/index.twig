{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}{{ content_type.name|e }} — Entries{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ content_type.name|e }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    <a class="admin-link" href="{{ url_for('admin.content_types.index') }}">← Content types</a>
    · Slug <code class="admin-inline-code">{{ content_type.slug|e }}</code>
    · {{ field_count }} field{{ field_count == 1 ? '' : 's' }}
    {% if content_type.hasPublicRoute %}
      · Public base: <code class="admin-inline-code">{{ site_url }}/{{ content_type.slug|e }}/…</code>
    {% endif %}
  </p>
{% endblock %}

{% block admin_body_class %}admin-body--dash-ref admin-body--content-types{% endblock %}

{% block admin_content %}
  {% set summary = entry_summary|default({ total: 0, published: 0, draft: 0, in_review: 0 }) %}
  {% set can_edit_entries = cms_can('edit_content') or cms_can('review_content') %}
  {% set can_publish_entries = cms_can('publish_content') %}
  {% set can_trash_entries = cms_can('delete_content') %}
  {% set can_bulk = entry_rows is not empty and (can_edit_entries or can_publish_entries or can_trash_entries) %}
  {% set entry_page = page|default(1) %}
  {% set entry_per_page = per_page|default(25) %}
  {% set entry_total_pages = total_pages|default(1) %}
  {% set entry_pagination_query = entry_per_page != 25 ? { per_page: entry_per_page } : {} %}

  <div class="admin-content-layout">
    {% include 'admin/content/_content_tree.twig' %}

    <div class="admin-content-main">
  <div class="admin-entry-toolbar">
    {% if entry_rows is not empty %}
      <div class="admin-ct-summary" aria-label="Entry overview">
        <span class="admin-ct-summary-item"><strong>{{ summary.total }}</strong> entr{{ summary.total == 1 ? 'y' : 'ies' }}</span>
        {% if summary.published > 0 %}
          <span class="admin-ct-summary-sep" aria-hidden="true">·</span>
          <span class="admin-ct-summary-item admin-ct-summary-item--live">{{ summary.published }} live</span>
        {% endif %}
        {% if summary.draft > 0 or summary.in_review > 0 %}
          <span class="admin-ct-summary-sep" aria-hidden="true">·</span>
          <span class="admin-ct-summary-item admin-ct-summary-item--draft">{{ summary.draft + summary.in_review }} draft</span>
        {% endif %}
      </div>
    {% else %}
      <span></span>
    {% endif %}
    <div class="admin-entry-toolbar-actions">
      {% if cms_can('create_content') %}
        <a class="admin-btn-primary" href="{{ url_for('admin.content_types.entries.new', { id: content_type.id }) }}">New entry</a>
      {% endif %}
      {% if content_type.hasPublicRoute %}
        <a class="admin-btn-ghost" href="{{ url_for('public.content_type_index', { typeSlug: content_type.slug }) }}" target="_blank" rel="noopener noreferrer">View public index</a>
      {% endif %}
      {% if cms_can('manage_content_types') %}
        <a class="admin-btn-ghost" href="{{ url_for('admin.content_types.fields.index', { id: content_type.id }) }}">Fields</a>
        <a class="admin-btn-ghost" href="{{ url_for('admin.content_types.edit', { id: content_type.id }) }}">Type settings</a>
      {% endif %}
      {% if cms_can('manage_taxonomies') and taxonomy_count|default(0) > 0 %}
        <a class="admin-btn-ghost" href="{{ url_for('admin.content_types.taxonomies.index', { id: content_type.id }) }}">Taxonomies</a>
      {% endif %}
    </div>
  </div>

  {% if entry_rows is empty %}
    {{ ui.empty_state(
      'No entries yet',
      'Create an entry to store structured content for this type. You can draft, send for review, and publish when ready.',
      cms_can('create_content') ? url_for('admin.content_types.entries.new', { id: content_type.id }) : '',
      cms_can('create_content') ? 'New entry' : '',
      '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>'
    ) }}
  {% else %}
    {% if can_bulk %}
      <form id="admin-entry-bulk-form" method="post" action="{{ url_for('admin.content_types.entries.bulk', { id: content_type.id }) }}" class="admin-entry-bulk-form" hidden aria-hidden="true">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <input type="hidden" name="return_page" value="{{ entry_page }}" />
        <input type="hidden" name="return_per_page" value="{{ entry_per_page }}" />
      </form>

      {% if taxonomies is defined and taxonomies is not empty %}
        <form id="admin-entry-bulk-taxonomy-form" method="post" action="{{ url_for('admin.content_types.entries.bulk', { id: content_type.id }) }}" class="admin-entry-bulk-form" hidden aria-hidden="true">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <input type="hidden" name="bulk_action" value="assign_taxonomy" />
          <input type="hidden" name="taxonomy_id" value="" />
          <input type="hidden" name="taxonomy_mode" value="merge" />
          <input type="hidden" name="return_page" value="{{ entry_page }}" />
          <input type="hidden" name="return_per_page" value="{{ entry_per_page }}" />
        </form>
      {% endif %}

      <div class="admin-entry-bulk-bar admin-toolbar admin-toolbar--spread" id="admin-entry-bulk-bar">
        <div class="admin-entry-bulk-start">
          <label class="admin-entry-bulk-select-all">
            <input type="checkbox" id="admin-entry-select-all" class="admin-cb" autocomplete="off" aria-label="Select all entries on this page" />
            <span>Select all on page</span>
          </label>
          <span class="admin-entry-bulk-count" id="admin-entry-bulk-count" hidden></span>
        </div>
        <div class="admin-entry-bulk-actions">
          {% if can_publish_entries %}
            <button type="submit" form="admin-entry-bulk-form" name="bulk_action" value="publish" class="admin-btn-primary admin-entry-bulk-publish" id="admin-entry-bulk-publish" disabled title="Select entries below">Publish selected</button>
          {% endif %}
          {% if can_trash_entries %}
            <button type="submit" form="admin-entry-bulk-form" name="bulk_action" value="trash" class="admin-btn-danger admin-entry-bulk-trash" id="admin-entry-bulk-trash" disabled title="Select entries below">Move to trash</button>
          {% endif %}
        </div>
        {% if taxonomies is defined and taxonomies is not empty %}
          <div class="admin-entry-bulk-taxonomy" id="admin-entry-bulk-taxonomy-panel">
            <label class="admin-entry-bulk-taxonomy-label">
              <span class="admin-table-muted">Taxonomy</span>
              <select class="admin-select admin-select--sm" id="admin-entry-bulk-taxonomy-select">
                {% for tx in taxonomies %}
                  <option value="{{ tx.id }}">{{ tx.name|e }}</option>
                {% endfor %}
              </select>
            </label>
            <fieldset class="admin-entry-bulk-taxonomy-mode">
              <label class="admin-check admin-check--inline">
                <input type="radio" name="entry_bulk_taxonomy_mode" value="merge" checked />
                <span>Add terms</span>
              </label>
              <label class="admin-check admin-check--inline">
                <input type="radio" name="entry_bulk_taxonomy_mode" value="replace" />
                <span>Replace</span>
              </label>
            </fieldset>
            <button type="submit" form="admin-entry-bulk-taxonomy-form" class="admin-btn-ghost admin-entry-bulk-taxonomy-apply" id="admin-entry-bulk-taxonomy-apply" disabled>Apply terms</button>
          </div>
        {% endif %}
      </div>

      {% if taxonomies is defined and taxonomies is not empty %}
        <div class="admin-entry-bulk-term-panels" id="admin-entry-bulk-term-panels" hidden aria-hidden="true">
          {% for tx in taxonomies %}
            {% set rows = taxonomy_term_rows[tx.id] ?? [] %}
            <div class="admin-entry-bulk-term-panel admin-card" data-entry-bulk-taxonomy-id="{{ tx.id }}" {% if not loop.first %}hidden aria-hidden="true"{% endif %}>
              <p class="admin-entry-bulk-term-panel-title">{{ tx.name|e }} terms</p>
              {% if rows is empty %}
                <p class="admin-hint">No terms yet — <a class="admin-link" href="{{ url_for('admin.content_types.taxonomies.terms.index', { id: content_type.id, taxId: tx.id }) }}">add terms</a>.</p>
              {% else %}
                <div class="admin-entry-bulk-term-list">
                  {% for row in rows %}
                    {% set term = row.term %}
                    <label class="admin-check" style="padding-left: {{ row.depth }}rem">
                      <input type="checkbox" value="{{ term.id }}" data-entry-bulk-term="1" />
                      <span>{{ term.name|e }}</span>
                    </label>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}

    <div class="admin-entry-list-toolbar">
      <p class="admin-entry-list-count">
        Showing {{ ((entry_page - 1) * entry_per_page) + 1 }}–{{ entry_page * entry_per_page > summary.total ? summary.total : entry_page * entry_per_page }} of {{ summary.total }}
      </p>
      <form class="admin-entry-list-per-page" method="get" action="{{ url_for('admin.content_types.entries.index', { id: content_type.id }) }}">
        <label class="admin-media-filter-label">
          <span class="admin-media-filter-name">Per page</span>
          <select class="admin-select admin-select--sm" name="per_page" onchange="this.form.submit()">
            {% for n in per_page_choices|default([25, 50, 100]) %}
              <option value="{{ n }}" {{ entry_per_page == n ? 'selected' : '' }}>{{ n }}</option>
            {% endfor %}
          </select>
        </label>
      </form>
    </div>

    <ul class="admin-entry-list" role="list">
      {% for e in entry_rows %}
        {% set edit_url = url_for('admin.content_types.entries.edit', { id: content_type.id, entryId: e.id }) %}
        <li class="admin-entry-item">
          <div class="admin-entry-card">
            {% if can_bulk %}
              <label class="admin-entry-select" aria-label="Select {{ e.title|e('html_attr') }}">
                <input
                  type="checkbox"
                  class="admin-cb admin-entry-row-cb"
                  value="{{ e.id }}"
                  data-entry-id="{{ e.id }}"
                  autocomplete="off"
                />
              </label>
            {% endif %}
            {% if can_edit_entries %}
              <a class="admin-entry-row" href="{{ edit_url|e('html_attr') }}">
            {% else %}
              <div class="admin-entry-row admin-entry-row--static">
            {% endif %}
              <span class="admin-entry-row-icon" aria-hidden="true">
                {% include 'admin/content/_content_type_icon.twig' with { icon: '', slug: '', name: e.title } %}
              </span>
              <span class="admin-entry-row-body">
                <span class="admin-entry-row-head">
                  <strong class="admin-entry-row-title">{{ e.title|e }}</strong>
                  {% if can_edit_entries %}
                    <span class="admin-entry-row-go" aria-hidden="true">→</span>
                  {% endif %}
                </span>
                <code class="admin-entry-row-slug">{{ e.slug|e }}</code>
                {% if e.author_email|default('') != '' %}
                  <span class="admin-entry-row-by">{{ e.author_email|e }}</span>
                {% endif %}
              </span>
              <span class="admin-entry-row-meta">
                {{ ui.status_badge(e.status) }}
                <time class="admin-entry-row-date" datetime="{{ e.updated_at|e('html_attr') }}">{{ e.updated_at|e }}</time>
              </span>
            {% if can_edit_entries %}
              </a>
            {% else %}
              </div>
            {% endif %}
            {% if content_type.hasPublicRoute and e.status == 'published' %}
              <div class="admin-entry-item-actions">
                <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ site_url }}/{{ content_type.slug|e }}/{{ e.slug|e }}" target="_blank" rel="noopener noreferrer">View live</a>
              </div>
            {% endif %}
            {% if cms_can('create_content') %}
              <div class="admin-entry-item-actions">
                <form method="post" action="{{ url_for('admin.content_types.entries.duplicate', { id: content_type.id, entryId: e.id }) }}" class="admin-inline-form">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                  <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm">Duplicate</button>
                </form>
              </div>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
    {% if can_edit_entries %}
      <p class="admin-hint admin-entry-list-hint">Click a row to edit{% if can_bulk %} · use checkboxes for bulk actions{% endif %}.</p>
    {% endif %}

    {{ ui.pagination(
      'admin.content_types.entries.index',
      entry_page,
      entry_total_pages,
      entry_pagination_query,
      'Entry list pages',
      { id: content_type.id }
    ) }}
  {% endif %}
    </div>
  </div>
{% endblock %}

{% block admin_scripts %}
  {% if can_bulk|default(false) %}
    <script src="{{ asset('js/admin-entry-list.js') }}" defer></script>
  {% endif %}
{% endblock %}
