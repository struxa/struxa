{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}Users{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Users</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">CMS staff accounts — access is controlled by roles.</p>
{% endblock %}

{% block admin_hero_actions %}
  <a class="admin-btn-primary" href="{{ url_for('admin.users.new') }}">New user</a>
{% endblock %}

{% block admin_content %}
  {% set active_users = users|filter(u => u.is_active)|length %}

  <div class="admin-settings-page admin-settings-page--system">
    {% include 'admin/partials/_system_subnav.twig' with { system_nav_active: 'users' } %}

    <div class="admin-settings-intro admin-settings-intro--users">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">Who can use the CMS</p>
        <p class="admin-settings-intro-text">
          Each user links to a login account and one or more <a class="admin-link" href="{{ url_for('admin.roles.index') }}">roles</a> that define permissions.
          Inactive CMS users cannot access the panel even if login is enabled.
        </p>
      </div>
    </div>

    <div class="admin-metrics admin-hub-metrics" aria-label="User summary">
      <article class="admin-metric">
        <p class="admin-metric-label">Total users</p>
        <p class="admin-metric-value">{{ users_total|default(users|length) }}</p>
        <p class="admin-metric-meta">{% if users_total_pages|default(1) > 1 %}Page {{ users_page }} of {{ users_total_pages }}{% else %}All accounts{% endif %}</p>
      </article>
      <article class="admin-metric admin-metric--health-good">
        <p class="admin-metric-label">Active in CMS</p>
        <p class="admin-metric-value">{{ active_users }}</p>
        <p class="admin-metric-meta">Can access admin when logged in</p>
      </article>
    </div>

    {% if users is empty %}
      <section class="admin-card admin-settings-card">
        {{ ui.empty_state(
          'No CMS users',
          'Create an account to grant admin or content access.',
          url_for('admin.users.new'),
          'New user',
          '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>'
        ) }}
      </section>
    {% else %}
      <section class="admin-card admin-settings-card">
        <div class="admin-toolbar admin-toolbar--spread" style="margin-bottom:0.85rem">
          <h2 class="admin-settings-card-title" style="margin:0">All users</h2>
          <a class="admin-btn-primary admin-btn-primary--sm" href="{{ url_for('admin.users.new') }}">New user</a>
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table admin-table--comfortable">
            <thead>
              <tr>
                <th scope="col">Email</th>
                <th scope="col">Username</th>
                <th scope="col">Display</th>
                <th scope="col">CMS</th>
                <th scope="col">Login</th>
                <th scope="col">Firebase</th>
                <th class="admin-table-col-actions" scope="col"><span class="admin-table-muted">Actions</span></th>
              </tr>
            </thead>
            <tbody>
              {% for u in users %}
                <tr>
                  <td><strong class="admin-table-primary">{{ u.email|e }}</strong></td>
                  <td class="admin-table-muted">{% if u.username|default('')|trim != '' %}{{ u.username|e }}{% else %}—{% endif %}</td>
                  <td>{{ u.display_name|e }}</td>
                  <td>
                    {% if u.is_active %}
                      <span class="admin-badge admin-badge--ok">Active</span>
                    {% else %}
                      <span class="admin-badge admin-badge--muted">Inactive</span>
                    {% endif %}
                  </td>
                  <td class="admin-table-muted">{{ (u.phpauth_isactive ?? 1) ? 'Enabled' : 'Disabled' }}</td>
                  <td class="admin-table-muted admin-table-mono">{{ u.firebase_uid|default('')|trim != '' ? u.firebase_uid|e : '—' }}</td>
                  <td class="admin-table-actions">
                    <a class="admin-link" href="{{ url_for('admin.users.edit', { id: u.id }) }}">Edit</a>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {{ ui.pagination('admin.users.index', users_page, users_total_pages, {}, 'User list pages') }}
      </section>
    {% endif %}
  </div>
{% endblock %}
