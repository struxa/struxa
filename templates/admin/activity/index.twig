{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}Activity{% endblock %}

{% block admin_hero_title %}<h1 class="admin-hero-title">Activity log</h1>{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">CMS events, newest first.</p>
{% endblock %}

{% block admin_content %}
  {% if log_rows is empty and activity_total|default(0) == 0 %}
    {{ ui.empty_state(
      'No activity yet',
      'Saves, publishes, logins, and other actions will show up here as your team uses the CMS.',
      '',
      '',
      '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>'
    ) }}
  {% else %}
    <div class="admin-toolbar admin-toolbar--spread">
      <p class="admin-hint" style="margin:0">
        {% if activity_total|default(0) > 0 %}
          {{ activity_total }} event{% if activity_total != 1 %}s{% endif %}{% if activity_total_pages|default(1) > 1 %} · Page {{ activity_page }} of {{ activity_total_pages }}{% endif %}
        {% else %}
          No events
        {% endif %}
      </p>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th scope="col">When</th>
            <th scope="col">Event</th>
            <th scope="col">User</th>
            <th scope="col">Subject</th>
          </tr>
        </thead>
        <tbody>
          {% for row in log_rows %}
            <tr>
              <td class="admin-table-muted">{{ row.created_at|e }}</td>
              <td><code class="admin-inline-code">{{ row.event_type|e }}</code></td>
              <td>{{ row.user_email|default('—')|e }}</td>
              <td class="admin-table-muted">
                {% if row.subject_type %}
                  {{ row.subject_type|e }} #{{ row.subject_id|e }}
                {% else %}
                  —
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if activity_total_pages|default(1) > 1 %}
      <nav class="admin-pagination" aria-label="Activity pages">
        {% if activity_page > 1 %}
          <a class="admin-pagination-btn" href="{{ url_for('admin.activity.index', {}, { page: activity_page - 1 }) }}">Previous</a>
        {% endif %}
        <span class="admin-pagination-status">Page {{ activity_page }} / {{ activity_total_pages }}</span>
        {% if activity_page < activity_total_pages %}
          <a class="admin-pagination-btn" href="{{ url_for('admin.activity.index', {}, { page: activity_page + 1 }) }}">Next</a>
        {% endif %}
      </nav>
    {% endif %}
  {% endif %}
{% endblock %}
