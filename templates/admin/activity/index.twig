{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}Activity{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Activity log</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">Audit trail of CMS actions — saves, publishes, logins, and more.</p>
{% endblock %}

{% block admin_content %}
  <div class="admin-settings-page admin-settings-page--system">
    {% include 'admin/partials/_system_subnav.twig' with { system_nav_active: 'activity' } %}

    <div class="admin-settings-intro admin-settings-intro--activity">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">Who did what, and when</p>
        <p class="admin-settings-intro-text">
          Every significant CMS action is logged with the user, event type, and affected content.
          Old entries can be purged from <a class="admin-link" href="{{ url_for('admin.tools.maintenance') }}">Maintenance</a>.
        </p>
      </div>
    </div>

    {% if log_rows is empty and activity_total|default(0) == 0 %}
      <section class="admin-card admin-settings-card">
        {{ ui.empty_state(
          'No activity yet',
          'Saves, publishes, logins, and other actions will show up here as your team uses the CMS.',
          '',
          '',
          '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>'
        ) }}
      </section>
    {% else %}
      <div class="admin-metrics admin-hub-metrics" aria-label="Activity summary">
        <article class="admin-metric">
          <p class="admin-metric-label">Total events</p>
          <p class="admin-metric-value">{{ activity_total|default(0) }}</p>
          <p class="admin-metric-meta">{% if activity_total_pages|default(1) > 1 %}Page {{ activity_page }} of {{ activity_total_pages }}{% else %}Newest first{% endif %}</p>
        </article>
      </div>

      <section class="admin-card admin-settings-card">
        <h2 class="admin-settings-card-title">Recent activity</h2>
        <p class="admin-settings-card-desc">Chronological log of CMS events.</p>
        <div class="admin-table-wrap" style="margin-top:0.85rem">
          <table class="admin-table admin-table--comfortable">
            <thead>
              <tr>
                <th scope="col">When</th>
                <th scope="col">Event</th>
                <th scope="col">User</th>
                <th scope="col">Subject</th>
              </tr>
            </thead>
            <tbody>
              {% for row in log_rows %}
                <tr>
                  <td class="admin-table-muted">{{ row.created_at|e }}</td>
                  <td><code class="admin-inline-code">{{ row.event_type|e }}</code></td>
                  <td>{{ row.user_email|default('—')|e }}</td>
                  <td class="admin-table-muted">
                    {% if row.subject_type %}
                      {{ row.subject_type|e }} #{{ row.subject_id|e }}
                    {% else %}
                      —
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {{ ui.pagination('admin.activity.index', activity_page, activity_total_pages, {}, 'Activity pages') }}
      </section>
    {% endif %}
  </div>
{% endblock %}
