{% extends 'admin/base.twig' %}

{% block admin_title %}External link analytics{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">External link analytics</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">See where visitors go when they leave your site — outbound clicks from the storefront.</p>
{% endblock %}

{% block admin_content %}
  {% set dest_count = top_destinations|length %}
  {% set source_count = top_sources|length %}

  <div class="admin-settings-page admin-settings-page--analytics">
    <div class="admin-settings-intro admin-settings-intro--analytics">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.72" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.72-1.72" />
        </svg>
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">Outbound click tracking</p>
        <p class="admin-settings-intro-text">
          A lightweight storefront script records clicks on external links (different host than your site).
          Use this to see popular affiliate links, partner sites, and which pages send the most traffic away.
          Tracking must be enabled below — when off, no new clicks are stored.
        </p>
      </div>
      {% if tracking_enabled %}
        <span class="admin-pill admin-pill--ok admin-hub-status-pill">Tracking on</span>
      {% else %}
        <span class="admin-pill admin-pill--warn admin-hub-status-pill">Tracking off</span>
      {% endif %}
    </div>

    <div class="admin-toolbar admin-toolbar--spread admin-hub-range-bar">
      <nav class="admin-filter-pills" aria-label="Date range">
        {% for key, label in { '7': '7 days', '30': '30 days', '90': '90 days', 'all': 'All time' } %}
          <a class="admin-filter-pill{{ range == key ? ' is-current' : '' }}" href="?range={{ key|e('url') }}">{{ label }}</a>
        {% endfor %}
      </nav>
    </div>

    <div class="admin-metrics admin-hub-metrics" aria-label="Click summary">
      <article class="admin-metric{% if total_clicks > 0 %} admin-metric--health-good{% endif %}">
        <p class="admin-metric-label">Total clicks</p>
        <p class="admin-metric-value">{{ total_clicks }}</p>
        <p class="admin-metric-meta">{% if range != 'all' %}Last {{ range }} day{{ range == '1' ? '' : 's' }}{% else %}All recorded{% endif %}</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Top destinations</p>
        <p class="admin-metric-value">{{ dest_count }}</p>
        <p class="admin-metric-meta">Unique outbound URLs</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Top sources</p>
        <p class="admin-metric-value">{{ source_count }}</p>
        <p class="admin-metric-meta">Pages sending clicks away</p>
      </article>
      <article class="admin-metric">
        <p class="admin-metric-label">Retention</p>
        <p class="admin-metric-value admin-metric-value--sm">{% if retention_days > 0 %}{{ retention_days }}d{% else %}Off{% endif %}</p>
        <p class="admin-metric-meta">Auto-purge old events</p>
      </article>
    </div>

    <div class="admin-settings-stack">
      <section class="admin-card admin-settings-card admin-settings-section" id="analytics-destinations">
        <header class="admin-settings-card-head-row">
          <div>
            <h2 class="admin-settings-card-title">Top destinations</h2>
            <p class="admin-settings-card-desc" style="margin-bottom:0">Where users go when they leave your site.</p>
          </div>
        </header>
        {% if top_destinations is empty %}
          <p class="admin-hint admin-settings-card-footnote">No clicks recorded yet{% if not tracking_enabled %} — enable tracking below{% endif %}.</p>
        {% else %}
          <div class="admin-table-wrap admin-table-wrap--hub" style="margin-top:0.85rem">
            <table class="admin-table admin-table--comfortable admin-table--hub">
              <thead>
                <tr>
                  <th scope="col">Destination URL</th>
                  <th scope="col">Host</th>
                  <th scope="col">Clicks</th>
                  <th scope="col">Source pages</th>
                  <th scope="col">Last clicked</th>
                </tr>
              </thead>
              <tbody>
                {% for row in top_destinations %}
                  <tr>
                    <td class="admin-table-url"><a class="admin-link" href="{{ row.destination_url|e('html_attr') }}" rel="noopener noreferrer nofollow" target="_blank">{{ row.destination_url|e }}</a></td>
                    <td class="admin-table-muted">{{ row.destination_host|e }}</td>
                    <td><strong class="admin-table-primary">{{ row.clicks }}</strong></td>
                    <td class="admin-table-muted">{{ row.unique_sources }}</td>
                    <td class="admin-table-muted"><time datetime="{{ row.last_clicked_at|e('html_attr') }}">{{ row.last_clicked_at|e }}</time></td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="analytics-sources">
        <header class="admin-settings-card-head-row">
          <div>
            <h2 class="admin-settings-card-title">Top source pages</h2>
            <p class="admin-settings-card-desc" style="margin-bottom:0">Pages on your site that send the most users away.</p>
          </div>
        </header>
        {% if top_sources is empty %}
          <p class="admin-hint admin-settings-card-footnote">No clicks recorded yet.</p>
        {% else %}
          <div class="admin-table-wrap admin-table-wrap--hub" style="margin-top:0.85rem">
            <table class="admin-table admin-table--comfortable admin-table--hub">
              <thead>
                <tr>
                  <th scope="col">Source page</th>
                  <th scope="col">Clicks</th>
                  <th scope="col">Unique destinations</th>
                  <th scope="col">Last clicked</th>
                </tr>
              </thead>
              <tbody>
                {% for row in top_sources %}
                  <tr>
                    <td><a class="admin-link admin-table-primary" href="{{ row.source_path|e('html_attr') }}" target="_blank" rel="noopener">{{ row.source_path|e }}</a></td>
                    <td><strong class="admin-table-primary">{{ row.clicks }}</strong></td>
                    <td class="admin-table-muted">{{ row.unique_destinations }}</td>
                    <td class="admin-table-muted"><time datetime="{{ row.last_clicked_at|e('html_attr') }}">{{ row.last_clicked_at|e }}</time></td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="analytics-recent">
        <header class="admin-settings-card-head-row">
          <div>
            <h2 class="admin-settings-card-title">Recent clicks</h2>
            <p class="admin-settings-card-desc" style="margin-bottom:0">The 50 most recent outbound clicks (any time range).</p>
          </div>
        </header>
        {% if recent_clicks is empty %}
          <p class="admin-hint admin-settings-card-footnote">No clicks recorded yet.</p>
        {% else %}
          <div class="admin-table-wrap admin-table-wrap--hub" style="margin-top:0.85rem">
            <table class="admin-table admin-table--comfortable admin-table--hub">
              <thead>
                <tr>
                  <th scope="col">When</th>
                  <th scope="col">Source page</th>
                  <th scope="col">Destination</th>
                  <th scope="col">Anchor text</th>
                  <th scope="col">User</th>
                </tr>
              </thead>
              <tbody>
                {% for row in recent_clicks %}
                  <tr>
                    <td class="admin-table-muted"><time datetime="{{ row.clicked_at|e('html_attr') }}">{{ row.clicked_at|e }}</time></td>
                    <td><a class="admin-link" href="{{ row.source_path|e('html_attr') }}" target="_blank" rel="noopener">{{ row.source_path|e }}</a></td>
                    <td class="admin-table-url"><a class="admin-link" href="{{ row.destination_url|e('html_attr') }}" rel="noopener noreferrer nofollow" target="_blank">{{ row.destination_url|e }}</a></td>
                    <td class="admin-table-muted">{{ row.link_text|default('')|e }}</td>
                    <td class="admin-table-muted">{% if row.user_id %}#{{ row.user_id }}{% else %}—{% endif %}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="short-links">
        <header class="admin-settings-card-head-row">
          <div>
            <h2 class="admin-settings-card-title">Short links</h2>
            <p class="admin-settings-card-desc" style="margin-bottom:0">
              Create branded short URLs that redirect to any destination — e.g.
              <code class="admin-inline-code">{{ short_link_example_url|default('/go/abc123')|e }}</code>.
            </p>
          </div>
          {% if short_link_enabled|default(false) %}
            <span class="admin-pill admin-pill--ok admin-hub-status-pill">Short links on</span>
          {% else %}
            <span class="admin-pill admin-pill--warn admin-hub-status-pill">Short links off</span>
          {% endif %}
        </header>

        <form method="post" action="{{ url_for('admin.analytics.short_links.create') }}" class="admin-form admin-settings-form" style="margin-top:0.85rem">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="short-destination">Destination URL</label>
              <input class="admin-input" type="url" id="short-destination" name="destination_url" required placeholder="https://partner.example.com/landing" />
            </div>
            <div class="admin-field">
              <label class="admin-label" for="short-code">Short code (optional)</label>
              <input class="admin-input" id="short-code" name="code" maxlength="12" pattern="[a-z0-9]{4,12}" placeholder="dsf6sh" autocomplete="off" />
              <p class="admin-hint">4–12 lowercase letters/numbers. Leave blank to auto-generate.</p>
            </div>
            <div class="admin-field">
              <label class="admin-label" for="short-label">Label (optional)</label>
              <input class="admin-input" id="short-label" name="label" maxlength="255" placeholder="Affiliate spring campaign" />
            </div>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="admin-btn-primary"{% if not short_link_enabled|default(false) %} disabled title="Enable short links in settings below"{% endif %}>Create short link</button>
          </div>
        </form>

        {% if short_link_rows is empty %}
          <p class="admin-hint admin-settings-card-footnote">No short links yet.</p>
        {% else %}
          <div class="admin-table-wrap admin-table-wrap--hub" style="margin-top:1rem">
            <table class="admin-table admin-table--comfortable admin-table--hub">
              <thead>
                <tr>
                  <th scope="col">Short URL</th>
                  <th scope="col">Destination</th>
                  <th scope="col">Label</th>
                  <th scope="col">Clicks</th>
                  <th scope="col">Created</th>
                  <th scope="col"><span class="visually-hidden">Actions</span></th>
                </tr>
              </thead>
              <tbody>
                {% for row in short_link_rows %}
                  <tr>
                    <td>
                      <a class="admin-link admin-table-primary" href="{{ row.short_url|e('html_attr') }}" target="_blank" rel="noopener">{{ row.short_url|e }}</a>
                    </td>
                    <td class="admin-table-url"><a class="admin-link" href="{{ row.destination_url|e('html_attr') }}" rel="noopener noreferrer" target="_blank">{{ row.destination_url|e }}</a></td>
                    <td class="admin-table-muted">{{ row.label|default('')|e }}</td>
                    <td><strong class="admin-table-primary">{{ row.clicks }}</strong></td>
                    <td class="admin-table-muted"><time datetime="{{ row.created_at|e('html_attr') }}">{{ row.created_at|e }}</time></td>
                    <td>
                      <form method="post" action="{{ url_for('admin.analytics.short_links.delete', { id: row.id }) }}" onsubmit="return confirm('Delete this short link?');">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
                        <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm admin-btn-danger">Delete</button>
                      </form>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </section>

      <section class="admin-card admin-settings-card admin-settings-section" id="analytics-settings">
        <h2 class="admin-settings-card-title">Tracker &amp; short link settings</h2>
        <p class="admin-settings-card-desc">Enable click tracking, short link redirects, excluded hosts, and data retention.</p>
        <form method="post" action="{{ url_for('admin.analytics.external_links.settings') }}" class="admin-form admin-settings-form">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <div class="admin-form-grid">
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="enabled" value="1" {% if tracking_enabled %}checked{% endif %} />
                Track outbound link clicks on the storefront
              </label>
              <p class="admin-hint">When off, the tracking script does not send events and this report stops growing.</p>
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="short_link_enabled" value="1" {% if short_link_enabled|default(false) %}checked{% endif %} />
                Enable short link redirects
              </label>
            </div>
            <div class="admin-field">
              <label class="admin-label" for="short-link-prefix">URL prefix segment</label>
              <input class="admin-input" id="short-link-prefix" name="short_link_prefix" maxlength="32" value="{{ short_link_prefix|default('go')|e('html_attr') }}" placeholder="go" />
              <p class="admin-hint">Creates URLs like <code class="admin-inline-code">/{{ short_link_prefix|default('go')|e }}/dsf6sh</code>. Use a single segment (letters, numbers, hyphens).</p>
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label admin-settings-check-label">
                <input type="checkbox" name="short_link_root_mode" value="1" {% if short_link_root_mode|default(false) %}checked{% endif %} />
                Also allow root short URLs (<code class="admin-inline-code">/{{ 'code' }}</code>)
              </label>
              <p class="admin-hint">When enabled, <code class="admin-inline-code">https://yoursite.com/dsf6sh</code> works in addition to prefixed URLs. Avoid codes that match existing page slugs.</p>
            </div>
            <div class="admin-field admin-field--full">
              <label class="admin-label" for="exclude-hosts">Exclude destinations (one host per line)</label>
              <textarea class="admin-textarea admin-input--code" id="exclude-hosts" name="exclude_hosts" rows="4">{{ exclude_hosts|e }}</textarea>
              <p class="admin-hint">Subdomains match — e.g. <code class="admin-inline-code">google.com</code> skips <code class="admin-inline-code">www.google.com</code> too.</p>
            </div>
            <div class="admin-field">
              <label class="admin-label" for="retention-days">Auto-purge after (days)</label>
              <input type="number" id="retention-days" min="0" name="retention_days" value="{{ retention_days }}" class="admin-input" />
              <p class="admin-hint">Set to <strong>0</strong> to keep all clicks until you purge manually.</p>
            </div>
          </div>
          <div class="admin-form-actions">
            <button type="submit" class="admin-btn-primary">Save settings</button>
          </div>
        </form>
      </section>

      <section class="admin-card admin-settings-card admin-card--danger-zone admin-settings-section" id="analytics-maintenance">
        <h2 class="admin-settings-card-title">Maintenance</h2>
        <p class="admin-settings-card-desc">Delete older click events or wipe the log entirely. You can also purge from <a class="admin-link" href="{{ url_for('admin.tools.maintenance') }}">Maintenance</a>.</p>
        <form method="post" action="{{ url_for('admin.analytics.external_links.purge') }}" class="admin-hub-inline-purge-form">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <input type="hidden" name="mode" value="older_than" />
          <label class="admin-hint admin-hub-inline-label">
            Delete clicks older than
            <input type="number" name="days" min="1" value="90" class="admin-input admin-input--inline admin-hub-inline-days" />
            days
          </label>
          <button type="submit" class="admin-btn-ghost admin-btn-ghost--sm">Delete old clicks</button>
        </form>
        <form method="post" action="{{ url_for('admin.analytics.external_links.purge') }}" class="admin-form" style="margin-top:0.85rem" onsubmit="return confirm('Delete ALL external-link click events? This cannot be undone.');">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <input type="hidden" name="mode" value="all" />
          <button type="submit" class="admin-btn admin-btn--danger">Delete all clicks</button>
        </form>
      </section>
    </div>
  </div>
{% endblock %}
