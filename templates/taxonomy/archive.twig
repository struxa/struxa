{% extends 'base.twig' %}

{% block title %}{{ taxonomy_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ taxonomy_meta_description|default('')|e }}{% endblock %}

{% block body %}
<main class="taxonomy-archive theme-cms-page">
  <article class="cms-page-inner">
    <header class="cms-page-header">
      <p class="cms-page-eyebrow">{{ taxonomy.name|e }} · {{ content_type.name|e }}</p>
      <h1 class="cms-page-title">{{ taxonomy_term.name|e }}</h1>
      {% if taxonomy_term.description %}
        <p class="taxonomy-archive-desc">{{ taxonomy_term.description|e }}</p>
      {% endif %}
    </header>

    {% if archive_entries is empty %}
      <p class="admin-hint" style="color:var(--muted, inherit)">No published entries in this archive yet.</p>
    {% else %}
      <ul class="taxonomy-archive-list" style="list-style:none;margin:0;padding:0;display:grid;gap:1rem">
        {% for row in archive_entries %}
          <li>
            <a href="{{ site_url }}/{{ content_type.slug|e }}/{{ row.slug|e }}" style="font-weight:700">{{ row.title|e }}</a>
            {% if row.published_at %}
              <span class="admin-hint" style="margin-left:0.5rem">{{ row.published_at|e }}</span>
            {% endif %}
          </li>
        {% endfor %}
      </ul>

      {% if archive_total_pages > 1 %}
        <nav class="taxonomy-archive-pager" style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;align-items:center" aria-label="Pagination">
          {% if archive_page > 1 %}
            <a class="admin-link" href="{{ url_for('public.taxonomy_archive', { typeSlug: content_type.slug, taxonomySlug: taxonomy.slug, termSlug: taxonomy_term.slug }) }}?page={{ archive_page - 1 }}">← Newer</a>
          {% endif %}
          <span class="admin-hint">Page {{ archive_page }} of {{ archive_total_pages }}</span>
          {% if archive_page < archive_total_pages %}
            <a class="admin-link" href="{{ url_for('public.taxonomy_archive', { typeSlug: content_type.slug, taxonomySlug: taxonomy.slug, termSlug: taxonomy_term.slug }) }}?page={{ archive_page + 1 }}">Older →</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endif %}
  </article>
</main>
{% include 'partials/_footer.twig' %}
{% endblock %}
