{# Fonts: non-blocking preloadâ†’stylesheet. Theme CSS uses normal stylesheet links to avoid a layout FOUC. #}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
{% if font_url|default('')|trim != '' %}
  <link rel="preload" as="style" href="{{ font_url|e('html_attr') }}" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="{{ font_url|e('html_attr') }}" /></noscript>
{% endif %}
{% for sheet in theme_stylesheets|default([]) %}
  {% set href = theme_asset(sheet) %}
  <link rel="stylesheet" href="{{ href|e('html_attr') }}" />
{% endfor %}
{% for sheet in theme_stylesheets_async|default([]) %}
  {% set href = theme_asset(sheet) %}
  <link rel="preload" as="style" href="{{ href|e('html_attr') }}" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="{{ href|e('html_attr') }}" /></noscript>
{% endfor %}
