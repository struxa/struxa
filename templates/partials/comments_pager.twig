{% set p = comments_pager|default({}) %}
{% set base = comments_pager_base|default('/') %}
{% set page = p.page|default(1) %}
{% set pages = p.total_pages|default(1) %}
{% set total = p.total_roots|default(0) %}
{% if pages > 1 %}
  <nav class="cms-comments-pager" aria-label="Comment threads pagination">
    <p class="cms-comments-pager-meta">
      Threads <strong>{{ p.from|default(0) }}</strong>–<strong>{{ p.to|default(0) }}</strong> of <strong>{{ total }}</strong>
      · page <strong>{{ page }}</strong> / <strong>{{ pages }}</strong>
    </p>
    <div class="cms-comments-pager-row">
      {% if page > 1 %}
        {% set prev = page - 1 %}
        <a class="cms-comments-pager-btn" rel="prev" href="{{ prev == 1 ? base : base ~ '?c_page=' ~ prev }}">Newer</a>
      {% else %}
        <span class="cms-comments-pager-btn cms-comments-pager-btn--disabled" aria-disabled="true">Newer</span>
      {% endif %}
      {% if page < pages %}
        <a class="cms-comments-pager-btn" rel="next" href="{{ base ~ '?c_page=' ~ (page + 1) }}">Older</a>
      {% else %}
        <span class="cms-comments-pager-btn cms-comments-pager-btn--disabled" aria-disabled="true">Older</span>
      {% endif %}
    </div>
  </nav>
{% elseif total > 0 %}
  <p class="cms-comments-pager-meta cms-comments-pager-meta--solo">{{ total }} thread{% if total != 1 %}s{% endif %}</p>
{% endif %}
