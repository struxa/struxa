<section class="section showcase" id="showcase">
  <div class="section-head section-head--center reveal" data-reveal>
    <p class="section-kicker">Live previews</p>
    <h2>Apps &amp; web products</h2>
    <p>
      Photo previews (Unsplash) inside browser and device frames — replace the <code>src</code> URLs with your
      own screenshots when you ship.
    </p>
  </div>
  <div class="showcase-grid">
    <article class="showcase-card showcase-card--violet reveal" data-reveal>
      <div class="showcase-preview">
        <div class="mock-browser">
          <div class="mock-browser-bar">
            <span class="mock-browser-dots"><i></i><i></i><i></i></span>
            <span class="mock-browser-url">app.example.com/dashboard</span>
          </div>
          <div class="mock-browser-content mock-browser-content--shot">
            <img
              class="mock-shot mock-shot--browser"
              src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&amp;h=500&amp;fit=crop&amp;auto=format&amp;q=82"
              alt="Dashboard with charts and KPI widgets"
              width="800"
              height="500"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
      <div class="showcase-body">
        <div class="showcase-tags">
          <span class="showcase-tag">Web app</span>
          <span class="showcase-tag">React</span>
        </div>
        <h3 class="showcase-title">Northline Ops</h3>
        <p class="showcase-desc">Operations dashboard with live KPIs, filters, and CSV exports for on-call teams.</p>
      </div>
    </article>

    <article class="showcase-card showcase-card--cyan reveal" data-reveal>
      <div class="showcase-preview showcase-preview--phone">
        <div class="mock-phone">
          <div class="mock-phone-notch"></div>
          <div class="mock-phone-screen mock-phone-screen--shot">
            <img
              class="mock-shot mock-shot--phone"
              src="https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?w=520&amp;h=940&amp;fit=crop&amp;auto=format&amp;q=82"
              alt="Mobile app on a smartphone held in hand"
              width="260"
              height="470"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
      <div class="showcase-body">
        <div class="showcase-tags">
          <span class="showcase-tag">iOS &amp; Android</span>
          <span class="showcase-tag">Offline-first</span>
        </div>
        <h3 class="showcase-title">SitePulse Mobile</h3>
        <p class="showcase-desc">Offline-capable crew app with sync queues, camera capture, and push handoffs.</p>
      </div>
    </article>

    <article class="showcase-card showcase-card--rose reveal" data-reveal>
      <div class="showcase-preview">
        <div class="mock-browser mock-browser--compact">
          <div class="mock-browser-bar">
            <span class="mock-browser-dots"><i></i><i></i><i></i></span>
            <span class="mock-browser-url">billing.studio.app</span>
          </div>
          <div class="mock-browser-content mock-browser-content--shot">
            <img
              class="mock-shot mock-shot--browser"
              src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&amp;h=500&amp;fit=crop&amp;auto=format&amp;q=82"
              alt="Laptop showing analytics and business metrics"
              width="800"
              height="500"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
      <div class="showcase-body">
        <div class="showcase-tags">
          <span class="showcase-tag">SaaS</span>
          <span class="showcase-tag">Stripe-ready</span>
        </div>
        <h3 class="showcase-title">LedgerLite Billing</h3>
        <p class="showcase-desc">Subscription console with plan builder, usage meters, and invoice history views.</p>
      </div>
    </article>
  </div>
  <p class="showcase-foot reveal" data-reveal>
    <a class="showcase-foot-link" href="#work">See all offerings →</a>
  </p>
</section>
