{% extends 'base.twig' %}

{% set _desc = content_meta_description|default('') %}
{% if _desc == '' and settings.default_meta_description|default('') %}
  {% set _desc = settings.default_meta_description %}
{% endif %}

{% block title %}{{ content_page_title|e }} — {{ settings.site_name|default('Site')|e }}{% endblock %}
{% block meta_description %}{{ _desc|e }}{% endblock %}
{% block og_title %}{{ content_page_title|e }}{% endblock %}
{% block og_description %}{{ _desc|e }}{% endblock %}
{% block twitter_title %}{{ content_page_title|e }}{% endblock %}
{% block twitter_description %}{{ _desc|e }}{% endblock %}

{% block head_extra %}
  {% if content_featured_url %}
    <meta property="og:image" content="{{ site_url }}{{ content_featured_url|e('html_attr') }}" />
    <meta name="twitter:image" content="{{ site_url }}{{ content_featured_url|e('html_attr') }}" />
  {% endif %}
  <link rel="canonical" href="{{ site_url }}/{{ content_type.slug }}/{{ content_entry.slug }}" />
{% endblock %}

{% block body %}
<main class="content-entry cms-page">
  <article class="content-entry-inner cms-page-inner">
    <header class="cms-page-header content-entry-header">
      <p class="cms-page-eyebrow">{{ content_type.name|e }}</p>
      <h1 class="cms-page-title content-entry-title">{{ content_entry.title|e }}</h1>
      {% if content_entry.publishedAt %}
        <p class="content-entry-meta">
          <time datetime="{{ content_entry.publishedAt|e('html_attr') }}">{{ content_entry.publishedAt|e }}</time>
        </p>
      {% endif %}
    </header>

    {% if content_featured_url %}
      <figure class="content-entry-featured">
        <img src="{{ content_featured_url|e('html_attr') }}" alt="" loading="eager" decoding="async" />
      </figure>
    {% endif %}

    <div class="content-entry-body cms-page-body">
      {% for row in content_field_rows %}
        <section class="content-entry-block" data-field-key="{{ row.field_key|e('html_attr') }}">
          <h2 class="content-entry-label">{{ row.label|e }}</h2>
          <div class="content-entry-value content-entry-value--{{ row.field_type|e('html_attr') }}">
            {{ row.html|raw }}
          </div>
        </section>
      {% endfor %}
    </div>
    {% include 'partials/comments_widget.twig' %}
  </article>
</main>
{% include 'partials/_footer.twig' %}
{% endblock %}
