{% extends theme_layout() %}

{% block title %}Register — {{ settings.site_name|default('Your Studio')|e }}{% endblock %}

{% block meta_extra %}
  {{ parent() }}
  <meta name="robots" content="noindex, nofollow" />
{% endblock %}

{% block body %}
<main id="main-content" class="theme-public-solo{% if active_theme|default('') == 'queue' %} theme-fq-editorial theme-fq-editorial--narrow{% endif %}" {% if active_theme|default('') == 'queue' %}data-fq-subpage{% endif %}>
  <article class="theme-cms-page theme-auth-page" aria-labelledby="auth-register-heading">
    <header class="theme-cms-page-hero">
      <p class="eyebrow">
        <span class="eyebrow-pulse" aria-hidden="true"></span>
        {{ 'Account'|e }}
      </p>
      <h1 class="theme-cms-page-title" id="auth-register-heading">{{ 'Register'|e }}</h1>
      <p class="theme-auth-page__intro auth-lede">
        Create an account. Already have one? <a href="{{ url_for('login') }}">Log in</a>.
      </p>

      {% if flash_error %}
        <p class="auth-flash auth-flash--error" role="alert">{{ flash_error }}</p>
      {% endif %}

      <div class="theme-auth-page__form-wrap">
        <form id="register-form" class="auth-form" method="post" action="{{ url_for('register') }}" autocomplete="on" novalidate>
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          {% if registration_collect_username|default(false) %}
            <div class="auth-field">
              <label class="auth-label" for="register-username"><span>Username</span></label>
              <input class="auth-input" id="register-username" type="text" name="username" autocomplete="username" maxlength="32" required pattern="[a-zA-Z0-9][a-zA-Z0-9_-]*" title="Letters, numbers, underscores, or hyphens; start with a letter or number." autocapitalize="none" spellcheck="false" />
            </div>
          {% endif %}
          <div class="auth-field">
            <label class="auth-label" for="register-email"><span>Email</span></label>
            <input class="auth-input" id="register-email" type="email" name="email" inputmode="email" autocomplete="email" autocapitalize="none" spellcheck="false" required />
          </div>
          <div class="auth-field">
            <label class="auth-label" for="register-password"><span>Password</span></label>
            <input class="auth-input" id="register-password" type="password" name="password" autocomplete="new-password" required />
          </div>
          <div class="auth-field">
            <label class="auth-label" for="register-password-confirm"><span>Confirm password</span></label>
            <input class="auth-input" id="register-password-confirm" type="password" name="password_confirm" autocomplete="new-password" required />
          </div>
          <button class="btn btn-primary btn-lg auth-submit" type="submit">Create account</button>
        </form>
      </div>
    </header>
  </article>
</main>
{% endblock %}
