{% extends theme_layout() %}

{% block title %}Sign out — {{ settings.site_name|default('Your Studio')|e }}{% endblock %}

{% block meta_extra %}
  {{ parent() }}
  <meta name="robots" content="noindex, nofollow" />
{% endblock %}

{% block body %}
<main id="main-content" class="theme-public-solo{% if active_theme|default('') == 'queue' %} theme-fq-editorial theme-fq-editorial--narrow{% endif %}" {% if active_theme|default('') == 'queue' %}data-fq-subpage{% endif %}>
  <article class="theme-cms-page theme-auth-page" aria-labelledby="logout-heading">
    <header class="theme-cms-page-hero">
      <p class="eyebrow">
        <span class="eyebrow-pulse" aria-hidden="true"></span>
        {{ 'Account'|e }}
      </p>
      <h1 class="theme-cms-page-title" id="logout-heading">{{ 'Sign out'|e }}</h1>
      <p class="theme-auth-page__intro auth-lede">Confirm that you want to end your session on this device.</p>
      <div class="theme-auth-page__form-wrap">
        <form id="logout-form" class="auth-form" method="post" action="{{ url_for('logout') }}">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <button type="submit" class="btn btn-primary btn-lg auth-submit">Sign out</button>
        </form>
        <p class="theme-auth-page__footer-link auth-lede"><a href="{{ url_for('home') }}">Cancel — back to site</a></p>
      </div>
    </header>
  </article>
</main>
{% endblock %}
