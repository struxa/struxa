{% extends theme_layout() %}

{% block title %}Sign out — {{ settings.site_name|default('Your Studio')|e }}{% endblock %}

{% block body %}
<main id="main-content" class="{% if active_theme|default('') == 'queue' %}theme-fq-editorial theme-fq-editorial--narrow{% endif %}">
  <section class="section section-auth" aria-labelledby="logout-heading">
    <div class="auth-card glass-panel">
      <h1 class="auth-title" id="logout-heading">Sign out</h1>
      <p class="auth-lede">Confirm that you want to end your session on this device.</p>
      <form class="auth-form" method="post" action="{{ url_for('logout') }}" style="margin-top:1rem">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <button type="submit" class="btn btn-primary btn-lg auth-submit">Sign out</button>
      </form>
      <p class="auth-lede" style="margin-top:1.25rem;font-size:0.9rem"><a href="{{ url_for('home') }}">Cancel — back to site</a></p>
    </div>
  </section>
</main>
{% endblock %}
