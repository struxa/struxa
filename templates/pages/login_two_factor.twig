{% extends theme_layout() %}

{% block title %}Two-factor authentication — {{ settings.site_name|default('Your Studio')|e }}{% endblock %}

{% block meta_extra %}
  {{ parent() }}
  <meta name="robots" content="noindex, nofollow" />
{% endblock %}

{% block body %}
<main id="main-content" class="theme-public-solo{% if active_theme|default('') == 'queue' %} theme-fq-editorial theme-fq-editorial--narrow{% endif %}" {% if active_theme|default('') == 'queue' %}data-fq-subpage{% endif %}>
  <article class="theme-cms-page theme-auth-page" aria-labelledby="auth-2fa-heading">
    <header class="theme-cms-page-hero">
      <p class="eyebrow">
        <span class="eyebrow-pulse" aria-hidden="true"></span>
        {{ 'Security'|e }}
      </p>
      <h1 class="theme-cms-page-title" id="auth-2fa-heading">{{ 'Authenticator code'|e }}</h1>
      <p class="theme-auth-page__intro auth-lede">
        Enter the 6-digit code from your authenticator app to finish signing in.
      </p>

      {% if flash_error %}
        <p class="auth-flash auth-flash--error" role="alert">{{ flash_error }}</p>
      {% endif %}

      <div class="theme-auth-page__form-wrap">
        <form id="login-two-factor-form" class="auth-form" method="post" action="{{ url_for('login.two_factor.submit') }}" autocomplete="one-time-code" novalidate>
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          {% if login_next %}
            <input type="hidden" name="next" value="{{ login_next }}" />
          {% endif %}
          <div class="auth-field">
            <label class="auth-label" for="login-totp-code"><span>Code</span></label>
            <input class="auth-input" id="login-totp-code" type="text" name="code" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="12" required autofocus />
          </div>
          <button class="btn btn-primary btn-lg auth-submit" type="submit">Continue</button>
        </form>
        <p class="theme-auth-page__footer-link auth-lede"><a href="{{ url_for('login') }}">Back to log in</a></p>
      </div>
    </header>
  </article>
</main>
{% endblock %}
