{% extends theme_layout() %}

{% block title %}Log in — {{ settings.site_name|default('Your Studio')|e }}{% endblock %}

{% block meta_extra %}
  {{ parent() }}
  <meta name="robots" content="noindex, nofollow" />
{% endblock %}

{% block body %}
<main id="main-content" class="theme-public-solo{% if active_theme|default('') == 'queue' %} theme-fq-editorial theme-fq-editorial--narrow{% endif %}" {% if active_theme|default('') == 'queue' %}data-fq-subpage{% endif %}>
  <article class="theme-cms-page theme-auth-page" aria-labelledby="auth-login-heading">
    <header class="theme-cms-page-hero">
      <p class="eyebrow">
        <span class="eyebrow-pulse" aria-hidden="true"></span>
        {{ 'Account'|e }}
      </p>
      <h1 class="theme-cms-page-title" id="auth-login-heading">{{ 'Log in'|e }}</h1>
      <p class="theme-auth-page__intro auth-lede">
        Access your studio account. New here? <a href="{{ url_for('register') }}">Create one</a>. Staff with two-factor enabled will be asked for an app code after the password.
      </p>

      {% if flash_error %}
        <p class="auth-flash auth-flash--error" role="alert">{{ flash_error }}</p>
      {% endif %}
      {% if flash_success %}
        <p class="auth-flash auth-flash--success" role="status">{{ flash_success }}</p>
      {% endif %}

      <div class="theme-auth-page__form-wrap">
        {% if firebase_sso_enabled and firebase_client_config %}
          <div class="auth-oauth">
            <button type="button" class="btn btn-secondary btn-lg auth-submit" id="btn-firebase-sign-in">Continue with Firebase</button>
          </div>
          <form id="firebase-session-form" method="post" action="{{ url_for('auth.firebase.session') }}" hidden>
            <input type="hidden" name="id_token" value="" />
            <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
            {% if login_next %}
              <input type="hidden" name="next" value="{{ login_next }}" />
            {% endif %}
          </form>
          {% if google_sso_enabled %}
            <p class="auth-divider" role="presentation">or</p>
          {% endif %}
        {% endif %}
        {% if google_sso_enabled %}
          <div class="auth-oauth">
            <a class="btn btn-secondary btn-lg auth-submit" href="{{ url_for('auth.google.start', {}, login_next ? { next: login_next } : {}) }}">Continue with Google</a>
          </div>
          <p class="auth-divider" role="presentation">or use your email and password</p>
        {% elseif not firebase_sso_enabled %}
          {# no oauth — email form only #}
        {% else %}
          <p class="auth-divider" role="presentation">or use your email and password</p>
        {% endif %}

        <form id="login-form" name="login" class="auth-form" method="post" action="{{ url_for('login') }}" autocomplete="on" novalidate>
          <div class="auth-field">
            <label class="auth-label" for="username"><span>Email</span></label>
            <input
              class="auth-input"
              id="username"
              type="email"
              name="username"
              inputmode="email"
              autocomplete="username"
              autocapitalize="none"
              autocorrect="off"
              spellcheck="false"
              required
            />
          </div>
          <div class="auth-field">
            <label class="auth-label" for="password"><span>Password</span></label>
            <input
              class="auth-input"
              id="password"
              type="password"
              name="password"
              autocomplete="current-password"
              required
            />
          </div>
          <label class="auth-check">
            <input type="checkbox" name="remember" value="1" />
            <span>Remember me</span>
          </label>
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          {% if login_next %}
            <input type="hidden" name="next" value="{{ login_next }}" />
          {% endif %}
          <button class="btn btn-primary btn-lg auth-submit" type="submit">Log in</button>
        </form>
      </div>
    </header>
  </article>
</main>
{% endblock %}

{% block scripts_extra %}
  {% if firebase_sso_enabled and firebase_client_config %}
    <script>
      window.STRUXA_FIREBASE_CONFIG = {{ firebase_client_config|json_encode|raw }};
    </script>
    <script src="https://www.gstatic.com/firebasejs/11.6.0/firebase-app-compat.js" crossorigin="anonymous"></script>
    <script src="https://www.gstatic.com/firebasejs/11.6.0/firebase-auth-compat.js" crossorigin="anonymous"></script>
    <script src="/js/firebase-login.js" defer></script>
  {% endif %}
{% endblock %}
