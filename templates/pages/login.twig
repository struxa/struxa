{% extends theme_layout() %}

{% block title %}Log in — {{ settings.site_name|default('Your Studio')|e }}{% endblock %}

{% block body %}
<main id="main-content" class="{% if active_theme|default('') == 'queue' %}theme-fq-editorial theme-fq-editorial--narrow{% endif %}">
  <section class="section section-auth" aria-labelledby="auth-login-heading">
    <div class="auth-card glass-panel">
      <p class="eyebrow reveal" data-reveal><span class="eyebrow-pulse"></span> Account</p>
      <h1 class="auth-title" id="auth-login-heading">Log in</h1>
      <p class="auth-lede">Access your studio account. New here? <a href="{{ url_for('register') }}">Create one</a>. Staff with two-factor enabled will be asked for an app code after the password.</p>

      {% if flash_error %}
        <p class="auth-flash auth-flash--error" role="alert">{{ flash_error }}</p>
      {% endif %}
      {% if flash_success %}
        <p class="auth-flash auth-flash--success" role="status">{{ flash_success }}</p>
      {% endif %}

      {% if google_sso_enabled %}
        <div class="auth-oauth">
          <a class="btn btn-secondary btn-lg auth-submit" href="{{ url_for('auth.google.start', {}, login_next ? { next: login_next } : {}) }}">Continue with Google</a>
        </div>
        <p class="auth-divider" role="presentation">or use your email and password</p>
      {% endif %}

      {# ids username + password match common browser/extension heuristics (with name="username" for email login). #}
      <form id="login-form" name="login" class="auth-form" method="post" action="{{ url_for('login') }}" autocomplete="on" novalidate>
        <div class="auth-field">
          <label class="auth-label" for="username"><span>Email</span></label>
          <input
            class="auth-input"
            id="username"
            type="email"
            name="username"
            inputmode="email"
            autocomplete="username"
            autocapitalize="none"
            autocorrect="off"
            spellcheck="false"
            required
          />
        </div>
        <div class="auth-field">
          <label class="auth-label" for="password"><span>Password</span></label>
          <input
            class="auth-input"
            id="password"
            type="password"
            name="password"
            autocomplete="current-password"
            required
          />
        </div>
        <label class="auth-check">
          <input type="checkbox" name="remember" value="1" />
          <span>Remember me</span>
        </label>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        {% if login_next %}
          <input type="hidden" name="next" value="{{ login_next }}" />
        {% endif %}
        <button class="btn btn-primary btn-lg auth-submit" type="submit">Log in</button>
      </form>
    </div>
  </section>
</main>
{% endblock %}
