{% extends 'base.twig' %}

{% block title %}Cart — {{ settings.site_name|default('Site')|e }}{% endblock %}

{% block body %}
<main class="theme-content-entry theme-commerce-cart">
  <h1>Your cart</h1>
  <p class="theme-commerce-nav-links">
    <a href="{{ url_for('public.commerce.orders') }}">My orders</a>
    ·
    <a href="{{ url_for('public.commerce.orders.lookup') }}">Track an order</a>
  </p>

  {% if cart_error %}
    <p class="theme-commerce-cart-error">{{ cart_error|e }}</p>
  {% endif %}
  {% if cart_coupon_error %}
    <p class="theme-commerce-cart-error">{{ cart_coupon_error|e }}</p>
  {% endif %}

  {% if cart_lines is empty %}
    <p>Your cart is empty.</p>
    <p><a href="{{ url_for('home') }}">Continue shopping</a></p>
  {% else %}
    <ul class="theme-commerce-cart-list">
      {% for line in cart_lines %}
        <li class="theme-commerce-cart-item">
          <div class="theme-commerce-cart-item-main">
            <a href="/{{ line.product.contentTypeSlug|e('url') }}/{{ line.product.entrySlug|e('url') }}">{{ line.product.title|e }}</a>
            <span class="theme-commerce-price">{{ line.product.formattedPrice() }}</span>
          </div>
          <form method="post" action="{{ url_for('public.commerce.cart.update') }}" class="theme-commerce-cart-qty-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
            <input type="hidden" name="content_entry_id" value="{{ line.product.entryId }}" />
            <label>
              Qty
              <input type="number" name="quantity" value="{{ line.quantity }}" min="0" max="99" />
            </label>
            <button type="submit" class="theme-btn theme-btn--ghost">Update</button>
          </form>
          <p class="theme-commerce-cart-line-total">Line total: {{ (line.lineTotalCents / 100)|number_format(2) }} {{ cart_currency|upper|e }}</p>
        </li>
      {% endfor %}
    </ul>

    <section class="theme-commerce-cart-coupon">
      <h2>Coupon</h2>
      {% if cart_coupon_code %}
        <p>Applied: <strong>{{ cart_coupon_code|e }}</strong></p>
        <form method="post" action="{{ url_for('public.commerce.cart.coupon') }}">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <input type="hidden" name="action" value="remove" />
          <button type="submit" class="theme-btn theme-btn--ghost">Remove coupon</button>
        </form>
      {% else %}
        <form method="post" action="{{ url_for('public.commerce.cart.coupon') }}" class="theme-commerce-coupon-form">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <input type="hidden" name="action" value="apply" />
          <label>
            Code
            <input type="text" name="coupon_code" maxlength="64" autocomplete="off" />
          </label>
          <button type="submit" class="theme-btn theme-btn--ghost">Apply</button>
        </form>
      {% endif %}
    </section>

    {% if cart_totals %}
      <dl class="theme-commerce-cart-totals">
        <dt>Subtotal</dt><dd>{{ (cart_totals.subtotalCents / 100)|number_format(2) }} {{ cart_currency|upper|e }}</dd>
        {% if cart_totals.discountCents > 0 %}
          <dt>Discount{% if cart_totals.couponCode %} ({{ cart_totals.couponCode|e }}){% endif %}</dt>
          <dd>−{{ (cart_totals.discountCents / 100)|number_format(2) }} {{ cart_currency|upper|e }}</dd>
        {% endif %}
        {% if cart_totals.taxCents > 0 %}
          <dt>Tax</dt><dd>{{ (cart_totals.taxCents / 100)|number_format(2) }} {{ cart_currency|upper|e }}</dd>
        {% endif %}
        {% if cart_totals.shippingCents > 0 %}
          <dt>{{ cart_totals.shippingLabel|default('Shipping')|e }}</dt>
          <dd>{{ (cart_totals.shippingCents / 100)|number_format(2) }} {{ cart_currency|upper|e }}</dd>
        {% elseif cart_totals.shippingLabel %}
          <dt>{{ cart_totals.shippingLabel|e }}</dt><dd>Free</dd>
        {% endif %}
        <dt><strong>Total</strong></dt><dd><strong>{{ (cart_totals.totalCents / 100)|number_format(2) }} {{ cart_currency|upper|e }}</strong></dd>
      </dl>
    {% else %}
      <p class="theme-commerce-cart-subtotal"><strong>Subtotal:</strong> {{ (cart_subtotal_cents / 100)|number_format(2) }} {{ cart_currency|upper|e }}</p>
    {% endif %}

    <form method="post" action="{{ url_for('public.commerce.cart.checkout') }}">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
      <button type="submit" class="theme-btn">Checkout with Stripe</button>
    </form>
  {% endif %}
</main>
{% endblock %}
