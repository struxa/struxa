{% extends 'pages/plugin_public_theme_shell.twig' %}

{% block title %}Content stream — {{ settings.site_name|default('Site')|e }}{% endblock %}

{% block plugin_public_body %}
{% set cs_has_result = content_stream_error|default('')|trim == '' and content_stream_brief|default('')|trim != '' %}
<main id="main-content" class="{% if active_theme|default('') == 'queue' %}theme-fq-editorial theme-fq-editorial--narrow {% endif %}cs-stream-page-root">
  <section class="section section-auth cs-stream-page" aria-labelledby="cs-stream-heading">
  <div class="auth-card glass-panel cs-stream-card">
    {% if active_theme|default('') == 'queue' %}
    <p class="eyebrow reveal" data-reveal><span class="eyebrow-pulse"></span> Staff tool</p>
    {% endif %}
    <h1 class="auth-title" id="cs-stream-heading"{% if active_theme|default('') != 'queue' %} style="margin-top:0"{% endif %}>Content stream</h1>
    <p class="auth-lede">Staff-only: domain → analysis → keyword metrics → monthly plan (same flow as the admin domain tool).</p>

    {% if not content_stream_table_ok|default(false) %}
      <p class="auth-flash auth-flash--error" role="alert">This feature is not fully installed yet (database table missing). Ask an administrator to run the plugin migration.</p>
    {% else %}
      <p id="cs-error-wrap" class="auth-flash auth-flash--error" role="alert"{% if content_stream_error|default('')|trim == '' %} hidden{% endif %}><span id="cs-error-text">{{ content_stream_error|e }}</span></p>

      {% include '@plugin_content_stream_plugin/partials/content_stream_analysis_styles.twig' %}

      <style>
        /* Queue (and any theme) excludes .cs-stream-card from global auth-card padding — restore it here. */
        .cs-stream-page-root .auth-card.cs-stream-card {
          max-width: 56rem;
          width: min(100%, 56rem);
          margin-left: auto;
          margin-right: auto;
          padding: clamp(1.35rem, 4vw, 2.25rem);
          box-sizing: border-box;
        }
        /* Themes without Queue editorial shell: page gutters so the card is not edge-to-edge. */
        main.cs-stream-page-root:not(.theme-fq-editorial) {
          padding: clamp(1.25rem, 4vw, 2rem);
          box-sizing: border-box;
        }
        .cs-stream-page-root .cs-wizard-canvas {
          position: relative;
          --admin-radius: 12px;
          --admin-border: rgba(255, 255, 255, 0.12);
          --admin-card: rgba(0, 0, 0, 0.22);
        }
        .cs-stream-wizard-domains {
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0, 0, 0, 0);
          white-space: nowrap;
          border: 0;
        }
        .cs-stream-page-root .admin-section-title { font-size: 1.15rem; margin: 0; }
        .cs-stream-page-root .admin-btn-primary,
        .cs-stream-page-root .admin-btn-ghost {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: 0.35rem;
          padding: 0.65rem 1.15rem;
          border-radius: 10px;
          font-weight: 600;
          font-size: 0.9375rem;
          cursor: pointer;
          text-decoration: none;
          border: none;
          font-family: inherit;
        }
        .cs-stream-page-root .admin-btn-primary {
          background: linear-gradient(135deg, var(--accent-violet, #6366f1), var(--accent-violet-dark, #4f46e5));
          color: #fff;
        }
        .cs-stream-page-root .admin-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
        .cs-stream-page-root .admin-btn-ghost {
          background: transparent;
          color: inherit;
          border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .cs-stream-page-root .admin-link { color: var(--accent-cyan, #22d3ee); text-decoration: underline; text-underline-offset: 2px; }
        .cs-stream-page-root .admin-callout {
          padding: 0.85rem 1rem;
          border-radius: 10px;
          border: 1px solid rgba(239, 68, 68, 0.35);
          background: rgba(239, 68, 68, 0.08);
          margin-top: 1rem;
        }
        .cs-stream-page-root .admin-table-wrap { overflow-x: auto; margin-top: 1rem; -webkit-overflow-scrolling: touch; }
        .cs-stream-page-root .admin-table {
          width: 100%;
          border-collapse: collapse;
          font-size: 0.8125rem;
        }
        .cs-stream-page-root .admin-table th,
        .cs-stream-page-root .admin-table td {
          border: 1px solid rgba(255, 255, 255, 0.1);
          padding: 0.5rem 0.6rem;
          text-align: left;
          vertical-align: top;
        }
        .cs-stream-page-root .admin-table thead th { font-weight: 700; opacity: 0.9; }
        .cs-stream-page-root .admin-input {
          width: 100%;
          max-width: 20rem;
          padding: 0.55rem 0.75rem;
          border-radius: 8px;
          border: 1px solid rgba(255, 255, 255, 0.15);
          background: rgba(0, 0, 0, 0.2);
          color: inherit;
          font: inherit;
        }
        .cs-stream-page-root .admin-label { display: block; font-weight: 600; font-size: 0.8125rem; margin-bottom: 0.35rem; }
        .cs-stream-page-root .admin-field { margin-top: 0.85rem; }
        .cs-stream-page-root .admin-code-block {
          font-family: ui-monospace, monospace;
          font-size: 0.75rem;
          line-height: 1.45;
          margin: 0;
        }
        .cs-stream-page-root .cs-wizard-actions { display: flex; flex-wrap: wrap; gap: 0.65rem; align-items: center; margin-top: 1rem; }
        .cs-stream-page-root .cs-brief-progress {
          margin-top: 1rem;
          padding: 1rem 1.1rem;
          border-radius: 12px;
          border: 1px solid rgba(255, 255, 255, 0.12);
          background: rgba(0, 0, 0, 0.2);
        }
        .cs-stream-page-root .cs-brief-progress-title { margin: 0 0 0.65rem; font-size: 0.9375rem; font-weight: 700; }
        .cs-stream-page-root .cs-brief-progress-track { position: relative; height: 6px; border-radius: 999px; overflow: hidden; background: rgba(255, 255, 255, 0.12); }
        .cs-stream-page-root .cs-brief-progress-fill {
          position: absolute;
          inset: 0 auto 0 0;
          width: 35%;
          border-radius: inherit;
          background: linear-gradient(90deg, var(--accent-violet, #6366f1), var(--accent-cyan, #22d3ee), var(--accent-violet, #6366f1));
          background-size: 200% 100%;
          animation: cs-stream-brief-progress 1.1s ease-in-out infinite;
        }
        .cs-stream-page-root .cs-brief-progress-hint { margin: 0.65rem 0 0; font-size: 0.8125rem; opacity: 0.85; }
        @keyframes cs-stream-brief-progress { 0% { transform: translateX(-100%); } 100% { transform: translateX(320%); } }
        @media (prefers-reduced-motion: reduce) {
          .cs-stream-page-root .cs-brief-progress-fill { animation: none; width: 100%; opacity: 0.35; }
        }
        .cs-stream-page-root .admin-updates-apply-progress { margin-top: 1rem; }
        .cs-stream-page-root .admin-updates-apply-progress-title { margin: 0 0 0.5rem; font-weight: 700; font-size: 0.875rem; }
        .cs-stream-page-root .admin-updates-apply-progress-track { height: 6px; border-radius: 999px; background: rgba(255,255,255,0.12); overflow: hidden; }
        .cs-stream-page-root .admin-updates-apply-progress-fill { height: 100%; width: 40%; background: linear-gradient(90deg, #6366f1, #22d3ee); animation: cs-stream-brief-progress 1.1s ease-in-out infinite; }
      </style>

    <div class="cs-wizard-canvas">
      <div class="cs-stream-wizard-domains" aria-hidden="true">
        <span id="cs-result-domain">{{ content_stream_domain|e }}</span>
        <span id="cs-result-domain-metrics">{{ content_stream_domain|e }}</span>
      </div>

      <div class="cs-wizard-shell">
        <div class="cs-wizard-track cs-wizard-track--four" id="cs-wizard-track" role="navigation" aria-label="Wizard progress">
          <span id="cs-wizard-crumb-1" class="cs-wizard-crumb{% if not cs_has_result %} is-active{% else %} is-done{% endif %}">
            <span class="cs-wizard-crumb-num" aria-hidden="true">1</span>
            <span class="cs-wizard-crumb-label">Domain</span>
          </span>
          <span class="cs-wizard-track-line" aria-hidden="true"></span>
          <span id="cs-wizard-crumb-2" class="cs-wizard-crumb{% if cs_has_result %} is-active{% endif %}">
            <span class="cs-wizard-crumb-num" aria-hidden="true">2</span>
            <span class="cs-wizard-crumb-label">Analysis</span>
          </span>
          <span class="cs-wizard-track-line" aria-hidden="true"></span>
          <span id="cs-wizard-crumb-3" class="cs-wizard-crumb">
            <span class="cs-wizard-crumb-num" aria-hidden="true">3</span>
            <span class="cs-wizard-crumb-label">Metrics</span>
          </span>
          <span class="cs-wizard-track-line" aria-hidden="true"></span>
          <span id="cs-wizard-crumb-4" class="cs-wizard-crumb">
            <span class="cs-wizard-crumb-num" aria-hidden="true">4</span>
            <span class="cs-wizard-crumb-label">Plan</span>
          </span>
        </div>

        <div class="cs-wizard-step-heading" id="cs-wizard-step-label" aria-live="polite">
          {% if cs_has_result %}
            <span class="cs-wizard-step-kicker">Step 2 of 4</span>
            <span class="cs-wizard-step-title">Review the analysis</span>
          {% else %}
            <span class="cs-wizard-step-kicker">Step 1 of 4</span>
            <span class="cs-wizard-step-title">Enter the company domain</span>
          {% endif %}
        </div>
      </div>

      <form id="cs-brief-form" class="auth-form" method="post" action="{{ content_stream_form_action|e('html_attr') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
        <div id="cs-wizard-step1"{% if cs_has_result %} hidden{% endif %}>
          <div id="cs-progress" class="cs-brief-progress" hidden aria-live="polite">
            <p class="cs-brief-progress-title">Analysing domain…</p>
            <div class="cs-brief-progress-track" role="presentation"><div class="cs-brief-progress-fill"></div></div>
            <p class="cs-brief-progress-hint">Fetching the homepage and calling OpenAI — may take up to a minute.</p>
          </div>

          <section class="admin-section cs-wizard-panel cs-wizard-panel--domain">
            <div class="cs-wizard-panel-head">
              <h2 class="admin-section-title cs-wizard-panel-title">Domain</h2>
              <p class="cs-wizard-panel-lead">We fetch the site and run a two-pass evidence-based analysis.</p>
            </div>
            <label class="auth-label admin-label" for="cs_domain">Hostname</label>
            <input class="auth-input admin-input" type="text" id="cs_domain" name="domain" value="{{ content_stream_domain|default('')|e('html_attr') }}" placeholder="example.com" autocomplete="off" required />
            <div class="cs-wizard-actions">
              <button type="submit" class="btn btn-primary btn-lg admin-btn-primary" id="cs-brief-submit">Run analysis</button>
            </div>
            {% if not content_stream_api_configured|default(false) %}
              <p class="auth-lede" style="margin-top:1rem;font-size:0.875rem;opacity:0.9">Configure an OpenAI API key under <a class="admin-link" href="{{ url_for('plugin.content_stream_plugin.admin') }}">Admin → Content Stream</a>.</p>
            {% endif %}
          </section>
        </div>
      </form>

      <div id="cs-wizard-step2"{% if not cs_has_result %} hidden{% endif %}>
        <section class="admin-section cs-wizard-panel">
          <div class="cs-wizard-panel-head">
            <h2 class="admin-section-title cs-wizard-panel-title">Analysis</h2>
          </div>

          <div id="cs-analysis-cards" class="cs-analysis-cards" aria-live="polite"></div>
          <textarea id="cs-analysis-raw" autocomplete="off" readonly aria-hidden="true">{{ content_stream_brief|default('')|e }}</textarea>

          <details class="cs-analysis-raw-wrap">
            <summary>Technical · raw JSON</summary>
            <pre class="admin-code-block" id="cs-analysis-json-fallback" style="white-space:pre-wrap;line-height:1.5"></pre>
          </details>

          <div class="cs-wizard-actions cs-wizard-actions--footer" style="margin-top:1.5rem">
            <button type="button" class="admin-btn-primary" id="cs-wizard-to-metrics">Next: Keyword metrics</button>
            <button type="button" class="admin-btn-ghost" id="cs-wizard-back-step1">Back to domain</button>
            <button type="button" class="admin-btn-ghost cs-wizard-restart" id="cs-wizard-restart">Analyse another domain</button>
          </div>
        </section>
      </div>

      <div id="cs-wizard-step3" hidden>
        <section class="admin-section cs-wizard-panel cs-wizard-panel--metrics">
          <div class="cs-wizard-panel-head">
            <h2 class="admin-section-title cs-wizard-panel-title">Keyword metrics</h2>
            <p class="cs-wizard-panel-lead">Phrases come from your analysis, then DataForSEO enriches volume, CPC, competition, and difficulty.</p>
          </div>

          <div class="cs-wizard-actions">
            <button type="button" class="admin-btn-primary" id="cs-fetch-keyword-metrics"
              data-metrics-url="{{ content_stream_keyword_metrics_url|default('')|e('html_attr') }}"
              data-csrf="{{ csrf_token()|e('html_attr') }}"
              {% if not content_stream_dataforseo_configured|default(false) %} disabled{% endif %}>Fetch live keyword metrics</button>
          </div>
          {% if not content_stream_dataforseo_configured|default(false) %}
            <p class="auth-lede cs-wizard-hint-below" style="margin-top:0.75rem;font-size:0.875rem;opacity:0.9">Add DataForSEO under <a class="admin-link" href="{{ url_for('plugin.content_stream_plugin.admin') }}">API settings</a>.</p>
          {% endif %}

          <div id="cs-keyword-progress" class="admin-updates-apply-progress" hidden aria-live="polite" style="margin-top:1rem">
            <p class="admin-updates-apply-progress-title">Fetching keyword data…</p>
            <div class="admin-updates-apply-progress-track" role="presentation">
              <div class="admin-updates-apply-progress-fill"></div>
            </div>
            <p class="auth-lede" style="margin:0.5rem 0 0;font-size:0.8125rem;opacity:0.85">OpenAI keyword pass, then DataForSEO — often 30–90 seconds.</p>
          </div>

          <div id="cs-keyword-error-wrap" class="admin-callout" role="alert" hidden style="margin-top:1rem;border-color:rgba(239,68,68,0.4)">
            <p class="admin-prose" style="margin:0;" id="cs-keyword-error-text"></p>
          </div>

          <div class="admin-table-wrap" id="cs-keyword-table-wrap" hidden style="margin-top:1rem">
            <table class="admin-table" id="cs-keyword-table">
              <thead>
                <tr>
                  <th scope="col">Keyword</th>
                  <th scope="col">Search volume</th>
                  <th scope="col">CPC (USD)</th>
                  <th scope="col">Competition</th>
                  <th scope="col">Difficulty</th>
                  <th scope="col">Variations</th>
                </tr>
              </thead>
              <tbody id="cs-keyword-tbody"></tbody>
            </table>
          </div>

          <div class="cs-wizard-actions cs-wizard-actions--footer" style="margin-top:1.5rem">
            <button type="button" class="admin-btn-primary" id="cs-wizard-to-engine">Next: Monthly plan</button>
            <button type="button" class="admin-btn-ghost" id="cs-wizard-back-step2">Back to analysis</button>
            <button type="button" class="admin-btn-ghost cs-wizard-restart" id="cs-wizard-restart-from-metrics">Analyse another domain</button>
          </div>
        </section>
      </div>

      <div id="cs-wizard-step4" hidden>
        <section id="cs-wizard-step4-section" class="admin-section cs-wizard-panel">
          <div class="cs-wizard-panel-head">
            <h2 class="admin-section-title cs-wizard-panel-title">Keyword engine</h2>
            <p class="cs-wizard-panel-lead">One post per day for the calendar month. Plans are stored in the database.</p>
          </div>
          <p class="auth-lede cs-engine-plan-meta" id="cs-engine-plan-meta" hidden style="font-size:0.875rem"></p>

          {% if not content_stream_keyword_plan_ready|default(false) %}
            <div class="admin-callout" role="alert" style="margin-top:1rem;border-color:rgba(251,191,36,0.4);background:rgba(251,191,36,0.08)">
              <p class="admin-prose" style="margin:0">Run <code class="admin-code-block" style="display:inline">003_keyword_engine.sql</code> if plan tables are missing.</p>
            </div>
          {% endif %}

          <div class="admin-field admin-field--full" style="margin-top:1rem">
            <label class="admin-label" for="cs-engine-month">Calendar month</label>
            <input class="admin-input" type="month" id="cs-engine-month" value="{{ content_stream_keyword_plan_default_month|e('html_attr') }}" {% if not content_stream_keyword_plan_ready|default(false) %} disabled{% endif %} />
          </div>
          <div class="admin-field admin-field--full">
            <label class="admin-label" for="cs-engine-label">Label (optional)</label>
            <input class="admin-input" type="text" id="cs-engine-label" maxlength="255" placeholder="Campaign or client name" {% if not content_stream_keyword_plan_ready|default(false) %} disabled{% endif %} />
          </div>
          <div class="cs-wizard-actions">
            <button type="button" class="admin-btn-primary" id="cs-engine-generate"
              data-generate-url="{{ content_stream_keyword_plan_generate_url|default('')|e('html_attr') }}"
              data-csrf="{{ csrf_token()|e('html_attr') }}"
              {% if not content_stream_keyword_plan_ready|default(false) %} disabled{% endif %}>Generate monthly plan</button>
            <button type="button" class="admin-btn-ghost" id="cs-wizard-back-step3">Back to metrics</button>
          </div>

          <div id="cs-engine-progress" class="admin-updates-apply-progress" hidden aria-live="polite" style="margin-top:1rem">
            <p class="admin-updates-apply-progress-title">Building editorial calendar…</p>
            <div class="admin-updates-apply-progress-track" role="presentation">
              <div class="admin-updates-apply-progress-fill"></div>
            </div>
            <p class="auth-lede" style="margin:0.5rem 0 0;font-size:0.8125rem;opacity:0.85">OpenAI drafting — often 1–3 minutes.</p>
          </div>

          <div id="cs-engine-error-wrap" class="admin-callout" role="alert" hidden style="margin-top:1rem">
            <p class="admin-prose" style="margin:0;" id="cs-engine-error-text"></p>
          </div>

          <div id="cs-engine-html-result" class="cs-engine-html-mount cs-wizard-engine-mount" hidden></div>

          <div class="admin-table-wrap" id="cs-engine-table-wrap" hidden style="margin-top:1rem">
            <table class="admin-table" id="cs-engine-table">
              <thead>
                <tr>
                  <th scope="col">Day</th>
                  <th scope="col">Keyword</th>
                  <th scope="col">Intent</th>
                  <th scope="col">Score</th>
                  <th scope="col">Title &amp; outline</th>
                </tr>
              </thead>
              <tbody id="cs-engine-tbody"></tbody>
            </table>
          </div>

          <div class="cs-wizard-actions" style="margin-top:1.25rem">
            <button type="button" class="admin-btn-ghost cs-wizard-restart" id="cs-wizard-restart-from-step4">Analyse another domain</button>
          </div>
        </section>
      </div>
    </div>

    {% include '@plugin_content_stream_plugin/partials/content_stream_wizard_admin_script.twig' %}
    {% endif %}
  </div>
  </section>
</main>
{% endblock %}
