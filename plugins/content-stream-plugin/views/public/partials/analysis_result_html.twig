{# Structured display for OpenAI domain analysis (public staff page). Expects: analysis (array), analysis_raw (string, optional pretty JSON for <details>). Domain is shown outside #cs-result-body (see stream.twig). #}
<div class="cs-ap">
  {% if analysis.business_name is defined and analysis.business_name|trim != '' %}
    <h2 class="cs-ap-title">{{ analysis.business_name|e }}</h2>
  {% endif %}

  {% if analysis.website_url is defined and analysis.website_url|trim != '' %}
    <p class="cs-ap-row">
      <a class="cs-ap-link" href="{{ analysis.website_url|e('html_attr') }}" rel="noopener noreferrer" target="_blank">{{ analysis.website_url|e }}</a>
    </p>
  {% endif %}

  {% set ev = analysis.evidence|default([]) %}
  {% if ev is iterable and ev|length > 0 %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">On-page evidence</h3>
      <p class="cs-ap-prose cs-ap-ev-intro">Verbatim snippets from the fetched homepage (used for classification).</p>
      <ul class="cs-ap-ul cs-ap-ev-list">{% for q in ev %}<li class="cs-ap-quote">{{ q|e }}</li>{% endfor %}</ul>
    </div>
  {% endif %}

  {% if analysis.business_summary is defined and analysis.business_summary|trim != '' %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">Summary</h3>
      <p class="cs-ap-prose">{{ analysis.business_summary|e }}</p>
    </div>
  {% endif %}

  {% if analysis.vertical_niche is defined %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">Vertical / niche</h3>
      <p class="cs-ap-prose">{{ analysis.vertical_niche|e }}</p>
    </div>
  {% endif %}

  <dl class="cs-ap-dl">
    {% if analysis.industry is defined %}
      <dt>Industry</dt><dd>{{ analysis.industry|e }}</dd>
    {% endif %}
    {% if analysis.business_type is defined and analysis.business_type|trim != '' %}
      <dt>Business type</dt><dd>{{ analysis.business_type|e }}</dd>
    {% endif %}
    {% if analysis.brand_tone is defined and analysis.brand_tone|trim != '' %}
      <dt>Brand tone</dt><dd>{{ analysis.brand_tone|e }}</dd>
    {% endif %}
  </dl>

  {% set audiences = analysis.target_audience|default([]) %}
  {% if audiences is iterable and audiences|length > 0 %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">Target audience</h3>
      <ul class="cs-ap-ul">{% for item in audiences %}<li>{{ item|e }}</li>{% endfor %}</ul>
    </div>
  {% endif %}

  {% set use_cases = analysis.primary_use_cases|default([]) %}
  {% if use_cases is iterable and use_cases|length > 0 %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">Primary use cases</h3>
      <ul class="cs-ap-ul">{% for item in use_cases %}<li>{{ item|e }}</li>{% endfor %}</ul>
    </div>
  {% endif %}

  {% set products = analysis.core_products_or_services|default([]) %}
  {% if products is iterable and products|length > 0 %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">Products or services</h3>
      <ul class="cs-ap-ul">{% for item in products %}<li>{{ item|e }}</li>{% endfor %}</ul>
    </div>
  {% endif %}

  {% set locs = analysis.locations_served|default([]) %}
  {% if locs is iterable and locs|length > 0 %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">Locations served</h3>
      <ul class="cs-ap-ul">{% for item in locs %}<li>{{ item|e }}</li>{% endfor %}</ul>
    </div>
  {% endif %}

  {% set topics = analysis.top_seo_topics|default([]) %}
  {% if topics is iterable and topics|length > 0 %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">Top SEO topics</h3>
      <ul class="cs-ap-ul">{% for item in topics %}<li>{{ item|e }}</li>{% endfor %}</ul>
    </div>
  {% endif %}

  {% set seeds = analysis.seed_keywords|default([]) %}
  {% if seeds is iterable and seeds|length > 0 %}
    <div class="cs-ap-section">
      <h3 class="cs-ap-h">Seed keywords</h3>
      <ul class="cs-ap-ul">{% for item in seeds %}<li>{{ item|e }}</li>{% endfor %}</ul>
    </div>
  {% endif %}

  {% if analysis_raw|default('')|trim != '' %}
    <details class="cs-ap-raw">
      <summary class="cs-ap-raw-sum">View raw JSON</summary>
      <pre class="cs-ap-pre" tabindex="0">{{ analysis_raw|e }}</pre>
    </details>
  {% endif %}
</div>
