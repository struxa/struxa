{% extends '@plugin_struxa_admin/public/_catalog_layout.twig' %}

{% block catalog_body %}
  {% set p = catalog_package %}
  {% set kind_label = catalog_package_kind == 'plugin' ? 'Plugin' : 'Theme' %}
  {% set detail_path = url_for(catalog_package_kind == 'plugin' ? 'public.struxa_catalog.plugin_show' : 'public.struxa_catalog.theme_show', {slug: p.slug}) %}

  <p class="st-catalog__back">
    <a href="{{ url_for(catalog_list_url) }}">← All {{ catalog_package_kind == 'plugin' ? 'plugins' : 'themes' }}</a>
  </p>

  {% if flash_success|default('') %}
    <p class="st-catalog__notice st-catalog__notice--ok">{{ flash_success|e }}</p>
  {% endif %}
  {% if flash_error|default('') %}
    <p class="st-catalog__notice st-catalog__notice--error">{{ flash_error|e }}</p>
  {% endif %}

  <article class="st-catalog__detail">
    <header class="st-catalog__detail-head">
      <div class="st-catalog__detail-copy">
        <p class="st-eyebrow">{{ kind_label|e }}</p>
        <h1 class="st-catalog__detail-title">{{ p.name|e }}</h1>
        <p class="st-catalog__meta">
          <code class="st-catalog__slug">{{ p.slug|e }}</code>{% if p.version %} · v{{ p.version|e }}{% endif %}
        </p>
        {% if p.author %}<p class="st-catalog__byline">by {{ p.author|e }}</p>{% endif %}
        {% if p.requires_cms_version %}<p class="st-catalog__req">Requires CMS {{ p.requires_cms_version|e }}+</p>{% endif %}
        {% include '@plugin_struxa_admin/public/_catalog_stats.twig' with { item: p } only %}
      </div>
      {% if p.screenshot_url %}
        <div class="st-catalog__detail-media">
          <img class="st-catalog__detail-shot" src="{{ p.screenshot_url|e('html_attr') }}" alt="" width="960" height="540" />
        </div>
      {% endif %}
    </header>

    {% if p.description %}
      <section class="st-catalog__detail-section">
        <h2 class="st-catalog__section-title">About</h2>
        <p class="st-catalog__detail-desc">{{ p.description|e|nl2br }}</p>
      </section>
    {% endif %}

    <section class="st-catalog__detail-section st-catalog__detail-actions">
      <h2 class="st-catalog__section-title">Install</h2>
      <p class="st-catalog__detail-lead">On any Struxa site: <strong>Admin → Extensions</strong> → Browse catalog, or download the ZIP directly.</p>
      <div class="st-catalog__action-row">
        {% if p.download_url %}
          <a class="st-btn st-btn--primary" href="{{ p.download_url|e('html_attr') }}" rel="noopener">Download ZIP</a>
        {% endif %}
        {% if p.repository_url %}
          <a class="st-btn st-btn--outline" href="{{ p.repository_url|e('html_attr') }}" rel="noopener noreferrer">Source repository</a>
        {% endif %}
      </div>
    </section>

    <section class="st-catalog__detail-section" id="rate">
      <h2 class="st-catalog__section-title">Rate this {{ kind_label|lower|e }}</h2>
      {% if catalog_can_engage %}
        <form class="st-catalog__rate-form" method="post" action="{{ url_for(catalog_rate_action, {slug: p.slug}) }}">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <fieldset class="st-catalog__rate-fieldset">
            <legend class="st-catalog__rate-legend">Your rating{% if catalog_user_rating %} (currently {{ catalog_user_rating }} star{{ catalog_user_rating == 1 ? '' : 's' }}){% endif %}</legend>
            <div class="st-catalog__rate-stars">
              {% for star in 1..5 %}
                <label class="st-catalog__rate-label">
                  <input class="st-catalog__rate-input" type="radio" name="rating" value="{{ star }}"{% if catalog_user_rating == star %} checked{% endif %} required />
                  <span class="st-catalog__rate-star" aria-hidden="true">★</span>
                  <span class="visually-hidden">{{ star }} star{{ star == 1 ? '' : 's' }}</span>
                </label>
              {% endfor %}
            </div>
          </fieldset>
          <button type="submit" class="st-btn st-btn--primary st-catalog__rate-submit">Save rating</button>
        </form>
      {% else %}
        <p class="st-catalog__engage-hint">
          <a href="{{ url_for('login') }}?next={{ detail_path|url_encode }}">Sign in</a> to rate this {{ kind_label|lower|e }}.
        </p>
      {% endif %}
    </section>

    <section class="st-catalog__detail-section" id="comments">
      <h2 class="st-catalog__section-title">
        Comments
        <span class="st-catalog__pill st-catalog__pill--comments st-catalog__pill--inline">{{ p.comment_count|default(0) }}</span>
      </h2>

      {% if catalog_can_engage %}
        <form class="st-catalog__comment-form" method="post" action="{{ url_for(catalog_comment_action, {slug: p.slug}) }}">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <label class="st-catalog__label" for="catalog_comment_body">Add a comment</label>
          <textarea class="st-catalog__textarea" id="catalog_comment_body" name="body" rows="4" maxlength="2000" required placeholder="Share feedback, tips, or questions…"></textarea>
          <div class="st-catalog__actions">
            <button type="submit" class="st-btn st-btn--primary">Post comment</button>
          </div>
        </form>
      {% else %}
        <p class="st-catalog__engage-hint">
          <a href="{{ url_for('login') }}?next={{ detail_path|url_encode }}#comments">Sign in</a> to join the discussion.
        </p>
      {% endif %}

      {% if catalog_comments is empty %}
        <p class="st-catalog__empty st-catalog__empty--inline">No comments yet. Be the first to share feedback.</p>
      {% else %}
        <ol class="st-catalog__comment-list">
          {% for c in catalog_comments %}
            <li class="st-catalog__comment">
              <p class="st-catalog__comment-meta">
                <strong class="st-catalog__comment-author">{{ c.author_name|e }}</strong>
                {% if c.created_at %}
                  · <time datetime="{{ c.created_at|e('html_attr') }}">{{ c.created_at|date('M j, Y') }}</time>
                {% endif %}
              </p>
              <p class="st-catalog__comment-body">{{ c.body|e|nl2br }}</p>
            </li>
          {% endfor %}
        </ol>
      {% endif %}
    </section>
  </article>
{% endblock %}
