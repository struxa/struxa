{% set _sort = catalog_sort|default('latest') %}
{% set _route = catalog_list_route|default('') %}
{% set _page = catalog_pagination.page|default(1) %}
{% set _total = catalog_pagination.total|default(0) %}

<div class="st-catalog__toolbar">
  <form class="st-catalog__sort-form" method="get" action="{{ url_for(_route) }}">
    {% if _page > 1 %}
      <input type="hidden" name="page" value="1">
    {% endif %}
    <label class="st-catalog__sort-label" for="catalog-sort">Sort by</label>
    <select class="st-catalog__sort-select" name="sort" id="catalog-sort" onchange="this.form.submit()">
      <optgroup label="Date listed">
        <option value="latest"{% if _sort == 'latest' %} selected{% endif %}>Latest first</option>
        <option value="oldest"{% if _sort == 'oldest' %} selected{% endif %}>Oldest first</option>
      </optgroup>
      <optgroup label="Rating">
        <option value="rating"{% if _sort == 'rating' %} selected{% endif %}>Highest rated</option>
        <option value="rating_asc"{% if _sort == 'rating_asc' %} selected{% endif %}>Lowest rated</option>
      </optgroup>
      <optgroup label="Downloads">
        <option value="downloads"{% if _sort == 'downloads' %} selected{% endif %}>Most downloaded</option>
        <option value="downloads_asc"{% if _sort == 'downloads_asc' %} selected{% endif %}>Least downloaded</option>
      </optgroup>
      <optgroup label="Comments">
        <option value="comments"{% if _sort == 'comments' %} selected{% endif %}>Most commented</option>
        <option value="comments_asc"{% if _sort == 'comments_asc' %} selected{% endif %}>Least commented</option>
      </optgroup>
    </select>
  </form>
  {% if _total > 0 %}
    <p class="st-catalog__result-count">{{ _total }} package{{ _total == 1 ? '' : 's' }}</p>
  {% endif %}
</div>
