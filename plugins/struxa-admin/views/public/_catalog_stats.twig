{% set avg = item.rating_average|default(null) %}
{% set rc = item.rating_count|default(0) %}
{% set cc = item.comment_count|default(0) %}
{% set dc = item.download_count|default(0) %}
<div class="st-catalog__stats" aria-label="Community stats">
  {% if rc > 0 and avg is not null %}
    <span class="st-catalog__pill st-catalog__pill--rating" title="{{ rc }} rating{{ rc == 1 ? '' : 's' }}">
      <span class="st-catalog__stars" aria-hidden="true">
        {% for i in 1..5 %}
          <span class="st-catalog__star{% if avg >= i %} is-on{% elseif avg >= i - 0.5 %} is-half{% endif %}">★</span>
        {% endfor %}
      </span>
      <span class="st-catalog__pill-value">{{ avg|number_format(1) }}</span>
    </span>
  {% else %}
    <span class="st-catalog__pill st-catalog__pill--muted">No ratings yet</span>
  {% endif %}
  <span class="st-catalog__pill st-catalog__pill--comments">
    <span class="st-catalog__pill-icon" aria-hidden="true">💬</span>
    {{ cc }} comment{{ cc == 1 ? '' : 's' }}
  </span>
  <span class="st-catalog__pill st-catalog__pill--downloads">
    <span class="st-catalog__pill-icon" aria-hidden="true">↓</span>
    {{ dc }} download{{ dc == 1 ? '' : 's' }}
  </span>
</div>
