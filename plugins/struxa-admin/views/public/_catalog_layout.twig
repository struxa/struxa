{% extends 'pages/plugin_public_theme_shell.twig' %}

{% block title %}{{ page_title|default('Struxa catalog')|e }} — {{ settings.site_name|default('Struxa')|e }}{% endblock %}
{% block meta_description %}Browse Struxa CMS plugins and themes. Install from Admin → Extensions on any Struxa site.{% endblock %}

{% block plugin_public_body %}
  <main id="main-content" class="st-page st-page--catalog">
    <div class="st-page__inner st-page__inner--wide">
      <header class="st-catalog__head">
        <p class="st-eyebrow"><a class="st-eyebrow__link" href="/">Struxa</a> · Community catalog</p>
        <h1 class="st-catalog__title">{{ page_title|e }}</h1>
        <p class="st-catalog__lead">Install these in any Struxa site via <strong>Admin → Extensions</strong> → Browse catalog. Packages are built from public Git repositories — nothing is uploaded except an optional screenshot.</p>
        <nav class="st-catalog__nav" aria-label="Catalog sections">
          <a class="st-btn st-btn--ghost{% if catalog_nav|default('') == 'plugins' %} is-active{% endif %}" href="{{ url_for('public.struxa_catalog.plugins') }}">Plugins</a>
          <a class="st-btn st-btn--ghost{% if catalog_nav|default('') == 'themes' %} is-active{% endif %}" href="{{ url_for('public.struxa_catalog.themes') }}">Themes</a>
          <a class="st-btn st-btn--primary" href="{{ url_for('public.struxa_catalog.plugins.submit_form') }}">Submit a plugin</a>
          <a class="st-btn st-btn--outline" href="{{ url_for('public.struxa_catalog.themes.submit_form') }}">Submit a theme</a>
        </nav>
      </header>
      {% block catalog_body %}{% endblock %}
    </div>
  </main>
  <style>
    .st-page--catalog { padding-bottom: 3rem; }
    .st-catalog__head { margin-bottom: 2rem; }
    .st-catalog__title { margin: .35rem 0 .75rem; font-size: clamp(1.75rem, 3vw, 2.35rem); line-height: 1.15; }
    .st-catalog__lead { margin: 0 0 1.25rem; max-width: 52rem; line-height: 1.55; opacity: .88; }
    .st-catalog__nav { display: flex; flex-wrap: wrap; gap: .55rem; align-items: center; }
    .st-catalog__nav .st-btn.is-active { box-shadow: inset 0 0 0 2px currentColor; }
    .st-catalog__back { margin: 0 0 1rem; font-size: .92rem; }
    .st-catalog__back a { color: inherit; opacity: .78; text-decoration: none; }
    .st-catalog__back a:hover { opacity: 1; text-decoration: underline; }
    .st-catalog__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
      gap: 1.25rem;
    }
    .st-catalog__card {
      position: relative;
      display: flex;
      flex-direction: column;
      min-height: 100%;
      border: 1px solid rgba(0,0,0,.09);
      border-radius: 16px;
      background: rgba(255,255,255,.78);
      box-shadow: 0 1px 2px rgba(0,0,0,.04), 0 8px 24px rgba(0,0,0,.04);
      overflow: hidden;
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }
    a.st-catalog__card--link {
      text-decoration: none;
      color: inherit;
      cursor: pointer;
    }
    a.st-catalog__card--link:focus-visible {
      outline: 2px solid rgba(230, 120, 30, .85);
      outline-offset: 3px;
    }
    .st-catalog__card:hover,
    a.st-catalog__card--link:hover {
      transform: translateY(-2px);
      border-color: rgba(0,0,0,.14);
      box-shadow: 0 2px 6px rgba(0,0,0,.05), 0 14px 32px rgba(0,0,0,.08);
    }
    .st-catalog__card-cta {
      margin-top: .55rem;
      font-size: .84rem;
      font-weight: 600;
      opacity: .72;
    }
    a.st-catalog__card--link:hover .st-catalog__card-cta { opacity: 1; }
    .st-catalog__card-media {
      aspect-ratio: 16 / 9;
      background: linear-gradient(145deg, rgba(0,0,0,.03), rgba(0,0,0,.06));
      overflow: hidden;
    }
    .st-catalog__card-media--placeholder {
      display: grid;
      place-items: center;
      color: rgba(0,0,0,.22);
      font-size: 2rem;
    }
    .st-catalog__shot, .st-catalog__detail-shot {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .st-catalog__card-body { display: flex; flex-direction: column; gap: .45rem; padding: 1rem 1.05rem 1.1rem; flex: 1; }
    .st-catalog__card-title { margin: 0; font-size: 1.12rem; line-height: 1.25; font-weight: 650; }
    .st-catalog__meta { margin: 0; font-size: .84rem; opacity: .78; }
    .st-catalog__slug {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: .82em;
      padding: .08rem .35rem;
      border-radius: 6px;
      background: rgba(0,0,0,.05);
    }
    .st-catalog__byline { margin: 0; font-size: .86rem; opacity: .72; }
    .st-catalog__req { margin: 0; font-size: .82rem; opacity: .68; }
    .st-catalog__desc { margin: 0; font-size: .92rem; line-height: 1.45; opacity: .86; flex: 1; }
    .st-catalog__stats {
      display: flex;
      flex-wrap: wrap;
      gap: .4rem;
      margin-top: .35rem;
      position: relative;
      z-index: 2;
      pointer-events: none;
    }
    .st-catalog__pill {
      display: inline-flex;
      align-items: center;
      gap: .28rem;
      padding: .22rem .55rem;
      border-radius: 999px;
      font-size: .76rem;
      font-weight: 600;
      letter-spacing: .01em;
      background: rgba(0,0,0,.06);
      color: inherit;
      white-space: nowrap;
    }
    .st-catalog__pill--muted { opacity: .72; font-weight: 500; }
    .st-catalog__pill--rating { background: rgba(255, 160, 40, .14); }
    .st-catalog__pill--comments { background: rgba(60, 120, 255, .12); }
    .st-catalog__pill--downloads { background: rgba(40, 160, 90, .12); }
    .st-catalog__pill--inline { margin-left: .35rem; vertical-align: middle; font-size: .72rem; }
    .st-catalog__pill-icon { opacity: .75; font-size: .9em; }
    .st-catalog__stars { display: inline-flex; gap: .02rem; letter-spacing: -.05em; }
    .st-catalog__star { color: rgba(0,0,0,.18); }
    .st-catalog__star.is-on { color: #e69500; }
    .st-catalog__star.is-half {
      background: linear-gradient(90deg, #e69500 50%, rgba(0,0,0,.18) 50%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .st-catalog__empty { margin: 1rem 0 0; opacity: .82; line-height: 1.5; }
    .st-catalog__empty--inline { margin-top: 1.25rem; }
    .st-catalog__notice {
      margin: 0 0 1rem;
      padding: .75rem 1rem;
      border-radius: 10px;
      font-size: .92rem;
      line-height: 1.45;
    }
    .st-catalog__notice--ok { background: rgba(40, 160, 90, .12); border: 1px solid rgba(40, 160, 90, .25); }
    .st-catalog__notice--error { background: rgba(220, 60, 60, .1); border: 1px solid rgba(220, 60, 60, .22); }
    .st-catalog__detail {
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 18px;
      background: rgba(255,255,255,.76);
      box-shadow: 0 10px 40px rgba(0,0,0,.06);
      padding: 1.35rem 1.35rem 1.5rem;
    }
    @media (min-width: 900px) {
      .st-catalog__detail { padding: 1.75rem 1.85rem 2rem; }
    }
    .st-catalog__detail-head {
      display: grid;
      gap: 1.25rem;
      align-items: start;
      margin-bottom: 1.5rem;
    }
    @media (min-width: 900px) {
      .st-catalog__detail-head { grid-template-columns: minmax(0, 1fr) minmax(280px, 42%); }
    }
    .st-catalog__detail-title { margin: .2rem 0 .45rem; font-size: clamp(1.6rem, 3vw, 2.2rem); line-height: 1.12; }
    .st-catalog__detail-media {
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,.08);
      aspect-ratio: 16 / 9;
      background: rgba(0,0,0,.04);
    }
    .st-catalog__detail-section { margin-top: 1.65rem; padding-top: 1.35rem; border-top: 1px solid rgba(0,0,0,.07); }
    .st-catalog__section-title { margin: 0 0 .75rem; font-size: 1.05rem; }
    .st-catalog__detail-desc, .st-catalog__detail-lead { margin: 0; line-height: 1.6; opacity: .9; max-width: 52rem; }
    .st-catalog__action-row { display: flex; flex-wrap: wrap; gap: .55rem; margin-top: .85rem; }
    .st-catalog__engage-hint { margin: 0; opacity: .82; line-height: 1.5; }
    .st-catalog__rate-form { max-width: 28rem; }
    .st-catalog__rate-fieldset { border: 0; margin: 0; padding: 0; }
    .st-catalog__rate-legend { margin: 0 0 .55rem; font-size: .88rem; opacity: .78; }
    .st-catalog__rate-stars { display: flex; gap: .15rem; margin-bottom: .75rem; }
    .st-catalog__rate-label { position: relative; cursor: pointer; }
    .st-catalog__rate-input {
      position: absolute;
      opacity: 0;
      width: 1px;
      height: 1px;
      pointer-events: none;
    }
    .st-catalog__rate-star {
      display: block;
      font-size: 1.85rem;
      line-height: 1;
      color: rgba(0,0,0,.2);
      transition: color .12s ease, transform .12s ease;
    }
    .st-catalog__rate-label:hover .st-catalog__rate-star,
    .st-catalog__rate-label:hover ~ .st-catalog__rate-label .st-catalog__rate-star,
    .st-catalog__rate-input:checked ~ .st-catalog__rate-star,
    .st-catalog__rate-input:focus-visible ~ .st-catalog__rate-star { color: #e69500; }
    .st-catalog__rate-label:hover .st-catalog__rate-star { transform: scale(1.06); }
    .st-catalog__comment-form { margin-bottom: 1.25rem; max-width: 40rem; }
    .st-catalog__label { display: block; margin-bottom: .35rem; font-size: .88rem; font-weight: 600; }
    .st-catalog__textarea, .st-catalog__input {
      width: 100%;
      border: 1px solid rgba(0,0,0,.14);
      border-radius: 10px;
      padding: .65rem .75rem;
      font: inherit;
      line-height: 1.45;
      background: rgba(255,255,255,.92);
    }
    .st-catalog__textarea { resize: vertical; min-height: 6rem; }
    .st-catalog__actions { margin-top: .65rem; }
    .st-catalog__comment-list {
      list-style: none;
      margin: 1rem 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: .85rem;
    }
    .st-catalog__comment {
      padding: .85rem .95rem;
      border-radius: 12px;
      border: 1px solid rgba(0,0,0,.07);
      background: rgba(255,255,255,.55);
    }
    .st-catalog__comment-meta { margin: 0 0 .35rem; font-size: .82rem; opacity: .78; }
    .st-catalog__comment-author { opacity: 1; color: inherit; }
    .st-catalog__comment-body { margin: 0; line-height: 1.55; white-space: pre-wrap; }
    .st-catalog__form-wrap {
      width: 100%;
      max-width: none;
      padding: 1.35rem 1.45rem;
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 16px;
      background: rgba(255,255,255,.76);
      box-shadow: 0 8px 28px rgba(0,0,0,.05);
    }
    .st-catalog__member-main { min-width: 0; width: 100%; }
    .st-catalog__form-title { margin: 0 0 .5rem; font-size: 1.25rem; }
    .st-catalog__form-lead { margin: 0 0 1rem; line-height: 1.55; opacity: .86; }
    .st-catalog__field { margin-bottom: 1rem; }
    .st-catalog__hint { margin: .35rem 0 0; font-size: .82rem; opacity: .72; }
    .st-catalog__errors { margin: 0 0 1rem; padding-left: 1.1rem; color: #b42318; }
    .visually-hidden {
      position: absolute !important;
      width: 1px !important;
      height: 1px !important;
      padding: 0 !important;
      margin: -1px !important;
      overflow: hidden !important;
      clip: rect(0, 0, 0, 0) !important;
      white-space: nowrap !important;
      border: 0 !important;
    }
  </style>
  {% if catalog_member is defined and catalog_member %}
  <style>
    .st-catalog__member-layout { display: grid; gap: 1.75rem; align-items: start; }
    @media (min-width: 960px) {
      .st-catalog__member-layout--with-sidebar { grid-template-columns: minmax(240px, 280px) minmax(0, 1fr); }
    }
    .st-catalog__member-main { min-width: 0; width: 100%; }
    .st-catalog__sidebar { display: flex; flex-direction: column; gap: 1rem; }
    .st-catalog__sidebar-card {
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 12px;
      padding: 1rem 1.1rem;
      background: rgba(255,255,255,.72);
    }
    .st-catalog__sidebar-eyebrow { margin: 0 0 .35rem; font-size: .75rem; text-transform: uppercase; letter-spacing: .06em; opacity: .65; }
    .st-catalog__sidebar-name { margin: 0; font-size: 1.05rem; font-weight: 650; }
    .st-catalog__sidebar-email { margin: .25rem 0 0; font-size: .88rem; opacity: .75; word-break: break-word; }
    .st-catalog__sidebar-nav { display: flex; flex-direction: column; gap: .35rem; margin-top: .85rem; }
    .st-catalog__sidebar-link { font-size: .92rem; text-decoration: none; color: inherit; opacity: .82; }
    .st-catalog__sidebar-link:hover, .st-catalog__sidebar-link.is-active { opacity: 1; text-decoration: underline; }
    .st-catalog__sidebar-title { margin: 0 0 .65rem; font-size: .95rem; }
    .st-catalog__sidebar-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .75rem; }
    .st-catalog__sidebar-item { display: grid; gap: .15rem; }
    .st-catalog__sidebar-item-kind { font-size: .72rem; text-transform: uppercase; letter-spacing: .05em; opacity: .6; }
    .st-catalog__sidebar-item-name { font-size: .92rem; }
    .st-catalog__sidebar-item-meta, .st-catalog__sidebar-item-date { font-size: .78rem; opacity: .72; }
    .st-catalog__sidebar-more { margin: .75rem 0 0; font-size: .85rem; }
    .st-catalog__sidebar-empty { margin: 0; font-size: .88rem; opacity: .78; line-height: 1.45; }
    .st-catalog__submission-table-wrap { overflow-x: auto; margin-top: .5rem; }
    .st-catalog__submission-table { width: 100%; border-collapse: collapse; font-size: .92rem; }
    .st-catalog__submission-table th, .st-catalog__submission-table td { text-align: left; padding: .65rem .5rem; border-bottom: 1px solid rgba(0,0,0,.08); vertical-align: top; }
    .st-catalog__submission-table th { font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; opacity: .65; }
  </style>
  {% endif %}
{% endblock %}
