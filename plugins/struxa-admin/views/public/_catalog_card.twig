<article class="st-catalog__card">
  <a class="st-catalog__card-hit" href="{{ url_for(show_route, {slug: item.slug}) }}" aria-label="View {{ item.name|e }}"></a>
  {% if item.screenshot_url %}
    <div class="st-catalog__card-media">
      <img class="st-catalog__shot" src="{{ item.screenshot_url|e('html_attr') }}" alt="" loading="lazy" width="640" height="360" />
    </div>
  {% else %}
    <div class="st-catalog__card-media st-catalog__card-media--placeholder" aria-hidden="true">
      <span class="st-catalog__card-placeholder-icon">{% if show_route == 'public.struxa_catalog.plugin_show' %}⚙{% else %}◆{% endif %}</span>
    </div>
  {% endif %}
  <div class="st-catalog__card-body">
    <h2 class="st-catalog__card-title">{{ item.name|e }}</h2>
    <p class="st-catalog__meta">
      <code class="st-catalog__slug">{{ item.slug|e }}</code>{% if item.version %} · v{{ item.version|e }}{% endif %}
    </p>
    {% if item.author %}
      <p class="st-catalog__byline">by {{ item.author|e }}</p>
    {% endif %}
    {% if item.description %}
      {% set desc = item.description|e %}
      <p class="st-catalog__desc">{{ desc|length > 140 ? desc|slice(0, 137) ~ '…' : desc }}</p>
    {% endif %}
    {% include '@plugin_struxa_admin/public/_catalog_stats.twig' with { item: item } only %}
  </div>
</article>
