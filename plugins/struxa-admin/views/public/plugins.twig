{% extends '@plugin_struxa_admin/public/_catalog_layout.twig' %}

{% block catalog_body %}
  {% if not catalog_ok %}
    <div class="st-catalog__notice st-catalog__notice--error"><p>{{ catalog_error|e }}</p></div>
  {% elseif catalog_plugins is empty %}
    <p class="st-catalog__empty">No plugins in the catalog yet. Be the first to <a href="{{ url_for('public.struxa_catalog.plugins.submit_form') }}">submit one</a>.</p>
  {% else %}
    <div class="st-catalog__grid">
      {% for p in catalog_plugins %}
        <article class="st-catalog__card">
          {% if p.screenshot_url %}
            <img class="st-catalog__shot" src="{{ p.screenshot_url|e('html_attr') }}" alt="" loading="lazy" />
          {% endif %}
          <h2 class="st-catalog__card-title">{{ p.name|e }}</h2>
          <p class="st-catalog__meta"><code class="st-catalog__slug">{{ p.slug|e }}</code>{% if p.version %} · v{{ p.version|e }}{% endif %}</p>
          {% if p.author %}<p class="st-catalog__byline">by {{ p.author|e }}</p>{% endif %}
          {% if p.requires_cms_version %}<p class="st-catalog__req">Requires CMS {{ p.requires_cms_version|e }}+</p>{% endif %}
          {% if p.description %}<p class="st-catalog__desc">{{ p.description|e }}</p>{% endif %}
          {% if p.repository_url %}
            <p class="st-catalog__links"><a href="{{ p.repository_url|e('html_attr') }}" rel="noopener noreferrer">Source repository</a></p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
