{% extends 'admin/base.twig' %}
{% import 'admin/_ui_macros.twig' as ui %}

{% block admin_title %}{{ submission.name|e }} — Catalog submission{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ submission.name|e }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub admin-hero-sub--tight">
    <a class="admin-link" href="{{ url_for('admin.struxa_catalog.submissions') }}">← Submissions</a>
  </p>
{% endblock %}

{% block admin_hero_meta %}
  <div class="admin-hero-chips" aria-label="Package summary">
    <span class="admin-hero-chip admin-hero-chip--mono"><code class="admin-inline-code">{{ submission.slug|e }}</code></span>
    <span class="admin-hero-chip">v{{ submission.version|e }}</span>
    {% if submission.kind == 'theme' %}
      <span class="admin-hero-chip admin-hero-chip--accent">Theme</span>
    {% else %}
      <span class="admin-hero-chip">Plugin</span>
    {% endif %}
    {% if submission.status == 'pending' %}
      <span class="admin-hero-chip admin-hero-chip--warn">Pending review</span>
    {% elseif submission.status == 'approved' %}
      <span class="admin-hero-chip admin-hero-chip--ok">Live in catalog</span>
    {% elseif submission.status == 'rejected' %}
      <span class="admin-hero-chip admin-hero-chip--danger">Rejected</span>
    {% else %}
      <span class="admin-hero-chip">{{ submission.status|e }}</span>
    {% endif %}
  </div>
{% endblock %}

{% block admin_hero_actions %}
  <a class="admin-btn-ghost" href="{{ url_for('admin.struxa_catalog.settings') }}">Catalog settings</a>
  {% if submission.kind == 'theme' %}
    <a class="admin-btn-ghost" href="{{ url_for('public.struxa_catalog.themes') }}" target="_blank" rel="noopener">Public themes</a>
  {% else %}
    <a class="admin-btn-ghost" href="{{ url_for('public.struxa_catalog.plugins') }}" target="_blank" rel="noopener">Public plugins</a>
  {% endif %}
  {% if zip_base_url is defined and zip_base_url %}
    <a class="admin-btn-ghost" href="{{ zip_base_url|e('html_attr') }}/{{ submission.slug|e }}.zip" target="_blank" rel="noopener">Download ZIP</a>
  {% endif %}
{% endblock %}

{% block admin_content %}
  {% include '@plugin_struxa_admin/admin/_catalog_zip_warning.twig' %}
  <div class="admin-settings-page admin-catalog-submission-page">
    {% set _status_intro = submission.status == 'pending' ? 'pending' : (submission.status == 'approved' ? 'approved' : (submission.status == 'rejected' ? 'rejected' : 'default')) %}

    <div class="admin-settings-intro admin-catalog-submission-intro admin-catalog-submission-intro--{{ _status_intro }}">
      <div class="admin-settings-intro-icon" aria-hidden="true">
        {% if submission.kind == 'theme' %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="13.5" cy="6.5" r="0.5" fill="currentColor" />
            <circle cx="17.5" cy="10.5" r="0.5" fill="currentColor" />
            <circle cx="8.5" cy="7.5" r="0.5" fill="currentColor" />
            <circle cx="6.5" cy="12.5" r="0.5" fill="currentColor" />
            <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z" />
          </svg>
        {% else %}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
            <line x1="12" y1="22.08" x2="12" y2="12" />
          </svg>
        {% endif %}
      </div>
      <div class="admin-settings-intro-body">
        <p class="admin-settings-intro-title">
          Submission #{{ submission.id }}
          {% if submission.status == 'pending' %}
            · Awaiting review
          {% elseif submission.status == 'approved' %}
            · Published to catalog
          {% elseif submission.status == 'rejected' %}
            · Not published
          {% endif %}
        </p>
        <p class="admin-settings-intro-text">
          {% if submission.status == 'pending' %}
            Approve to download the GitHub repo, build <code class="admin-inline-code">{{ submission.slug|e }}.zip</code>, and regenerate
            <code class="admin-inline-code">repo.json</code> from all approved packages.
          {% elseif submission.status == 'approved' %}
            This package is included when the catalog regenerates
            <code class="admin-inline-code">repo.json</code> from approved submissions.
            {% if submission.publishedAt %}Last published {{ submission.publishedAt|e }}.{% endif %}
          {% elseif submission.status == 'rejected' %}
            This submission was rejected and is not listed in the public catalog.
            {% if submission.reviewedAt %}Reviewed {{ submission.reviewedAt|e }}.{% endif %}
          {% else %}
            Catalog submission for <strong class="admin-settings-intro-strong">{{ submission.slug|e }}</strong>.
          {% endif %}
        </p>
      </div>
      {% if submission.status == 'pending' %}
        <span class="admin-pill admin-pill--warn admin-hub-status-pill">Action required</span>
      {% elseif submission.status == 'approved' %}
        <span class="admin-pill admin-pill--ok admin-hub-status-pill">Approved</span>
      {% endif %}
    </div>

    <div class="admin-metrics admin-catalog-submission-metrics" aria-label="Submission details">
      <article class="admin-metric">
        <p class="admin-metric-label">Submitted</p>
        <p class="admin-metric-value admin-metric-value--mono">{{ submission.createdAt|e }}</p>
        <p class="admin-metric-meta">Queue entry</p>
      </article>
      {% if submission.author %}
        <article class="admin-metric">
          <p class="admin-metric-label">Author</p>
          <p class="admin-metric-value">{{ submission.author|e }}</p>
          <p class="admin-metric-meta">Manifest author</p>
        </article>
      {% endif %}
      {% if submission.manifest.requires_cms_version is defined and submission.manifest.requires_cms_version %}
        <article class="admin-metric">
          <p class="admin-metric-label">Requires CMS</p>
          <p class="admin-metric-value admin-metric-value--mono">{{ submission.manifest.requires_cms_version|e }}+</p>
          <p class="admin-metric-meta">Minimum version</p>
        </article>
      {% endif %}
      {% if submission.status == 'approved' %}
        <article class="admin-metric admin-metric--health-good">
          <p class="admin-metric-label">Downloads</p>
          <p class="admin-metric-value">{{ download_count|default(0) }}</p>
          <p class="admin-metric-meta">Catalog ZIP installs</p>
        </article>
      {% endif %}
      {% if submission.publishedAt %}
        <article class="admin-metric admin-metric--health-good">
          <p class="admin-metric-label">Published</p>
          <p class="admin-metric-value admin-metric-value--mono">{{ submission.publishedAt|e }}</p>
          <p class="admin-metric-meta">In live catalog</p>
        </article>
      {% endif %}
    </div>

    <div class="admin-catalog-submission-layout">
      <div class="admin-catalog-submission-main">
        <section class="admin-card admin-settings-card admin-catalog-submission-card" id="edit">
          <header class="admin-settings-card-head-row">
            <div>
              <h2 class="admin-settings-card-title">Edit submission</h2>
              <p class="admin-settings-card-desc" style="margin-bottom:0">Update catalog metadata, author, source repo, or linked member account.</p>
            </div>
          </header>
          <form id="catalog-submission-edit-form" method="post" action="{{ url_for('admin.struxa_catalog.submission_update', { id: submission.id }) }}" class="admin-form admin-catalog-submission-edit-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
            <div class="admin-form-grid">
              <div class="admin-field">
                <label class="admin-label" for="catalog_edit_name">Name</label>
                <input class="admin-input" id="catalog_edit_name" name="name" required maxlength="255" value="{{ submission.name|e('html_attr') }}" />
              </div>
              <div class="admin-field">
                <label class="admin-label" for="catalog_edit_version">Version</label>
                <input class="admin-input" id="catalog_edit_version" name="version" required maxlength="64" value="{{ submission.version|e('html_attr') }}" />
              </div>
              <div class="admin-field">
                <label class="admin-label" for="catalog_edit_author">Author</label>
                <input class="admin-input" id="catalog_edit_author" name="author" maxlength="255" value="{{ submission.author|e('html_attr') }}" placeholder="Shown in the public catalog" />
                <p class="admin-hint">Display name on <a class="admin-link" href="{{ submission.kind == 'theme' ? url_for('public.struxa_catalog.theme_show', {slug: submission.slug}) : url_for('public.struxa_catalog.plugin_show', {slug: submission.slug}) }}" target="_blank" rel="noopener">public listing</a>.</p>
              </div>
              <div class="admin-field">
                <label class="admin-label" for="catalog_edit_requires_cms">Requires CMS</label>
                <input class="admin-input" id="catalog_edit_requires_cms" name="requires_cms_version" maxlength="32" value="{{ submission.manifest.requires_cms_version|default('')|e('html_attr') }}" placeholder="1.1.33" />
              </div>
            </div>
            <div class="admin-field">
              <label class="admin-label" for="catalog_edit_description">Description</label>
              <textarea class="admin-input" id="catalog_edit_description" name="description" rows="5" maxlength="8000">{{ submission.description|e }}</textarea>
            </div>
            <div class="admin-form-grid">
              <div class="admin-field">
                <label class="admin-label" for="catalog_edit_git">Git repository URL</label>
                <input class="admin-input" id="catalog_edit_git" name="git_repo_url" required value="{{ submission.gitRepoUrl|e('html_attr') }}" />
              </div>
              <div class="admin-field">
                <label class="admin-label" for="catalog_edit_branch">Branch</label>
                <input class="admin-input" id="catalog_edit_branch" name="git_branch" required maxlength="120" value="{{ submission.gitBranch|e('html_attr') }}" />
              </div>
            </div>
            <div class="admin-form-grid">
              <div class="admin-field">
                <label class="admin-label" for="catalog_edit_submitter_email">Submitter email</label>
                <input
                  class="admin-input"
                  type="email"
                  id="catalog_edit_submitter_email"
                  name="submitter_email"
                  maxlength="191"
                  value="{{ submission.submitterEmail|default('')|e('html_attr') }}"
                  placeholder="contact@example.com"
                  autocomplete="off"
                />
                <p class="admin-hint">Shown for staff reference; used when no linked member or after import.</p>
              </div>
              <div class="admin-field">
                <label class="admin-label" for="catalog_edit_submitter_username">Linked member username</label>
                <input
                  class="admin-input"
                  id="catalog_edit_submitter_username"
                  name="submitter_username"
                  maxlength="191"
                  value="{{ submission.submitterUsername|default('')|e('html_attr') }}"
                  placeholder="Search active members…"
                  autocomplete="off"
                  list="catalog_member_usernames"
                  data-member-search-url="{{ member_search_url|default('')|e('html_attr') }}"
                />
                <datalist id="catalog_member_usernames"></datalist>
              </div>
            </div>
            <p class="admin-hint">Type at least 2 characters in username to search members. Linking a member fills email only when the email field above is empty.</p>
            {% if submission.submitterUserId %}
              <label class="admin-checkbox-label" style="margin-top:.35rem">
                <input type="checkbox" name="clear_submitter_link" value="1" />
                Remove member link (keep submitter email)
              </label>
            {% endif %}
            <p class="admin-hint">Slug <code class="admin-inline-code">{{ submission.slug|e }}</code> is fixed after submission.{% if submission.status == 'approved' %} Saving regenerates <code class="admin-inline-code">repo.json</code>.{% endif %}</p>
            <div class="admin-catalog-submission-review-actions">
              <button type="submit" class="admin-btn-primary">Save changes</button>
            </div>
          </form>
        </section>

        {% if submission.description %}
          <section class="admin-card admin-settings-card admin-catalog-submission-card">
            <header class="admin-settings-card-head-row">
              <div>
                <h2 class="admin-settings-card-title">About this package</h2>
                <p class="admin-settings-card-desc" style="margin-bottom:0">Preview of the public catalog description.</p>
              </div>
            </header>
            <div class="admin-prose admin-catalog-submission-desc">{{ submission.description|e }}</div>
          </section>
        {% endif %}

        <section class="admin-card admin-settings-card admin-catalog-submission-card">
          <header class="admin-settings-card-head-row">
            <div>
              <h2 class="admin-settings-card-title">Package identifiers</h2>
              <p class="admin-settings-card-desc" style="margin-bottom:0">Slug and distribution paths (read-only).</p>
            </div>
          </header>
          <dl class="admin-catalog-kv">
            <div class="admin-catalog-kv-row">
              <dt>Slug</dt>
              <dd><code class="admin-inline-code">{{ submission.slug|e }}</code></dd>
            </div>
            <div class="admin-catalog-kv-row">
              <dt>Kind</dt>
              <dd>
                {% if submission.kind == 'theme' %}
                  <span class="admin-pill admin-pill--accent">Theme</span>
                {% else %}
                  <span class="admin-pill">Plugin</span>
                {% endif %}
              </dd>
            </div>
            <div class="admin-catalog-kv-row">
              <dt>Dist ZIP</dt>
              <dd><code class="admin-inline-code admin-tools-code-break">{{ dist_root|e }}/zips/{{ submission.slug|e }}.zip</code></dd>
            </div>
            {% if zip_base_url is defined and zip_base_url %}
              <div class="admin-catalog-kv-row">
                <dt>Public URL</dt>
                <dd>
                  <a class="admin-link admin-tools-code-break" href="{{ zip_base_url|e('html_attr') }}/{{ submission.slug|e }}.zip" target="_blank" rel="noopener">{{ zip_base_url|e }}/{{ submission.slug|e }}.zip</a>
                </dd>
              </div>
            {% endif %}
          </dl>
        </section>

        <details class="admin-card admin-settings-card admin-catalog-submission-card admin-catalog-submission-details">
          <summary class="admin-catalog-submission-details-summary">
            <span>
              <strong class="admin-settings-card-title">Manifest JSON</strong>
              <span class="admin-settings-card-desc">Parsed from <code class="admin-inline-code">plugin.json</code> or <code class="admin-inline-code">theme.json</code></span>
            </span>
            <span class="admin-catalog-submission-details-chevron" aria-hidden="true"></span>
          </summary>
          <pre class="admin-jobs-payload-pre admin-catalog-submission-manifest">{{ submission.manifest|json_encode(128)|e }}</pre>
        </details>
      </div>

      <aside class="admin-catalog-submission-aside">
        <section class="admin-card admin-settings-card admin-catalog-submission-card">
          <header class="admin-settings-card-head-row">
            <div>
              <h2 class="admin-settings-card-title">Submitter</h2>
              {% if submission.submitterEmail == 'catalog@import.local' %}
                <p class="admin-settings-card-desc" style="margin-bottom:0">Seeded from repo.json import.</p>
              {% endif %}
            </div>
          </header>
          <dl class="admin-catalog-kv admin-catalog-kv--compact admin-catalog-kv--aside">
            {% set _submitter = submission.submitterUsername|default('') != '' ? submission.submitterUsername : submission.submitterName %}
            {% if _submitter != '' %}
              <div class="admin-catalog-kv-row">
                <dt>Username</dt>
                <dd class="admin-catalog-kv-break">{{ _submitter|e }}</dd>
              </div>
            {% endif %}
            {% if submission.submitterUserId %}
              <div class="admin-catalog-kv-row">
                <dt>Member ID</dt>
                <dd><code class="admin-inline-code">#{{ submission.submitterUserId }}</code></dd>
              </div>
            {% endif %}
            {% if submission.submitterEmail != 'catalog@import.local' and submission.submitterEmail != '' %}
              <div class="admin-catalog-kv-row">
                <dt>Email</dt>
                <dd class="admin-catalog-kv-break"><a class="admin-link" href="mailto:{{ submission.submitterEmail|e('html_attr') }}">{{ submission.submitterEmail|e }}</a></dd>
              </div>
            {% endif %}
            {% if submission.submitterIp|default('') != '' %}
              <div class="admin-catalog-kv-row">
                <dt>IP address</dt>
                <dd><code class="admin-inline-code admin-catalog-kv-break">{{ submission.submitterIp|e }}</code></dd>
              </div>
            {% endif %}
            {% if submission.submitterUserAgent|default('') != '' %}
              <div class="admin-catalog-kv-row admin-catalog-kv-row--stack">
                <dt>Browser</dt>
                <dd>
                  <pre class="admin-catalog-submitter-ua">{{ submission.submitterUserAgent|e }}</pre>
                </dd>
              </div>
            {% endif %}
          </dl>
        </section>

        <section class="admin-card admin-settings-card admin-catalog-submission-card" id="screenshot">
          <header class="admin-settings-card-head-row">
            <div>
              <h2 class="admin-settings-card-title">Catalog screenshot</h2>
              <p class="admin-settings-card-desc" style="margin-bottom:0">Shown on the public plugins/themes listing and detail pages.</p>
            </div>
          </header>
          {% set _screenshot_src = catalog_screenshot_preview_url|default('') %}
          {% if media_picker_enabled|default(false) %}
            <input type="hidden" form="catalog-submission-edit-form" name="screenshot_media_id" id="catalog-screenshot-media-id" value="" autocomplete="off" />
            <div class="admin-page-featured admin-catalog-screenshot-picker">
              <button type="button" class="admin-page-featured-hit" id="catalog-screenshot-picker-trigger" title="Open media library to upload or choose an image" aria-label="Choose catalog screenshot from media library">
                <span class="admin-page-featured-placeholder" id="catalog-screenshot-placeholder"{% if _screenshot_src != '' %} hidden{% endif %}>
                  <span class="admin-page-featured-placeholder-art" aria-hidden="true"></span>
                  <span class="admin-page-featured-placeholder-title">No screenshot</span>
                  <span class="admin-page-featured-placeholder-sub">Click to choose from media library</span>
                </span>
                <img id="catalog-screenshot-preview" class="admin-page-featured-preview admin-catalog-screenshot-img" {% if _screenshot_src != '' %}src="{{ _screenshot_src|e('html_attr') }}" {% endif %}alt="" width="640" height="360"{% if _screenshot_src != '' %} loading="lazy" decoding="async"{% endif %}{% if _screenshot_src == '' %} hidden{% endif %} />
              </button>
              <div class="admin-catalog-screenshot-actions">
                <button type="button" class="admin-link admin-page-featured-clear" id="catalog-screenshot-clear">Clear selection</button>
              </div>
            </div>
            <p class="admin-hint">Choose or upload an image, then click <strong>Save changes</strong> in the edit form.{% if submission.screenshotPath %} Replacing copies the file into catalog storage.{% endif %}</p>
          {% else %}
            {% if _screenshot_src != '' %}
              <figure class="admin-catalog-screenshot">
                <img src="{{ _screenshot_src|e('html_attr') }}" alt="Screenshot for {{ submission.name|e('html_attr') }}" loading="lazy" />
              </figure>
            {% else %}
              <p class="admin-hint">No screenshot yet.</p>
            {% endif %}
            <p class="admin-hint">Assign <strong>Manage media</strong> to use the media library picker here, or upload via the <a class="admin-link" href="{{ url_for('admin.media.index') }}">media library</a> and ask a user with catalog access to attach it.</p>
          {% endif %}
          {% if submission.screenshotPath %}
            <label class="admin-checkbox-label admin-catalog-screenshot-remove">
              <input type="checkbox" form="catalog-submission-edit-form" name="clear_screenshot" value="1" />
              Remove screenshot on save
            </label>
          {% endif %}
        </section>

        {% if submission.status == 'pending' %}
          <section class="admin-card admin-settings-card admin-catalog-submission-card admin-catalog-submission-review">
            <header class="admin-settings-card-head-row">
              <div>
                <h2 class="admin-settings-card-title">Review</h2>
                <p class="admin-settings-card-desc" style="margin-bottom:0">Approve builds the ZIP and updates the live catalog.</p>
              </div>
            </header>
            <form method="post" action="{{ url_for('admin.struxa_catalog.submission_review', { id: submission.id }) }}" class="admin-form admin-catalog-submission-review-form">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
              <div class="admin-field">
                <label class="admin-label" for="reviewer_notes">Reviewer notes (optional)</label>
                <textarea class="admin-input" id="reviewer_notes" name="reviewer_notes" rows="4" placeholder="Reason for approval or rejection…">{{ submission.reviewerNotes|default('')|e }}</textarea>
              </div>
              <p class="admin-hint">Updates <code class="admin-inline-code">publish.json</code> and regenerates <code class="admin-inline-code">repo.json</code>.</p>
              <div class="admin-catalog-submission-review-actions">
                <button type="submit" name="action" value="approve" class="admin-btn-primary"{% if php_zip_available is defined and not php_zip_available %} disabled title="Enable the PHP zip extension first"{% else %} onclick="return confirm('Publish this package to the live catalog?');"{% endif %}>Approve &amp; publish</button>
                <button type="submit" name="action" value="reject" class="admin-btn-ghost admin-btn-danger" onclick="return confirm('Reject this submission?');">Reject</button>
              </div>
            </form>
          </section>
        {% endif %}

        {% if submission.reviewerNotes or submission.reviewedAt %}
          <section class="admin-card admin-settings-card admin-catalog-submission-card">
            <header class="admin-settings-card-head-row">
              <div>
                <h2 class="admin-settings-card-title">Review history</h2>
              </div>
            </header>
            <dl class="admin-catalog-kv admin-catalog-kv--compact">
              {% if submission.reviewedAt %}
                <div class="admin-catalog-kv-row">
                  <dt>Reviewed</dt>
                  <dd>{{ submission.reviewedAt|e }}</dd>
                </div>
              {% endif %}
              {% if submission.reviewerNotes %}
                <div class="admin-catalog-kv-row admin-catalog-kv-row--stack">
                  <dt>Notes</dt>
                  <dd class="admin-prose admin-catalog-submission-notes">{{ submission.reviewerNotes|e }}</dd>
                </div>
              {% endif %}
            </dl>
          </section>
        {% endif %}

        {% if submission.status == 'approved' %}
          <section class="admin-card admin-settings-card admin-catalog-submission-card admin-catalog-submission-live">
            <header class="admin-settings-card-head-row">
              <div>
                <h2 class="admin-settings-card-title">Live catalog</h2>
                <p class="admin-settings-card-desc" style="margin-bottom:0">Included in the public distribution index.</p>
              </div>
            </header>
            <div class="admin-catalog-submission-live-links">
              <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for('admin.extensions.plugins.browse') }}">Browse in admin</a>
              {% if submission.kind == 'theme' %}
                <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for('public.struxa_catalog.themes') }}" target="_blank" rel="noopener">Public themes page</a>
              {% else %}
                <a class="admin-btn-ghost admin-btn-ghost--sm" href="{{ url_for('public.struxa_catalog.plugins') }}" target="_blank" rel="noopener">Public plugins page</a>
              {% endif %}
            </div>
          </section>
        {% endif %}
      </aside>
    </div>
  </div>
  {% if member_search_url|default('') %}
  <script>
  (function () {
    var input = document.getElementById('catalog_edit_submitter_username');
    var list = document.getElementById('catalog_member_usernames');
    if (!input || !list || !input.dataset.memberSearchUrl) return;
    var timer = null;
    input.addEventListener('input', function () {
      window.clearTimeout(timer);
      timer = window.setTimeout(function () {
        var q = input.value.trim();
        list.innerHTML = '';
        if (q.length < 2) return;
        fetch(input.dataset.memberSearchUrl + '?q=' + encodeURIComponent(q), {
          headers: { Accept: 'application/json' },
          credentials: 'same-origin'
        }).then(function (res) { return res.ok ? res.json() : { members: [] }; })
          .then(function (data) {
            (data.members || []).forEach(function (m) {
              var opt = document.createElement('option');
              opt.value = m.username || '';
              opt.label = (m.display_name || m.username || '') + (m.email ? ' · ' + m.email : '');
              list.appendChild(opt);
            });
          }).catch(function () {});
      }, 250);
    });
  })();
  </script>
  {% endif %}
{% endblock %}

{% block admin_scripts %}
  {% if media_picker_enabled|default(false) %}
    <script type="application/json" id="admin-page-media-picker-config">{{ {
      enabled: true,
      csrfToken: csrf_token(),
      listUrl: url_for('admin.media.api.images'),
      uploadUrl: url_for('admin.media.api.upload'),
      maxMb: media_picker_max_mb|default(5),
      textareaId: '',
      initialImages: media_picker_initial|default([]),
      screenshotImage: {
        inputId: 'catalog-screenshot-media-id',
        previewId: 'catalog-screenshot-preview',
        placeholderId: 'catalog-screenshot-placeholder',
        triggerId: 'catalog-screenshot-picker-trigger',
        clearId: 'catalog-screenshot-clear'
      }
    }|json_encode|raw }}</script>

    <div id="admin-page-media-modal" class="admin-media-modal" hidden role="dialog" aria-modal="true" aria-labelledby="admin-page-media-title">
      <div class="admin-media-modal-backdrop" id="admin-page-media-backdrop"></div>
      <div class="admin-media-modal-panel">
