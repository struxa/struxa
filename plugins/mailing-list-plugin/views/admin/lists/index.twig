{% extends 'admin/base.twig' %}

{% block admin_title %}Mailing lists{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Mailing lists</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">Create lists for newsletters or announcements. Subscribers are validated emails stored per list.</p>
{% endblock %}

{% block admin_content %}
  <div class="admin-toolbar admin-toolbar--spread">
    <a class="admin-btn-primary" href="{{ url_for('plugin.mailing_list_plugin.lists.new') }}">New list</a>
  </div>

  {% if list_rows is empty %}
    <div class="admin-card">
      <p>No mailing lists yet. Create one, then share the subscribe URL or embed the signup form in a theme.</p>
    </div>
  {% else %}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Slug</th>
            <th scope="col">Subscribers</th>
            <th scope="col">Status</th>
            <th class="admin-table-col-actions" scope="col"><span class="admin-table-muted">Actions</span></th>
          </tr>
        </thead>
        <tbody>
          {% for row in list_rows %}
            {% set list = row.list %}
            <tr>
              <td>
                <strong>{{ list.name|e }}</strong>
                {% if list.description %}<br /><span class="admin-hint" style="margin:0">{{ list.description|e|slice(0, 100) }}{% if list.description|length > 100 %}…{% endif %}</span>{% endif %}
              </td>
              <td><code class="admin-inline-code">{{ list.slug|e }}</code></td>
              <td>{{ row.subscriber_count }}</td>
              <td>
                <span class="admin-pill {{ list.isActive ? 'admin-pill--accent' : '' }}">{{ list.isActive ? 'Active' : 'Inactive' }}</span>
              </td>
              <td class="admin-table-actions">
                <a class="admin-link" href="{{ url_for('plugin.mailing_list_plugin.subscribers.index', { id: list.id }) }}">Subscribers</a>
                <a class="admin-link" href="{{ url_for('plugin.mailing_list_plugin.lists.edit', { id: list.id }) }}">Edit</a>
                {% if list.isActive %}
                  <a class="admin-link" href="{{ site_url|default('') }}/mailing-list/subscribe/{{ list.slug|e('url') }}" target="_blank" rel="noopener">Subscribe page</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}

  <div class="admin-card" style="margin-top:1.5rem">
    <h2 class="admin-card-title">Embed signup form</h2>
    <p class="admin-hint">Include in a theme Twig template (replace <code class="admin-inline-code">newsletter</code> with your list slug):</p>
    <pre class="admin-code-block" style="overflow:auto;margin-top:0.75rem">{% verbatim %}{% include '@plugin_mailing_list_plugin/public/partials/signup_form.twig' with {
  list_slug: 'newsletter',
  button_label: 'Subscribe'
} %}{% endverbatim %}</pre>
    <p class="admin-hint">POST target: <code class="admin-inline-code">/mailing-list/subscribe</code> with fields <code class="admin-inline-code">list</code> and <code class="admin-inline-code">email</code>.</p>
  </div>
{% endblock %}
