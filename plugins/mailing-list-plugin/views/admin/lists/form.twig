{% extends 'admin/base.twig' %}

{% set is_edit = list is not null %}
{% set o = old ?? {} %}
{% set nm = o.name|default(list ? list.name : '') %}
{% set sl = o.slug|default(list ? list.slug : '') %}
{% set desc = o.description|default(list ? (list.description ?? '') : '') %}
{% set active = o.is_active is defined ? o.is_active : (list ? list.isActive : true) %}

{% block admin_title %}{{ is_edit ? 'Edit list' : 'New list' }}{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">{{ is_edit ? 'Edit mailing list' : 'New mailing list' }}</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub"><a class="admin-link" href="{{ url_for('plugin.mailing_list_plugin.lists.index') }}">← Mailing lists</a></p>
{% endblock %}

{% block admin_content %}
  <form class="admin-form admin-form--wide" method="post" action="{{ is_edit ? url_for('plugin.mailing_list_plugin.lists.update', { id: list.id }) : url_for('plugin.mailing_list_plugin.lists.store') }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />

    <div class="admin-form-grid">
      <div class="admin-field {{ errors.name is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="ml-name">Name <span class="admin-req">*</span></label>
        <input class="admin-input" id="ml-name" name="name" type="text" maxlength="191" value="{{ nm|e }}" required />
        {% if errors.name is defined %}<p class="admin-field-error">{{ errors.name|e }}</p>{% endif %}
      </div>

      <div class="admin-field {{ errors.slug is defined ? 'admin-field--error' : '' }}">
        <label class="admin-label" for="ml-slug">Slug</label>
        <input class="admin-input" id="ml-slug" name="slug" type="text" value="{{ sl|e }}" placeholder="auto from name" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" autocomplete="off" />
        <p class="admin-hint">Used in URLs and the embed form. Lowercase letters, numbers, hyphens.</p>
        {% if errors.slug is defined %}<p class="admin-field-error">{{ errors.slug|e }}</p>{% endif %}
      </div>

      <div class="admin-field admin-field--full">
        <label class="admin-label" for="ml-desc">Description</label>
        <textarea class="admin-textarea" id="ml-desc" name="description" rows="3">{{ desc|e }}</textarea>
        {% if errors.description is defined %}<p class="admin-field-error">{{ errors.description|e }}</p>{% endif %}
      </div>

      <div class="admin-field admin-field--full">
        <label class="admin-check">
          <input type="checkbox" name="is_active" value="1" {{ active ? 'checked' : '' }} />
          <span>Active (accept new subscribers)</span>
        </label>
      </div>
    </div>

    <div class="admin-form-actions">
      <button class="admin-btn-primary" type="submit">{{ is_edit ? 'Save list' : 'Create list' }}</button>
      <a class="admin-btn-ghost" href="{{ url_for('plugin.mailing_list_plugin.lists.index') }}">Cancel</a>
      {% if is_edit %}
        <button
          class="admin-btn-ghost admin-btn-ghost--danger"
          type="submit"
          formaction="{{ url_for('plugin.mailing_list_plugin.lists.delete', { id: list.id }) }}"
          formmethod="post"
          onclick="return confirm('Delete this list and all subscribers?');"
        >Delete list</button>
      {% endif %}
    </div>
  </form>
{% endblock %}
