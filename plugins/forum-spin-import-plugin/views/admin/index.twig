{% extends 'admin/base.twig' %}

{% block admin_title %}Forum spin import{% endblock %}

{% block admin_head %}
  <style>
    /* Scoped to this plugin page only — follows admin.css tokens */
    .fspi-page {
      --fspi-accent: #2dd4bf;
      --fspi-accent2: #a855f7;
      --fspi-glow: rgba(45, 212, 191, 0.12);
      max-width: 1180px;
    }
    .fspi-page .fspi-lead {
      margin: 0 0 1.5rem;
      font-size: 0.9375rem;
      line-height: 1.65;
      color: var(--admin-muted);
      max-width: 52rem;
    }
    .fspi-page .fspi-lead strong { color: var(--admin-text); font-weight: 600; }
    .fspi-page .fspi-lead code { font-size: 0.85em; }

    .fspi-page .fspi-alert {
      margin: 0 0 1rem;
      padding: 0.9rem 1.1rem;
      border-radius: var(--admin-radius-sm);
      border: 1px solid rgba(251, 191, 36, 0.35);
      background: linear-gradient(135deg, rgba(120, 53, 15, 0.35), rgba(15, 23, 42, 0.85));
      color: #fde68a;
      font-size: 0.9rem;
      line-height: 1.5;
    }
    .fspi-page .fspi-alert a.admin-link { color: #7dd3fc; }
    .fspi-page .fspi-alert strong { color: #fff; }

    .fspi-page .fspi-grid {
      display: grid;
      gap: 1.1rem;
      margin-bottom: 1.25rem;
    }
    @media (min-width: 1024px) {
      .fspi-page .fspi-grid {
        grid-template-columns: 1fr 1fr;
        align-items: start;
      }
    }

    .fspi-page .fspi-panel {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: linear-gradient(165deg, rgba(17, 26, 42, 0.98), rgba(9, 15, 26, 0.92));
      box-shadow:
        0 0 0 1px rgba(168, 85, 247, 0.08),
        0 18px 48px -20px rgba(0, 0, 0, 0.65);
    }
    .fspi-page .fspi-panel::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--fspi-accent), var(--fspi-accent2));
      opacity: 0.85;
      pointer-events: none;
    }
    .fspi-page .fspi-panel--run::before {
      background: linear-gradient(90deg, var(--fspi-accent2), #38bdf8);
    }
    .fspi-page .fspi-panel .admin-section-title {
      margin-top: 0.15rem;
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .fspi-page .fspi-panel .admin-section-title .fspi-ico {
      display: inline-flex;
      width: 2rem;
      height: 2rem;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      background: var(--admin-purple-soft);
      border: 1px solid rgba(168, 85, 247, 0.35);
      color: #e9d5ff;
      font-size: 0.85rem;
    }
    .fspi-page .fspi-panel--run .admin-section-title .fspi-ico {
      background: var(--admin-teal-dim);
      border-color: rgba(45, 212, 191, 0.4);
      color: #99f6e4;
    }

    .fspi-page .fspi-panel .admin-field-hint {
      color: var(--admin-dim);
    }
    .fspi-page .fspi-panel .admin-label {
      color: #cbd5e1;
      font-weight: 600;
    }
    .fspi-page .fspi-panel .admin-input {
      background: rgba(15, 23, 42, 0.65);
      border-color: rgba(255, 255, 255, 0.1);
      color: var(--admin-text);
    }
    .fspi-page .fspi-panel .admin-input:focus {
      border-color: rgba(45, 212, 191, 0.55);
      box-shadow: 0 0 0 3px var(--fspi-glow);
    }
    .fspi-page .fspi-panel .admin-input::placeholder {
      color: #64748b;
    }
    .fspi-page .fspi-panel input[type="file"].admin-input {
      padding: 0.55rem 0.65rem;
      cursor: pointer;
    }
    .fspi-page .fspi-panel input[type="file"].admin-input::file-selector-button {
      margin-right: 0.75rem;
      padding: 0.35rem 0.75rem;
      border-radius: 8px;
      border: 1px solid rgba(168, 85, 247, 0.45);
      background: rgba(168, 85, 247, 0.15);
      color: #e9d5ff;
      font-family: inherit;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
    }
    .fspi-page .fspi-panel input[type="file"].admin-input::file-selector-button:hover {
      background: rgba(168, 85, 247, 0.28);
    }

    .fspi-page .fspi-mini-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      max-width: 28rem;
    }
    @media (max-width: 520px) {
      .fspi-page .fspi-mini-grid { grid-template-columns: 1fr; max-width: none; }
    }

    .fspi-page .fspi-toolbar {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      gap: 0.85rem 1.25rem;
      margin-top: 0.5rem;
    }
    .fspi-page .fspi-toolbar .admin-field { margin-bottom: 0; }
    .fspi-page .fspi-check {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.35rem 0.65rem;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(15, 23, 42, 0.45);
      color: var(--admin-muted);
      font-size: 0.875rem;
      cursor: pointer;
      user-select: none;
    }
    .fspi-page .fspi-check input { accent-color: var(--fspi-accent); }

    .fspi-page .fspi-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }
    .fspi-page .fspi-actions .admin-btn-primary {
      box-shadow: 0 4px 20px -4px rgba(45, 212, 191, 0.45);
    }

    .fspi-page #fspi-log {
      margin-top: 1rem;
      padding: 1rem 1.1rem;
      min-height: 7rem;
      max-height: 300px;
      overflow: auto;
      overscroll-behavior: contain;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 0.75rem;
      line-height: 1.55;
      color: #a5f3fc;
      background: radial-gradient(ellipse 120% 80% at 10% 0%, rgba(45, 212, 191, 0.08), transparent 55%),
        linear-gradient(180deg, #050a12 0%, #0c1220 100%);
      border: 1px solid rgba(45, 212, 191, 0.22);
      border-radius: var(--admin-radius-sm);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }
    .fspi-page #fspi-upload-msg {
      margin-top: 0.75rem;
      padding: 0.5rem 0.65rem;
      border-radius: 8px;
      background: rgba(59, 130, 246, 0.08);
      border: 1px solid rgba(59, 130, 246, 0.2);
      color: #93c5fd;
      font-size: 0.875rem;
      min-height: 0;
    }
    .fspi-page #fspi-upload-msg:empty {
      display: none;
    }

    .fspi-page .fspi-table-wrap {
      overflow: auto;
      border-radius: var(--admin-radius-sm);
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(15, 23, 42, 0.5);
    }
    .fspi-page .fspi-table {
      width: 100%;
      min-width: 720px;
      border-collapse: collapse;
      font-size: 0.875rem;
    }
    .fspi-page .fspi-table thead th {
      text-align: left;
      padding: 0.65rem 0.85rem;
      font-size: 0.65rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #94a3b8;
      background: rgba(15, 23, 42, 0.95);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .fspi-page .fspi-table tbody td {
      padding: 0.65rem 0.85rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      color: #e2e8f0;
    }
    .fspi-page .fspi-table tbody tr:hover td {
      background: rgba(168, 85, 247, 0.06);
    }
    .fspi-page .fspi-table tbody tr:last-child td { border-bottom: none; }
    .fspi-page .fspi-table code {
      font-size: 0.8em;
      padding: 0.12rem 0.35rem;
      border-radius: 6px;
      background: rgba(0, 0, 0, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.06);
      color: #c4b5fd;
    }
    .fspi-page .fspi-empty {
      padding: 1.25rem;
      text-align: center;
      color: var(--admin-dim);
    }

    .fspi-page .fspi-badge {
      display: inline-block;
      padding: 0.2rem 0.5rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border: 1px solid transparent;
    }
    .fspi-page .fspi-badge--idle { color: #94a3b8; background: rgba(148, 163, 184, 0.12); border-color: rgba(148, 163, 184, 0.25); }
    .fspi-page .fspi-badge--running { color: #6ee7b7; background: rgba(16, 185, 129, 0.12); border-color: rgba(45, 212, 191, 0.35); }
    .fspi-page .fspi-badge--paused { color: #fcd34d; background: rgba(251, 191, 36, 0.1); border-color: rgba(251, 191, 36, 0.35); }
    .fspi-page .fspi-badge--stopped { color: #fca5a5; background: rgba(248, 113, 113, 0.1); border-color: rgba(248, 113, 113, 0.35); }
    .fspi-page .fspi-badge--completed { color: #93c5fd; background: rgba(59, 130, 246, 0.12); border-color: rgba(59, 130, 246, 0.35); }
    .fspi-page .fspi-badge--error { color: #fecaca; background: rgba(239, 68, 68, 0.15); border-color: rgba(248, 113, 113, 0.45); }
  </style>
{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">
    <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true" style="margin-right:8px;opacity:.9"></i>
    Forum spin import
  </h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    Stage a scraped TSV, then replay threads into a target forum with OpenAI paraphrasing, synthetic members, and shifted timestamps.
          Chunked <strong>AJAX</strong> steps (a few replies per request) keep PHP inside HTTP limits; every reply in the file is still imported across steps. You must have the right to republish the source material.
  </p>
{% endblock %}

{% block admin_content %}
  <div class="fspi-page">
    <p class="fspi-lead">
      Each TSV row is typically one reply; topic columns repeat per row. Resolve the destination from a <strong>forum URL</strong>
      (for example <code class="admin-inline-code">/forum/british-airways</code>), a <strong>slug</strong>, or a numeric forum id.
      Replies (and whole topics) that mention <code class="admin-inline-code">headforpoints.com</code> are skipped and not posted.
      OpenAI is told the topic&rsquo;s <strong>author login strings</strong> from the TSV so it avoids copying them; anything that slips through is scrubbed to the synthetic display name (or a generic phrase for patterns like &ldquo;X mentioned&rdquo;).
    </p>

    {% if not fspi_ready %}
      <div class="fspi-alert">
        <strong>Plugin tables missing.</strong> Enable <em>Forum spin import</em> from
        <a class="admin-link" href="/admin/plugins">Plugins</a> so migrations run, then refresh.
      </div>
    {% endif %}

    {% if fspi_ready and not fspi_forum_ok %}
      <div class="fspi-alert">
        <strong>Forum plugin not detected.</strong> Enable the Forum plugin first.
      </div>
    {% endif %}

    {% if fspi_ready and fspi_forum_ok and not fspi_openai %}
      <div class="fspi-alert">
        <strong>No OpenAI API key.</strong> Add one under
        <a class="admin-link" href="/admin/system/api-keys">System → API keys</a> or set <code class="admin-inline-code">OPENAI_API_KEY</code> in the environment.
      </div>
    {% endif %}

    <div class="fspi-grid">
      <section class="admin-card fspi-panel fspi-panel--upload">
        <h2 class="admin-section-title">
          <span class="fspi-ico" aria-hidden="true"><i class="fa-solid fa-cloud-arrow-up"></i></span>
          Upload &amp; stage
        </h2>
        <form id="fspi-upload-form" class="admin-form" enctype="multipart/form-data" data-form-uses-csrf>
          <input type="hidden" name="_csrf_token" value="{{ csrf_token() }}" />
          <div class="admin-field admin-field--full">
            <label class="admin-label" for="fspi-target">Target forum</label>
            <input class="admin-input" id="fspi-target" name="target_forum" type="text" required
              placeholder="URL, slug, or id — e.g. british-airways" />
            <p class="admin-field-hint">Paste a forum URL, the slug only, or the numeric <code class="admin-inline-code">forum_forums.id</code>.</p>
          </div>
          <div class="fspi-mini-grid">
            <div class="admin-field">
              <label class="admin-label" for="fspi-max">Max new threads</label>
              <input class="admin-input" id="fspi-max" name="max_threads" type="number" min="1" max="50000" value="500" />
            </div>
            <div class="admin-field">
              <label class="admin-label" for="fspi-per">Replies per AJAX step</label>
              <input class="admin-input" id="fspi-per" name="replies_per_tick" type="number" min="1" max="20" value="2" title="Chunk size per HTTP request for the current thread, not a total cap" />
              <p class="admin-field-hint" style="margin-top:0.35rem;">How many replies to spin and post in <strong>one</strong> step for the thread in progress. The importer repeats steps until <em>all</em> replies for that thread are done, then moves to the next topic. Lower = safer; higher = fewer round-trips.</p>
            </div>
          </div>
          <div class="admin-field admin-field--full">
            <label class="admin-label" for="fspi-tsv">TSV file</label>
            <input class="admin-input" id="fspi-tsv" name="tsv" type="file" accept=".tsv,text/tab-separated-values" required />
            <p class="admin-field-hint" style="margin-top:0.35rem;">
              PHP limits on this server: <code class="admin-inline-code">{{ fspi_ini_upload_raw|e }}</code> per file,
              <code class="admin-inline-code">{{ fspi_ini_post_raw|e }}</code> per request (the whole form must fit under the latter).
              If uploads fail or you see a “POST Content-Length exceeds the limit” warning, raise both in
              <code class="admin-inline-code">docker/php/conf.d/zz-uploads.ini</code> (Docker) or <code class="admin-inline-code">php.ini</code>, then rebuild or restart PHP.
            </p>
          </div>
          <div class="fspi-actions">
            <button class="admin-btn-primary" type="submit" {% if not fspi_ready or not fspi_forum_ok %}disabled{% endif %}>
              <i class="fa-solid fa-database" style="margin-right:6px" aria-hidden="true"></i>Upload &amp; stage
            </button>
          </div>
          <p id="fspi-upload-msg" class="admin-field-hint"></p>
        </form>
      </section>

      <section class="admin-card fspi-panel fspi-panel--run">
        <h2 class="admin-section-title">
          <span class="fspi-ico" aria-hidden="true"><i class="fa-solid fa-bolt"></i></span>
          Run import
        </h2>
        <p class="admin-field-hint" style="margin-top:0;">
          <strong>Start</strong> or <strong>Resume</strong> sets the batch to <code class="admin-inline-code">running</code> in the database (armed for import).
          <strong>Nothing posts until</strong> you click <strong>One step</strong> or turn on <strong>Auto-run</strong> in <em>this</em> browser tab.
          Refreshing the page stops the timer but <strong>does not</strong> change DB status, so the table can still show <code class="admin-inline-code">running</code> while idle — use <strong>Pause</strong> or <strong>Stop</strong> to clear that, or resume stepping.
        </p>
        <div class="fspi-toolbar">
          <div class="admin-field">
            <label class="admin-label" for="fspi-batch">Batch id</label>
            <input class="admin-input" id="fspi-batch" type="number" min="1" step="1" style="max-width:9rem;" placeholder="id" />
          </div>
          <label class="fspi-check">
            <input type="checkbox" id="fspi-auto" />
            <span>Auto-run steps</span>
          </label>
        </div>
        <div class="fspi-actions">
          <button type="button" class="admin-btn-primary" id="fspi-start"><i class="fa-solid fa-play" style="margin-right:6px" aria-hidden="true"></i>Start</button>
          <button type="button" class="admin-btn-primary" id="fspi-resume"><i class="fa-solid fa-rotate-right" style="margin-right:6px" aria-hidden="true"></i>Resume</button>
          <button type="button" class="admin-btn-secondary" id="fspi-pause"><i class="fa-solid fa-pause" style="margin-right:6px" aria-hidden="true"></i>Pause</button>
          <button type="button" class="admin-btn-secondary" id="fspi-stop"><i class="fa-solid fa-stop" style="margin-right:6px" aria-hidden="true"></i>Stop</button>
          <button type="button" class="admin-btn-secondary" id="fspi-step"><i class="fa-solid fa-forward-step" style="margin-right:6px" aria-hidden="true"></i>One step</button>
        </div>
        <pre id="fspi-log" aria-label="Import log output"></pre>
      </section>
    </div>

    <section class="admin-card fspi-panel" style="margin-top:0.25rem;">
      <h2 class="admin-section-title">
        <span class="fspi-ico" aria-hidden="true"><i class="fa-solid fa-clock-rotate-left"></i></span>
        Recent batches
      </h2>
      <div class="fspi-table-wrap">
        <p class="admin-field-hint" style="margin:0 0 0.75rem;">
          Status <code class="admin-inline-code">running</code> means the batch is <strong>armed</strong> for import, not that a background worker is active.
          Use <strong>Pause</strong> / <strong>Stop</strong> here if you want the list to show something other than running after you closed the tab.
        </p>
        <table class="fspi-table">
          <thead>
            <tr>
              <th>Id</th>
              <th>File</th>
              <th>Forum</th>
              <th>Rows</th>
              <th>Done</th>
              <th>Max</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {% for b in fspi_batches %}
              <tr>
                <td><code>{{ b.id }}</code></td>
                <td>{{ b.original_filename|e }}</td>
                <td><code>{{ b.target_forum_slug|e }}</code></td>
                <td>{{ b.staging_rows }}</td>
                <td>{{ b.topics_done|default(0) }}</td>
                <td>{{ b.max_threads }}</td>
                <td>
                  {% set st = b.job_status|default('') %}
                  <span class="fspi-badge fspi-badge--{{ st }}">{{ st|e }}</span>
                </td>
              </tr>
            {% else %}
              <tr><td colspan="7" class="fspi-empty">No batches yet. Upload a TSV to create one.</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <script>
  (function () {
    var csrf = {{ csrf_token()|json_encode|raw }};
    var fspiClientMaxBytes = {{ fspi_client_max_bytes|default(0) }};
    var fspiIniUploadRaw = {{ fspi_ini_upload_raw|default('')|json_encode|raw }};
    var fspiIniPostRaw = {{ fspi_ini_post_raw|default('')|json_encode|raw }};
    var uploadForm = document.getElementById('fspi-upload-form');
    var logEl = document.getElementById('fspi-log');
    var uploadMsg = document.getElementById('fspi-upload-msg');
    var batchInput = document.getElementById('fspi-batch');
    var autoEl = document.getElementById('fspi-auto');
    var autoTimer = null;

    function log(line) {
      if (!logEl) return;
      var t = new Date().toISOString().slice(11, 19);
      logEl.textContent += '[' + t + '] ' + line + '\n';
      logEl.scrollTop = logEl.scrollHeight;
    }

    function batchId() {
      var v = batchInput && batchInput.value ? parseInt(batchInput.value, 10) : 0;
      return v > 0 ? v : 0;
    }

    function parseJsonResponse(r) {
      var ct = (r.headers.get('content-type') || '').toLowerCase();
      if (ct.indexOf('application/json') !== -1) {
        return r.json();
      }
      return r.text().then(function (t) {
        var msg = (t || '').replace(/\s+/g, ' ').trim().slice(0, 500);
        if (!msg) {
          msg = 'Non-JSON response (HTTP ' + r.status + ').';
        }
        throw new Error(msg);
      });
    }

    function postJson(url, body) {
      return fetch(url, {
        method: 'POST',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrf
        },
        body: JSON.stringify(body || {})
      }).then(function (r) {
        return parseJsonResponse(r).then(function (j) {
          return { ok: r.ok, status: r.status, json: j };
        });
      });
    }

    function stopAuto() {
      if (autoTimer !== null) {
        clearTimeout(autoTimer);
        autoTimer = null;
      }
    }

    /** Run the next auto step only after the previous one finishes (avoids stacked requests). */
    function scheduleNextAutoTick() {
      stopAuto();
      if (!autoEl || !autoEl.checked) {
        return;
      }
      autoTimer = setTimeout(function () {
        autoTimer = null;
        if (!autoEl || !autoEl.checked) {
          return;
        }
        stepOnce().finally(function () {
          if (autoEl && autoEl.checked) {
            scheduleNextAutoTick();
          }
        });
      }, 1500);
    }

    function stopPollingUi() {
      stopAuto();
      if (autoEl) autoEl.checked = false;
    }

    function stepOnce() {
      var id = batchId();
      if (!id) { log('Set batch id first.'); return Promise.resolve(); }
      return postJson('/admin/forum-spin-import/batch/' + id + '/step', { _csrf_token: csrf }).then(function (res) {
        var j = res.json || {};
        if (!res.ok || !j.ok) {
          log('Step error: ' + (j.error || j.message || res.status));
          stopPollingUi();
          return;
        }
        if (j.message !== 'Job is not running.') {
          log((j.message || 'ok') + ' | status=' + (j.status || '') + ' topics_done=' + (j.topics_done || 0) + '/' + (j.max_threads || 0));
        }
        if (j.status !== 'running') {
          stopPollingUi();
        }
      }).catch(function (e) {
        log('Step network: ' + (e && e.message ? e.message : e));
        stopPollingUi();
      });
    }

    if (uploadForm) {
      uploadForm.addEventListener('submit', function (ev) {
        ev.preventDefault();
        var tsvEl = document.getElementById('fspi-tsv');
        if (tsvEl && tsvEl.files && tsvEl.files[0] && fspiClientMaxBytes > 0 && tsvEl.files[0].size > fspiClientMaxBytes) {
          var fsz = Math.round(tsvEl.files[0].size / 1048576 * 10) / 10;
          var cap = Math.round(fspiClientMaxBytes / 1048576 * 100) / 100;
          uploadMsg.textContent =
            'This file is about ' + fsz + ' MB, but with the current PHP settings the file can be at most about '
            + cap + ' MB (upload_max_filesize ' + fspiIniUploadRaw + ', post_max_size ' + fspiIniPostRaw
            + '). Raise both so post_max_size is a few MB larger than the file; if you use Docker, rebuild after '
            + 'changing docker/php/conf.d/zz-uploads.ini, then retry.';
          return;
        }
        var fd = new FormData(uploadForm);
        uploadMsg.textContent = 'Uploading…';
        fetch({{ url_for('plugin.forum_spin_import.upload')|json_encode|raw }}, {
          method: 'POST',
          headers: {
            'Accept': 'application/json',
            'X-CSRF-Token': csrf
          },
          body: fd
        })
          .then(function (r) {
            return parseJsonResponse(r).then(function (j) { return { ok: r.ok, json: j }; });
          })
          .then(function (res) {
            var j = res.json || {};
            if (!res.ok || !j.ok) {
              uploadMsg.textContent = j.message || j.error || 'Upload failed';
              return;
            }
            uploadMsg.textContent = 'Staged ' + j.rows + ' row(s). Batch id ' + j.batch_id + '.';
            if (batchInput) batchInput.value = String(j.batch_id);
          })
          .catch(function (e) { uploadMsg.textContent = 'Error: ' + (e && e.message ? e.message : e); });
      });
    }

    function wireBtn(id, urlBuilder, onSuccess) {
      var el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('click', function () {
        var idn = batchId();
        if (!idn) { log('Set batch id first.'); return; }
        postJson(urlBuilder(idn), { _csrf_token: csrf }).then(function (res) {
          var j = res.json || {};
          if (!res.ok || j.ok === false) {
            log(id + ' failed: ' + (j.message || j.error || ('HTTP ' + res.status)));
            return;
          }
          log(id + ' OK: ' + JSON.stringify(j));
          if (typeof onSuccess === 'function') onSuccess(j);
        }).catch(function (e) {
          log(id + ' error: ' + (e && e.message ? e.message : e));
        });
      });
    }
    wireBtn('fspi-start', function (id) { return '/admin/forum-spin-import/batch/' + id + '/start'; });
    wireBtn('fspi-resume', function (id) { return '/admin/forum-spin-import/batch/' + id + '/resume'; });
    wireBtn('fspi-pause', function (id) { return '/admin/forum-spin-import/batch/' + id + '/pause'; }, stopPollingUi);
    wireBtn('fspi-stop', function (id) { return '/admin/forum-spin-import/batch/' + id + '/stop'; }, stopPollingUi);

    var stepBtn = document.getElementById('fspi-step');
    if (stepBtn) stepBtn.addEventListener('click', function () { stepOnce(); });

    if (autoEl) {
      autoEl.addEventListener('change', function () {
        stopAuto();
        if (autoEl.checked) {
          scheduleNextAutoTick();
        }
      });
    }
  })();
  </script>
{% endblock %}
